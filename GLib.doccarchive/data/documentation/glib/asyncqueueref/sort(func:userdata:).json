ations"},{"kind":"content","content":[{"anchor":"discussion","text":"Discussion","level":2,"type":"heading"},{"inlineContent":[{"text":"The sort function ","type":"text"},{"type":"codeVoice","code":"func"},{"text":" is passed two elements of the ","type":"text"},{"code":"queue","type":"codeVoice"},{"type":"text","text":"."},{"text":" ","type":"text"},{"type":"text","text":"It should return 0 if they are equal, a negative value if the"},{"text":" ","type":"text"},{"type":"text","text":"first element should be higher in the "},{"type":"codeVoice","code":"queue"},{"type":"text","text":" or a positive value"},{"text":" ","type":"text"},{"text":"if the first element should be lower in the ","type":"text"},{"type":"codeVoice","code":"queue"},{"type":"text","text":" than the second"},{"text":" ","type":"text"},{"text":"element.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This function will lock "},{"code":"queue","type":"codeVoice"},{"type":"text","text":" before it sorts the queue and unlock"},{"text":" ","type":"text"},{"type":"text","text":"it when it is finished."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"If you were sorting a list of priority numbers to make sure the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"lowest priority would be at the top of the queue, you could use:"},{"type":"text","text":" "},{"type":"text","text":"(C Language Example):"}]},{"syntax":"C","code":[" gint32 id1;"," gint32 id2;",""," id1 = GPOINTER_TO_INT (element1);"," id2 = GPOINTER_TO_INT (element2);",""," return (id1 > id2 ? +1 : id1 == id2 ? 0 : -1);"],"type":"codeListing"}]}],"variants":[{"paths":["\/documentation\/glib\/asyncqueueref\/sort(func:userdata:)"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://GLib/documentation/GLib":{"kind":"symbol","role":"collection","abstract":[],"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","type":"topic","url":"\/documentation\/glib"},"doc: