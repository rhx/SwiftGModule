type":"text","text":" "},{"type":"codeVoice","code":"g_base64_encode_close()"},{"text":" to flush the saved state.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"The output buffer must be large enough to fit all the data that will","type":"text"},{"type":"text","text":" "},{"type":"text","text":"be written to it. Due to the way base64 encodes you will need"},{"type":"text","text":" "},{"type":"text","text":"at least: ("},{"code":"len","type":"codeVoice"},{"text":" \/ 3 + 1) * 4 + 4 bytes (+ 4 may be needed in case of","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"non-zero state). If you enable line-breaking you will need at least:"},{"type":"text","text":" "},{"type":"text","text":"(("},{"type":"codeVoice","code":"len"},{"type":"text","text":" \/ 3 + 1) * 4 + 4) \/ 76 + 1 bytes of extra space."}],"type":"paragraph"},{"inlineContent":[{"code":"breakLines","type":"codeVoice"},{"text":" is typically used when putting base64-encoded data in emails.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"It breaks the lines at 76 columns instead of putting all of the text on"},{"text":" ","type":"text"},{"type":"text","text":"the same line. This avoids problems with long lines in the email system."},{"type":"text","text":" "},{"type":"text","text":"Note however that it breaks the lines with "},{"type":"codeVoice","code":"LF"},{"type":"text","text":" characters, not"},{"type":"text","text":" "},{"type":"codeVoice","code":"CR LF"},{"type":"text","text":" sequences, so the result cannot be passed directly to SMTP"},{"type":"text","text":" "},{"type":"text","text":"or certain other protocols."}],"type":"paragraph"}],"kind":"content"}],"sections":[],"metadata":{"symbolKind":"func","modules":[{"name":"GLib"}],"externalID":"s:4GLib16base64EncodeStep2in3len10breakLines3out5state4saveSiSPys5UInt8VGSg_SiSbSpys4Int8VGSgSpys5Int32VGSgATtF","role":"symbol","roleHeading":"Function","fragments":[{"kind":"keyword","text":"func"},{"text":" ",