{"primaryContentSections":[{"declarations":[{"tokens":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"BookmarkFile","kind":"identifier"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"content":[{"text":"Overview","type":"heading","anchor":"overview","level":2},{"inlineContent":[{"type":"text","text":"Bookmarks refer to a URI, along with some meta-data about the resource"},{"text":" ","type":"text"},{"type":"text","text":"pointed by the URI like its MIME type, the application that is registering"},{"type":"text","text":" "},{"text":"the bookmark and the icon that should be used to represent the bookmark.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"The data is stored using the"},{"text":" ","type":"text"},{"type":"reference","identifier":"https:\/\/www.freedesktop.org\/wiki\/Specifications\/desktop-bookmark-spec\/","isActive":true},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The syntax of the bookmark files is described in detail inside the"},{"text":" ","type":"text"},{"type":"text","text":"Desktop Bookmark Specification, here is a quick summary: bookmark"},{"text":" ","type":"text"},{"text":"files use a sub-class of the XML Bookmark Exchange Language","type":"text"},{"text":" ","type":"text"},{"text":"specification, consisting of valid UTF-8 encoded XML, under the","type":"text"},{"text":" ","type":"text"},{"code":"<xbel>","type":"codeVoice"},{"type":"text","text":" root element; each bookmark is stored inside a"},{"text":" ","type":"text"},{"code":"<bookmark>","type":"codeVoice"},{"text":" element, using its URI: no relative paths can","type":"text"},{"type":"text","text":" "},{"text":"be used inside a bookmark file. The bookmark may have a user defined","type":"text"},{"text":" ","type":"text"},{"text":"title and description, to be used instead of the URI. Under the","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"<metadata>"},{"type":"text","text":" element, with its owner attribute set to"},{"type":"text","text":" "},{"code":"http:\/\/freedesktop.org","type":"codeVoice"},{"text":", is stored the meta-data about a resource","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"pointed by its URI. The meta-data consists of the resource’s MIME"},{"text":" ","type":"text"},{"type":"text","text":"type; the applications that have registered a bookmark; the groups"},{"type":"text","text":" "},{"text":"to which a bookmark belongs to; a visibility flag, used to set the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"bookmark as “private” to the applications and groups that has it"},{"text":" ","type":"text"},{"type":"text","text":"registered; the URI and MIME type of an icon, to be used when"},{"text":" ","type":"text"},{"text":"displaying the bookmark inside a GUI.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Here is an example of a bookmark file:"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"https:\/\/gitlab.gnome.org\/GNOME\/glib\/-\/blob\/HEAD\/glib\/tests\/bookmarks.xbel"}]},{"type":"paragraph","inlineContent":[{"text":"A bookmark file might contain more than one bookmark; each bookmark","type":"text"},{"text":" ","type":"text"},{"text":"is accessed through its URI.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The important caveat of bookmark files is that when you add a new","type":"text"},{"text":" ","type":"text"},{"text":"bookmark you must also add the application that is registering it, using","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"[method"},{"code":"GLib.BookmarkFile.add_application","type":"codeVoice"},{"text":"] or [method","type":"text"},{"type":"codeVoice","code":"GLib.BookmarkFile.set_application_info"},{"text":"].","type":"text"},{"type":"text","text":" "},{"type":"text","text":"If a bookmark has no applications then it won’t be dumped when creating"},{"type":"text","text":" "},{"text":"the on disk representation, using [method","type":"text"},{"type":"codeVoice","code":"GLib.BookmarkFile.to_data"},{"text":"] or","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"[method"},{"type":"codeVoice","code":"GLib.BookmarkFile.to_file"},{"text":"].","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/BookmarkFile"},{"text":" type acts as an owner of an underlying ","type":"text"},{"code":"GBookmarkFile","type":"codeVoice"},{"type":"text","text":" instance."},{"type":"text","text":" "},{"text":"It provides the methods that can operate on this data type through ","type":"text"},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/BookmarkFileProtocol","type":"reference"},{"type":"text","text":" conformance."},{"type":"text","text":" "},{"type":"text","text":"Use "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/BookmarkFile","isActive":true},{"type":"text","text":" as a strong reference or owner of a "},{"type":"codeVoice","code":"GBookmarkFile"},{"text":" instance.","type":"text"}]},{"name":"Note","style":"note","content":[{"type":"paragraph","inlineContent":[{"text":"Use ","type":"text"},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/BookmarkFileRef","type":"reference"},{"type":"text","text":" (instead of "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/BookmarkFile","isActive":true},{"type":"text","text":") for a lightweight Swift reference to an underlying "},{"code":"GBookmarkFile","type":"codeVoice"},{"type":"text","text":" instance."}]}],"type":"aside"}],"kind":"content"}],"abstract":[{"code":"GBookmarkFile","type":"codeVoice"},{"text":" lets you parse, edit or create files containing bookmarks.","type":"text"}],"relationshipsSections":[{"identifiers":["doc:\/\/GLib\/documentation\/GLi