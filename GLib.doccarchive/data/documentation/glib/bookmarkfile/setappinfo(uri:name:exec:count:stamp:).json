ist of registered applications.","type":"codeVoice"},{"type":"text","text":"stamp` is the Unix time of the last registration; if it is -1, the"},{"text":" ","type":"text"},{"type":"text","text":"current time will be used."}]},{"type":"paragraph","inlineContent":[{"text":"If you try to remove an application by setting its registration count to","type":"text"},{"text":" ","type":"text"},{"text":"zero, and no bookmark for ","type":"text"},{"type":"codeVoice","code":"uri"},{"text":" is found, ","type":"text"},{"type":"codeVoice","code":"false"},{"text":" is returned and","type":"text"},{"type":"text","text":" "},{"code":"error","type":"codeVoice"},{"type":"text","text":" is set to "},{"type":"codeVoice","code":"uriNotFound"},{"text":"; similarly,","type":"text"},{"type":"text","text":" "},{"text":"in the event that no application ","type":"text"},{"type":"codeVoice","code":"name"},{"text":" has registered a bookmark","type":"text"},{"type":"text","text":" "},{"text":"for ","type":"text"},{"code":"uri","type":"codeVoice"},{"text":",  ","type":"text"},{"type":"codeVoice","code":"false"},{"text":" is returned and error is set to","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"appNotRegistered"},{"text":".  Otherwise, if no bookmark","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"for "},{"type":"codeVoice","code":"uri"},{"type":"text","text":" is found, one is created."}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"set_app_info is deprecated:"}]},{"text":" ","type":"text"},{"text":"Use g_bookmark_file_set_application_info() instead, as","type":"text"},{"type":"text","text":" "},{"code":"time_t","type":"codeVoice"},{"type":"text","text":" is deprecated due to the year 2038 problem."}]}]}],"metadata":{"role":"symbol","title":"setAppInfo(uri:name:exec:count:stamp:)","symbolKind":"method","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text"