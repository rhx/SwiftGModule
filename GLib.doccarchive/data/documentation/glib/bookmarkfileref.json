{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/BookmarkFileRef"},"schemaVersion":{"major":0,"minor":3,"patch":0},"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/bookmarkfileref"]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"BookmarkFileRef"}],"languages":["swift"],"platforms":["macOS"]}]},{"content":[{"level":2,"text":"Overview","type":"heading","anchor":"overview"},{"type":"paragraph","inlineContent":[{"text":"Bookmarks refer to a URI, along with some meta-data about the resource","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"pointed by the URI like its MIME type, the application that is registering"},{"type":"text","text":" "},{"type":"text","text":"the bookmark and the icon that should be used to represent the bookmark."},{"type":"text","text":" "},{"type":"text","text":"The data is stored using the"},{"type":"text","text":" "},{"identifier":"https:\/\/www.freedesktop.org\/wiki\/Specifications\/desktop-bookmark-spec\/","isActive":true,"type":"reference"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The syntax of the bookmark files is described in detail inside the"},{"type":"text","text":" "},{"type":"text","text":"Desktop Bookmark Specification, here is a quick summary: bookmark"},{"type":"text","text":" "},{"type":"text","text":"files use a sub-class of the XML Bookmark Exchange Language"},{"type":"text","text":" "},{"type":"text","text":"specification, consisting of valid UTF-8 encoded XML, under the"},{"text":" ","type":"text"},{"type":"codeVoice","code":"<xbel>"},{"text":" root element; each bookmark is stored inside a","type":"text"},{"text":" ","type":"text"},{"code":"<bookmark>","type":"codeVoice"},{"type":"text","text":" element, using its URI: no relative paths can"},{"type":"text","text":" "},{"type":"text","text":"be used inside a bookmark file. The bookmark may have a user defined"},{"type":"text","text":" "},{"type":"text","text":"title and description, to be used instead of the URI. Under the"},{"type":"text","text":" "},{"code":"<metadata>","type":"codeVoice"},{"text":" element, with its owner attribute set to","type":"text"},{"text":" ","type":"text"},{"code":"http:\/\/freedesktop.org","type":"codeVoice"},{"type":"text","text":", is stored the meta-data about a resource"},{"type":"text","text":" "},{"text":"pointed by its URI. The meta-data consists of the resource’s MIME","type":"text"},{"text":" ","type":"text"},{"text":"type; the applications that have registered a bookmark; the groups","type":"text"},{"text":" ","type":"text"},{"text":"to which a bookmark belongs to; a visibility flag, used to set the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"bookmark as “private” to the applications and groups that has it"},{"text":" ","type":"text"},{"type":"text","text":"registered; the URI and MIME type of an icon, to be used when"},{"text":" ","type":"text"},{"text":"displaying the bookmark inside a GUI.","type":"text"}]},{"inlineContent":[{"type":"text","text":"Here is an example of a bookmark file:"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"https:\/\/gitlab.gnome.org\/GNOME\/glib\/-\/blob\/HEAD\/glib\/tests\/bookmarks.xbel"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"A bookmark file might contain more than one bookmark; each bookmark"},{"type":"text","text":" "},{"text":"is accessed through its URI.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The important caveat of bookmark files is that when you add a new","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"bookmark you must also add the application that is registering it, using"},{"type":"text","text":" "},{"text":"[method","type":"text"},{"type":"codeVoice","code":"GLib.BookmarkFile.add_application"},{"text":"] or [method","type":"text"},{"code":"GLib.BookmarkFile.set_application_info","type":"codeVoice"},{"text":"].","type":"text"},{"text":" ","type":"text"},{"text":"If a bookmark has no applications then it won’t be dumped when creating","type":"text"},{"text":" ","type":"text"},{"text":"the on disk representation, using [method","type":"text"},{"code":"GLib.BookmarkFile.to_data","type":"codeVoice"},{"type":"text","text":"] or"},{"type":"text","text":" "},{"type":"text","text":"[method"},{"code":"GLib.BookmarkFile.to_file","type":"codeVoice"},{"type":"text","text":"]."}]},{"inlineContent":[{"text":"The ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/BookmarkFileRef"},{"type":"text","text":" type acts as a lightweight Swift reference to an underlying "},{"code":"GBookmarkFile","type":"codeVoice"},{"type":"text","text":" instance."},{"type":"text","text":" "},{"type":"text","text":"It exposes methods that can operate on this data type through "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/BookmarkFileProtocol","isActive":true,"type":"reference"},{"text":" conformance.","type":"text"},{"type":"text","text":" "},{"text":"Use ","type":"text"},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/BookmarkFileRef","type":"reference"},{"text":" only as an ","type":"text"},{"type":"codeVoice","code":"unowned"},{"text":" reference to an existing ","type":"text"},{"code":"GBookmarkFile","type":"codeVoice"},{"text":" instance.","type":"text"}],"type":"paragraph"},{"style":"note","type":"aside","content":[{"type":"paragraph","inlineContent":[{"text":"Use ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/BookmarkFile"},{"type":"text","text":" (instead of "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/BookmarkFileRef"},{"text":") if you want to use Automatic Reference Counting for memory management of the underlying ","type":"text"},{"type":"codeVoice","code":"GBookmarkFile"},{"type":"text","text":" instance."}]}],"name":"Note"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"topicSections":[{"title":"Initializers","identifiers":["doc:\/\/GLib\/documentation\/GLib\/BookmarkFileRef\/init()","doc:\/\/GLib\/documentation\/GLib\/BookmarkFileRef\/init(_:)-2fawg","doc:\/\/GLib\/documentation\/GLib\/BookmarkFileRef\/init(_:)-2gux1","doc:\/\/GLib\/documentation\/GLib\/BookmarkFileRef\/init(_:)-5l1bm","doc:\/\/GLib\/documentation\/GLib\/BookmarkFileRef\/init(_:)-9fjcb","doc:\/\/GLib\/documentation\/GLib\/BookmarkFileRef\/init(_:)-x28p","doc:\/\/GLib\/documentation\/GLib\/BookmarkFileRef\/init(cPointer:)","doc:\/\/GLib\/documentation\/GLib\/BookmarkFileRef\/init(constPointer:)","doc:\/\/GLib\/documentation\/GLib\/BookmarkFileRef\/init(gconstpointer:)","doc:\/\/GLib\/documentation\/GLib\/BookmarkFileRef\/init(gpointer:)","doc:\/\/GLib\/documentation\/GLib\/BookmarkFileRef\/init(mutating:)","doc:\/\/GLib\/documentation\/GLib\/BookmarkFileRef\/init(opaquePointer:)"],"generated":true,"anchor":"Initializers"},{"identifiers":["doc:\/\/GLib\/documentation\/GLib\/BookmarkFileRef\/ptr"],"generated":true,"title":"Instance Properties","anchor":"Instance-Properties"},{"title":"Default Implementations","anchor":"Default-Implementations","identifiers":["doc:\/\/GLib\/documentation\/GLib\/BookmarkFileRef\/BookmarkFileProtocol-Implementations","doc:\/\/GLib\/documentation\/GLib\/BookmarkFileRef\/PointerWrapper-Implementations"],"generated":true}],"abstract":[{"type":"codeVoice","code":"GBookmarkFile"},{"type":"text","text":" lets you parse, edit or create files containing bookmarks."}],"kind":"symbol","relationshipsSections":[{"type":"conformsTo","kind":"relationships","title":"Conforms To","identifiers":["doc:\/\/GLib\/documentation\/GLib\/BookmarkFileProtocol","doc:\/\/GLib\/documentation\/GLib\/PointerWrapper"]}],"meta