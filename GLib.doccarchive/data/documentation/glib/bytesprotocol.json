Lib\/ByteArray","isActive":true},{"text":"], use the [func","type":"text"},{"code":"GLib.ByteArray.free_to_bytes","type":"codeVoice"},{"type":"text","text":"]"},{"type":"text","text":" "},{"type":"text","text":"function."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/BytesProtocol","type":"reference"},{"type":"text","text":" protocol exposes the methods and properties of an underlying "},{"type":"codeVoice","code":"GBytes"},{"type":"text","text":" instance."},{"text":" ","type":"text"},{"text":"The default implementation of these can be found in the protocol extension below.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"For a concrete class that implements these methods and properties, see "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Bytes","type":"reference","isActive":true},{"text":".","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Alternatively, use "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/BytesRef","isActive":true},{"type":"text","text":" as a lighweight, "},{"code":"unowned","type":"codeVoice"},{"text":" reference if you already have an instance you just want to use.","type":"text"}]}],"kind":"content"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/BytesProtocol"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/bytesprotocol"]}],"metadata":{"modules":[{"name":"GLib"}],"role":"symbol","fragments":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"text":"BytesProtocol","kind":"identifier"}],"roleHeading":"Protocol","symbolKind":"protocol","title":"BytesProtocol","navigatorTitle":[{"text":"BytesProtocol","kind":"identifier"}],"externalID":"s:4GLib13BytesProtocolP"},"references":{"doc://GLib/documentation/GLib/BytesProtocol/newFromBytes(offset:length:)":{"identifier":"doc:\/\/GLib\/document