{"schemaVersion":{"major":0,"patch":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"kind":"symbol","sections":[],"topicSections":[{"identifiers":["doc:\/\/GLib\/documentation\/GLib\/BytesProtocol\/bytes_ptr-7x533","doc:\/\/GLib\/documentation\/GLib\/BytesProtocol\/size"],"generated":true,"title":"Instance Properties","anchor":"Instance-Properties"},{"identifiers":["doc:\/\/GLib\/documentation\/GLib\/BytesProtocol\/compare(bytes2:)","doc:\/\/GLib\/documentation\/GLib\/BytesProtocol\/computeChecksumForBytes(checksumType:)","doc:\/\/GLib\/documentation\/GLib\/BytesProtocol\/computeHmacForBytes(digestType:data:)","doc:\/\/GLib\/documentation\/GLib\/BytesProtocol\/equal(bytes2:)","doc:\/\/GLib\/documentation\/GLib\/BytesProtocol\/getData(size:)","doc:\/\/GLib\/documentation\/GLib\/BytesProtocol\/getRegion(elementSize:offset:nElements:)","doc:\/\/GLib\/documentation\/GLib\/BytesProtocol\/getSize()","doc:\/\/GLib\/documentation\/GLib\/BytesProtocol\/hash()","doc:\/\/GLib\/documentation\/GLib\/BytesProtocol\/newFromBytes(offset:length:)","doc:\/\/GLib\/documentation\/GLib\/BytesProtocol\/ref()","doc:\/\/GLib\/documentation\/GLib\/BytesProtocol\/unref()","doc:\/\/GLib\/documentation\/GLib\/BytesProtocol\/unrefToArray()","doc:\/\/GLib\/documentation\/GLib\/BytesProtocol\/unrefToData(size:)"],"generated":true,"anchor":"Instance-Methods","title":"Instance Methods"}],"abstract":[{"text":"A simple reference counted data type representing an immutable sequence of","type":"text"},{"type":"text","text":" "},{"text":"zero or more bytes from an unspecified origin.","type":"text"}],"relationshipsSections":[{"title":"Inherits From","type":"inheritsFrom","kind":"relationships","identifiers":["doc:\/\/GLib\/documentation\/GLib\/PointerWrapper"]},{"kind":"relationships","identifiers":["doc:\/\/GLib\/documentation\/GLib\/Bytes","doc:\/\/GLib\/documentation\/GLib\/BytesRef"],"type":"conformingTypes","title":"Conforming Types"}],"primaryContentSections":[{"kind":"d