xternalParam","text":"priority"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"kind":"text","text":", "},{"text":"pid","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"c:@T@GPid","kind":"typeIdentifier","text":"GPid"},{"text":", ","kind":"text"},{"text":"function","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"GChildWatchFunc","preciseIdentifier":"c:@T@GChildWatchFunc"},{"kind":"text","text":"?, "},{"text":"data","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gpointer","text":"gpointer"},{"kind":"text","text":"? = nil, "},{"kind":"externalParam","text":"notify"},{"text":": ","kind":"text"},{"text":"GDestroyNotify","preciseIdentifier":"c:@T@GDestroyNotify","kind":"typeIdentifier"},{"text":"? = nil) -> ","kind":"text"},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"inlineContent":[{"type":"text","text":"If you obtain "},{"code":"pid","type":"codeVoice"},{"text":" from [func","type":"text"},{"type":"codeVoice","code":"GLib.spawn_async"},{"text":"] or","type":"text"},{"type":"text","text":" "},{"text":"[func","type":"text"},{"code":"GLib.spawn_async_with_pipes","type":"codeVoice"},{"text":"] you will need to pass","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[flags"},{"code":"GLib.SpawnFlags.DO_NOT_REAP_CHILD","type":"codeVoice"},{"type":"text","text":"] as a flag to the spawn function for"},{"type":"text","text":" "},{"text":"the child watching to work.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"In many programs, you will want to call [func"},{"type":"codeVoice","code":"GLib.spawn_check_wait_status"},{"text":"]","type":"text"},{"type":"text","text":" "},{"type":"text","text":"in the callback to determine whether or not the child exited"},{"text":" ","type":"text"},{"type":"text","text":"successfully."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Also, note that on platforms where [type","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Pid","type":"reference","isActive":true},{"text":"] must be explicitly closed","type":"text"},{"type":"text","text":" "},{"type":"text","text":"(see [func"},{"type":"codeVoice","code":"GLib.spawn_close_pid"},{"text":"]) ","type":"text"},{"type":"codeVoice","code":"pid"},{"text":" must not be closed while the source","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"is still active.  Typically, you should invoke [func"},{"code":"GLib.spawn_close_pid","type":"codeVoice"},{"type":"text","text":"]"},{"type":"text","text":" "},{"text":"in the callback function for the source.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"GLib supports only a single callback per process ID.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"On POSIX platforms, the same restrictions mentioned for"},{"text":" ","type":"text"},{"type":"text","text":"[func"},{"code":"GLib.child_watch_source_new","type":"codeVoice"},{"text":"] apply to this function.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"This internally creates a main loop source using","type":"text"},{"type":"text","text":" "},{"text":"[func","type":"text"},{"type":"codeVoice","code":"GLib.child_watch_source_new"},{"type":"text","text":"] and attaches it to the main loop context"},{"text":" ","type":"text"},{"text":"using [method","type":"text"},{"type":"codeVoice","code":"GLib.Source.attach"},{"type":"text","text":"]. You can do these steps manually if you"},{"type":"text","text":" "},{"text":"need greater control.","type":"text"}]}],"kind":"content"}],"kind":"symbol","abstract":[{"type":"text","text":"Sets a function to be called when the child indicated by "},{"code":"pid