dprotocol\/init_()","title":"init_()","identifier":"doc:\/\/GLib\/documentation\/GLib\/CondProtocol\/init_()"},"doc://GLib/documentation/GLib/CondProtocol/signal()":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/CondProtocol\/signal()","kind":"symbol","url":"\/documentation\/glib\/condprotocol\/signal()","role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"signal","kind":"identifier"},{"kind":"text","text":"()"}],"abstract":[{"text":"If threads are waiting for ","type":"text"},{"code":"cond","type":"codeVoice"},{"text":", at least one of them is unblocked.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"If no threads are waiting for "},{"type":"codeVoice","code":"cond"},{"text":", this function has no effect.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"It is good practice to hold the same lock as the waiting thread"},{"type":"text","text":" "},{"text":"while calling this function, though not required.","type":"text"}],"type":"topic","title":"signal()"},"doc://GLib/documentation/GLib/CondProtocol/free()":{"abstract":[{"text":"Destroys a ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Cond","type":"reference","isActive":true},{"text":" that has been created with ","type":"text"},{"type":"codeVoice","code":"g_cond_new()"},{"text":".","type":"text"}],"title":"free()","identifier":"doc:\/\/GLib\/documentation\/GLib\/CondProtocol\/free()","kind":"symbol","type":"topic","role":"symbol","deprecated":true,"fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"free","kind":"identifier"},{"text":"()","kind":"text"}],"url":"\/documentation\/glib\/condprotocol\/free()"},"doc://GLib/documentation/GLib/PointerWrapper":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/PointerWrapper","kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"PointerWrapper"}],"role":"symbol","abstract":[{"type":"text","text":"Protocol for GLib types that wrap poi