threads are waiting for ","type":"text"},{"type":"codeVoice","code":"cond"},{"text":", all of them are unblocked.","type":"text"},{"text":" ","type":"text"},{"text":"If no threads are waiting for ","type":"text"},{"code":"cond","type":"codeVoice"},{"text":", this function has no effect.","type":"text"},{"type":"text","text":" "},{"text":"It is good practice to lock the same mutex as the waiting threads","type":"text"},{"type":"text","text":" "},{"type":"text","text":"while calling this function, though not required."}],"kind":"symbol","type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib\/CondProtocol\/broadcast()","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"broadcast","kind":"identifier"},{"kind":"text","text":"()"}],"url":"\/documentation\/glib\/condprotocol\/broadcast()"},"doc://GLib/documentation/GLib/CondProtocol":{"title":"CondProtocol","role":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/CondProtocol","abstract":[{"text":"The ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Cond"},{"text":" struct is an opaque data structure that represents a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"condition. Threads can block on a "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Cond","isActive":true,"type":"reference"},{"text":" if they find a certain","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"condition to be false. If other threads change the state of this"},{"type":"text","text":" "},{"type":"text","text":"condition they signal the "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Cond","isActive":true},{"text":", and that causes the waiting","type":"text"},{"type":"text","text":" "},{"type":"text","text":"threads to be woken up."}],"fragments":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"CondProtocol"}],"navigatorTitle":[{"kind":"identifier","text":"CondProtocol"}],"url":"\/documentation\/glib\/condprotocol","kind":"symbol","type":"topic"},"doc://GLib/documentation/GLib/CondProtocol/wait(mutex:)":{"role":"symbol","kind":"symbol","type":"topic","abstract":[{"text":"Atomically releases ","type":"text"},{"type":"codeVoice","code":"mutex"},{"text":" and waits until ","type":"text"},{"code":"cond","type":"codeVoice"},{"type":"text","text":" is signalled."},{"text":" ","type":"text"},{"text":"When this function returns, ","type":"text"},{"type":"codeVoice","code":"mutex"},{"type":"text","text":" is locked again and owned by the"},{"type":"text","text":" "},{"type":"text","text":"calling thread."}],"title":"wait(mutex:)","identifier":"doc:\/\/GLib\/documentation\/GLib\/CondProtocol\/wait(mutex:)","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"wait"},{"text":"<","kind":"text"},{"text":"MutexT","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"mutex","kind":"externalParam"},{"kind":"text","text":": "},{"text":"MutexT","kind":"typeIdentifier"},{"kind":"text","text":")"}],"url":"\/documentation\/glib\/condprotocol\/wait(mutex:)"},"doc://GLib/documentation/GLib/CondProtocol/waitUntil(mutex:endTime:)":{"kind":"symbol","url":"\/documentation\/glib\/condprotocol\/waituntil(mutex:endtime:)","title":"waitUntil(mutex:endTime:)","type":"topic","abstract":[{"type":"text","text":"Waits until either "},{"type":"codeVoice","code":"cond"},{"type":"text","text":" is signalled or "},{"type":"codeVoice","code":"endTime"},{"type":"text","text":" has passed."}],"fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"waitUntil"},{"text":"<","kind":"text"},{"text":"MutexT","kind":"genericParameter"},{"kind":"text","text":">("},{"text":"mutex","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"MutexT","kind":"typeIdentifier"},{"kind":"text","text":", "},{"kind":"externalParam","text":"endTime"},{"kind":"text"