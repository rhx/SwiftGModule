{"kind":"symbol","hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/CondRef","doc:\/\/GLib\/documentation\/GLib\/CondRef\/CondProtocol-Implementations"]]},"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"waitUntil"},{"kind":"text","text":"<"},{"text":"MutexT","kind":"genericParameter"},{"kind":"text","text":">("},{"text":"mutex","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"MutexT","kind":"typeIdentifier"},{"kind":"text","text":", "},{"text":"endTime","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gint64","text":"gint64"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"},{"text":" ","kind":"text"},{"kind":"keyword","text":"where"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"MutexT"},{"text":" : ","kind":"text"},{"text":"MutexProtocol","identifier":"doc:\/\/GLib\/documentation\/GLib\/MutexProtocol","kind":"typeIdentifier","preciseIdentifier":"s:4GLib13MutexProtocolP"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"text":"Discussion","type":"heading","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"As with ","type":"text"},{"type":"codeVoice","code":"g_cond_wait()"},{"text":" it is possible that a spurious or stolen wakeup","type":"text"},{"type":"text","text":" "},{"type":"text","text":"could occur.  For that reason, waiting on a condition variable should"},{"text":" ","type":"text"},{"type":"text","text":"always be in a loop, based on an explicitly-checked predicate."}]},{"inlineContent":[{"code":"true","type":"codeVoice"},{"text":" is returned if the condition variable was signalled (or in the","type":"text"},{"type":"text","text":" "},{"text":"case of a spurious wakeup).  ","type":"text"},{"type":"codeVoice","code":"false"},{"type":"text","text":" is returned if "},{"code":"endTime","type":"codeVoice"},{"type":"text","text":" has"},{"type":"text","text":" "},{"type":"text","text":"passed."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The following code shows how to correctly perform a timed wait on a"},{"type":"text","text":" "},{"type":"text","text":"condition variable (extending the example presented in the"},{"text":" ","type":"text"},{"type":"text","text":"documentation for "},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/Cond","type":"reference"},{"text":"):","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"(C Language Example):","type":"text"}]},{"syntax":"C","type":"codeListing","code":["gpointer","pop_data_timed (void)","{","  gint64 end_time;","  gpointer data;","","  g_mutex_lock (&data_mutex);","","  end_time = g_get_monotonic_time () + 5 * G_TIME_SPAN_SECOND;","  while (!current_data)","    if (!g_cond_wait_until (&data_cond, &data_mutex, end_time))","      {","        \/\/ timeout has passed.","        g_mutex_unlock (&data_mutex);","        return NULL;","      }","","  \/\/ there is data for us","  data = current_data;","  current_data = NULL;","","  g_mutex_unlock (&data_mutex);","","  return data;","}"]},{"inlineContent":[{"type":"text","text":"Notice that the end time is calculated once, before entering the"},{"type":"text","text":" "},{"text":"loop and reused.  This is the motivation behind the use of absolute","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"time on this API – if a relative time of 5 seconds were passed"},{"type":"text","text":" "},{"text":"directly to the call and a spurious wakeup occurred, the program would","type":"text"},{"type":"text","text":" "},{"type":"text","text":"have to start over waiting again (which would lead to a total wait"},{"text":" ","type":"text"},{"text":"time of more than 5 seconds).","type":"text"}],"type":"paragraph"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/condref\/waituntil(mutex:endtime:)"]}],"metadata":{"modules":[{"name":"GLib"}],"title":"waitUntil(mutex:endTime:)","symbolKind":"method","roleHeading":"Instance Method","role":"symbol","extendedModule":"GLib","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"waitUntil"},{"kind":"text","text":"<"},{"text":"MutexT","kind":"genericParameter"},{"text":">(","kind":"text"},{"kind":"externalParam","text":"mutex"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"MutexT"},{"text":", ","kind":"text"},{"text":"endTime","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"gint64","kind":"typeIdentifier","preciseIdentifier":"c:@T@gint64"},{"text":") -> ","kind":"text"},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"}],"externalID":"s:4GLib12CondProtocolPAAE9waitUntil5mutex7endTimeSbqd___s5Int64VtAA05MutexC0Rd__lF::SYNTHESIZED::s:4GLib7CondRefV"},"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/CondRef\/waitUntil(mutex:endTime:)","interfaceLanguage":"swift"},"schemaVersion":{"major":0,"minor":3,"patch":0},"abstract":[{"type":"text","text":"Waits until either "},{"type":"codeVoice","code":"cond"},{"type":"text","text":" is signalled or "},{"code":"endTime","type":"codeVoice"},{"text":" has passed.","type":"text"}],"references":{"doc://GLib/documentation/GLib/CondRef":{"title":"CondRef","kind":"symbol","url":"\/documentation\/glib\/condref","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"CondRef","kind":"identifier"}],"type":"topic","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"CondRef"}],"abstract":[{"type":"text","text":"The "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Cond","isActive":true,"type":"reference"},{"type":"text","text":" struct is an opaque data structure that represents a"},{"text":" ","type":"text"},{"text":"condition. Threads can block on a ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Cond","isActive":true},{"type":"text","text":" if they find a certain"},{"type":"text","text":" "},{"type":"text","text":"condition to be false. If other threads change the state of this"},{"text":" ","type":"text"},{"type":"text","text":"condition they signal the "},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/Cond","type":"reference"},{"text":", and that causes the waiting","type":"text"},{"type":"text","text":" "},{"type":"text","text":"threads to be woken up."}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/CondRef"},"doc://GLib/documentation/GLib/MutexProtocol":{"abstract":[{"type":"text","text":"The "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex","type":"reference","isActive":true},{"text":" struct is an opaque data structure to represent a mutex","type":"text"},{"type":"text","text":" "},{"text":"(mutual exclusion). It can be used to protect data against shared","type":"text"},{"type":"text","text":" "},{"type":"text","text":"access."}],"navigatorTitle":[{"text":"MutexProtocol","kind":"identifier"}],"role":"symbol","kind":"symbol","title":"MutexProtocol","type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib\/MutexProtocol","url":"\/documentation\/glib\/mutexprotocol","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"MutexProtocol"}]},"doc://GLib/documentation/GLib/CondRef/CondProtocol-Implementations":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/CondRef\/CondProtocol-Implementations","abstract":[],"type":"topic","url":"\/documentation\/glib\/condref\/condprotocol-implementations","kind":"article","role":"collectionGroup","title":"CondProtocol Implementations"},"doc://GLib/documentation/GLib":{"kind":"symbol","role":"collection","abstract":[],"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","type":"topic","url":"\/documentation\/gl