{"metadata":{"fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"Date"}],"roleHeading":"Class","modules":[{"name":"GLib"}],"title":"Date","navigatorTitle":[{"kind":"identifier","text":"Date"}],"externalID":"s:4GLib4DateC","role":"symbol","symbolKind":"class"},"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"Date","kind":"identifier"}],"platforms":["macOS"],"languages":["swift"]}]},{"content":[{"text":"Overview","level":2,"anchor":"overview","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"type":"codeVoice","code":"GDate"},{"type":"text","text":" data structure represents a day between January 1, Year 1,"},{"type":"text","text":" "},{"type":"text","text":"and sometime a few thousand years in the future (right now it will go"},{"text":" ","type":"text"},{"type":"text","text":"to the year 65535 or so, but [method"},{"code":"GLib.Date.set_parse","type":"codeVoice"},{"type":"text","text":"] only parses up to the"},{"text":" ","type":"text"},{"type":"text","text":"year 8000 or so - just count on “a few thousand”). "},{"code":"GDate","type":"codeVoice"},{"text":" is meant to","type":"text"},{"type":"text","text":" "},{"type":"text","text":"represent everyday dates, not astronomical dates or historical dates"},{"text":" ","type":"text"},{"type":"text","text":"or ISO timestamps or the like. It extrapolates the current Gregorian"},{"text":" ","type":"text"},{"text":"calendar forward and backward in time; there is no attempt to change","type":"text"},{"text":" ","type":"text"},{"text":"the calendar to match time periods or locations. ","type":"text"},{"code":"GDate","type":"codeVoice"},{"text":" does not store","type":"text"},{"type":"text","text":" "},{"text":"time information; it represents a day.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"code":"GDate","type":"codeVoice"},{"type":"text","text":" implementation has several nice features; it is only a"},{"text":" ","type":"text"},{"text":"64-bit struct, so storing large numbers of dates is very efficient. It","type":"text"},{"type":"text","text":" "},{"type":"text","text":"can keep both a Julian and day-month-year representation of the date,"},{"text":" ","type":"text"},{"type":"text","text":"since some calculations are much easier with one representation or the"},{"type":"text","text":" "},{"text":"other. A Julian representation is simply a count of days since some","type":"text"},{"type":"text","text":" "},{"type":"text","text":"fixed day in the past; for "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Date","isActive":true},{"type":"text","text":" the fixed day is January 1, 1 AD."},{"type":"text","text":" "},{"type":"text","text":"(“Julian” dates in the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/Date"},{"text":" API aren’t really Julian dates in the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"technical sense; technically, Julian dates count from the start of the"},{"type":"text","text":" "},{"type":"text","text":"Julian period, Jan 1, 4713 BC)."}]},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"GDate"},{"text":" is simple to use. First you need a “blank” date; you can get a","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"dynamically allocated date from [ctor"},{"type":"codeVoice","code":"GLib.Date.new"},{"text":"], or you can declare an","type":"text"},{"text":" ","type":"text"},{"text":"automatic variable or array and initialize it by calling [method","type":"text"},{"code":"GLib.Date.clear","type":"codeVoice"},{"text":"].","type":"text"},{"type":"text","text":" "},{"type":"text","text":"A cleared date is safe; it’s safe to call [method"},{"code":"GLib.Date.set_dmy","type":"codeVoice"},{"type":"text","text":"] and the other"},{"text":" ","type":"text"},{"text":"mutator functions to initialize the value of a cleared date. However, a cleared date","type":"text"},{"type":"text","text":" "},{"type":"text","text":"is initially invalid, meaning that it doesn’t represent a day that exists."},{"type":"text","text":" "},{"type":"text","text":"It is undefined to call any of the date calculation routines on an invalid date."},{"type":"text","text":" "},{"type":"text","text":"If you obtain a date from a user or other unpredictable source, you should check"},{"text":" ","type":"text"},{"text":"its validity with the [method","type":"text"},{"type":"codeVoice","code":"GLib.Date.valid"},{"text":"] predicate. [method","type":"text"},{"code":"GLib.Date.valid","type":"codeVoice"},{"type":"text","text":"]"},{"type":"text","text":" "},{"type":"text","text":"is also used to check for errors with [method"},{"type":"codeVoice","code":"GLib.Date.set_parse"},{"type":"text","text":"] and other functions"},{"type":"text","text":" "},{"type":"text","text":"that can fail. Dates can be invalidated by calling [method"},{"type":"codeVoice","code":"GLib.Date.clear"},{"text":"] again.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"It is very important to use the API to access the "},{"code":"GDate","type":"codeVoice"},{"type":"text","text":" struct. Often only the"},{"type":"text","text":" "},{"text":"day-month-year or only the Julian representation is valid. Sometimes neither is valid.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Use the API."}]},{"type":"paragraph","inlineContent":[{"text":"GLib also features ","type":"text"},{"type":"codeVoice","code":"GDateTime"},{"type":"text","text":" which represents a precise time."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Date","isActive":true},{"text":" type acts as an owner of an underlying ","type":"text"},{"type":"codeVoice","code":"GDate"},{"type":"text","text":" instance."},{"text":" ","type":"text"},{"type":"text","text":"It provides the methods that can operate on this data type through "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/DateProtocol"},{"type":"text","text":" conformance."},{"type":"text","text":" "},{"type":"text","text":"Use "},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/Date","type":"reference"},{"text":" as a strong reference or owner of a ","type":"text"},{"code":"GDate","type":"codeVoice"},{"type":"text","text":" instance."}]},{"style":"note","content":[{"inlineContent":[{"text":"Use ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/DateRef","type":"reference","isActive":true},{"text":" (instead of ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Date"},{"type":"text","text":") for a lightweight Swift reference to an underlying "},{"type":"codeVoice","code":"GDate"},{"text":" instance.","type":"text"}],"type":"paragraph"}],"name":"Note","type":"aside"}],"kind":"content"}],"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/date"]}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/Date","interfaceLanguage":"swift"},"relationshipsSections":[{"kind":"relationships","type":"conformsTo","title":"Conforms To","identifiers":["doc:\/\/GLib\/documentation\/GLib\/DateProtocol","doc:\/\/GLib\/documentation\/GLib\/PointerWrapper"]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"abstract":[{"code":"GDate","type":"codeVoice"},{"type":"text","text":" is a struct for calendrical calculations."}],"topicSections":[{"title":"Initializers","generated":true,"identifiers":["doc:\/\/GLib\/documentation\/GLib\/Date\/init()","doc:\/\/GLib\/documentation\/GLib\/Date\/init(_:)-1xuni","doc:\/\/GLib\/documentation\/GLib\/Date\/init(_:)-