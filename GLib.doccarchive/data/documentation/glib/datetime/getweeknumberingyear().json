{"kind":"symbol","abstract":[{"text":"Returns the ISO 8601 week-numbering year in which the week containing","type":"text"},{"text":" ","type":"text"},{"code":"datetime","type":"codeVoice"},{"text":" falls.","type":"text"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/DateTime\/getWeekNumberingYear()"},"schemaVersion":{"minor":3,"patch":0,"major":0},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"getWeekNumberingYear"},{"kind":"text","text":"() -> "},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"}]}],"kind":"declarations"},{"content":[{"text":"Discussion","type":"heading","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This function, taken together with "},{"code":"g_date_time_get_week_of_year()","type":"codeVoice"},{"text":" and","type":"text"},{"text":" ","type":"text"},{"code":"g_date_time_get_day_of_week()","type":"codeVoice"},{"type":"text","text":" can be used to determine the full ISO"},{"text":" ","type":"text"},{"type":"text","text":"week date on which "},{"type":"codeVoice","code":"datetime"},{"text":" falls.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"This is usually equal to the normal Gregorian year (as returned by","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_date_time_get_year()"},{"text":"), except as detailed below:","type":"text"}]},{"inlineContent":[{"type":"text","text":"For Thursday, the week-numbering year is always equal to the usual"},{"text":" ","type":"text"},{"text":"calendar year.  For other days, the number is such that every day","type":"text"},{"type":"text","text":" "},{"type":"text","text":"within a complete week (Monday to Sunday) is contained within the"},{"type":"text","text":" "},{"type":"text","text":"same week-numbering year."}],"type":"paragraph"},{"inlineContent":[{"text":"For Monday, Tuesday and Wednesday occurring near the end of the year,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"this may mean that the week-numbering year is one greater than the"},{"text":" ","type":"text"},{"type":"text","text":"calendar year (so that these days have the same week-numbering year"},{"text":" ","type":"text"},{"type":"text","text":"as the Thursday occurring early in the next year)."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For Friday, Saturday and Sunday occurring near the start of the year,"},{"type":"text","text":" "},{"text":"this may mean that the week-numbering year is one less than the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"calendar year (so that these days have the same week-numbering year"},{"text":" ","type":"text"},{"text":"as the Thursday occurring late in the previous year).","type":"text"}]},{"inlineContent":[{"type":"text","text":"An equivalent description is that the week-numbering year is equal to"},{"type":"text","text":" "},{"type":"text","text":"the calendar year containing the majority of the days in the current"},{"type":"text","text":" "},{"text":"week (Monday to Sunday).","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Note that January 1 0001 in the proleptic Gregorian calendar is a","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Monday, so this function never returns 0."}]}],"kind":"content"}],"sections":[],"variants":[{"paths":["\/documentation\/glib\/datetime\/getweeknumberingyear()"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/DateTime","doc:\/\/GLib\/documentation\/GLib\/DateTime\/DateTimeProtocol-Implementations"]]},"metadata":{"symbolKind":"method","externalID":"s:4GLib16DateTimeProtocolPAAE20getWeekNumberingYearSiyF::SYNTHESIZED::s:4GLib8DateTimeC","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"getWeekNumberingYear","kind":"identifier"},{"kind":"text","text":"() -> "},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"}],"title":"getWeekNumberingYear()","roleHeading":"Instance Method","extendedModule":"GLib","modules":[{"name":"GLib"}],"role":"symbol"},"references":{"doc://GLib/documentation/GLib/DateTime/DateTimeProtocol-Implementations":{"kind":"article","abstract":[],"role":"collectionGroup","url":"\/documentation\/glib\/datetime\/datetimeprotocol-implementations","type":"topic","title":"DateTimeProtocol Implementations","identifier":"doc:\/\/GLib\/documentation\/GLib\/DateTime\/DateTimeProtocol-Implementations"},"doc://GLib/documentation/GLib":{"kind":"symbol","role":"collection","abstract":[],"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","type":"topic","url":"\/documentation\/glib"},"doc://GLib/documentation/GLib/DateTime":{"abstract":[{"type":"codeVoice","code":"GDateTime"},{"type":"text","text":" is a structure that combines a Gregorian date and time"},{"text":" ","type":"text"},{"text":"into a single structure.","type":"text"}],"role":"symbol","url":"\/documentation\/glib\/datetime","type":"topic","title":"DateTime","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"DateTime","kind":"identifier"}],"kind":"symbol","navigatorTitle":[{"text":"DateTime","kind":"identifier"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/DateTime"},"doc://GLib/documentation/GLib/DateTime/getWeekNumberingYear()":{"url":"\/documentation\/glib\/datetime\/getweeknumberingyear()","identifier":"doc:\/\/GLib\/documentation\/GLib\/DateTime\/getWeekNumberingYear()","kind":"symbol","title":"getWeekNumberingYear()","abstract":[{"type":"text","text":"Returns the ISO 8601 week-numbering year in which the week containing"},{"text":" ","type":"text"},{"type":"codeVoice","code":"datetime"},{"type":"text","text":" falls."}],"fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"getWeekNumberingYear","kind":"identifier"},{"kind":"text","text":"() -> "},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"}],"type":"topic","role":"symbol"}}}