{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/datetime\/weeknumberingyear"]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"abstract":[{"type":"text","text":"Returns the ISO 8601 week-numbering year in which the week containing"},{"text":" ","type":"text"},{"code":"datetime","type":"codeVoice"},{"text":" falls.","type":"text"}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/DateTime","doc:\/\/GLib\/documentation\/GLib\/DateTime\/DateTimeProtocol-Implementations"]]},"sections":[],"metadata":{"extendedModule":"GLib","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"text":"weekNumberingYear","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"}],"roleHeading":"Instance Property","symbolKind":"property","modules":[{"name":"GLib"}],"role":"symbol","externalID":"s:4GLib16DateTimeProtocolPAAE17weekNumberingYearSivp::SYNTHESIZED::s:4GLib8DateTimeC","title":"weekNumberingYear"},"kind":"symbol","primaryContentSections":[{"declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"text":"var","kind":"keyword"},{"kind":"text","text":" "},{"text":"weekNumberingYear","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"kind":"text","text":" { "},{"kind":"keyword","text":"get"},{"text":" }","kind":"text"}]}],"kind":"declarations"},{"kind":"content","content":[{"anchor":"discussion","level":2,"text":"Discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"This function, taken together with "},{"type":"codeVoice","code":"g_date_time_get_week_of_year()"},{"type":"text","text":" and"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_date_time_get_day_of_week()"},{"type":"text","text":" can be used to determine the full ISO"},{"type":"text","text":" "},{"type":"text","text":"week date on which "},{"code":"datetime","type":"codeVoice"},{"type":"text","text":" falls."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This is usually equal to the normal Gregorian year (as returned by"},{"type":"text","text":" "},{"code":"g_date_time_get_year()","type":"codeVoice"},{"type":"text","text":"), except as detailed below:"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"For Thursday, the week-numbering year is always equal to the usual"},{"text":" ","type":"text"},{"text":"calendar year.  For other days, the number is such that every day","type":"text"},{"type":"text","text":" "},{"text":"within a complete week (Monday to Sunday) is contained within the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"same week-numbering year."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"For Monday, Tuesday and Wednesday occurring near the end of the year,","type":"text"},{"text":" ","type":"text"},{"text":"this may mean that the week-numbering year is one greater than the","type":"text"},{"text":" ","type":"text"},{"text":"calendar year (so that these days have the same week-numbering year","type":"text"},{"type":"text","text":" "},{"type":"text","text":"as the Thursday occurring early in the next year)."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For Friday, Saturday and Sunday occurring near the start of the year,"},{"text":" ","type":"text"},{"type":"text","text":"this may mean that the week-numbering year is one less than the"},{"type":"text","text":" "},{"type":"text","text":"calendar year (so that these days have the same week-numbering year"},{"type":"text","text":" "},{"type":"text","text":"as the Thursday occurring late in the previous year)."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"An equivalent description is that the week-numbering year is equal to"},{"type":"text","text":" "},{"text":"the calendar year containing the majority of the days in the current","type":"text"},{"text":" ","type":"text"},{"text":"week (Monday to Sunday).","type":"text"}]},{"inlineContent":[{"type":"text","text":"Note that January 1 0001 in the proleptic Gregorian calendar is a"},{"type":"text","text":" "},{"text":"Monday, so this function never returns 0.","type":"text"}],"type":"paragraph"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/DateTime\/weekNumberingYear"},"references":{"doc://GLib/documentation/GLib/DateTime":{"abstract":[{"type":"codeVoice","code":"GDateTime"},{"type":"text","text":" is a structure that combines a Gregorian date and time"},{"text":" ","type":"text"},{"text":"into a single structure.","type":"text"}],"role":"symbol","url":"\/documentation\/glib\/datetime","type":"topic","title":"DateTime","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"DateTime","kind":"identifier"}],"kind":"symbol","navigatorTitle":[{"text":"DateTime","kind":"identifier"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/DateTime"},"doc://GLib/documentation/GLib":{"kind":"symbol","role":"collection","abstract":[],"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","type":"topic","url":"\/documentation\/glib"},"doc://GLib/documentation/GLib/DateTime/DateTimeProtocol-Implementations":{"kind":"article","abstract":[],"role":"collectionGroup","url":"\/documentation\/glib\/datetime\/datetimeprotocol-implementations","type":"topic","title":"DateTimeProtocol Implementations","identifier":"doc:\/\/GLib\/documentation\/GLib\/DateTime\/DateTimeProtocol-Implementations"},"doc://GLib/documentation/GLib/DateTime/weekNumberingYear":{"abstract":[{"type":"text","text":"Returns the ISO 8601 week-numbering year in which the week containing"},{"type":"text","text":" "},{"code":"datetime","type":"codeVoice"},{"type":"text","text":" falls."}],"fragments":[{"text":"var","kind":"keyword"},{"kind":"text","text":" "},{"text":"weekNumberingYear","kind":"identifier"},{"text":": ","kind":"text"},{"kind":"typeId