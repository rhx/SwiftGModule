{"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"weekOfYear"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"kind":"text","text":" { "},{"kind":"keyword","text":"get"},{"kind":"text","text":" }"}],"languages":["swift"]}]},{"kind":"content","content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"inlineContent":[{"text":"The first week of the year is week 1.  This is the week that contains","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the first Thursday of the year.  Equivalently, this is the first week"},{"type":"text","text":" "},{"type":"text","text":"that has more than 4 of its days falling within the calendar year."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The value 0 is never returned by this function.  Days contained","type":"text"},{"type":"text","text":" "},{"text":"within a year but occurring before the first ISO 8601 week of that","type":"text"},{"type":"text","text":" "},{"type":"text","text":"year are considered as being contained in the last week of the"},{"text":" ","type":"text"},{"text":"previous year.  Similarly, the final days of a calendar year may be","type":"text"},{"text":" ","type":"text"},{"text":"considered as being part of the first ISO 8601 week of the next year","type":"text"},{"type":"text","text":" "},{"type":"text","text":"if 4 or more days of that week are contained within the new year."}]}]}],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/DateTime","doc:\/\/GLib\/documentation\/GLib\/DateTime\/DateTimeProtocol-Implementations"]]},"sections":[],"schemaVersion":{"minor":3,"patch":0,"major":0},"metadata":{"symbolKind":"property","extendedModule":"GLib","roleHeading":"Instance Property","modules":[{"name":"GLib"}],"role":"symbol","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"weekOfYear"},{"kind":"text","text":": "},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"}],"externalID":"s:4GLib16DateTimeProtocolPAAE10weekOfYearSivp::SYNTHESIZED::s:4GLib8DateTimeC","title":"weekOfYear"},"variants":[{"paths":["\/documentation\/glib\/datetime\/weekofyear"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/DateTime\/weekOfYear","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"Returns the ISO 8601 week number for the week containing "},{"type":"codeVoice","code":"datetime"},{"text":".","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"The ISO 8601 week number is the same for every day of the week (from"},{"text":" ","type":"text"},{"type":"text","text":"Moday through Sunday).  That can produce some unusual results"},{"type":"text","text":" "},{"text":"(described below).","type":"text"}],"references":{"doc://GLib/documentation/GLib":{"kind":"symbol","role":"collection","abstract":[],"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","type":"topic","url":"\/documentation\/glib"},"doc://GLib/documentation/GLib/DateTime":{"abstract":[{"type":"codeVoice","code":"GDateTime"},{"type":"text","text":" is a structure that combines a Gregorian date and time"},{"text":" ","type":"text"},{"text":"into a single structure.","type":"text"}],"role":"symbol","url":"\/documentation\/glib\/datetime","type":"topic","title":"DateTime","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"DateTime","kind":"identifier"}],"kind":"symbol","navigatorTitle":[{"text":"DateTime","kind":"identifier"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/DateTime"},"doc://GLib/documentation/GLib/DateTime/DateTimeProtocol-Implementations":{"kind":"article","abstract":[],"role":"collectionGroup","url":"\/documentation\/glib\/datetime\/datetimeprotocol-implementations","type":"topic","title":"DateTimeProtocol Implementations","identifier":"doc:\/\/GLib\/documentation\/GLib\/DateTime\/DateTimeProtocol-Implementations"},"doc://GLib/documentation/GLib/DateTime/weekOfYear":{"fragments":[{"kind":"keyword","text":"var"},{"text":" ","kind":"text"},{"text":"weekOfYear","kind":"identifier"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"}],"kind":"symbol","role":"symbol","url":"\/documentation\/glib\/datetime\/weekofyear","type":"topic","abstract":[{"text":"Returns the ISO 8601 week number for the week containing ","type":"text"},{"type":"codeVoice","code":"datetime"},{"type":"text","text":"."},{"text":" ","type":"text"},{"type":"text","text":"The ISO 8601 week number is the same for every day of the week (from"},{"text":" ","type":"text"},{"text":"Moday through Sunday).  That can produce some unusual results","type":"text"},{"type":"text","text":" "},{"type":"text","text":"(described below)."}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/DateTime\/weekOfYear","title":"weekOfYear"}}}