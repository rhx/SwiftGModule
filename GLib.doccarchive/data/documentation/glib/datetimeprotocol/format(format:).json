{"sections":[],"metadata":{"externalID":"s:4GLib16DateTimeProtocolPAAE6formatADSSSgSPys4Int8VGSg_tF","extendedModule":"GLib","symbolKind":"method","title":"format(format:)","role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"format","kind":"identifier"},{"kind":"text","text":"("},{"text":"format","kind":"externalParam"},{"kind":"text","text":": "},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"kind":"text","text":"<"},{"preciseIdentifier":"c:@T@gchar","kind":"typeIdentifier","text":"gchar"},{"kind":"text","text":">!) -> "},{"preciseIdentifier":"s:SS","text":"String","kind":"typeIdentifier"},{"text":"!","kind":"text"}],"modules":[{"name":"GLib"}],"roleHeading":"Instance Method"},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"format","kind":"identifier"},{"text":"(","kind":"text"},{"text":"format","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"UnsafePointer","preciseIdentifier":"s:SP","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"preciseIdentifier":"c:@T@gchar","text":"gchar","kind":"typeIdentifier"},{"text":">!) -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:SS","text":"String"},{"kind":"text","text":"!"}],"languages":["swift"],"platforms":["macOS"]}]},{"kind":"content","content":[{"text":"Discussion","type":"heading","anchor":"discussion","level":2},{"type":"paragraph","inlineContent":[{"text":"The format strings understood by this function are a subset of the","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"strftime()"},{"type":"text","text":" format language as specified by C99.  The "},{"code":"D","type":"codeVoice"},{"text":", ","type":"text"},{"code":"U","type":"codeVoice"},{"type":"text","text":" and "},{"type":"codeVoice","code":"W"},{"text":" ","type":"text"},{"type":"text","text":"conversions are not supported, nor is the "},{"code":"E","type":"codeVoice"},{"text":" modifier.  The GNU","type":"text"},{"type":"text","text":" "},{"type":"text","text":"extensions "},{"code":"k","type":"codeVoice"},{"text":", ","type":"text"},{"code":"l","type":"codeVoice"},{"text":", ","type":"text"},{"code":"s","type":"codeVoice"},{"type":"text","text":" and "},{"type":"codeVoice","code":"P"},{"text":" are supported, however, as are the","type":"text"},{"type":"text","text":" "},{"code":"0","type":"codeVoice"},{"text":", ","type":"text"},{"code":"_","type":"codeVoice"},{"type":"text","text":" and "},{"code":"-","type":"codeVoice"},{"type":"text","text":" modifiers. The Python extension "},{"type":"codeVoice","code":"f"},{"type":"text","text":" is also supported."}]},{"inlineContent":[{"text":"In contrast to ","type":"text"},{"code":"strftime()","type":"codeVoice"},{"type":"text","text":", this function always produces a UTF-8"},{"type":"text","text":" "},{"type":"text","text":"string, regardless of the current locale.  Note that the rendering of"},{"text":" ","type":"text"},{"text":"many formats is locale-dependent and may not match the ","type":"text"},{"code":"strftime()","type":"codeVoice"},{"type":"text","text":" "},{"text":"output exactly.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"The following format specifiers are supported:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"code":"a","type":"codeVoice"},{"type":"text","text":": the abbreviated weekday name according to the current locale"}]}]},{"content":[{"inlineContent":[{"code":"A","type":"codeVoice"},{"type":"text","text":": the full weekday name according to the current locale"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"b","type":"codeVoice"},{"type":"text","text":": the abbreviated month name according to the current locale"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"B"},{"text":": the full month name according to the current locale","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"c","type":"codeVoice"},{"type":"text","text":": the preferred date and time representation for the current locale"}]}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"C"},{"type":"text","text":": the century number (year\/100) as a 2-digit integer (00-99)"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"code":"d","type":"codeVoice"},{"type":"text","text":": the day of the month as a decimal number (range 01 to 31)"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/GLib\/documentation\/GLib\/e-3m6a4","isActive":true,"type":"reference"},{"type":"text","text":": the day of the month as a decimal number (range 1 to 31);"},{"text":" ","type":"text"},{"text":"single digits are preceded by a figure space (U+2007)","type":"text"}]}]},{"content":[{"inlineContent":[{"code":"F","type":"codeVoice"},{"text":": equivalent to ","type":"text"},{"type":"codeVoice","code":"Y-"},{"type":"text","text":"m-"},{"type":"codeVoice","code":"d"},{"text":" (the ISO 8601 date format)","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"g","type":"codeVoice"},{"type":"text","text":": the last two digits of the ISO 8601 week-based year as a"},{"text":" ","type":"text"},{"text":"decimal number (00-99). This works well with ","type":"text"},{"code":"V","type":"codeVoice"},{"type":"text","text":" and "},{"code":"u","type":"codeVoice"},{"text":".","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"G","type":"codeVoice"},{"type":"text","text":": the ISO 8601 week-based year as a decimal number. This works"},{"type":"text","text":" "},{"text":"well with ","type":"text"},{"type":"codeVoice","code":"V"},{"text":" and ","type":"text"},{"code":"u","type":"codeVoice"},{"type":"text","text":"."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"h"},{"type":"text","text":": equivalent to "},{"type":"codeVoice","code":"b"}]}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"H"},{"type":"text","text":": the hour as a decimal number using a 24-hour clock (range 00 to 23)"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"I"},{"text":": the hour as a decimal number using a 12-hour clock (range 01 to 12)","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"j"},{"text":": the day of the year as a decimal number (range 001 to 366)","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"k","type":"codeVoice"},{"text":": the hour (24-hour clock) as a decimal number (range 0 to 23);","type":"text"},{"type":"text","text":" "},{"text":"single digits are preceded by a figure space (U+2007)","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"l"},{"type":"text","text":": the hour (12-hour clock) as a decimal number (range 1 to 12);"},{"text":" ","type":"text"},{"text":"single digits are preceded by a figure space (U+2007)","type":"text"}]}]},{"content":[{"inlineContent":[{"code":"m","type":"codeVoice"},{"type":"text","text":": the month as a decimal number (range 01 to 12)"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"M","type":"codeVoice"},{"type":"text","text":": the minute as a decimal number (range 00 to 59)"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"f","type":"codeVoice"},{"text":": the microsecond as a decimal number (range 000000 to 999999)","type":"text"}]}]},{"content":[{"inlineContent":[{"code":"p","type":"codeVoice"},{"type":"text","text":": either ‘AM’ or ‘PM’ according to the given time value, or the"},{"text":" ","type":"text"},{"type":"text","text":"corresponding  strings for the current locale.  Noon is treated as"},{"text":" ","type":"text"},{"text":"‘PM’ and midnight as ‘AM’. Use of this format specifier is discouraged, as","type":"text"},{"type":"text","text":" "},{"text":"many locales have no concept of AM\/PM formatting. Use ","type":"text"},{"type":"codeVoice","code":"c"},{"text":" or ","type":"text"},{"type":"codeVoice","code":"X"},{"type":"text","text":" instead."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"P"},{"text":": like ","type":"text"},{"code":"p","type":"codeVoice"},{"text":" but lowercase: ‘am’ or ‘pm’ or a corresponding string for","type":"text"},{"text":" ","type":"text"},{"text":"the current locale. Use of this format specifier is discouraged, as","type":"text"},{"type":"text","text":" "},{"type":"text","text":"many locales have no concept of AM\/PM formatting. Use "},{"type":"codeVoice","code":"c"},{"text":" or ","type":"text"},{"type":"codeVoice","code":"X"},{"type":"text","text":" instead."}]}]},{"content":[{"inlineContent":[{"code":"r","type":"codeVoice"},{"type":"text","text":": the time in a.m. or p.m. notation. Use of this format specifier is"},{"text":" ","type":"text"},{"type":"text","text":"discouraged, as many locales have no concept of AM\/PM formatting. Use "},{"type":"codeVoice","code":"c"},{"type":"text","text":" "},{"type":"text","text":"or "},{"type":"codeVoice","code":"X"},{"type":"text","text":" instead."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"R","type":"codeVoice"},{"type":"text","text":": the time in 24-hour notation ("},{"code":"H:","type":"codeVoice"},{"text":"M``)","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"s","type":"codeVoice"},{"type":"text","text":": the number of seconds since the Epoch, that is, since 1970-01-01"},{"type":"text","text":" "},{"text":"00:00:00 UTC","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"S"},{"text":": the second as a decimal number (range 00 to 60)","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"t"},{"type":"text","text":": a tab character"}]}]},{"content":[{"inlineContent":[{"code":"T","type":"codeVoice"},{"text":": the time in 24-hour notation with seconds (","type":"text"},{"code":"H:","type":"codeVoice"},{"type":"text","text":"M:"},{"type":"codeVoice","code":"S"},{"text":")","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"u"},{"text":": the ISO 8601 standard day of the week as a decimal, range 1 to 7,","type":"text"},{"type":"text","text":" "},{"text":"Monday being 1. This works well with ","type":"text"},{"code":"G","type":"codeVoice"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"V"},{"type":"text","text":"."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"V","type":"codeVoice"},{"text":": the ISO 8601 standard week number of the current year as a decimal","type":"text"},{"type":"text","text":" "},{"text":"number, range 01 to 53, where week 1 is the first week that has at","type":"text"},{"text":" ","type":"text"},{"text":"least 4 days in the new year. See ","type":"text"},{"type":"codeVoice","code":"g_date_time_get_week_of_year()"},{"type":"text","text":"."},{"type":"text","text":" "},{"text":"This works well with ","type":"text"},{"code":"G","type":"codeVoice"},{"type":"text","text":" and "},{"type":"codeVoice","code":"u"},{"type":"text","text":"."}]}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"w"},{"type":"text","text":": the day of the week as a decimal, range 0 to 6, Sunday being 0."},{"type":"text","text":" "},{"type":"text","text":"This is not the ISO 8601 standard format — use "},{"code":"u","type":"codeVoice"},{"text":" instead.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"x"},{"text":": the preferred date representation for the current locale without","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the time"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"code":"X","type":"codeVoice"},{"type":"text","text":": the preferred time representation for the current locale without"},{"text":" ","type":"text"},{"text":"the date","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"y","type":"codeVoice"},{"type":"text","text":": the year as a decimal number without the century"}]}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"Y"},{"type":"text","text":": the year as a decimal number including the century"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"z"},{"text":": the time zone as an offset from UTC (","type":"text"},{"code":"+hhmm","type":"codeVoice"},{"text":")","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":":z"},{"type":"text","text":": the time zone as an offset from UTC ("},{"type":"codeVoice","code":"+hh:mm"},{"type":"text","text":")."},{"text":" ","type":"text"},{"text":"This is a gnulib ","type":"text"},{"code":"strftime()","type":"codeVoice"},{"type":"text","text":" extension. Since: 2.38"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"::z"},{"text":": the time zone as an offset from UTC (","type":"text"},{"type":"codeVoice","code":"+hh:mm:ss"},{"text":"). This is a","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"gnulib "},{"type":"codeVoice","code":"strftime()"},{"text":" extension. Since: 2.38","type":"text"}]}]},{"content":[{"inlineContent":[{"code":":::z","type":"codeVoice"},{"type":"text","text":": the time zone as an offset from UTC, with "},{"type":"codeVoice","code":":"},{"text":" to necessary","type":"text"},{"type":"text","text":" "},{"text":"precision (e.g., ","type":"text"},{"type":"codeVoice","code":"-04"},{"text":", ","type":"text"},{"type":"codeVoice","code":"+05:30"},{"text":"). This is a gnulib ","type":"text"},{"code":"strftime()","type":"codeVoice"},{"text":" extension. Since: 2.38","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"Z"},{"text":": the time zone or name or abbreviation","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"``````: a literal ```` character","type":"text"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"text":"Some conversion specifications can be modified by preceding the","type":"text"},{"type":"text","text":" "},{"text":"conversion specifier by one or more modifier characters.","type":"text"}]},{"inlineContent":[{"type":"text","text":"The following modifiers are supported for many of the numeric"},{"text":" ","type":"text"},{"text":"conversions:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"code":"O","type":"codeVoice"},{"type":"text","text":": Use alternative numeric symbols, if the current locale supports those."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"code":"_","type":"codeVoice"},{"text":": Pad a numeric result with spaces. This overrides the default padding","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"for the specifier."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"-"},{"text":": Do not pad a numeric result. This overrides the default padding","type":"text"},{"text":" ","type":"text"},{"text":"for the specifier.","type":"text"}]}]},{"content":[{"inlineContent":[{"code":"0","type":"codeVoice"},{"type":"text","text":": Pad a numeric result with zeros. This overrides the default padding"},{"type":"text","text":" "},{"type":"text","text":"for the specifier."}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"text":"The following modifiers are supported for many of the alphabetic conversions:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"code":"^","type":"codeVoice"},{"text":": Use upper case if possible. This is a gnulib ","type":"text"},{"code":"strftime()","type":"codeVoice"},{"type":"text","text":" extension."},{"text":" ","type":"text"},{"text":"Since: 2.80","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"#","type":"codeVoice"},{"text":": Use opposite case if possible. This is a gnulib ","type":"text"},{"type":"codeVoice","code":"strftime()"},{"type":"text","text":" "},{"text":"extension. Since: 2.80","type":"text"}]}]}]},{"type":"paragraph","inlineContent":[{"text":"Additionally, when ","type":"text"},{"code":"O","type":"codeVoice"},{"text":" is used with ","type":"text"},{"code":"B","type":"codeVoice"},{"type":"text","text":", "},{"code":"b","type":"codeVoice"},{"text":", or ","type":"text"},{"type":"codeVoice","code":"h"},{"text":", it produces the alternative","type":"text"},{"type":"text","text":" "},{"type":"text","text":"form of a month name. The alternative form should be used when the month"},{"type":"text","text":" "},{"text":"name is used without a day number (e.g., standalone). It is required in","type":"text"},{"type":"text","text":" "},{"text":"some languages (Baltic, Slavic, Greek, and more) due to their grammatical","type":"text"},{"text":" ","type":"text"},{"text":"rules. For other languages there is no difference. ","type":"text"},{"code":"OB","type":"codeVoice"},{"text":" is a GNU and BSD","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"strftime()"},{"text":" extension expected to be added to the future POSIX specification,","type":"text"},{"text":" ","type":"text"},{"code":"Ob","type":"codeVoice"},{"type":"text","text":" and "},{"type":"codeVoice","code":"Oh"},{"type":"text","text":" are GNU "},{"type":"codeVoice","code":"strftime()"},{"text":" extensions. Since: 2.56","type":"text"}]},{"inlineContent":[{"type":"text","text":"Since GLib 2.80, when "},{"type":"codeVoice","code":"E"},{"type":"text","text":" is used with "},{"type":"codeVoice","code":"c"},{"text":", ","type":"text"},{"type":"codeVoice","code":"C"},{"type":"text","text":", "},{"code":"x","type":"codeVoice"},{"text":", ","type":"text"},{"type":"codeVoice","code":"X"},{"type":"text","text":", "},{"type":"codeVoice","code":"y"},{"type":"text","text":" or "},{"type":"codeVoice","code":"Y"},{"text":",","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the date is formatted using an alternate era representation specific to the"},{"text":" ","type":"text"},{"text":"locale. This is typically used for the Thai solar calendar or Japanese era","type":"text"},{"type":"text","text":" "},{"text":"names, for example.","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"Ec"},{"type":"text","text":": the preferred date and time representation for the current locale,"},{"type":"text","text":" "},{"text":"using the alternate era representation","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"EC","type":"codeVoice"},{"type":"text","text":": the name of the era"}]}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"Ex"},{"type":"text","text":": the preferred date representation for the current locale without"},{"type":"text","text":" "},{"type":"text","text":"the time, using the alternate era representation"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"code":"EX","type":"codeVoice"},{"type":"text","text":": the preferred time representation for the current locale without"},{"text":" ","type":"text"},{"type":"text","text":"the date, using the alternate era representation"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"Ey"},{"text":": the year since the beginning of the era denoted by the ","type":"text"},{"type":"codeVoice","code":"EC"},{"text":" ","type":"text"},{"type":"text","text":"specifier"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"EY","type":"codeVoice"},{"type":"text","text":": the full alternative year representation"}]}]}]}]}],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/DateTimeProtocol\/format(format:)","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/DateTimeProtocol"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/datetimeprotocol\/format(format:)"]}],"kind":"symbol","schemaVersion":{"major":0,"minor":3,"patch":0},"abstract":[{"text":"Creates a newly allocated string representing the requested ","type":"text"},{"type":"codeVoice","code":"format"},{"type":"text","text":"."}],"references":{"doc://GLib/documentation/GLib/e-3m6a4":{"title":"e","identifier":"doc:\/\/GLib\/documentation\/GLib\/e-3m6a4","kind":"symbol","url":"\/documentation\/glib\/e-3m6a4","role":"symbol","type":"topic","fragments":[{"kind":"keyword","text":"let"},{"text":" ","kind":"text"},{"text":"e","kind":"identifier"},{"kind":"text","text":": "},{"text":"Double","kind":"typeIdentifier","preciseIdentifier":"s:Sd"}],"abstract":[{"type":"text","text":"The base of natural logarithms."}]},"doc://GLib/documentation/GLib/DateTimeProtocol/format(format:)":{"url":"\/documentation\/glib\/datetimeprotocol\/format(format:)","role":"symbol","kind":"symbol","type":"topic","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"format","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"format"},{"kind":"text","text":": "},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar","text":"gchar"},{"kind":"text","text":">!) -> "},{"text":"String","preciseIdentifier":"s:SS","kind":"typeIdentifier"},{"text":"!","kind":"text"}],"abstract":[{"type":"text","text":"Creates a newly allocated string representing the requested "},{"code":"format","type":"codeVoice"},{"text":".","type":"text"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/DateTimeProtocol\/format(format:)","title":"format(format:)"},"doc://GLib/documentation/GLib":{"kind":"symbol","role":"collection","abstract":[],"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","type":"topic","url":"\/documentation\/glib"},"doc://GLib/documentation/GLib/DateTimeProtocol":{"type":"topic","abstract":[{"code":"GDateTime","type":"codeVoice"},{"type":"text","text":" is a structure that combines a Gregorian date and time"},{"text":" ","type":"text"},{"type":"text","text":"into a single structure."}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/DateTimeProtocol","url":"\/documentation\/glib\/datetimeprotocol","kind":"symbol","role":"symbol","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"DateTimeProtocol"}],"navigatorTitle":[{"text":"DateTimeProtocol","kind":"identifier"}],"title":"DateTimeProtocol"}}}