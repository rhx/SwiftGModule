{"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/DateTimeProtocol"]]},"sections":[],"abstract":[{"text":"Returns the ISO 8601 week-numbering year in which the week containing","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"datetime"},{"text":" falls.","type":"text"}],"kind":"symbol","metadata":{"fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"getWeekNumberingYear","kind":"identifier"},{"text":"() -> ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"}],"modules":[{"name":"GLib"}],"symbolKind":"method","externalID":"s:4GLib16DateTimeProtocolPAAE20getWeekNumberingYearSiyF","extendedModule":"GLib","role":"symbol","roleHeading":"Instance Method","title":"getWeekNumberingYear()"},"schemaVersion":{"major":0,"minor":3,"patch":0},"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/DateTimeProtocol\/getWeekNumberingYear()","interfaceLanguage":"swift"},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"getWeekNumberingYear"},{"kind":"text","text":"() -> "},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"anchor":"discussion","level":2,"text":"Discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"This function, taken together with "},{"type":"codeVoice","code":"g_date_time_get_week_of_year()"},{"type":"text","text":" and"},{"text":" ","type":"text"},{"code":"g_date_time_get_day_of_week()","type":"codeVoice"},{"text":" can be used to determine the full ISO","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"week date on which "},{"type":"codeVoice","code":"datetime"},{"text":" falls.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This is usually equal to the normal Gregorian year (as returned by"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_date_time_get_year()"},{"type":"text","text":"), except as detailed below:"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For Thursday, the week-numbering year is always equal to the usual"},{"text":" ","type":"text"},{"type":"text","text":"calendar year.  For other days, the number is such that every day"},{"type":"text","text":" "},{"type":"text","text":"within a complete week (Monday to Sunday) is contained within the"},{"type":"text","text":" "},{"type":"text","text":"same week-numbering year."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For Monday, Tuesday and Wednesday occurring near the end of the year,"},{"text":" ","type":"text"},{"text":"this may mean that the week-numbering year is one greater than the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"calendar year (so that these days have the same week-numbering year"},{"text":" ","type":"text"},{"type":"text","text":"as the Thursday occurring early in the next year)."}]},{"inlineContent":[{"text":"For Friday, Saturday and Sunday occurring near the start of the year,","type":"text"},{"text":" ","type":"text"},{"text":"this may mean that the week-numbering year is one less than the","type":"text"},{"text":" ","type":"text"},{"text":"calendar year (so that these days have the same week-numbering year","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"as the Thursday occurring late in the previous year)."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"An equivalent description is that the week-numbering year is equal to"},{"text":" ","type":"text"},{"text":"the calendar year containing the majority of the days in the current","type":"text"},{"type":"text","text":" "},{"type":"text","text":"week (Monday to Sunday)."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Note that January 1 0001 in the proleptic Gregorian calendar is a"},{"type":"text","text":" "},{"text":"Monday, so this function never returns 0.","type":"text"}],"type":"paragraph"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/datetimeprotocol\/getweeknumberingyear()"]}],"references":{"doc://GLib/documentation/GLib/DateTimeProtocol":{"type":"topic","abstract":[{"code":"GDateTime","type":"codeVoice"},{"type":"text","text":" is a structure that combines a Gregorian date and time"},{"text":" ","type":"text"},{"type":"text","text":"into a single structure."}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/DateTimeProtocol","url":"\/documentation\/glib\/datetimeprotocol","kind":"symbol","role":"symbol","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"DateTimeProtocol"}],"navigatorTitle":[{"text":"DateTimeProtocol","kind":"identifier"}],"title":"DateTimeProtocol"},"doc://GLib/documentation/GLib/DateTimeProtocol/getWeekNumberingYear()":{"role":"symbol","url":"\/documentation\/glib\/datetimeprotocol\/getweeknumberingyear()","abstract":[{"type":"text","text":"Returns the ISO 8601 week-numbering year in which the week containing"},{"type":"text","text":" "},{"type":"codeVoice","code":"datetime"},{"text":" falls.","type":"text"}],"title":"getWeekNumberingYear()","kind":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"getWeekNumberingYear","kind":"identifier"},{"kind":"text","text":"() -> "},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/DateTimeProtocol\/getWeekNumberingYear()","type":"topic"},"doc://GLib/documentation/GLib":{"kind":"symbol","role":"collection","abstract":[],"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","type":"topic","url":"\/documentation\/glib"}}}