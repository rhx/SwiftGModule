{"abstract":[{"text":"Returns the ISO 8601 week number for the week containing ","type":"text"},{"code":"datetime","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"text":"The ISO 8601 week number is the same for every day of the week (from","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Moday through Sunday).  That can produce some unusual results"},{"text":" ","type":"text"},{"text":"(described below).","type":"text"}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/DateTimeProtocol"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/DateTimeProtocol\/getWeekOfYear()"},"schemaVersion":{"minor":3,"major":0,"patch":0},"kind":"symbol","sections":[],"metadata":{"externalID":"s:4GLib16DateTimeProtocolPAAE13getWeekOfYearSiyF","modules":[{"name":"GLib"}],"fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"getWeekOfYear"},{"text":"() -> ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"}],"symbolKind":"method","title":"getWeekOfYear()","extendedModule":"GLib","roleHeading":"Instance Method","role":"symbol"},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"getWeekOfYear"},{"kind":"text","text":"() -> "},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"}]}]},{"kind":"content","content":[{"text":"Discussion","anchor":"discussion","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"The first week of the year is week 1.  This is the week that contains"},{"type":"text","text":" "},{"type":"text","text":"the first Thursday of the year.  Equivalently, this is the first week"},{"text":" ","type":"text"},{"text":"that has more than 4 of its days falling within the calendar year.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The value 0 is never returned by this function.  Days contained","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"within a year but occurring before the first ISO 8601 week of that"},{"text":" ","type":"text"},{"type":"text","text":"year are considered as being contained in the last week of the"},{"type":"text","text":" "},{"text":"previous year.  Similarly, the final days of a calendar year may be","type":"text"},{"type":"text","text":" "},{"type":"text","text":"considered as being part of the first ISO 8601 week of the next year"},{"text":" ","type":"text"},{"type":"text","text":"if 4 or more days of that week are contained within the new year."}]}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/datetimeprotocol\/getweekofyear()"]}],"references":{"doc://GLib/documentation/GLib/DateTimeProtocol":{"type":"topic","abstract":[{"code":"GDateTime","type":"codeVoice"},{"type":"text","text":" is a structure that combines a Gregorian date and time"},{"text":" ","type":"text"},{"type":"text","text":"into a single structure."}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/DateTimeProtocol","url":"\/documentation\/glib\/datetimeprotocol","kind":"symbol","role":"symbol","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"DateTimeProtocol"}],"navigatorTitle":[{"text":"DateTimeProtocol","kind":"identifier"}],"title":"DateTimeProtocol"},"doc://GLib/documentation/GLib/DateTimeProtocol/getWeekOfYear()":{"role":"symbol","type":"topic","abstract":[{"text":"Returns the ISO 8601 week number for the week containing ","type":"text"},{"code":"datetime","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"text":"The ISO 8601 week number is the same for every day of the week (from","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Moday through Sunday).  That can produce some unusual results"},{"text":" ","type":"text"},{"type":"text","text":"(described below)."}],"fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"getWeekOfYear","kind":"identifier"},{"text":"() -> ","kind":"text"},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"}],"title":"getWeekOfYear()","kind":"symbol","url":"\/documentation\/glib\/datetimeprotocol\/getweekofyear()","identifier":"doc:\/\/GLib\/documentation\/GLib\/DateTimeProtocol\/getWeekOfYear()"},"doc://GLib/documentation/GLib":{"kind":"symbol","role":"collection","abstract":[],"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","type":"topic","url":"\/documentation\/glib"}}}