{"kind":"symbol","abstract":[{"type":"text","text":"Returns the ISO 8601 week-numbering year in which the week containing"},{"type":"text","text":" "},{"code":"datetime","type":"codeVoice"},{"type":"text","text":" falls."}],"metadata":{"role":"symbol","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"weekNumberingYear"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"}],"symbolKind":"property","extendedModule":"GLib","roleHeading":"Instance Property","title":"weekNumberingYear","externalID":"s:4GLib16DateTimeProtocolPAAE17weekNumberingYearSivp","modules":[{"name":"GLib"}]},"variants":[{"paths":["\/documentation\/glib\/datetimeprotocol\/weeknumberingyear"],"traits":[{"interfaceLanguage":"swift"}]}],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"var"},{"text":" ","kind":"text"},{"text":"weekNumberingYear","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"kind":"text","text":" { "},{"text":"get","kind":"keyword"},{"kind":"text","text":" }"}]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Discussion","anchor":"discussion","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"This function, taken together with "},{"code":"g_date_time_get_week_of_year()","type":"codeVoice"},{"type":"text","text":" and"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_date_time_get_day_of_week()"},{"type":"text","text":" can be used to determine the full ISO"},{"text":" ","type":"text"},{"text":"week date on which ","type":"text"},{"code":"datetime","type":"codeVoice"},{"type":"text","text":" falls."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This is usually equal to the normal Gregorian year (as returned by"},{"type":"text","text":" "},{"code":"g_date_time_get_year()","type":"codeVoice"},{"type":"text","text":"), except as detailed below:"}]},{"type":"paragraph","inlineContent":[{"text":"For Thursday, the week-numbering year is always equal to the usual","type":"text"},{"text":" ","type":"text"},{"text":"calendar year.  For other days, the number is such that every day","type":"text"},{"text":" ","type":"text"},{"text":"within a complete week (Monday to Sunday) is contained within the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"same week-numbering year."}]},{"inlineContent":[{"text":"For Monday, Tuesday and Wednesday occurring near the end of the year,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"this may mean that the week-numbering year is one greater than the"},{"type":"text","text":" "},{"type":"text","text":"calendar year (so that these days have the same week-numbering year"},{"type":"text","text":" "},{"text":"as the Thursday occurring early in the next year).","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For Friday, Saturday and Sunday occurring near the start of the year,"},{"type":"text","text":" "},{"type":"text","text":"this may mean that the week-numbering year is one less than the"},{"type":"text","text":" "},{"type":"text","text":"calendar year (so that these days have the same week-numbering year"},{"type":"text","text":" "},{"text":"as the Thursday occurring late in the previous year).","type":"text"}]},{"inlineContent":[{"type":"text","text":"An equivalent description is that the week-numbering year is equal to"},{"type":"text","text":" "},{"text":"the calendar year containing the majority of the days in the current","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"week (Monday to Sunday)."}],"type":"paragraph"},{"inlineContent":[{"text":"Note that January 1 0001 in the proleptic Gregorian calendar is a","type":"text"},{"type":"text","text":" "},{"text":"Monday, so this function never returns 0.","type":"text"}],"type":"paragraph"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/DateTimeProtocol\/weekNumberingYear"},"sections":[],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/DateTimeProtocol"]]},"schemaVersion":{"major":0,"minor":3,"patch":0},"references":{"doc://GLib/documentation/GLib":{"kind":"symbol","role":"collection","abstract":[],"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","type":"topic","url":"\/documentation\/glib"},"doc://GLib/documentation/GLib/DateTimeProtocol":{"type":"topic","abstract":[{"code":"GDateTime","type":"codeVoice"},{"type":"text","text":" is a structure that combines a Gregorian date and time"},{"text":" ","type":"text"},{"type":"text","text":"into a single structure."}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/DateTimeProtocol","url":"\/documentation\/glib\/datetimeprotocol","kind":"symbol","role":"symbol","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"DateTimeProtocol"}],"navigatorTitle":[{"text":"DateTimeProtocol","kind":"identifier"}],"title":"DateTimeProtocol"},"doc://GLib/documentation/GLib/DateTimeProtocol/weekNumberingYear":{"kind":"symbol","abstract":[{"text":"Returns the ISO 8601 week-numbering year in which the week containing","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"datetime"},{"type":"text","text":" falls."}],"fragments":[{"kind":"keyword","text":"var"},{"text":" ","kind":"text"},{"text":"weekNumberingYear","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"}],"title":"weekNumberingYear","identifier":"doc:\/\/GLib\/documentation\/GLib\/DateTimeProtocol\/weekNumberingYear","role":"symbol","url":"\/documentation\/glib\/datetimeprotocol\/weeknumberingyear","type":"topic"}}}