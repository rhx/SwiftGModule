{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/datetimeref\/format(format:)"]}],"abstract":[{"type":"text","text":"Creates a newly allocated string representing the requested "},{"code":"format","type":"codeVoice"},{"text":".","type":"text"}],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/DateTimeRef","doc:\/\/GLib\/documentation\/GLib\/DateTimeRef\/DateTimeProtocol-Implementations"]]},"schemaVersion":{"minor":3,"patch":0,"major":0},"sections":[],"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"format"},{"kind":"text","text":"("},{"text":"format","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:SP","text":"UnsafePointer","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"preciseIdentifier":"c:@T@gchar","text":"gchar","kind":"typeIdentifier"},{"text":">!) -> ","kind":"text"},{"preciseIdentifier":"s:SS","kind":"typeIdentifier","text":"String"},{"kind":"text","text":"!"}],"platforms":["macOS"]}],"kind":"declarations"},{"content":[{"text":"Discussion","anchor":"discussion","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"text":"The format strings understood by this function are a subset of the","type":"text"},{"text":" ","type":"text"},{"code":"strftime()","type":"codeVoice"},{"text":" format language as specified by C99.  The ","type":"text"},{"code":"D","type":"codeVoice"},{"type":"text","text":", "},{"type":"codeVoice","code":"U"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"W"},{"type":"text","text":" "},{"text":"conversions are not supported, nor is the ","type":"text"},{"type":"codeVoice","code":"E"},{"text":" modifier.  The GNU","type":"text"},{"type":"text","text":" "},{"text":"extensions ","type":"text"},{"type":"codeVoice","code":"k"},{"type":"text","text":", "},{"type":"codeVoice","code":"l"},{"text":", ","type":"text"},{"type":"codeVoice","code":"s"},{"type":"text","text":" and "},{"code":"P","type":"codeVoice"},{"type":"text","text":" are supported, however, as are the"},{"text":" ","type":"text"},{"type":"codeVoice","code":"0"},{"type":"text","text":", "},{"type":"codeVoice","code":"_"},{"type":"text","text":" and "},{"code":"-","type":"codeVoice"},{"text":" modifiers. The Python extension ","type":"text"},{"code":"f","type":"codeVoice"},{"text":" is also supported.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"In contrast to ","type":"text"},{"type":"codeVoice","code":"strftime()"},{"type":"text","text":", this function always produces a UTF-8"},{"type":"text","text":" "},{"text":"string, regardless of the current locale.  Note that the rendering of","type":"text"},{"type":"text","text":" "},{"type":"text","text":"many formats is locale-dependent and may not match the "},{"type":"codeVoice","code":"strftime()"},{"text":" ","type":"text"},{"type":"text","text":"output exactly."}]},{"inlineContent":[{"type":"text","text":"The following format specifiers are supported:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"code":"a","type":"codeVoice"},{"type":"text","text":": the abbreviated weekday name according to the current locale"}]}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"A"},{"text":": the full weekday name according to the current locale","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"b"},{"type":"text","text":": the abbreviated month name according to the current locale"}]}]},{"content":[{"inlineContent":[{"code":"B","type":"codeVoice"},{"text":": the full month name according to the current locale","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"c","type":"codeVoice"},{"text":": the preferred date and time representation for the current locale","type":"text"}]}]},{"content":[{"inlineContent":[{"code":"C","type":"codeVoice"},{"type":"text","text":": the century number (year\/100) as a 2-digit integer (00-99)"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"d"},{"text":": the day of the month as a decimal number (range 01 to 31)","type":"text"}]}]},{"content":[{"inlineContent":[{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/e-3m6a4","type":"reference"},{"type":"text","text":": the day of the month as a decimal number (range 1 to 31);"},{"type":"text","text":" "},{"text":"single digits are preceded by a figure space (U+2007)","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"F"},{"type":"text","text":": equivalent to "},{"code":"Y-","type":"codeVoice"},{"type":"text","text":"m-"},{"type":"codeVoice","code":"d"},{"text":" (the ISO 8601 date format)","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"code":"g","type":"codeVoice"},{"text":": the last two digits of the ISO 8601 week-based year as a","type":"text"},{"text":" ","type":"text"},{"text":"decimal number (00-99). This works well with ","type":"text"},{"type":"codeVoice","code":"V"},{"text":" and ","type":"text"},{"code":"u","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"G"},{"text":": the ISO 8601 week-based year as a decimal number. This works","type":"text"},{"type":"text","text":" "},{"type":"text","text":"well with "},{"type":"codeVoice","code":"V"},{"type":"text","text":" and "},{"code":"u","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"code":"h","type":"codeVoice"},{"text":": equivalent to ","type":"text"},{"code":"b","type":"codeVoice"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"code":"H","type":"codeVoice"},{"type":"text","text":": the hour as a decimal number using a 24-hour clock (range 00 to 23)"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"I","type":"codeVoice"},{"type":"text","text":": the hour as a decimal number using a 12-hour clock (range 01 to 12)"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"j","type":"codeVoice"},{"type":"text","text":": the day of the year as a decimal number (range 001 to 366)"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"k","type":"codeVoice"},{"text":": the hour (24-hour clock) as a decimal number (range 0 to 23);","type":"text"},{"type":"text","text":" "},{"type":"text","text":"single digits are preceded by a figure space (U+2007)"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"l","type":"codeVoice"},{"type":"text","text":": the hour (12-hour clock) as a decimal number (range 1 to 12);"},{"type":"text","text":" "},{"type":"text","text":"single digits are preceded by a figure space (U+2007)"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"m"},{"text":": the month as a decimal number (range 01 to 12)","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"M","type":"codeVoice"},{"text":": the minute as a decimal number (range 00 to 59)","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"f"},{"type":"text","text":": the microsecond as a decimal number (range 000000 to 999999)"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"p"},{"type":"text","text":": either ‘AM’ or ‘PM’ according to the given time value, or the"},{"text":" ","type":"text"},{"type":"text","text":"corresponding  strings for the current locale.  Noon is treated as"},{"text":" ","type":"text"},{"type":"text","text":"‘PM’ and midnight as ‘AM’. Use of this format specifier is discouraged, as"},{"text":" ","type":"text"},{"text":"many locales have no concept of AM\/PM formatting. Use ","type":"text"},{"code":"c","type":"codeVoice"},{"text":" or ","type":"text"},{"type":"codeVoice","code":"X"},{"type":"text","text":" instead."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"P"},{"type":"text","text":": like "},{"type":"codeVoice","code":"p"},{"type":"text","text":" but lowercase: ‘am’ or ‘pm’ or a corresponding string for"},{"type":"text","text":" "},{"type":"text","text":"the current locale. Use of this format specifier is discouraged, as"},{"type":"text","text":" "},{"text":"many locales have no concept of AM\/PM formatting. Use ","type":"text"},{"code":"c","type":"codeVoice"},{"type":"text","text":" or "},{"type":"codeVoice","code":"X"},{"text":" instead.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"r"},{"type":"text","text":": the time in a.m. or p.m. notation. Use of this format specifier is"},{"type":"text","text":" "},{"text":"discouraged, as many locales have no concept of AM\/PM formatting. Use ","type":"text"},{"type":"codeVoice","code":"c"},{"text":" ","type":"text"},{"text":"or ","type":"text"},{"type":"codeVoice","code":"X"},{"text":" instead.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"R","type":"codeVoice"},{"text":": the time in 24-hour notation (","type":"text"},{"type":"codeVoice","code":"H:"},{"text":"M``)","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"s"},{"type":"text","text":": the number of seconds since the Epoch, that is, since 1970-01-01"},{"type":"text","text":" "},{"type":"text","text":"00:00:00 UTC"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"S"},{"type":"text","text":": the second as a decimal number (range 00 to 60)"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"t"},{"type":"text","text":": a tab character"}]}]},{"content":[{"inlineContent":[{"code":"T","type":"codeVoice"},{"type":"text","text":": the time in 24-hour notation with seconds ("},{"code":"H:","type":"codeVoice"},{"type":"text","text":"M:"},{"type":"codeVoice","code":"S"},{"text":")","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"u","type":"codeVoice"},{"type":"text","text":": the ISO 8601 standard day of the week as a decimal, range 1 to 7,"},{"text":" ","type":"text"},{"text":"Monday being 1. This works well with ","type":"text"},{"code":"G","type":"codeVoice"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"V"},{"text":".","type":"text"}]}]},{"content":[{"inlineContent":[{"code":"V","type":"codeVoice"},{"type":"text","text":": the ISO 8601 standard week number of the current year as a decimal"},{"type":"text","text":" "},{"type":"text","text":"number, range 01 to 53, where week 1 is the first week that has at"},{"text":" ","type":"text"},{"type":"text","text":"least 4 days in the new year. See "},{"type":"codeVoice","code":"g_date_time_get_week_of_year()"},{"text":".","type":"text"},{"type":"text","text":" "},{"type":"text","text":"This works well with "},{"code":"G","type":"codeVoice"},{"type":"text","text":" and "},{"code":"u","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"w"},{"text":": the day of the week as a decimal, range 0 to 6, Sunday being 0.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"This is not the ISO 8601 standard format — use "},{"type":"codeVoice","code":"u"},{"type":"text","text":" instead."}]}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"x"},{"text":": the preferred date representation for the current locale without","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the time"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"X","type":"codeVoice"},{"text":": the preferred time representation for the current locale without","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the date"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"y","type":"codeVoice"},{"type":"text","text":": the year as a decimal number without the century"}]}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"Y"},{"type":"text","text":": the year as a decimal number including the century"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"z"},{"type":"text","text":": the time zone as an offset from UTC ("},{"type":"codeVoice","code":"+hhmm"},{"text":")","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":":z"},{"type":"text","text":": the time zone as an offset from UTC ("},{"type":"codeVoice","code":"+hh:mm"},{"type":"text","text":")."},{"type":"text","text":" "},{"type":"text","text":"This is a gnulib "},{"type":"codeVoice","code":"strftime()"},{"type":"text","text":" extension. Since: 2.38"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"::z","type":"codeVoice"},{"type":"text","text":": the time zone as an offset from UTC ("},{"type":"codeVoice","code":"+hh:mm:ss"},{"text":"). This is a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"gnulib "},{"code":"strftime()","type":"codeVoice"},{"text":" extension. Since: 2.38","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":":::z","type":"codeVoice"},{"text":": the time zone as an offset from UTC, with ","type":"text"},{"code":":","type":"codeVoice"},{"type":"text","text":" to necessary"},{"type":"text","text":" "},{"type":"text","text":"precision (e.g., "},{"code":"-04","type":"codeVoice"},{"type":"text","text":", "},{"code":"+05:30","type":"codeVoice"},{"type":"text","text":"). This is a gnulib "},{"type":"codeVoice","code":"strftime()"},{"text":" extension. Since: 2.38","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"Z","type":"codeVoice"},{"type":"text","text":": the time zone or name or abbreviation"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"``````: a literal ```` character","type":"text"}]}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Some conversion specifications can be modified by preceding the"},{"text":" ","type":"text"},{"text":"conversion specifier by one or more modifier characters.","type":"text"}]},{"inlineContent":[{"type":"text","text":"The following modifiers are supported for many of the numeric"},{"text":" ","type":"text"},{"type":"text","text":"conversions:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"code":"O","type":"codeVoice"},{"text":": Use alternative numeric symbols, if the current locale supports those.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"_"},{"text":": Pad a numeric result with spaces. This overrides the default padding","type":"text"},{"type":"text","text":" "},{"type":"text","text":"for the specifier."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"-"},{"type":"text","text":": Do not pad a numeric result. This overrides the default padding"},{"text":" ","type":"text"},{"type":"text","text":"for the specifier."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"0","type":"codeVoice"},{"type":"text","text":": Pad a numeric result with zeros. This overrides the default padding"},{"type":"text","text":" "},{"text":"for the specifier.","type":"text"}]}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The following modifiers are supported for many of the alphabetic conversions:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"code":"^","type":"codeVoice"},{"type":"text","text":": Use upper case if possible. This is a gnulib "},{"code":"strftime()","type":"codeVoice"},{"type":"text","text":" extension."},{"type":"text","text":" "},{"type":"text","text":"Since: 2.80"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"#","type":"codeVoice"},{"type":"text","text":": Use opposite case if possible. This is a gnulib "},{"code":"strftime()","type":"codeVoice"},{"type":"text","text":" "},{"text":"extension. Since: 2.80","type":"text"}]}]}]},{"inlineContent":[{"text":"Additionally, when ","type":"text"},{"type":"codeVoice","code":"O"},{"text":" is used with ","type":"text"},{"type":"codeVoice","code":"B"},{"text":", ","type":"text"},{"type":"codeVoice","code":"b"},{"type":"text","text":", or "},{"code":"h","type":"codeVoice"},{"type":"text","text":", it produces the alternative"},{"type":"text","text":" "},{"type":"text","text":"form of a month name. The alternative form should be used when the month"},{"text":" ","type":"text"},{"type":"text","text":"name is used without a day number (e.g., standalone). It is required in"},{"text":" ","type":"text"},{"text":"some languages (Baltic, Slavic, Greek, and more) due to their grammatical","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"rules. For other languages there is no difference. "},{"code":"OB","type":"codeVoice"},{"type":"text","text":" is a GNU and BSD"},{"text":" ","type":"text"},{"type":"codeVoice","code":"strftime()"},{"text":" extension expected to be added to the future POSIX specification,","type":"text"},{"text":" ","type":"text"},{"code":"Ob","type":"codeVoice"},{"type":"text","text":" and "},{"code":"Oh","type":"codeVoice"},{"type":"text","text":" are GNU "},{"type":"codeVoice","code":"strftime()"},{"text":" extensions. Since: 2.56","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Since GLib 2.80, when ","type":"text"},{"type":"codeVoice","code":"E"},{"type":"text","text":" is used with "},{"type":"codeVoice","code":"c"},{"type":"text","text":", "},{"code":"C","type":"codeVoice"},{"text":", ","type":"text"},{"type":"codeVoice","code":"x"},{"text":", ","type":"text"},{"code":"X","type":"codeVoice"},{"text":", ","type":"text"},{"code":"y","type":"codeVoice"},{"text":" or ","type":"text"},{"code":"Y","type":"codeVoice"},{"text":",","type":"text"},{"text":" ","type":"text"},{"text":"the date is formatted using an alternate era representation specific to the","type":"text"},{"type":"text","text":" "},{"text":"locale. This is typically used for the Thai solar calendar or Japanese era","type":"text"},{"type":"text","text":" "},{"text":"names, for example.","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"code":"Ec","type":"codeVoice"},{"type":"text","text":": the preferred date and time representation for the current locale,"},{"text":" ","type":"text"},{"type":"text","text":"using the alternate era representation"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"EC","type":"codeVoice"},{"text":": the name of the era","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"Ex"},{"text":": the preferred date representation for the current locale without","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the time, using the alternate era representation"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"EX"},{"text":": the preferred time representation for the current locale without","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the date, using the alternate era representation"}]}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"Ey"},{"text":": the year since the beginning of the era denoted by the ","type":"text"},{"code":"EC","type":"codeVoice"},{"type":"text","text":" "},{"text":"specifier","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"code":"EY","type":"codeVoice"},{"type":"text","text":": the full alternative year representation"}],"type":"paragraph"}]}]}],"kind":"content"}],"metadata":{"roleHeading":"Instance Method","modules":[{"name":"GLib"}]