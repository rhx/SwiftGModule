{"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/DateTimeRef","doc:\/\/GLib\/documentation\/GLib\/DateTimeRef\/DateTimeProtocol-Implementations"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/datetimeref\/getweeknumberingyear()"]}],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"getWeekNumberingYear","kind":"identifier"},{"text":"() -> ","kind":"text"},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"}],"languages":["swift"]}],"kind":"declarations"},{"content":[{"type":"heading","anchor":"discussion","text":"Discussion","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"This function, taken together with "},{"type":"codeVoice","code":"g_date_time_get_week_of_year()"},{"text":" and","type":"text"},{"type":"text","text":" "},{"code":"g_date_time_get_day_of_week()","type":"codeVoice"},{"type":"text","text":" can be used to determine the full ISO"},{"type":"text","text":" "},{"type":"text","text":"week date on which "},{"type":"codeVoice","code":"datetime"},{"text":" falls.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"This is usually equal to the normal Gregorian year (as returned by","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_date_time_get_year()"},{"text":"), except as detailed below:","type":"text"}]},{"inlineContent":[{"type":"text","text":"For Thursday, the week-numbering year is always equal to the usual"},{"text":" ","type":"text"},{"text":"calendar year.  For other days, the number is such that every day","type":"text"},{"type":"text","text":" "},{"type":"text","text":"within a complete week (Monday to Sunday) is contained within the"},{"text":" ","type":"text"},{"text":"same week-numbering year.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For Monday, Tuesday and Wednesday occurring near the end of the year,"},{"text":" ","type":"text"},{"type":"text","text":"this may mean that the week-numbering year is one greater than the"},{"text":" ","type":"text"},{"type":"text","text":"calendar year (so that these days have the same week-numbering year"},{"type":"text","text":" "},{"type":"text","text":"as the Thursday occurring early in the next year)."}]},{"inlineContent":[{"type":"text","text":"For Friday, Saturday and Sunday occurring near the start of the year,"},{"type":"text","text":" "},{"type":"text","text":"this may mean that the week-numbering year is one less than the"},{"text":" ","type":"text"},{"type":"text","text":"calendar year (so that these days have the same week-numbering year"},{"type":"text","text":" "},{"type":"text","text":"as the Thursday occurring late in the previous year)."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"An equivalent description is that the week-numbering year is equal to","type":"text"},{"type":"text","text":" "},{"text":"the calendar year containing the majority of the days in the current","type":"text"},{"type":"text","text":" "},{"type":"text","text":"week (Monday to Sunday)."}]},{"inlineContent":[{"type":"text","text":"Note that January 1 0001 in the proleptic Gregorian calendar is a"},{"type":"text","text":" "},{"type":"text","text":"Monday, so this function never returns 0."}],"type":"paragraph"}],"kind":"content"}],"metadata":{"roleHeading":"Instance Method","externalID":"s:4GLib16DateTimeProtocolPAAE20getWeekNumberingYearSiyF::SYNTHESIZED::s:4GLib11DateTimeRefV","symbolKind":"method","role":"symbol","title":"getWeekNumberingYear()","extendedModule":"GLib","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"getWeekNumberingYear","kind":"identifier"},{"kind":"text","text":"() -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"}],"modules":[{"name":"GLib"}]},"sections":[],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/DateTimeRef\/getWeekNumberingYear()","interfaceLanguage":"swift"},"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"symbol","abstract":[{"text":"Returns the ISO 8601 week-numbering year in which the week containing","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"datetime"},{"text":" falls.","type":"text"}],"references":{"doc://GLib/documentation/GLib/DateTimeRef":{"role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"DateTimeRef"}],"url":"\/documentation\/glib\/datetimeref","kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"DateTimeRef"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/DateTimeRef","title":"DateTimeRef","abstract":[{"type":"codeVoice","code":"GDateTime"},{"text":" is a structure that combines a Gregorian date and time","type":"text"},{"type":"text","text":" "},{"text":"into a single structure.","type":"text"}],"type":"topic"},"doc://GLib/documentation/GLib":{"kind":"symbol","role":"collection","abstract":[],"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","type":"topic","url":"\/documentation\/glib"},"doc://GLib/documentation/GLib/DateTimeRef/DateTimeProtocol-Implementations":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/DateTimeRef\/DateTimeProtocol-Implementations","role":"collectionGroup","kind":"article","type":"topic","title":"DateTimeProtocol Implementations","url":"\/documentation\/glib\/datetimeref\/datetimeprotocol-implementations","abstract":[]},"doc://GLib/documentation/GLib/DateTimeRef/getWeekNumberingYear()":{"role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"getWeekNumberingYear"},{"kind":"text","text":"() -> "},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"}],"kind":"symbol","title":"getWeekNumberingYear()","url":"\/documentation\/glib\/datetimeref\/getweeknumberingyear()","abstract":[{"text":"Returns the ISO 8601 week-numbering year in which the week containing","type":"text"},{"type":"text","text":" "},{"code":"datetime","type":"codeVoice"},{"text":" falls.","type":"text"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/DateTimeRef\/getWeekNumberingYear()","type":"topic"}}}