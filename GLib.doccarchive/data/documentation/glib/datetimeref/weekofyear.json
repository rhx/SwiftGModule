{"abstract":[{"type":"text","text":"Returns the ISO 8601 week number for the week containing "},{"type":"codeVoice","code":"datetime"},{"text":".","type":"text"},{"type":"text","text":" "},{"text":"The ISO 8601 week number is the same for every day of the week (from","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Moday through Sunday).  That can produce some unusual results"},{"text":" ","type":"text"},{"text":"(described below).","type":"text"}],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/DateTimeRef\/weekOfYear","interfaceLanguage":"swift"},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"var"},{"text":" ","kind":"text"},{"kind":"identifier","text":"weekOfYear"},{"kind":"text","text":": "},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"},{"text":" { ","kind":"text"},{"text":"get","kind":"keyword"},{"text":" }","kind":"text"}],"languages":["swift"],"platforms":["macOS"]}]},{"content":[{"anchor":"discussion","level":2,"text":"Discussion","type":"heading"},{"inlineContent":[{"text":"The first week of the year is week 1.  This is the week that contains","type":"text"},{"type":"text","text":" "},{"text":"the first Thursday of the year.  Equivalently, this is the first week","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"that has more than 4 of its days falling within the calendar year."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The value 0 is never returned by this function.  Days contained"},{"type":"text","text":" "},{"text":"within a year but occurring before the first ISO 8601 week of that","type":"text"},{"type":"text","text":" "},{"text":"year are considered as being contained in the last week of the","type":"text"},{"type":"text","text":" "},{"text":"previous year.  Similarly, the final days of a calendar year may be","type":"text"},{"text":" ","type":"text"},{"text":"considered as being part of the first ISO 8601 week of the next year","type":"text"},{"text":" ","type":"text"},{"text":"if 4 or more days of that week are contained within the new year.","type":"text"}]}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/DateTimeRef","doc:\/\/GLib\/documentation\/GLib\/DateTimeRef\/DateTimeProtocol-Implementations"]]},"kind":"symbol","variants":[{"paths":["\/documentation\/glib\/datetimeref\/weekofyear"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"title":"weekOfYear","symbolKind":"property","extendedModule":"GLib","roleHeading":"Instance Property","modules":[{"name":"GLib"}],"role":"symbol","externalID":"s:4GLib16DateTimeProtocolPAAE10weekOfYearSivp::SYNTHESIZED::s:4GLib11DateTimeRefV","fragments":[{"kind":"keyword","text":"var"},{"text":" ","kind":"text"},{"text":"weekOfYear","kind":"identifier"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"}]},"sections":[],"schemaVersion":{"major":0,"patch":0,"minor":3},"references":{"doc://GLib/documentation/GLib/DateTimeRef/DateTimeProtocol-Implementations":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/DateTimeRef\/DateTimeProtocol-Implementations","role":"collectionGroup","kind":"article","type":"topic","title":"DateTimeProtocol Implementations","url":"\/documentation\/glib\/datetimeref\/datetimeprotocol-implementations","abstract":[]},"doc://GLib/documentation/GLib/DateTimeRef":{"role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"DateTimeRef"}],"url":"\/documentation\/glib\/datetimeref","kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"DateTimeRef"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/DateTimeRef","title":"DateTimeRef","abstract":[{"type":"codeVoice","code":"GDateTime"},{"text":" is a structure that combines a Gregorian date and time","type":"text"},{"type":"text","text":" "},{"text":"into a single structure.","type":"text"}],"type":"topic"},"doc://GLib/documentation/GLib/DateTimeRef/weekOfYear":{"abstract":[{"type":"text","text":"Returns the ISO 8601 week number for the week containing "},{"code":"datetime","type":"codeVoice"},{"type":"text","text":"."},{"text":" ","type":"text"},{"text":"The ISO 8601 week number is the same for every day of the week (from","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Moday through Sunday).  That can produce some unusual results"},{"type":"text","text":" "},{"text":"(described below).","type":"text"}],"title":"weekOfYear","identifier":"doc:\/\/GLib\/documentation\/GLib\/DateTimeRef\/weekOfYear","type":"topic","kind":"symbol","role":"symbol","fragments":[{"kind":"keyword","text":"var"},{"text":" ","kind":"text"},{"kind":"identifier","text":"weekOfYear"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"}],"url":"\/documentation\/glib\/datetimeref\/weekofyear"},"doc://GLib/documentation/GLib":{"kind":"symbol","role":"collection","abstract":[],"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","type":"topic","url":"\/documentation\/glib"}}}