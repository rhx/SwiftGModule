{"metadata":{"roleHeading":"Function","role":"symbol","externalID":"s:4GLib8dgettext6domain5msgidSSSgSPys4Int8VGSg_AItF","modules":[{"name":"GLib"}],"title":"dgettext(domain:msgid:)","symbolKind":"func","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"dgettext"},{"text":"(","kind":"text"},{"text":"domain","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar","text":"gchar"},{"text":">?, ","kind":"text"},{"text":"msgid","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar","text":"gchar"},{"text":">!) -> ","kind":"text"},{"text":"String","kind":"typeIdentifier","preciseIdentifier":"s:SS"},{"kind":"text","text":"!"}]},"kind":"symbol","schemaVersion":{"minor":3,"major":0,"patch":0},"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/dgettext(domain:msgid:)","interfaceLanguage":"swift"},"sections":[],"abstract":[{"text":"This function is a wrapper of ","type":"text"},{"code":"dgettext()","type":"codeVoice"},{"type":"text","text":" which does not translate"},{"type":"text","text":" "},{"text":"the message if the default domain as set with ","type":"text"},{"code":"textdomain()","type":"codeVoice"},{"text":" has no","type":"text"},{"type":"text","text":" "},{"type":"text","text":"translations for the current locale."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"dgettext","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"domain"},{"kind":"text","text":": "},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar"},{"kind":"text","text":">? = nil, "},{"text":"msgid","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"UnsafePointer","preciseIdentifier":"s:SP","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"text":"gchar","preciseIdentifier":"c:@T@gchar","kind":"typeIdentifier"},{"kind":"text","text":">!) -> "},{"text":"String","preciseIdentifier":"s:SS","kind":"typeIdentifier"},{"text":"!","kind":"text"}],"platforms":["macOS"]}]},{"kind":"content","content":[{"text":"Discussion","level":2,"anchor":"discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"The advantage of using this function over ","type":"text"},{"code":"dgettext()","type":"codeVoice"},{"type":"text","text":" proper is that"},{"text":" ","type":"text"},{"text":"libraries using this function (like GTK) will not use translations","type":"text"},{"text":" ","type":"text"},{"text":"if the application using the library does not have translations for","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the current locale.  This results in a consistent English-only"},{"text":" ","type":"text"},{"type":"text","text":"interface instead of one having partial translations.  For this"},{"type":"text","text":" "},{"text":"feature to work, the call to ","type":"text"},{"type":"codeVoice","code":"textdomain()"},{"type":"text","text":" and "},{"code":"setlocale()","type":"codeVoice"},{"text":" should","type":"text"},{"type":"text","text":" "},{"text":"precede any ","type":"text"},{"code":"g_dgettext()","type":"codeVoice"},{"type":"text","text":" invocations.  For GTK, it means calling"},{"type":"text","text":" "},{"type":"codeVoice","code":"textdomain()"},{"type":"text","text":" before gtk_init or its variants."}]},{"inlineContent":[{"text":"This function disables translations if and only if upon its first","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"call all the following conditions