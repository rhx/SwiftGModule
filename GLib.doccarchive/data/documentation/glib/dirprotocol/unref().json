{"schemaVersion":{"major":0,"minor":3,"patch":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"unref"},{"text":"()","kind":"text"}],"platforms":["macOS"]}]},{"content":[{"type":"heading","anchor":"discussion","text":"Discussion","level":2},{"inlineContent":[{"text":"Once the reference count reaches zero, the directory will be closed and all","type":"text"},{"text":" ","type":"text"},{"text":"resources associated with it will be freed. If [method","type":"text"},{"type":"codeVoice","code":"GLib.Dir.close"},{"text":"] is","type":"text"},{"type":"text","text":" "},{"type":"text","text":"called when the reference count is greater than zero, the directory is closed"},{"type":"text","text":" "},{"type":"text","text":"but the "},{"code":"GDir","type":"codeVoice"},{"type":"text","text":" structure will not be freed until its reference count reaches"},{"type":"text","text":" "},{"text":"zero.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"It is an error to call any of the "},{"code":"GDir","type":"codeVoice"},{"text":" methods other than","type":"text"},{"text":" ","type":"text"},{"text":"[method","type":"text"},{"type":"codeVoice","code":"GLib.Dir.ref"},{"text":"] and [method","type":"text"},{"type":"codeVoice","code":"GLib.Dir.unref"},{"text":"] on a ","type":"text"},{"type":"codeVoice","code":"GDir"},{"text":" after calling","type":"text"},{"text":" ","type":"text"},{"text":"[method","type":"text"},{"code":"GLib.Dir.close","type":"codeVoice"},{"type":"text","text":"] on it."}],"type":"paragraph"}],"kind":"content"}],"metadata":{"modules":[{"name":"GLib"}],"title":"unref()","extendedModule":"GLib","role":"symbol","roleHeading":"Instance Method","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"unref","kind":"identifier"},{"text":"()","kind":"text"}],"externalID":"s:4GLib11DirProtocolPAAE5unrefyyF","symbolKind":"method"},"sections":[],"abstract":[{"type":"text","text":"Decrements the reference count of "},{"type":"codeVoice","code":"dir"},{"text":".","type":"text"}],"kind":"symbol","variants":[{"paths":["\/documentation\/glib\/dirprotocol\/unref()"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/DirProtocol"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/DirProtocol\/unref()"},"references":{"doc://GLib/documentation/GLib/DirProtocol":{"url":"\/documentation\/glib\/dirprotocol","identifier":"doc:\/\/GLib\/documentation\/GLib\/DirProtocol","kind":"symbol","abstract":[{"text":"An opaque structure representing an opened directory.","type":"text"}],"navigatorTitle":[{"kind":"identifier","text":"DirProtocol"}],"fragments":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"DirProtocol"}],"role":"symbol","type":"topic","title":"DirProtocol"},"doc://GLib/documentation/GLib/DirProtocol/unref()":{"abstract":[{"type":"text","text":"Decrements the reference count of "},{"type":"codeVoice","code":"dir"},{"type":"text","text":"."}],"role":"symbol","url":"\/documentation\/glib\/dirprotocol\/unref()","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"unref"},{"kind":"text","text":"()"}],"type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib\/DirProtocol\/unref()","kind":"symbol","title":"unref()"},"doc://GLib/documentation/GLib":{"kind":"symbol","role":"collection","abstract":[],"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","type":"topic","url":"\/documentation\/glib"}}}