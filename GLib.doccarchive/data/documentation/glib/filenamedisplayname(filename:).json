{"metadata":{"roleHeading":"Function","role":"symbol","modules":[{"name":"GLib"}],"title":"filenameDisplayName(filename:)","symbolKind":"func","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"filenameDisplayName","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"filename"},{"kind":"text","text":": "},{"preciseIdentifier":"s:SP","text":"UnsafePointer","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"preciseIdentifier":"c:@T@gchar","kind":"typeIdentifier","text":"gchar"},{"text":">!) -> ","kind":"text"},{"text":"String","preciseIdentifier":"s:SS","kind":"typeIdentifier"},{"kind":"text","text":"!"}],"externalID":"s:4GLib19filenameDisplayName0B0SSSgSPys4Int8VGSg_tF"},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"schemaVersion":{"minor":3,"patch":0,"major":0},"abstract":[{"text":"Converts a filename into a valid UTF-8 string. The conversion is","type":"text"},{"type":"text","text":" "},{"type":"text","text":"not necessarily reversible, so you should keep the original around"},{"type":"text","text":" "},{"type":"text","text":"and use the return value of this function only for display purposes."},{"text":" ","type":"text"},{"type":"text","text":"Unlike "},{"type":"codeVoice","code":"g_filename_to_utf8()"},{"text":", the result is guaranteed to be non-","type":"text"},{"code":"nil","type":"codeVoice"},{"text":" ","type":"text"},{"text":"even if the filename actually isn’t in the GLib file name encoding.","type":"text"}],"variants":[{"paths":["\/documentation\/glib\/filenamedisplayname(filename:)"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"symbol","identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/filenameDisplayName(filename:)","interfaceLanguage":"swift"},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"filenameDisplayName","kind":"identi