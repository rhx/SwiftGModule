{"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/filesetcontentsfull(filename:contents:length:flags:mode:)"]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"symbol","hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"metadata":{"title":"fileSetContentsFull(filename:contents:length:flags:mode:)","role":"symbol","symbolKind":"func","roleHeading":"Function","modules":[{"name":"GLib"}],"externalID":"s:4GLib19fileSetContentsFull8filename8contents6length5flags4modeSbSPys4Int8VGSg_AKSiAA04FilecD5FlagsVSitKF","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"fileSetContentsFull","kind":"identifier"},{"kind":"text","text":"("},{"text":"filename","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SP","kind":"typeIdentifier","text":"UnsafePointer"},{"kind":"text","text":"<"},{"text":"gchar","preciseIdentifier":"c:@T@gchar","kind":"typeIdentifier"},{"kind":"text","text":">!, "},{"text":"contents","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"UnsafePointer","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"preciseIdentifier":"c:@T@gchar","text":"gchar","kind":"typeIdentifier"},{"kind":"text","text":">!, "},{"text":"length","kind":"externalParam"},{"kind":"text","text":": "},{"text":"gssize","kind":"typeIdentifier","preciseIdentifier":"c:@T@gssize"},{"text":", ","kind":"text"},{"text":"flags","kind":"externalParam"},{"kind":"text","text":": "},{"text":"FileSetContentsFlags","kind":"typeIdentifier","preciseIdentifier":"s:4GLib20FileSetContentsFlagsV"},{"kind":"text","text":", "},{"kind":"externalParam","text":"mode"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"text":") ","kind":"text"},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"}]},"abstract":[{"text":"Writes all of ","type":"text"},{"code":"contents","type":"codeVoice"},{"text":" to a file named ","type":"text"},{"type":"codeVoice","code":"filename"},{"type":"text","text":", with good error checking."},{"text":" ","type":"text"},{"type":"text","text":"If a file called "},{"code":"filename","type":"codeVoice"},{"text":" already exists it will be overwritten.","type":"text"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/fileSetContentsFull(filename:contents:length:flags:mode:)"},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"fileSetContentsFull","kind":"identifier"},{"kind":"text","text":"("},{"text":"filename","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"UnsafePointer","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"preciseIdentifier":"c:@T@gchar","text":"gchar","kind":"typeIdentifier"},{"text":">!, ","kind":"text"},{"kind":"externalParam","text":"contents"},{"text":": ","kind":"text"},{"text":"UnsafePointer","preciseIdentifier":"s:SP","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"text":"gchar","preciseIdentifier":"c:@T@gchar","kind":"typeIdentifier"},{"kind":"text","text":">!, "},{"kind":"externalParam","text":"length"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gssize","text":"gssize"},{"text":", ","kind":"text"},{"text":"flags","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","identifier":"doc:\/\/GLib\/documentation\/GLib\/FileSetContentsFlags","preciseIdentifier":"s:4GLib20FileSetContentsFlagsV","text":"FileSetContentsFlags"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"mode"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"kind":"text","text":") "},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"text":"Bool","preciseIdentifier":"s:Sb","kind":"typeIdentifier"}]}],"kind":"declarations"},{"content":[{"text":"Discussion","type":"heading","level":2,"anchor":"discussion"},{"inlineContent":[{"type":"codeVoice","code":"flags"},{"text":" control the properties of the write operation: whether it’s atomic,","type":"text"},{"type":"text","text":" "},{"text":"and what the tradeoff is between returning quickly or being resilient to","type":"text"},{"text":" ","type":"text"},{"text":"system crashes.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"As this function performs file I\/O, it is recommended to not call it anywhere"},{"text":" ","type":"text"},{"text":"where blocking would cause problems, such as in the main loop of a graphical","type":"text"},{"type":"text","text":" "},{"type":"text","text":"application. In particular, if "},{"code":"flags","type":"codeVoice"},{"text":" has any value other than","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"none"},{"type":"text","text":" then this function may call "},{"code":"fsync()","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If "},{"code":"consistent","type":"codeVoice"},{"type":"text","text":" is set in "},{"code":"flags","type":"codeVoice"},{"text":", the operation is atomic","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"in the sense that it is first written to a temporary file which is then"},{"text":" ","type":"text"},{"text":"renamed to the final name.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Notes:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"On UNIX, if ","type":"text"},{"code":"filename","type":"codeVoice"},{"text":" already exists hard links to ","type":"text"},{"type":"codeVoice","code":"filename"},{"text":" will break.","type":"text"},{"text":" ","type":"text"},{"text":"Also since the file is recreated, existing permissions, access control","type":"text"},{"text":" ","type":"text"},{"text":"lists, metadata etc. may be lost. If ","type":"text"},{"code":"filename","type":"codeVoice"},{"type":"text","text":" is a symbolic link,"},{"text":" ","type":"text"},{"type":"text","text":"the link itself will be replaced, not the linked file."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"On UNIX, if "},{"code":"filename","type":"codeVoice"},{"type":"text","text":" already exists and is non-empty, and if the system"},{"type":"text","text":" "},{"text":"supports it (via a journalling filesystem or equivalent), and if","type":"text"},{"text":" ","type":"text"},{"code":"consistent","type":"codeVoice"},{"type":"text","text":" is set in "},{"type":"codeVoice","code":"flags"},{"text":", the ","type":"text"},{"type":"codeVoice","code":"fsync()"},{"type":"text","text":" call (or"},{"type":"text","text":" "},{"type":"text","text":"equivalent) will be used to ensure atomic replacement: "},{"type":"codeVoice","code":"filename"},{"text":" ","type":"text"},{"text":"will contain either its old contents or ","type":"text"},{"type":"codeVoice","code":"contents"},{"type":"text","text":", even in the face of"},{"type":"text","text":" "},{"text":"system power loss, the disk being unsafely removed, etc.","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"On UNIX, if ","type":"text"},{"type":"codeVoice","code":"filename"},{"text":" does not already exist or is empty, there is a","type":"text"},{"text":" ","type":"text"},{"text":"possibility that system power loss etc. after calling this function will","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"leave "},{"code":"filename","type":"codeVoice"},{"type":"text","text":" empty or full of NUL bytes, depending on the underlying"},{"type":"text","text":" "},{"type":"text","text":"filesystem, unless "},{"type":"codeVoice","code":"durable"},{"text":" and","type":"text"},{"text":" ","type":"text"},{"code":"consistent","type":"codeVoice"},{"type":"text","text":" are set in "},{"type":"codeVoice","code":"flags"},{"type":"text","text":"."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"On Windows renaming a file will not remove an existing file with the","type":"text"},{"text":" ","type":"text"},{"text":"new name, so on Windows there is a race condition between the existing","type":"text"},{"type":"text","text":" "},{"text":"file being removed and the temporary file being renamed.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"On Windows there is no way to remove a file that is open to some","type":"text"},{"type":"text","text":" "},{"type":"text","text":"process, or mapped into memory. Thus, this function will fail if"},{"text":" ","type":"text"},{"code":"filename","type":"codeVoice"},{"text":" already exists and is open.","type":"text"}]}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If the call was successful, it returns "},{"type":"codeVoice","code":"true"},{"type":"text","text":". If the call was not successful,"},{"text":" ","type":"text"},{"text":"it returns ","type":"text"},{"code":"false","type":"codeVoice"},{"text":" and sets ","type":"text"},{"type":"codeVoice","code":"error"},{"type":"text","text":". The error domain is "},{"type":"codeVoice","code":"G_FILE_ERROR"},{"type":"text","text":"."},{"text":" ","type":"text"},{"text":"Possible error codes are those in the ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/FileError"},{"text":" enumeration.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that the name for the temporary file is constructed by appending up"},{"text":" ","type":"text"},{"type":"text","text":"to 7 characters to "},{"type":"codeVoice","code":"filename"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If the file didn’t exist before and is created, it will be given the"},{"type":"text","text":" "},{"type":"text","text":"permissions from "},{"type":"codeVoice","code":"mode"},{"type":"text","text":". Otherwise, the permissions of the existing file will"},{"text":" ","type":"text"},{"text":"remain unchanged.","type":"text"}]}],"kind":"content"}],"references":{"doc://GLib/documentation/GLib/fileSetContentsFull(filename:contents:length:flags:mode:)":{"url":"\/documentation\/glib\/filesetcontentsfull(filename:contents:length:flags:mode:)","abstract":[{"text":"Writes all of ","type":"text"},{"code":"contents","type":"codeVoice"},{"type":"text","text":" to a file named "},{"type":"codeVoice","code":"filename"},{"type":"text","text":", with good error checking."},{"type":"text","text":" "},{"type":"text","text":"If a file called "},{"type":"codeVoice","code":"filename"},{"type":"text","text":" already exists it will be overwritten."}],"title":"fileSetContentsFull(filename:contents:length:flags:mode:)","kind":"symbol","type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib\/fileSetContentsFull(filename:contents:length:flags:mode:)","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"fileSetContentsFull"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"filename"},{"text":": ","kind":"text"},{"text":"UnsafePointer","preciseIdentifier":"s:SP","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar"},{"text":">!, ","kind":"text"},{"text":"contents","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SP","text":"UnsafePointer","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"preciseIdentifier":"c:@T@gchar","text":"gchar","kind":"typeIdentifier"},{"text":">!, ","kind":"text"},{"text":"length","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"gssize","preciseIdentifier":"c:@T@gssize"},{"kind":"text","text":", "},{"text":"flags","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:4GLib20FileSetContentsFlagsV","text":"FileSetContentsFlags","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"mode","kind":"externalParam"},{"kind":"text","text":": "},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"kind":"text","text":") "},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"}],"role":"symbol"},"doc://GLib/documentation/GLib":{"kind":"symbol","role":"collection","abstract":[],"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","type":"topic","url":"\/documentation\/glib"},"doc://GLib/documentation/GLib/FileSetContentsFlags":{"kind":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"FileSetContentsFlags","kind":"identifier"}],"title":"FileSetContentsFlags","identifier":"doc:\/\/GLib\/documentation\/GLib\/FileSetContentsFlags","url":"\/documentation\/glib\/filesetcontentsflags","role":"symbol","type":"topic","abstract":[{"type":"text","text":"Flags to pass to "},{"code":"g_file_set_contents_full()","type":"codeVoice"},{"type":"text","text":" to affect its safety and"},{"type":"text","text":" "},{"text":"performance.","type":"text"}],"navigatorTitle":[{"text":"FileSetContentsFlags","kind":"identifier"}]},"doc://GLib/documentation/GLib/FileError":{"url":"\/documentation\/glib\/fileerror","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"FileError"}],"kind":"symbol","type":"topic","fragments":[{"kind":"keyword","text":"typealias"},{"text":" ","kind":"text"},{"text":"FileError","kind":"identifier"}],"abstract":[{"type":"text","text":"Values corresponding to "},{"type":"codeVoice","code":"errno"},{"type":"text","text":" codes returned from file operations"},{"text":" ","type":"text"},{"text":"on UNIX. Unlike ","type":"text"},{"type":"codeVoice","code":"errno"},{"text":" codes, GFileError values are available on","type":"text"},{"type":"text","text":" "},{"type":"text","text":"all systems, even Windows. The exact meaning of each code depends"},{"type":"text","text":" "},{"text":"on what sort of file operation you were performing; the UNIX","type":"text"},{"type":"text","text":" "},{"type":"text","text":"documentation gives more details. The following error code descriptions"},{"type":"text","text":" "},{"text":"come from the GNU C Library manual, and are under the copyright","type":"text"},{"type":"text","text":" "},{"type":"text","text":"of that manual."}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/FileError","title":"FileError"}}}