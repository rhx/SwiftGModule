{"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/fileTest(filename:test:)","interfaceLanguage":"swift"},"abstract":[{"text":"Returns ","type":"text"},{"type":"codeVoice","code":"true"},{"type":"text","text":" if any of the tests in the bitfield "},{"code":"test","type":"codeVoice"},{"type":"text","text":" are"},{"type":"text","text":" "},{"code":"true","type":"codeVoice"},{"type":"text","text":". For example, "},{"code":"(G_FILE_TEST_EXISTS | G_FILE_TEST_IS_DIR)","type":"codeVoice"},{"type":"text","text":" "},{"text":"will return ","type":"text"},{"type":"codeVoice","code":"true"},{"text":" if the file exists; the check whether it’s a","type":"text"},{"text":" ","type":"text"},{"text":"directory doesn’t matter since the existence test is ","type":"text"},{"type":"codeVoice","code":"true"},{"text":". With","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the current set of available tests, there’s no point passing in"},{"text":" ","type":"text"},{"text":"more than one test at a time.","type":"text"}],"sections":[],"schemaVersion":{"patch":0,"major":0,"minor":3},"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/filetest(filename:test:)"]}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"fileTest"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"filename"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"text":"<","kind":"text"},{"preciseIdentifier":"c:@T@gchar","kind":"typeIdentifier","text":"gchar"},{"kind":"text","text":">!, "},{"kind":"externalParam","text":"test"},{"kind":"text","text":": "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/FileTest","preciseIdentifier":"s:4GLib8FileTestV","text":"FileTest","kind":"typeIdentifier"},{"kind":"text","text":") -> "},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Discussion","anchor":"discussion","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"Apart from "},{"type":"codeVoice","code":"isSymlink"},{"type":"text","text":" all tests follow symbolic links,"},{"type":"text","text":" "},{"text":"so for a symbolic link to a regular file ","type":"text"},{"type":"codeVoice","code":"g_file_test()"},{"text":" will return","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"true"},{"type":"text","text":" for both "},{"code":"isSymlink","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"isRegular","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Note, that for a dangling symbolic link ","type":"text"},{"type":"codeVoice","code":"g_file_test()"},{"text":" will return","type":"text"},{"type":"text","text":" "},{"code":"true","type":"codeVoice"},{"type":"text","text":" for "},{"type":"codeVoice","code":"isSymlink"},{"type":"text","text":" and "},{"code":"false","type":"codeVoice"},{"type":"text","text":" for all other flags."}]},{"inlineContent":[{"text":"You should never use ","type":"text"},{"code":"g_file_test()","type":"codeVoice"},{"text":" to test whether it is safe","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"to perform an operation, because there is always the possibility"},{"type":"text","text":" "},{"text":"of the condition changing before you actually perform the operation,","type":"text"},{"text":" ","type":"text"},{"text":"see ","type":"text"},{"type":"reference","identifier":"https:\/\/en.wikipedia.org\/wiki\/Time-of-check_to_time-of-use","isActive":true},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"For example, you might think you could use "},{"code":"isSymlink","type":"codeVoice"},{"type":"text","text":" "},{"text":"to know whether it is safe to write to a file without being","type":"text"},{"type":"text","text":" "},{"text":"tricked into writing into a different location. It doesn’t work!","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"(C Language Example):","type":"text"}]},{"code":[" \/\/ DON'T DO THIS"," if (!g_file_test (filename, G_FILE_TEST_IS_SYMLINK))","   {","     fd = g_open (filename, O_WRONLY);","     \/\/ write to fd","   }",""," \/\/ DO THIS INSTEAD"," fd = g_open (filename, O_WRONLY | O_NOFOLLOW | O_CLOEXEC);"," if (fd == -1)","   {","     \/\/ check error","     if (errno == ELOOP)","       \/\/ file is a symlink and can be ignored","     else","       \/\/ handle errors as before","   }"," else","   {","     \/\/ write to fd","   }"],"syntax":"C","type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"Another thing to note is that ","type":"text"},{"code":"exists","type":"codeVoice"},{"text":" and","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"isExecutable"},{"text":" are implemented using the ","type":"text"},{"code":"access()","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"system call. This usually doesn’t matter, but if your program"},{"type":"text","text":" "},{"text":"is setuid or setgid it means that these tests will give you","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the answer for the real user ID and group ID, rather than the"},{"type":"text","text":" "},{"text":"effective user ID and group ID.","type":"text"}]},{"inlineContent":[{"type":"text","text":"On Windows, there are no symlinks, so testing for"},{"type":"text","text":" "},{"code":"isSymlink","type":"codeVoice"},{"text":" will always return ","type":"text"},{"type":"codeVoice","code":"false"},{"type":"text","text":". Testing for"},{"type":"text","text":" "},{"type":"codeVoice","code":"isExecutable"},{"text":" will just check that the file exists and","type":"text"},{"type":"text","text":" "},{"type":"text","text":"its name indicates that it is executable, checking for well-known"},{"type":"text","text":" "},{"type":"text","text":"extensions and those listed in the "},{"code":"PATHEXT","type":"codeVoice"},{"text":" environment variable.","type":"text"}],"type":"paragraph"}]}],"metadata":{"symbolKind":"func","roleHeading":"Function","role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"fileTest"},{"kind":"text","text":"("},{"kind":"externalParam","text":"filename"},{"kind":"text","text":": "},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar","text":"gchar"},{"text":">!, ","kind":"text"},{"text":"test","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"FileTest","kind":"typeIdentifier","preciseIdentifier":"s:4GLib8FileTestV"},{"kind":"text","text":") -> "},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"}],"externalID":"s:4GLib8fileTest8filename4testSbSPys4Int8VGSg_AA04FileC0VtF","modules":[{"name":"GLib"}],"title":"fileTest(filename:test:)"},"references":{"doc://GLib/documentation/GLib/fileTest(filename:test:)":{"url":"\/documentation\/glib\/filetest(filename:test:)","kind":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/fileTest(filename:test:)","role":"symbol","type":"topic","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"fileTest"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"filename"},{"text":": ","kind":"text"},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar","text":"gchar"},{"text":">!, ","kind":"text"},{"kind":"externalParam","text":"test"},{"text":": ","kind":"text"},{"text":"FileTest","preciseIdentifier":"s:4GLib8FileTestV","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"text":"Bool","preciseIdentifier":"s:Sb","kind":"typeIdentifier"}],"abstract":[{"text":"Returns ","type":"text"},{"type":"codeVoice","code":"true"},{"text":" if any of the tests in the bitfield ","type":"text"},{"code":"test","type":"codeVoice"},{"type":"text","text":" are"},{"type":"text","text":" "},{"type":"codeVoice","code":"true"},{"type":"text","text":". For example, "},{"type":"codeVoice","code":"(G_FILE_TEST_EXISTS | G_FILE_TEST_IS_DIR)"},{"text":" ","type":"text"},{"text":"will return ","type":"text"},{"type":"codeVoice","code":"true"},{"type":"text","text":" if the file exists; the check whether it’s a"},{"text":" ","type":"text"},{"type":"text","text":"directory doesn’t matter since the existence test is "},{"type":"codeVoice","code":"true"},{"type":"text","text":". With"},{"text":" ","type":"text"},{"type":"text","text":"the current set of available tests, there’s no point passing in"},{"text":" ","type":"text"},{"type":"text","text":"more than one test at a time."}],"title":"fileTest(filename:test:)"},"doc://GLib/documentation/GLib":{"kind":"symbol","role":"collection","abstract":[],"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","type":"topic","url":"\/documentation\/glib"},"https://en.wikipedia.org/wiki/Time-of-check_to_time-of-use":{"identifier":"https:\/\/en.wikipedia.org\/wiki\/Time-of-check_to_time-of-use","titleInlineContent":[{"text":"TOCTOU","type":"text"}],"title":"TOCTOU","url":"https:\/\/en.wikipedia.org\/wiki\/Time-of-check_to_time-of-use","type":"link"},"doc://GLib/documentation/GLib/FileTest":{"kind":"symbol","role":"symbol","url":"\/documentation\/glib\/filetest","abstract":[{"type":"text","text":"A test to perform on a file using "},{"type":"codeVoice","code":"g_file_test()"},{"type":"text","text":"."}],"fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"FileTest","kind":"identifier"}],"type":"topic","navigatorTitle":[{"t