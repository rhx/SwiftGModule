cutable, and ","type":"text"},{"code":"nil","type":"codeVoice"},{"type":"text","text":" otherwise."}],"sections":[],"kind":"symbol","references":{"doc://GLib/documentation/GLib/findProgramInPath(program:)":{"role":"symbol","type":"topic","abstract":[{"type":"text","text":"Locates the first executable named "},{"code":"program","type":"codeVoice"},{"text":" in the user’s path, in the","type":"text"},{"type":"text","text":" "},{"text":"same way that ","type":"text"},{"code":"execvp()","type":"codeVoice"},{"type":"text","text":" would locate it. Returns an allocated string"},{"type":"text","text":" "},{"type":"text","text":"with the absolute path name, or "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" if the program is not found in"},{"type":"text","text":" "},{"text":"the path. If ","type":"text"},{"code":"program","type":"codeVoice"},{"type":"text","text":" is already an absolute path, returns a copy of"},{"type":"text","text":" "},{"type":"codeVoice","code":"program"},{"type":"text","text":" if "},{"type":"codeVoice","code":"program"},{"text":" exists and is executable, and ","type":"text"},{"type":"codeVoice","code":"nil"},{"type":"text","text":" otherwise."}],"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"findProgramInPath"},{"kind":"text","text":"("},{"kind":"externalParam","text":"program"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","text":"gchar","preciseIdentifier":"c:@T@gchar"},{"kind":"text","text":">!) -> "},{"text":"String","kind":"typeIdentifier","preciseIdentifier":"s:SS"},{"kind":"text","text":"!"}],"kind":"symbol","url":"\/documentation\/glib\/findprograminpath(program:)","title":"findProgramInPath(program:)","identifier":"doc:\/\/GLib\/documentation\/GLib\/findProgramInPath(program:)"},"doc://GLib/documentation/GLib":{"kind":"symbol","role":"collection","abstract":[],"iden