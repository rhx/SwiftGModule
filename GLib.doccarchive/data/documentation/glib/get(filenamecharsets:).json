type":"codeVoice","code":"G_BROKEN_FILENAMES"},{"text":" is,","type":"text"},{"type":"text","text":" "},{"text":"the character set of the current locale is taken as the filename","type":"text"},{"type":"text","text":" "},{"type":"text","text":"encoding. If neither environment variable  is set, UTF-8 is taken"},{"text":" ","type":"text"},{"type":"text","text":"as the filename encoding, but the character set of the current locale"},{"type":"text","text":" "},{"type":"text","text":"is also put in the list of encodings."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The returned "},{"code":"charsets","type":"codeVoice"},{"type":"text","text":" belong to GLib and must not be freed."}]},{"inlineContent":[{"type":"text","text":"Note that on Unix, regardless of the locale character set or"},{"type":"text","text":" "},{"type":"codeVoice","code":"G_FILENAME_ENCODING"},{"type":"text","text":" value, the actual file names present"},{"type":"text","text":" "},{"type":"text","text":"on a system might be in any random encoding or just gibberish."}],"type":"paragraph"}]}],"references":{"doc://GLib/documentation/GLib":{"kind":"symbol","role":"collection","abstract":[],"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","type":"topic","url":"\/documentation\/glib"},"running.html#locale":{"url":"running.html#locale","type":"link","title":"current locale","titleInlineContent":[{"type":"text","text":"current locale"}],"identifier":"running.html#locale"},"doc://GLib/documentation/GLib/get(filenameCharsets:)":{"type":"topic","kind":"symbol","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"get"},{"kind":"text","text":"("},{"text":"filenameCharsets","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"UnsafeMutablePointer","preciseIdentifier":"s:Sp"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","text":"UnsafeMutablePointer","preciseIdentifier":"s:Sp"},{