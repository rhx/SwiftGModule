{"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/getHomeDir()","interfaceLanguage":"swift"},"schemaVersion":{"patch":0,"major":0,"minor":3},"kind":"symbol","abstract":[{"text":"Gets the current user’s home directory.","type":"text"}],"variants":[{"paths":["\/documentation\/glib\/gethomedir()"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"metadata":{"symbolKind":"func","modules":[{"name":"GLib"}],"roleHeading":"Function","role":"symbol","externalID":"s:4GLib10getHomeDirSSSgyF","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"getHomeDir","kind":"identifier"},{"kind":"text","text":"() -> "},{"text":"String","kind":"typeIdentifier","preciseIdentifier":"s:SS"},{"kind":"text","text":"!"}],"title":"getHomeDir()"},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"getHomeDir","kind":"identifier"},{"kind":"text","text":"() -> "},{"text":"String","kind":"typeIdentifier","preciseIdentifier":"s:SS"},{"text":"!","kind":"text"}]}]},{"kind":"content","content":[{"anchor":"discussion","text":"Discussion","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"As with most UNIX tools, this function will return the value of the"},{"type":"text","text":" "},{"code":"HOME","type":"codeVoice"},{"type":"text","text":" environment variable if it is set to an existing absolute path"},{"text":" ","type":"text"},{"type":"text","text":"name, falling back to the "},{"code":"passwd","type":"codeVoice"},{"type":"text","text":" file in the case that it is unset."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If the path given in "},{"type":"codeVoice","code":"HOME"},{"type":"text","text":" is non-absolute, does not exist, or is"},{"text":" ","type":"text"},{"type":"text","text":"not a directory, the result is undefined."}]},{"inlineContent":[{"type":"text","text":"Before version 2.36 this function would ignore the "},{"code":"HOME","type":"codeVoice"},{"type":"text","text":" environment"},{"text":" ","type":"text"},{"text":"variable, taking the value from the ","type":"text"},{"type":"codeVoice","code":"passwd"},{"type":"text","text":" database instead. This was"},{"type":"text","text":" "},{"text":"changed to increase the compatibility of GLib with other programs (and","type":"text"},{"text":" ","type":"text"},{"text":"the XDG basedir specification) and to increase testability of programs","type":"text"},{"type":"text","text":" "},{"type":"text","text":"based on GLib (by making it easier to run them from test frameworks)."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If your program has a strong requirement for either the new or the"},{"text":" ","type":"text"},{"type":"text","text":"old behaviour (and if you don’t wish to increase your GLib"},{"text":" ","type":"text"},{"type":"text","text":"dependency to ensure that the new behaviour is in effect) then you"},{"text":" ","type":"text"},{"text":"should either directly check the ","type":"text"},{"type":"codeVoice","code":"HOME"},{"type":"text","text":" environment variable yourself"},{"type":"text","text":" "},{"type":"text","text":"or unset it before calling any functions in GLib."}]}]}],"sections":[],"references":{"doc://GLib/documentation/GLib/getHomeDir()":{"role":"symbol","type":"topic","abstract":[{"type":"text","text":"Gets the current user’s home directory."}],"fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"getHomeDir","kind":"identifier"},{"kind":"text","text":"() -> "},{"preciseIdentifier":"s:SS","text":"String","kind":"typeIdentifier"},{"kind":"text","text":"!"}],"kind":"symbol","url":"\/documentation\/glib\/gethomedir()","title":"getHomeDir()","identifier":"doc:\/\/GLib\/documentation\/GLib\/getHomeDir()"},"doc://GLib/documentation/GLib":{"kind":"symbol","role":"collection","abstract":[],"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","type":"topic","url":"\/documentation\/glib"}}}