{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/gethostname()"]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"sections":[],"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"getHostName","kind":"identifier"},{"kind":"text","text":"() -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:SS","text":"String"},{"kind":"text","text":"!"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"level":2,"anchor":"discussion","type":"heading","text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The returned name is not necessarily a fully-qualified domain name,"},{"type":"text","text":" "},{"text":"or even present in DNS or some other name service at all. It need","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"not even be unique on your local network or site, but usually it"},{"text":" ","type":"text"},{"type":"text","text":"is. Callers should not rely on the return value having any specific"},{"type":"text","text":" "},{"type":"text","text":"properties like uniqueness for security purposes. Even if the name"},{"type":"text","text":" "},{"text":"of the machine is changed while an application is running, the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"return value from this function does not change. The returned"},{"text":" ","type":"text"},{"type":"text","text":"string is owned by GLib and should not be modified or freed. If no"},{"type":"text","text":" "},{"text":"name can be determined, a default fixed string “localhost” is","type":"text"},{"type":"text","text":" "},{"text":"returned.","type":"text"}]},{"inlineContent":[{"text":"The encoding of the returned string is UTF-8.","type":"text"}],"type":"paragraph"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/getHostName()"},"abstract":[{"text