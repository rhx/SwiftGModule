"},{"text":"In this case the list of directories retrieved will be ","type":"text"},{"code":"XDG_CONFIG_DIRS","type":"codeVoice"},{"type":"text","text":"."}]},{"inlineContent":[{"text":"On Windows it follows XDG Base Directory Specification if ","type":"text"},{"code":"XDG_CONFIG_DIRS","type":"codeVoice"},{"type":"text","text":" is defined."},{"type":"text","text":" "},{"type":"text","text":"If "},{"code":"XDG_CONFIG_DIRS","type":"codeVoice"},{"text":" is undefined, the directory that contains application","type":"text"},{"text":" ","type":"text"},{"text":"data for all users is used instead. A typical path is","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"C:\\Documents and Settings\\All Users\\Application Data"},{"type":"text","text":"."},{"type":"text","text":" "},{"text":"This folder is used for application data","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"that is not user specific. For example, an application can store"},{"type":"text","text":" "},{"type":"text","text":"a spell-check dictionary, a database of clip art, or a log file in the"},{"type":"text","text":" "},{"text":"FOLDERID_ProgramData folder. This information will not roam and is available","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"to anyone using the computer."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The return value is cached and modifying it at runtime is not supported, as","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"it’s not thread-safe to modify environment variables at runtime."}]}]}],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"abstract":[{"text":"Returns an ordered list of base directories in which to access","type":"text"},{"type":"text","text":" "},{"type":"text","text":"system-wide configuration information."}],"references":{"doc://GLib/documentation/GLib/getSystemConfigDirs()":{"role":"symbol","type":"topic","identifier":"doc:\/\/GLib\/docu