{"kind":"symbol","hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"getSystemDataDirs","kind":"identifier"},{"kind":"text","text":"() -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"UnsafePointer","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"preciseIdentifier":"c:@T@gchar","text":"gchar","kind":"typeIdentifier"},{"text":">?>!","kind":"text"}],"languages":["swift"]}]},{"kind":"content","content":[{"anchor":"discussion","text":"Discussion","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"text":"On UNIX platforms this is determined using the mechanisms described","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"in the"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"http:\/\/www.freedesktop.org\/Standards\/basedir-spec"},{"text":" ","type":"text"},{"type":"text","text":"In this case the list of directories retrieved will be "},{"code":"XDG_DATA_DIRS","type":"codeVoice"},{"type":"text","text":"."}]},{"inlineContent":[{"type":"text","text":"On Windows it follows XDG Base Directory Specification if "},{"type":"codeVoice","code":"XDG_DATA_DIRS"},{"type":"text","text":" is defined."},{"text":" ","type":"text"},{"type":"text","text":"If "},{"type":"codeVoice","code":"XDG_DATA_DIRS"},{"text":" is undefined,","type":"text"},{"text":" ","type":"text"},{"text":"the first elements in the list are the Application Data","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"and Documents folders for All Users. (These can be determined only"},{"type":"text","text":" "},{"text":"on Windows 2000 or later and are not present in the list on other","type":"text"},{"type":"text","text":" "},{"text":"Windows versions.) See documentation for FOLDERID_ProgramData and","type":"text"},{"text":" ","type":"text"},{"text":"FOLDERID_PublicDocuments.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Then follows the “share” subfolder in the installation folder for","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the package containing the DLL that calls this function, if it can"},{"text":" ","type":"text"},{"type":"text","text":"be determined."}]},{"inlineContent":[{"text":"Finally the list contains the “share” subfolder in the installation","type":"text"},{"text":" ","type":"text"},{"text":"folder for GLib, and in the installation folder for the package the","type":"text"},{"type":"text","text":" "},{"text":"application’s .exe file belongs to.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"The installation folders above are determined by looking up the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"folder where the module (DLL or EXE) in question is located. If the"},{"type":"text","text":" "},{"type":"text","text":"folder’s name is “bin”, its parent is used, otherwise the folder"},{"text":" ","type":"text"},{"type":"text","text":"itself."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Note that on Windows the returned list can vary depending on where","type":"text"},{"text":" ","type":"text"},{"text":"this function is called.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The return value is cached and modifying it at runtime is not supported, as"},{"type":"text","text":" "},{"text":"it’s not thread-safe to modify environment variables at runtime.","type":"text"}]}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/getsystemdatadirs()"]}],"metadata":{"role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"getSystemDataDirs","kind":"identifier"},{"text":"() -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"UnsafePointer","preciseIdentifier":"s:SP"},{"kind":"text","text":"<"},{"preciseIdentifier":"c:@T@gchar","kind":"typeIdentifier","text":"gchar"},{"kind":"text","text":">?>!"}],"roleHeading":"Function","externalID":"s:4GLib17getSystemDataDirsSPySPys4Int8VGSgGSgyF","symbolKind":"func","modules":[{"name":"GLib"}],"title":"getSystemDataDirs()"},"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/getSystemDataDirs()","interfaceLanguage":"swift"},"schemaVersion":{"major":0,"minor":3,"patch":0},"abstract":[{"type":"text","text":"Returns an ordered list of base directories in which to access"},{"text":" ","type":"text"},{"text":"system-wide application data.","type":"text"}],"references":{"doc://GLib/documentation/GLib":{"kind":"symbol","role":"collection","abstract":[],"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","type":"topic","url":"\/documentation\/glib"},"http://www.freedesktop.org/Standards/basedir-spec":{"url":"http:\/\/www.freedesktop.org\/Standards\/basedir-spec","type":"link","title":"XDG Base Directory Specification","titleInlineContent":[{"text":"XDG Base Directory Specification","type":"text"}],"identifier":"http:\/\/www.freedesktop.org\/Standards\/basedir-spec"},"doc://GLib/documentation/GLib/getSystemDataDirs()":{"role":"symbol","type":"topic","abstract":[{"type":"text","text":"Returns an ordered list of base directories in which to access"},{"type":"text","text":" "},{"text":"system-wide application data.","type":"text"}],"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"getSystemDataDirs","kind":"identifier"},{"text":"() -> ","kind":"text"},{"preciseIdentifier":"s:SP","text":"UnsafePointer","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"UnsafePointer","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","text":"gchar","preciseIdentifier":"c:@T@gchar"},{"text":">?>!","kind":"text"}],"kind":"symbol","url":"\/documentation\/glib\/getsystemdatadirs()","title":"getSystemDataDirs()","identifier":"doc:\/\/GLib\/documentation\/GLib\/getSystemDataDirs()"}}}