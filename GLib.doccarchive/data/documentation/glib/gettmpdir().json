{"abstract":[{"type":"text","text":"Gets the directory to use for temporary files."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"getTmpDir","kind":"identifier"},{"kind":"text","text":"() -> "},{"text":"String","kind":"typeIdentifier","preciseIdentifier":"s:SS"},{"text":"!","kind":"text"}]}]},{"kind":"content","content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"inlineContent":[{"text":"On UNIX, this is taken from the ","type":"text"},{"type":"codeVoice","code":"TMPDIR"},{"type":"text","text":" environment variable."},{"type":"text","text":" "},{"type":"text","text":"If the variable is not set, "},{"code":"P_tmpdir","type":"codeVoice"},{"text":" is","type":"text"},{"text":" ","type":"text"},{"text":"used, as defined by the system C library. Failing that, a","type":"text"},{"text":" ","type":"text"},{"text":"hard-coded default of “\/tmp” is returned.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"On Windows, the "},{"type":"codeVoice","code":"TEMP"},{"type":"text","text":" environment variable is used, with the"},{"type":"text","text":" "},{"text":"root directory of the Windows installation (eg: “C:\") used","type":"text"},{"type":"text","text":" "},{"text":"as a default.","type":"text"}]},{"inlineContent":[{"type":"text","text":"The encoding of the returned string is system-defined. On Windows,"},{"text":" ","type":"text"},{"type":"text","text":"it is always UTF-8. The return value is never "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" or the empty"},{"type":"text","text":" "},{"text":"string.","type":"text"}],"type":"paragraph"}]}],"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/gettmpdir()"]}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"schemaVersion":{"patch":0,"major":0,"minor":3},"metadata":{"fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"getTmpDir"},{"text":"() -> ","kind":"text"},{"text":"String","kind":"typeIdentifier","preciseIdentifier":"s:SS"},{"kind":"text","text":"!"}],"symbolKind":"func","role":"symbol","roleHeading":"Function","title":"getTmpDir()","modules":[{"name":"GLib"}],"externalID":"s:4GLib9getTmpDirSSSgyF"},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/getTmpDir()"},"kind":"symbol","references":{"doc://GLib/documentation/GLib/getTmpDir()":{"fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"getTmpDir","kind":"identifier"},{"kind":"text","text":"() -> "},{"preciseIdentifier":"s:SS","text":"String","kind":"typeIdentifier"},{"kind":"text","text":"!"}],"type":"topic","role":"symbol","url":"\/documentation\/glib\/gettmpdir()","title":"getTmpDir()","kind":"symbol","abstract":[{"type":"text","text":"Gets the directory to use for temporary files."}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/getTmpDir()"},"doc://GLib/documentation/GLib":{"kind":"symbol","role":"collection","abstract":[],"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","type":"topic","url":"\/documentation\/glib"}}}