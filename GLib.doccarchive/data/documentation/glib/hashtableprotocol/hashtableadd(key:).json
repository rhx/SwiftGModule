{"abstract":[{"type":"text","text":"This is a convenience function for using a "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/HashTable","isActive":true,"type":"reference"},{"text":" as a set.  It","type":"text"},{"type":"text","text":" "},{"type":"text","text":"is equivalent to calling "},{"type":"codeVoice","code":"g_hash_table_replace()"},{"text":" with ","type":"text"},{"type":"codeVoice","code":"key"},{"text":" as both the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"key and the value."}],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/HashTableProtocol\/hashTableAdd(key:)","interfaceLanguage":"swift"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/hashtableprotocol\/hashtableadd(key:)"]}],"metadata":{"externalID":"s:4GLib17HashTableProtocolPAAE04hashC3Add3keySbSvSg_tF","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"hashTableAdd"},{"kind":"text","text":"("},{"text":"key","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"c:@T@gpointer","text":"gpointer","kind":"typeIdentifier"},{"text":"?) -> ","kind":"text"},{"text":"Bool","preciseIdentifier":"s:Sb","kind":"typeIdentifier"}],"roleHeading":"Instance Method","symbolKind":"method","modules":[{"name":"GLib"}],"extendedModule":"GLib","title":"hashTableAdd(key:)","role":"symbol"},"kind":"symbol","sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"hashTableAdd","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"key"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:@T@gpointer","text":"gpointer","kind":"typeIdentifier"},{"text":"? = nil) -> ","kind":"text"},{"text":"Bool","preciseIdentifier":"s:Sb","kind":"typeIdentifier"}]}]},{"content":[{"anchor":"discussion","text":"Discussion","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"text":"In particular, this means that if ","type":"text"},{"code":"key","type":"codeVoice"},{"type":"text","text":" already exists in the hash table, then"},{"text":" ","type":"text"},{"text":"the old copy of ","type":"text"},{"type":"codeVoice","code":"key"},{"type":"text","text":" in the hash table is freed and "},{"code":"key","type":"codeVoice"},{"type":"text","text":" replaces it in the"},{"type":"text","text":" "},{"type":"text","text":"table."}]},{"inlineContent":[{"type":"text","text":"When a hash table only ever contains keys that have themselves as the"},{"text":" ","type":"text"},{"text":"corresponding value it is able to be stored more efficiently.  See","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the discussion in the section description."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Starting from GLib 2.40, this function returns a boolean value to"},{"type":"text","text":" "},{"type":"text","text":"indicate whether the newly added value was already in the hash table"},{"text":" ","type":"text"},{"type":"text","text":"or not."}]}],"kind":"content"}],"schemaVersion":{"major":0,"patch":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/HashTableProtocol"]]},"references":{"doc://GLib/documentation/GLib/HashTableProtocol/hashTableAdd(key:)":{"abstract":[{"text":"This is a convenience function for using a ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/HashTable","isActive":true},{"type":"text","text":" as a set.  It"},{"type":"text","text":" "},{"type":"text","text":"is equivalent to calling "},{"code":"g_hash_table_replace()","type":"codeVoice"},{"text":" with ","type":"text"},{"type":"codeVoice","code":"key"},{"type":"text","text":" as both the"},{"text":" ","type":"text"},{"type":"text","text":"key and the value."}],"identifier":"doc:\/\/GLib\/