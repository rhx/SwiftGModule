{"schemaVersion":{"minor":3,"major":0,"patch":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"text":"init","kind":"keyword"},{"kind":"text","text":"("},{"kind":"externalParam","text":"unix"},{"text":" ","kind":"text"},{"text":"fd","kind":"internalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"text":")","kind":"text"}]}]},{"content":[{"type":"heading","level":2,"anchor":"discussion","text":"Discussion"},{"type":"paragraph","inlineContent":[{"text":"The returned ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/IOChannel"},{"type":"text","text":" has a reference count of 1."}]},{"inlineContent":[{"type":"text","text":"The default encoding for "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/IOChannel","isActive":true},{"type":"text","text":" is UTF-8. If your application"},{"type":"text","text":" "},{"type":"text","text":"is reading output from a command using via pipe, you may need to set"},{"type":"text","text":" "},{"type":"text","text":"the encoding to the encoding of the current locale (see"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_get_charset()"},{"type":"text","text":") with the "},{"type":"codeVoice","code":"g_io_channel_set_encoding()"},{"type":"text","text":" function."},{"text":" ","type":"text"},{"type":"text","text":"By default, the fd passed will not be closed when the final reference"},{"type":"text","text":" "},{"text":"to the ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/IOChannel","type":"reference","isActive":true},{"text":" data structure is dropped.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"If you want to read raw binary data without interpretation, then","type":"text"},{"type":"text","text":" "},{"text":"call the ","type":"text"},{"type":"codeVoice","code":"g_io_channel_set_encoding()"},{"text":" function with ","type":"text"},{"code":"nil","type":"codeVoice"},{"type":"text","text":" for the"},{"type":"text","text":" "},{"type":"text","text":"encoding argument."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"This function is available in GLib on Windows, too, but you should","type":"text"},{"type":"text","text":" "},{"type":"text","text":"avoid using it on Windows. The domain of file descriptors and"},{"text":" ","type":"text"},{"text":"sockets overlap. There is no way for GLib to know which one you mean","type":"text"},{"type":"text","text":" "},{"type":"text","text":"in case the argument you pass to this function happens to be both a"},{"type":"text","text":" "},{"type":"text","text":"valid file descriptor and socket. If that happens a warning is"},{"type":"text","text":" "},{"text":"issued, and GLib assumes that it is the file descriptor you mean.","type":"text"}]}],"kind":"content"}],"metadata":{"modules":[{"name":"GLib"}],"title":"init(unix:)","role":"symbol","roleHeading":"Initializer","fragments":[{"text":"init","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"unix"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":")","kind":"text"}],"externalID":"s:4GLib9IOChannelC4unixACSi_tcfc","symbolKind":"init"},"sections":[],"abstract":[{"text":"Creates a new ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/IOChannel","isActive":true},{"text":" given a file descriptor. On UNIX systems","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"this works for plain files, pipes, and sockets."}],"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/iochannel\/init(unix:)"]}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/IOChannel"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/IOChannel\/init(unix:)"},"references":{"doc://GLib/documentation/GLib":{"kind":"symbol","role":"collection","abstract":[],"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","type":"topic","url":"\/documentation\/glib"},"doc://GLib/documentation/GLib/IOChannel/init(unix:)":{"abstract":[{"type":"text","text":"Creates a new "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/IOChannel","isActive":true,"type":"reference"},{"text":" given a file descriptor. On UNIX systems","type":"text"},{"type":"text","text":" "},{"type":"text","text":"this works for plain files, pipes, and sockets."}],"url":"\/documentation\/glib\/iochannel\/init(unix:)","title":"init(unix:)","type":"topic","fragments":[{"text":"init","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"unix"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"},{"kind":"text","text":")"}],"kind":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/IOChannel\/init(unix:)","role":"symbol"},"doc://GLib/documentation/GLib/IOChannel":{"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"IOChannel","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"IOChannel"}],"kind":"symbol","url":"\/documentation\/glib\/iochannel","type":"topic","role":"symbol","abstract":[{"type":"text","text":"The "},{"type":"codeVoice","code":"GIOChannel"},{"type":"text","text":" data type aims to provide a portable method for"},{"type":"text","text":" "},{"type":"text","text":"using file descriptors, pipes, and sockets, and integrating them"},{"text":" ","type":"text"},{"type":"text","text":"into the main event loop (see [struct"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/MainContext","isActive":true,"type":"reference"},{"type":"text","text":"]). Currently,"},{"type":"text","text":" "},{"type":"text","text":"full support is available on UNIX platforms; support for Windows"},{"type":"text","text":" "},{"text":"is only partially complete.","type":"text"}],"title":"IOChannel","identifier":"doc:\/\/GLib\/documentation\/GLib\/IOChannel"},"doc://GLib/documentation/GLib/MainContext":{"abstract":[{"type":"text","text":"The "},{"type":"codeVoice","code":"GMainContext"},{"type":"text","text":" struct is an opaque data"},{"type":"text","text":" "},{"text":"type representing a set of sources to be handled in a main loop.","type":"text"}],"role":"symbol","kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"MainContext"}],"type":"topic","url":"\/documentation\/glib\/maincontext","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"MainContext"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/MainContext","title":"MainContext"}}}