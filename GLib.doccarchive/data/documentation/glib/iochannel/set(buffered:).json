{"metadata":{"modules":[{"name":"GLib"}],"symbolKind":"method","role":"symbol","roleHeading":"Instance Method","title":"set(buffered:)","externalID":"s:4GLib17IOChannelProtocolPAAE3set8bufferedySb_tF::SYNTHESIZED::s:4GLib9IOChannelC","extendedModule":"GLib","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"set"},{"kind":"text","text":"("},{"text":"buffered","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"},{"kind":"text","text":")"}]},"abstract":[{"text":"The buffering state can only be set if the channel’s encoding","type":"text"},{"type":"text","text":" "},{"text":"is ","type":"text"},{"code":"nil","type":"codeVoice"},{"type":"text","text":". For any other encoding, the channel must be buffered."}],"variants":[{"paths":["\/documentation\/glib\/iochannel\/set(buffered:)"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/IOChannel\/set(buffered:)","interfaceLanguage":"swift"},"sections":[],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/IOChannel","doc:\/\/GLib\/documentation\/GLib\/IOChannel\/IOChannelProtocol-Implementations"]]},"kind":"symbol","schemaVersion":{"major":0,"patch":0,"minor":3},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"set"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"buffered"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"},{"text":")","kind":"text"}]}]},{"kind":"content","content":[{"text":"Discussion","type":"heading","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A buffered channel can only be set unbuffered if the channel’s"},{"type":"text","text":" "},{"text":"internal buffers have been flushed. Newly created channels or","type":"text"},{"type":"text","text":" "},{"type":"text","text":"channels which have returned "},{"code":"eof","type":"codeVoice"},{"text":" ","type":"text"},{"type":"text","text":"not require such a flush. For write-only channels, a call to"},{"type":"text","text":" "},{"text":"g_io_channel_flush () is sufficient. For all other channels,","type":"text"},{"type":"text","text":" "},{"text":"the buffers may be flushed by a call to g_io_channel_seek_position ().","type":"text"},{"type":"text","text":" "},{"text":"This includes the possibility of seeking with seek type ","type":"text"},{"type":"codeVoice","code":"cur"},{"type":"text","text":" "},{"type":"text","text":"and an offset of zero. Note that this means that socket-based"},{"text":" ","type":"text"},{"type":"text","text":"channels cannot be set unbuffered once they have had data"},{"text":" ","type":"text"},{"text":"read from them.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"On unbuffered channels, it is safe to mix read and write"},{"type":"text","text":" "},{"type":"text","text":"calls from the new and old APIs, if this is necessary for"},{"type":"text","text":" "},{"type":"text","text":"maintaining old code."}]},{"inlineContent":[{"type":"text","text":"The default state of the channel is buffered."}],"type":"paragraph"}]}],"references":{"doc://GLib/documentation/GLib/MainContext":{"abstract":[{"type":"text","text":"The "},{"type":"codeVoice","code":"GMainContext"},{"type":"text","text":" struct is an opaque data"},{"type":"text","text":" "},{"text":"type representing a set of sources to be handled in a main loop.","type":"text"}],"role":"symbol","kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"MainContext"}],"type":"topic","url":"\/documentation\/glib\/maincontext","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"MainContext"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/MainContext","title":"MainContext"},"doc://GLib/documentation/GLib":{"kind":"symbol","role":"collection","abstract":[],"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","type":"topic","url":"\/documentation\/glib"},"doc://GLib/documentation/GLib/IOChannel/IOChannelProtocol-Implementations":{"kind":"article","type":"topic","url":"\/documentation\/glib\/iochannel\/iochannelprotocol-implementations","role":"collectionGroup","abstract":[],"identifier":"doc:\/\/GLib\/documentation\/GLib\/IOChannel\/IOChannelProtocol-Implementations","title":"IOChannelProtocol Implementations"},"doc://GLib/documentation/GLib/IOChannel":{"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"IOChannel","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"IOChannel"}],"kind":"symbol","url":"\/documentation\/glib\/iochannel","type":"topic","role":"symbol","abstract":[{"type":"text","text":"The "},{"type":"codeVoice","code":"GIOChannel"},{"type":"text","text":" data type aims to provide a portable method for"},{"type":"text","text":" "},{"type":"text","text":"using file descriptors, pipes, and sockets, and integrating them"},{"text":" ","type":"text"},{"type":"text","text":"into the main event loop (see [struct"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/MainContext","isActive":true,"type":"reference"},{"type":"text","text":"]). Currently,"},{"type":"text","text":" "},{"type":"text","text":"full support is available on UNIX platforms; support for Windows"},{"type":"text","text":" "},{"text":"is only partially complete.","type":"text"}],"title":"IOChannel","identifier":"doc:\/\/GLib\/documentation\/GLib\/IOChannel"},"doc://GLib/documentation/GLib/IOChannel/set(buffered:)":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/IOChannel\/set(buffered:)","kind":"symbol","role":"symbol","url":"\/documentation\/glib\/iochannel\/set(buffered:)","title":"set(buffered:)","type":"topic","abstract":[{"type":"text","text":"The buffering state can only be set if the channel’s encoding"},{"text":" ","type":"text"},{"type":"text","text":"is "},{"type":"codeVoice","code":"nil"},{"type":"text","text":". For any other encoding, the channel must be buffered."}],"fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"set"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"buffered"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sb","kind":"typeIdentifier","text":"Bool"},{"text":")","kind":"text"}]}}}