happens to be both a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"valid file descriptor and socket. If that happens a warning is"},{"type":"text","text":" "},{"type":"text","text":"issued, and GLib assumes that it is the file descriptor you mean."}],"type":"paragraph"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/iochannel\/unixnew(unix:)"]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/IOChannel\/unixNew(unix:)","interfaceLanguage":"swift"},"kind":"symbol","sections":[],"references":{"doc://GLib/documentation/GLib/MainContext":{"abstract":[{"type":"text","text":"The "},{"type":"codeVoice","code":"GMainContext"},{"type":"text","text":" struct is an opaque data"},{"type":"text","text":" "},{"text":"type representing a set of sources to be handled in a main loop.","type":"text"}],"role":"symbol","kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"MainContext"}],"type":"topic","url":"\/documentation\/glib\/maincontext","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"MainContext"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/MainContext","title":"MainContext"},"doc://GLib/documentation/GLib/IOChannel/unixNew(unix:)":{"abstract":[{"text":"Creates a new ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/IOChannel","isActive":true},{"text":" given a file descriptor. On UNIX systems","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"this works for plain files, pipes, and sockets."}],"url":"\/documentation\/glib\/iochannel\/unixnew(unix:)","title":"unixNew(unix:)","type":"topic","fragments":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"unixNew","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"unix"},{"text":": ","kind"