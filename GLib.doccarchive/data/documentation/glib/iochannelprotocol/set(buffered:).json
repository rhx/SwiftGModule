{"abstract":[{"type":"text","text":"The buffering state can only be set if the channel’s encoding"},{"type":"text","text":" "},{"type":"text","text":"is "},{"type":"codeVoice","code":"nil"},{"text":". For any other encoding, the channel must be buffered.","type":"text"}],"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"set"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"buffered"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sb","kind":"typeIdentifier","text":"Bool"},{"text":")","kind":"text"}],"platforms":["macOS"]}],"kind":"declarations"},{"content":[{"anchor":"discussion","text":"Discussion","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"A buffered channel can only be set unbuffered if the channel’s"},{"text":" ","type":"text"},{"text":"internal buffers have been flushed. Newly created channels or","type":"text"},{"type":"text","text":" "},{"text":"channels which have returned ","type":"text"},{"type":"codeVoice","code":"eof"},{"text":" ","type":"text"},{"type":"text","text":"not require such a flush. For write-only channels, a call to"},{"text":" ","type":"text"},{"type":"text","text":"g_io_channel_flush () is sufficient. For all other channels,"},{"text":" ","type":"text"},{"type":"text","text":"the buffers may be flushed by a call to g_io_channel_seek_position ()."},{"type":"text","text":" "},{"type":"text","text":"This includes the possibility of seeking with seek type "},{"type":"codeVoice","code":"cur"},{"text":" ","type":"text"},{"type":"text","text":"and an offset of zero. Note that this means that socket-based"},{"type":"text","text":" "},{"type":"text","text":"channels cannot be set unbuffered once they have had data"},{"type":"text","text":" "},{"type":"text","text":"read from them."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"On unbuffered channels, it is safe to mix read and write","type":"text"},{"type":"text","text":" "},{"type":"text","text":"calls from the new and old APIs, if this is necessary for"},{"type":"text","text":" "},{"text":"maintaining old code.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The default state of the channel is buffered.","type":"text"}]}],"kind":"content"}],"kind":"symbol","sections":[],"metadata":{"title":"set(buffered:)","symbolKind":"method","externalID":"s:4GLib17IOChannelProtocolPAAE3set8bufferedySb_tF","roleHeading":"Instance Method","role":"symbol","modules":[{"name":"GLib"}],"extendedModule":"GLib","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"set","kind":"identifier"},{"text":"(","kind":"text"},{"text":"buffered","kind":"externalParam"},{"kind":"text","text":": "},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"},{"text":")","kind":"text"}]},"schemaVersion":{"minor":3,"patch":0,"major":0},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/IOChannelProtocol\/set(buffered:)"},"variants":[{"paths":["\/documentation\/glib\/iochannelprotocol\/set(buffered:)"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/IOChannelProtocol"]]},"references":{"doc://GLib/documentation/GLib/MainContext":{"abstract":[{"type":"text","text":"The "},{"type":"codeVoice","code":"GMainContext"},{"type":"text","text":" struct is an opaque data"},{"type":"text","text":" "},{"text":"type representing a set of sources to be handled in a main loop.","type":"text"}],"role":"symbol","kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"MainContext"}],"type":"topic","url":"\/documentation\/glib\/maincontext","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"MainContext"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/MainContext","title":"MainContext"},"doc://GLib/documentation/GLib/IOChannelProtocol/set(buffered:)":{"abstract":[{"type":"text","text":"The buffering state can only be set if the channel’s encoding"},{"type":"text","text":" "},{"type":"text","text":"is "},{"code":"nil","type":"codeVoice"},{"type":"text","text":". For any other encoding, the channel must be buffered."}],"kind":"symbol","url":"\/documentation\/glib\/iochannelprotocol\/set(buffered:)","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"set"},{"kind":"text","text":"("},{"text":"buffered","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"},{"kind":"text","text":")"}],"role":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/IOChannelProtocol\/set(buffered:)","title":"set(buffered:)","type":"topic"},"doc://GLib/documentation/GLib":{"kind":"symbol","role":"collection","abstract":[],"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","type":"topic","url":"\/documentation\/glib"},"doc://GLib/documentation/GLib/IOChannelProtocol":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/IOChannelProtocol","kind":"symbol","type":"topic","abstract":[{"text":"The ","type":"text"},{"type":"codeVoice","code":"GIOChannel"},{"text":" data type aims to provide a portable method for","type":"text"},{"text":" ","type":"text"},{"text":"using file descriptors, pipes, and sockets, and integrating them","type":"text"},{"type":"text","text":" "},{"type":"text","text":"into the main event loop (see [struct"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/MainContext"},{"text":"]). Currently,","type":"text"},{"text":" ","type":"text"},{"text":"full support is available on UNIX platforms; support for Windows","type":"text"},{"text":" ","type":"text"},{"text":"is only partially complete.","type":"text"}],"url":"\/documentation\/glib\/iochannelprotocol","fragments":[{"kind":"keyword","text":"protocol"},{"text":" ","kind":"t