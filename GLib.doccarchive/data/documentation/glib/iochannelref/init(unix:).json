{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/IOChannelRef\/init(unix:)"},"kind":"symbol","sections":[],"abstract":[{"text":"Creates a new ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/IOChannel","type":"reference","isActive":true},{"text":" given a file descriptor. On UNIX systems","type":"text"},{"type":"text","text":" "},{"text":"this works for plain files, pipes, and sockets.","type":"text"}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/IOChannelRef"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/iochannelref\/init(unix:)"]}],"metadata":{"roleHeading":"Initializer","modules":[{"name":"GLib"}],"symbolKind":"init","title":"init(unix:)","role":"symbol","extendedModule":"GLib","fragments":[{"kind":"identifier","text":"init"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"unix"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"text":")","kind":"text"}],"externalID":"s:4GLib12IOChannelRefV4unixACSi_tcfc"},"schemaVersion":{"patch":0,"major":0,"minor":3},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"init","kind":"keyword"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"unix"},{"text":" ","kind":"text"},{"text":"fd","kind":"internalParam"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"kind":"text","text":")"}],"platforms":["macOS"]}]},{"kind":"content","content":[{"text":"Discussion","type":"heading","level":2,"anchor":"discussion"},{"inlineContent":[{"type":"text","text":"The returned "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/IOChannel","type":"reference","isActive":true},{"type":"text","text":" has a reference count of 1."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The default encoding for ","type":"text"},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/IOChannel","type":"reference"},{"type":"text","text":" is UTF-8. If your application"},{"type":"text","text":" "},{"type":"text","text":"is reading output from a command using via pipe, you may need to set"},{"text":" ","type":"text"},{"type":"text","text":"the encoding to the encoding of the current locale (see"},{"type":"text","text":" "},{"code":"g_get_charset()","type":"codeVoice"},{"type":"text","text":") with the "},{"code":"g_io_channel_set_encoding()","type":"codeVoice"},{"type":"text","text":" function."},{"type":"text","text":" "},{"type":"text","text":"By default, the fd passed will not be closed when the final reference"},{"text":" ","type":"text"},{"type":"text","text":"to the "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/IOChannel","type":"reference","isActive":true},{"text":" data structure is dropped.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you want to read raw binary data without interpretation, then"},{"text":" ","type":"text"},{"text":"call the ","type":"text"},{"type":"codeVoice","code":"g_io_channel_set_encoding()"},{"type":"text","text":" function with "},{"type":"codeVoice","code":"nil"},{"text":" for the","type":"text"},{"type":"text","text":" "},{"text":"encoding argument.","type":"text"}]},{"inlineContent":[{"type":"text","text":"This function is available in GLib on Windows, too, but you should"},{"text":" ","type":"text"},{"type":"text","text":"avoid using it on Windows. The domain of file descriptors and"},{"text":" ","type":"text"},{"type":"text","text":"sockets overlap. There is no way for GLib to know which one you mean"},{"type":"text","text":" "},{"type":"text","text":"in case the argument you pass to this function happens to be both a"},{"text":" ","type":"text"},{"text":"valid file descriptor and socket. If that happens a warning is","type":"text"},{"type":"text","text":" "},{"type":"text","text":"issued, and GLib as