{"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/IOChannelRef","doc:\/\/GLib\/documentation\/GLib\/IOChannelRef\/IOChannelProtocol-Implementations"]]},"kind":"symbol","metadata":{"title":"set(buffered:)","modules":[{"name":"GLib"}],"extendedModule":"GLib","roleHeading":"Instance Method","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"set","kind":"identifier"},{"text":"(","kind":"text"},{"text":"buffered","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"},{"text":")","kind":"text"}],"externalID":"s:4GLib17IOChannelProtocolPAAE3set8bufferedySb_tF::SYNTHESIZED::s:4GLib12IOChannelRefV","role":"symbol","symbolKind":"method"},"schemaVersion":{"major":0,"patch":0,"minor":3},"abstract":[{"text":"The buffering state can only be set if the channel’s encoding","type":"text"},{"text":" ","type":"text"},{"text":"is ","type":"text"},{"type":"codeVoice","code":"nil"},{"text":". For any other encoding, the channel must be buffered.","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/iochannelref\/set(buffered:)"]}],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"set"},{"kind":"text","text":"("},{"kind":"externalParam","text":"buffered"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sb","kind":"typeIdentifier","text":"Bool"},{"text":")","kind":"text"}]}],"kind":"declarations"},{"content":[{"anchor":"discussion","type":"heading","text":"Discussion","level":2},{"type":"paragraph","inlineContent":[{"text":"A buffered channel can only be set unbuffered if the channel’s","type":"text"},{"type":"text","text":" "},{"text":"internal buffers have been flushed. Newly created channels or","type":"text"},{"type":"text","text":" "},{"text":"channels which have returned ","type":"text"},{"type":"codeVoice","code":"eof"},{"type":"text","text":" "},{"type":"text","text":"not require such a flush. For write-only channels, a call to"},{"text":" ","type":"text"},{"text":"g_io_channel_flush () is sufficient. For all other channels,","type":"text"},{"text":" ","type":"text"},{"text":"the buffers may be flushed by a call to g_io_channel_seek_position ().","type":"text"},{"type":"text","text":" "},{"type":"text","text":"This includes the possibility of seeking with seek type "},{"type":"codeVoice","code":"cur"},{"type":"text","text":" "},{"text":"and an offset of zero. Note that this means that socket-based","type":"text"},{"type":"text","text":" "},{"type":"text","text":"channels cannot be set unbuffered once they have had data"},{"type":"text","text":" "},{"type":"text","text":"read from them."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"On unbuffered channels, it is safe to mix read and write"},{"type":"text","text":" "},{"type":"text","text":"calls from the new and old APIs, if this is necessary for"},{"type":"text","text":" "},{"type":"text","text":"maintaining old code."}]},{"inlineContent":[{"text":"The default state of the channel is buffered.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/IOChannelRef\/set(buffered:)","interfaceLanguage":"swift"},"sections":[],"references":{"doc://GLib/documentation/GLib/MainContext":{"abstract":[{"type":"text","text":"The "},{"type":"codeVoice","code":"GMainContext"},{"type":"text","text":" struct is an opaque data"},{"type":"text","text":" "},{"text":"type representing a set of sources to be handled in a main loop.","type":"text"}],"role":"symbol","kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"MainContext"}],"type":"topic","url":"\/documentation\/glib\/maincontext","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"MainContext"}],"i