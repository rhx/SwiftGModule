 and has not been written to or read from yet.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"The channel is write-only.","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"The channel is a file, and the file pointer was just repositioned","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"by a call to "},{"code":"g_io_channel_seek_position()","type":"codeVoice"},{"type":"text","text":". (This flushes all the"},{"type":"text","text":" "},{"type":"text","text":"internal buffers.)"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The current encoding is "},{"type":"codeVoice","code":"nil"},{"text":" or UTF-8.","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"One of the (new API) read functions has just returned ","type":"text"},{"type":"codeVoice","code":"eof"},{"type":"text","text":" "},{"type":"text","text":"(or, in the case of "},{"type":"codeVoice","code":"g_io_channel_read_to_end()"},{"type":"text","text":", "},{"type":"codeVoice","code":"normal"},{"text":").","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"One of the functions "},{"type":"codeVoice","code":"g_io_channel_read_chars()"},{"text":" or","type":"text"},{"text":" ","type":"text"},{"code":"g_io_channel_read_unichar()","type":"codeVoice"},{"text":" has returned ","type":"text"},{"type":"codeVoice","code":"again"},{"type":"text","text":" or"},{"text":" ","type":"text"},{"type":"codeVoice","code":"error"},{"type":"text","text":". This may be useful in the case of"},{"text":" ","type":"text"},{"type":"codeVoice","code":"illegalSequence"},{"text":".","type":"text"},{"type":"text","text":" "},{"text":"Returning one of these statuses from ","type":"text"},{"code":"g_io_channel_read_line()","type":"codeVoice"},{"type":"text","text":","},{"type":"text","text":" "},{"code":"g_io_channel_read_line_string()","type":"codeVoice"},{