{"sections":[],"metadata":{"externalID":"s:4GLib7KeyFileC","role":"symbol","symbolKind":"class","modules":[{"name":"GLib"}],"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"KeyFile","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"KeyFile"}],"title":"KeyFile","roleHeading":"Class"},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"abstract":[{"code":"GKeyFile","type":"codeVoice"},{"type":"text","text":" parses .ini-like config files."}],"topicSections":[{"anchor":"Initializers","generated":true,"title":"Initializers","identifiers":["doc:\/\/GLib\/documentation\/GLib\/KeyFile\/init()","doc:\/\/GLib\/documentation\/GLib\/KeyFile\/init(_:)-1hpxa","doc:\/\/GLib\/documentation\/GLib\/KeyFile\/init(_:)-2cylo","doc:\/\/GLib\/documentation\/GLib\/KeyFile\/init(_:)-55cb","doc:\/\/GLib\/documentation\/GLib\/KeyFile\/init(_:)-6cxh2","doc:\/\/GLib\/documentation\/GLib\/KeyFile\/init(_:)-7e0t2","doc:\/\/GLib\/documentation\/GLib\/KeyFile\/init(cPointer:)","doc:\/\/GLib\/documentation\/GLib\/KeyFile\/init(gconstpointer:)","doc:\/\/GLib\/documentation\/GLib\/KeyFile\/init(gpointer:)","doc:\/\/GLib\/documentation\/GLib\/KeyFile\/init(opaquePointer:)","doc:\/\/GLib\/documentation\/GLib\/KeyFile\/init(raw:)-1fvqt","doc:\/\/GLib\/documentation\/GLib\/KeyFile\/init(raw:)-9irr5","doc:\/\/GLib\/documentation\/GLib\/KeyFile\/init(retaining:)","doc:\/\/GLib\/documentation\/GLib\/KeyFile\/init(retainingCPointer:)","doc:\/\/GLib\/documentation\/GLib\/KeyFile\/init(retainingOpaquePointer:)","doc:\/\/GLib\/documentation\/GLib\/KeyFile\/init(retainingRaw:)-3tfsd","doc:\/\/GLib\/documentation\/GLib\/KeyFile\/init(retainingRaw:)-9y6hj"]},{"title":"Instance Properties","anchor":"Instance-Properties","identifiers":["doc:\/\/GLib\/documentation\/GLib\/KeyFile\/ptr"],"generated":true},{"generated":true,"title":"Default Implementations","identifiers":["doc:\/\/GLib\/documentation\/GLib\/KeyFile\/KeyFileProtocol-Implementations"],"anchor":"Default-Implementations"}],"schemaVersion":{"patch":0,"minor":3,"major":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"KeyFile","kind":"identifier"}],"platforms":["macOS"]}]},{"content":[{"level":2,"type":"heading","text":"Overview","anchor":"overview"},{"type":"paragraph","inlineContent":[{"code":"GKeyFile","type":"codeVoice"},{"type":"text","text":" lets you parse, edit or create files containing groups of"},{"type":"text","text":" "},{"type":"text","text":"key-value pairs, which we call ‘key files’ for lack of a better name."},{"type":"text","text":" "},{"type":"text","text":"Several freedesktop.org specifications use key files. For example, the"},{"type":"text","text":" "},{"isActive":true,"identifier":"https:\/\/specifications.freedesktop.org\/desktop-entry-spec\/latest\/","type":"reference"},{"text":" ","type":"text"},{"type":"text","text":"and the "},{"identifier":"https:\/\/specifications.freedesktop.org\/icon-theme-spec\/latest\/","type":"reference","isActive":true},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The syntax of key files is described in detail in the","type":"text"},{"text":" ","type":"text"},{"type":"reference","overridingTitle":"Desktop Entry Specification","overridingTitleInlineContent":[{"text":"Desktop Entry Specification","type":"text"}],"isActive":true,"identifier":"https:\/\/specifications.freedesktop.org\/desktop-entry-spec\/latest\/"},{"type":"text","text":","},{"text":" ","type":"text"},{"text":"here is a quick summary: Key files consists of groups of key-value pairs, interspersed","type":"text"},{"type":"text","text":" "},{"text":"with comments.","type":"text"}]},{"type":"codeListing","syntax":"txt","code":["# this is just an example","# there can be comments before the first group","","[First Group]","","Name=Key File Example\\tthis value shows\\nescaping","","# localized strings are stored in multiple key-value pairs","Welcome=Hello","Welcome[de]=Hallo","Welcome[fr_FR]=Bonjour","Welcome[it]=Ciao","","[Another Group]","","Numbers=2;20;-200;0","","Booleans=true;false;true;true"]},{"type":"paragraph","inlineContent":[{"text":"Lines beginning with a ","type":"text"},{"code":"#","type":"codeVoice"},{"text":" and blank lines are considered comments.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Groups are started by a header line containing the group name enclosed"},{"type":"text","text":" "},{"text":"in ","type":"text"},{"type":"codeVoice","code":"["},{"text":" and ","type":"text"},{"code":"]","type":"codeVoice"},{"type":"text","text":", and ended implicitly by the start of the next group or"},{"text":" ","type":"text"},{"type":"text","text":"the end of the file. Each key-value pair must be contained in a group."}]},{"type":"paragraph","inlineContent":[{"text":"Key-value pairs generally have the form ","type":"text"},{"code":"key=value","type":"codeVoice"},{"text":", with the exception","type":"text"},{"type":"text","text":" "},{"type":"text","text":"of localized strings, which have the form "},{"code":"key[locale]=value","type":"codeVoice"},{"text":", with a","type":"text"},{"text":" ","type":"text"},{"text":"locale identifier of the form ","type":"text"},{"type":"codeVoice","code":"lang_COUNTRY"},{"text":"MODIFIER`` where ","type":"text"},{"code":"COUNTRY","type":"codeVoice"},{"text":" ","type":"text"},{"type":"text","text":"and `MODIFIER` are optional. As a special case, the locale `C` is associated"},{"type":"text","text":" "},{"text":"with the untranslated pair `key=value` (since GLib 2.84). Space before and","type":"text"},{"text":" ","type":"text"},{"text":"after the `=` character is ignored. Newline, tab, carriage return and","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"backslash characters in value are escaped as `\\n`, `\\t`, `\\r`, and `\\\\`,"},{"text":" ","type":"text"},{"text":"respectively. To preserve leading spaces in values, these can also be escaped","type":"text"},{"type":"text","text":" "},{"text":"as `\\s`.","type":"text"}]},{"inlineContent":[{"text":"Key files can store strings (possibly with localized variants), integers,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"booleans and lists of these. Lists are separated by a separator character,"},{"text":" ","type":"text"},{"type":"text","text":"typically "},{"type":"codeVoice","code":";"},{"text":" or ","type":"text"},{"type":"codeVoice","code":","},{"text":". To use the list separator character in a value in","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"a list, it has to be escaped by prefixing it with a backslash."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This syntax is obviously inspired by the .ini files commonly met"},{"text":" ","type":"text"},{"text":"on Windows, but there are some important differences:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":".ini files use the "},{"type":"codeVoice","code":";"},{"type":"text","text":" character to begin comments,"},{"text":" ","type":"text"},{"text":"key files use the ","type":"text"},{"code":"#","type":"codeVoice"},{"text":" character.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Key files do not allow for ungrouped keys meaning only"},{"type":"text","text":" "},{"type":"text","text":"comments can precede the first group."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Key files are always encoded in UTF-8."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Key and Group names are case-sensitive. For example, a group called"},{"text":" ","type":"text"},{"type":"codeVoice","code":"[GROUP]"},{"text":" is a different from ","type":"text"},{"type":"codeVoice","code":"[group]"},{"text":".","type":"text"}]}]},{"content":[{"inlineContent":[{"text":".ini files don’t have a strongly typed boolean entry type,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"they only have "},{"type":"codeVoice","code":"GetProfileInt()"},{"type":"text","text":". In key files, only"},{"type":"text","text":" "},{"code":"true","type":"codeVoice"},{"type":"text","text":" and "},{"type":"codeVoice","code":"false"},{"text":" (in lower case) are allowed.","type":"text"}],"type":"paragraph"}]}]},{"inlineContent":[{"type":"text","text":"Note that in contrast to the"},{"type":"text","text":" "},{"overridingTitle":"Desktop Entry Specification","overridingTitleInlineContent":[{"text":"Desktop Entry Specification","type":"text"}],"identifier":"https:\/\/specifications.freedesktop.org\/desktop-entry-spec\/latest\/","isActive":true,"type":"reference"},{"type":"text","text":","},{"text":" ","type":"text"},{"type":"text","text":"groups in key files may contain the same key multiple times; the last entry wins."},{"type":"text","text":" "},{"type":"text","text":"Key files may also contain multiple groups with the same name; they are merged"},{"type":"text","text":" "},{"type":"text","text":"together. Another difference is that keys and group names in key files are not"},{"type":"text","text":" "},{"type":"text","text":"restricted to ASCII characters."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Here is an example of loading a key file and reading a value:"}]},{"syntax":"c","code":["`g_autoptr(GError)` error = NULL;","`g_autoptr(GKeyFile)` key_file = g_key_file_new ();","","if (!g_key_file_load_from_file (key_file, \"key-file.ini\", flags, &error))","  {","    if (!g_error_matches (error, G_FILE_ERROR, G_FILE_ERROR_NOENT))","      g_warning (\"Error loading key file: `s`\", error->message);","    return;","  }","","g_autofree gchar *val = g_key_file_get_string (key_file, \"Group Name\", \"SomeKey\", &error);","if (val == NULL &&","    !g_error_matches (error, G_KEY_FILE_ERROR, G_KEY_FILE_ERROR_KEY_NOT_FOUND))","  {","    g_warning (\"Error finding key in key file: `s`\", error->message);","    return;","  }","else if (val == NULL)","  {","    \/\/ Fall back to a default value.","    val = g_strdup (\"default-value\");","  }"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"Here is an example of creating and saving a key file:","type":"text"}]},{"type":"codeListing","syntax":"c","code":["`g_autoptr(GKeyFile)` key_file = g_key_file_new ();","const gchar *val = …;","`g_autoptr(GError)` error = NULL;","","g_key_file_set_string (key_file, \"Group Name\", \"SomeKey\", val);","","\/\/ Save as a file.","if (!g_key_file_save_to_file (key_file, \"key-file.ini\", &error))","  {","    g_warning (\"Error saving key file: `s`\", error->message);","    return;","  }","","\/\/ Or store to a GBytes for use elsewhere.","gsize data_len;","g_autofree guint8 *data = (guint8 *) g_key_file_to_data (key_file, &data_len, &error);","if (data == NULL)","  {","    g_warning (\"Error saving key file: `s`\", error->message);","    return;","  }","`g_autoptr(GBytes)` bytes = g_bytes_new_take (g_steal_pointer (&data), data_len);"]},{"inlineContent":[{"text":"The ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/KeyFile","isActive":true},{"type":"text","text":" type acts as a reference-counted owner of an underlying "},{"code":"GKeyFile","type":"codeVoice"},{"text":" instance.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"It provides the methods that can operate on this data type through "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/KeyFileProtocol","type":"reference","isActive":true},{"type":"text","text":" conformance."},{"text":" ","type":"text"},{"type":"text","text":"Use "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/KeyFile"},{"type":"text","text":" as a strong reference or owner of a "},{"type":"codeVoice","code":"GKeyFile"},{"type":"text","text":" instance."}],"type":"paragraph"},{"type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Use "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/KeyFileRef","isActive":true,"type":"reference"},{"text":" (instead of ","type":"text"},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/KeyFile","type":"reference"},{"text":") for a lightweight Swift reference to an underlying ","type":"text"},{"type":"codeVoice","code":"GKeyFile"},{"text":" instance.","type":"text"}]}],"style":"note","name":"Note"}],"kind":"content"}],"relationshipsSections":[{"kind":"relationships","title":"Conforms To","type":"conformsTo","identifiers":["doc:\/\/GLib\/documentation\/GLib\/KeyFileProtocol","doc:\/\/GLib\/documentation\/GLib\/PointerWrapper"]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/KeyFile"},"kind":"symbol","variants":[{"paths":["\/documentation\/glib\/keyfile"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://GLib/documentation/GLib/KeyFile/init(retainingOpaquePointer:)":{"url":"\/documentation\/glib\/keyfile\/init(retainingopaquepointer:)","fragments":[{"text":"init","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"retainingOpaquePointer"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:s13OpaquePointerV","text":"OpaquePointer","kind":"typeIdentifier"},{"text":")","kind":"text"}],"title":"init(retainingOpaquePointer:)","identifier":"doc:\/\/GLib\/documentation\/GLib\/KeyFile\/init(retainingOpaquePointer:)","type":"topic","abstract":[{"type":"text","text":"Unsafe untyped, retaining initialiser."},{"type":"text","text":" "},{"type":"strong","inlineContent":[{"text":"Do not use unless you know the underlying data type the pointer points to conforms to ","type":"text"},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/KeyFileProtocol","type":"reference"},{"type":"text","text":"."}]}],"role":"symbol","kind":"symbol"},"doc://GLib/documentation/GLib/KeyFile/KeyFileProtocol-Implementations":{"url":"\/documentation\/glib\/keyfile\/keyfileprotocol-implementations","role":"collectionGroup","type":"topic","kind":"article","identifier":"doc:\/\/GLib\/documentation\/GLib\/KeyFile\/KeyFileProtocol-Implementations","title":"KeyFileProtocol Implementations","abstract":[]},"doc://GLib/documentation/GLib/KeyFileRef":{"url":"\/documentation\/glib\/keyfileref","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"KeyFileRef","kind":"identifier"}],"title":"KeyFileRef","identifier":"doc:\/\/GLib\/documentation\/GLib\/KeyFileRef","type":"topic","abstract":[{"code":"GKeyFile","type":"codeVoice"},{"type":"text","text":" parses .ini-like config files."}],"role":"symbol","kind":"symbol","navigatorTitle":[{"text":"KeyFileRef","kind":"identifier"}]},"https://specifications.freedesktop.org/icon-theme-spec/latest/":{"type":"link","titleInlineContent":[{"type":"text","text":"Icon Theme Specification"}],"url":"https:\/\/specifications.freedesktop.org\/icon-theme-spec\/latest\/","identifier":"https:\/\/specifications.freedesktop.org\/icon-theme-spec\/latest\/","title":"Icon Theme Specification"},"doc://GLib/documentation/GLib":{"kind":"symbol","role":"collection","abstract":[],"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","type":"topic","url":"\/documentation\/glib"},"doc://GLib/documentation/GLib/PointerWrapper":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/PointerWrapper","kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"PointerWrapper"}],"role":"symbol","abstract":[{"type":"text","text":"Protocol for GLib types that wrap pointers."}],"title":"PointerWrapper","fragments":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"PointerWrapper"}],"url":"\/documentation\/glib\/pointerwrapper","type":"topic"},"doc://GLib/documentation/GLib/KeyFile/init(_:)-1hpxa":{"url":