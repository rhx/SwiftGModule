{"sections":[],"kind":"symbol","schemaVersion":{"major":0,"minor":3,"patch":0},"topicSections":[{"title":"Initializers","generated":true,"anchor":"Initializers","identifiers":["doc:\/\/GLib\/documentation\/GLib\/KeyFileRef\/init()","doc:\/\/GLib\/documentation\/GLib\/KeyFileRef\/init(_:)-5cs5o","doc:\/\/GLib\/documentation\/GLib\/KeyFileRef\/init(_:)-766bl","doc:\/\/GLib\/documentation\/GLib\/KeyFileRef\/init(_:)-776w8","doc:\/\/GLib\/documentation\/GLib\/KeyFileRef\/init(_:)-7qdi8","doc:\/\/GLib\/documentation\/GLib\/KeyFileRef\/init(_:)-935ll","doc:\/\/GLib\/documentation\/GLib\/KeyFileRef\/init(cPointer:)","doc:\/\/GLib\/documentation\/GLib\/KeyFileRef\/init(constPointer:)","doc:\/\/GLib\/documentation\/GLib\/KeyFileRef\/init(gconstpointer:)","doc:\/\/GLib\/documentation\/GLib\/KeyFileRef\/init(gpointer:)","doc:\/\/GLib\/documentation\/GLib\/KeyFileRef\/init(mutating:)","doc:\/\/GLib\/documentation\/GLib\/KeyFileRef\/init(opaquePointer:)"]},{"generated":true,"title":"Instance Properties","identifiers":["doc:\/\/GLib\/documentation\/GLib\/KeyFileRef\/ptr"],"anchor":"Instance-Properties"},{"anchor":"Default-Implementations","identifiers":["doc:\/\/GLib\/documentation\/GLib\/KeyFileRef\/KeyFileProtocol-Implementations","doc:\/\/GLib\/documentation\/GLib\/KeyFileRef\/PointerWrapper-Implementations"],"generated":true,"title":"Default Implementations"}],"relationshipsSections":[{"identifiers":["doc:\/\/GLib\/documentation\/GLib\/KeyFileProtocol","doc:\/\/GLib\/documentation\/GLib\/PointerWrapper"],"type":"conformsTo","kind":"relationships","title":"Conforms To"}],"metadata":{"symbolKind":"struct","modules":[{"name":"GLib"}],"role":"symbol","roleHeading":"Structure","externalID":"s:4GLib10KeyFileRefV","navigatorTitle":[{"kind":"identifier","text":"KeyFileRef"}],"fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"kind":"identifier","text":"KeyFileRef"}],"title":"KeyFileRef"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/keyfileref"]}],"abstract":[{"code":"GKeyFile","type":"codeVoice"},{"type":"text","text":" parses .ini-like config files."}],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/KeyFileRef","interfaceLanguage":"swift"},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"KeyFileRef"}]}]},{"kind":"content","content":[{"level":2,"text":"Overview","type":"heading","anchor":"overview"},{"inlineContent":[{"type":"codeVoice","code":"GKeyFile"},{"text":" lets you parse, edit or create files containing groups of","type":"text"},{"type":"text","text":" "},{"text":"key-value pairs, which we call ‘key files’ for lack of a better name.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Several freedesktop.org specifications use key files. For example, the"},{"type":"text","text":" "},{"identifier":"https:\/\/specifications.freedesktop.org\/desktop-entry-spec\/latest\/","isActive":true,"type":"reference"},{"type":"text","text":" "},{"type":"text","text":"and the "},{"isActive":true,"type":"reference","identifier":"https:\/\/specifications.freedesktop.org\/icon-theme-spec\/latest\/"},{"type":"text","text":"."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The syntax of key files is described in detail in the","type":"text"},{"type":"text","text":" "},{"overridingTitleInlineContent":[{"text":"Desktop Entry Specification","type":"text"}],"isActive":true,"type":"reference","overridingTitle":"Desktop Entry Specification","identifier":"https:\/\/specifications.freedesktop.org\/desktop-entry-spec\/latest\/"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"here is a quick summary: Key files consists of groups of key-value pairs, interspersed"},{"text":" ","type":"text"},{"type":"text","text":"with comments."}]},{"type":"codeListing","syntax":"txt","code":["# this is just an example","# there can be comments before the first group","","[First Group]","","Name=Key File Example\\tthis value shows\\nescaping","","# localized strings are stored in multiple key-value pairs","Welcome=Hello","Welcome[de]=Hallo","Welcome[fr_FR]=Bonjour","Welcome[it]=Ciao","","[Another Group]","","Numbers=2;20;-200;0","","Booleans=true;false;true;true"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Lines beginning with a "},{"code":"#","type":"codeVoice"},{"text":" and blank lines are considered comments.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Groups are started by a header line containing the group name enclosed"},{"text":" ","type":"text"},{"type":"text","text":"in "},{"code":"[","type":"codeVoice"},{"type":"text","text":" and "},{"code":"]","type":"codeVoice"},{"type":"text","text":", and ended implicitly by the start of the next group or"},{"type":"text","text":" "},{"type":"text","text":"the end of the file. Each key-value pair must be contained in a group."}]},{"type":"paragraph","inlineContent":[{"text":"Key-value pairs generally have the form ","type":"text"},{"type":"codeVoice","code":"key=value"},{"type":"text","text":", with the exception"},{"type":"text","text":" "},{"type":"text","text":"of localized strings, which have the form "},{"code":"key[locale]=value","type":"codeVoice"},{"type":"text","text":", with a"},{"type":"text","text":" "},{"type":"text","text":"locale identifier of the form "},{"type":"codeVoice","code":"lang_COUNTRY"},{"type":"text","text":"MODIFIER`` where "},{"type":"codeVoice","code":"COUNTRY"},{"text":" ","type":"text"},{"type":"text","text":"and `MODIFIER` are optional. As a special case, the locale `C` is associated"},{"text":" ","type":"text"},{"text":"with the untranslated pair `key=value` (since GLib 2.84). Space before and","type":"text"},{"type":"text","text":" "},{"text":"after the `=` character is ignored. Newline, tab, carriage return and","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"backslash characters in value are escaped as `\\n`, `\\t`, `\\r`, and `\\\\`,"},{"text":" ","type":"text"},{"type":"text","text":"respectively. To preserve leading spaces in values, these can also be escaped"},{"text":" ","type":"text"},{"type":"text","text":"as `\\s`."}]},{"inlineContent":[{"text":"Key files can store strings (possibly with localized variants), integers,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"booleans and lists of these. Lists are separated by a separator character,"},{"text":" ","type":"text"},{"type":"text","text":"typically "},{"code":";","type":"codeVoice"},{"text":" or ","type":"text"},{"code":",","type":"codeVoice"},{"text":". To use the list separator character in a value in","type":"text"},{"type":"text","text":" "},{"type":"text","text":"a list, it has to be escaped by prefixing it with a backslash."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"This syntax is obviously inspired by the .ini files commonly met","type":"text"},{"text":" ","type":"text"},{"text":"on Windows, but there are some important differences:","type":"text"}]},{"items":[{"content":[{"inlineContent":[{"type":"text","text":".ini files use the "},{"code":";","type":"codeVoice"},{"type":"text","text":" character to begin comments,"},{"type":"text","text":" "},{"type":"text","text":"key files use the "},{"type":"codeVoice","code":"#"},{"type":"text","text":" character."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Key files do not allow for ungrouped keys meaning only"},{"type":"text","text":" "},{"type":"text","text":"comments can precede the first group."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Key files are always encoded in UTF-8."}]}]},{"content":[{"inlineContent":[{"text":"Key and Group names are case-sensitive. For example, a group called","type":"text"},{"text":" ","type":"text"},{"code":"[GROUP]","type":"codeVoice"},{"type":"text","text":" is a different from "},{"code":"[group]","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":".ini files don’t have a strongly typed boolean entry type,"},{"type":"text","text":" "},{"type":"text","text":"they only have "},{"type":"codeVoice","code":"GetProfileInt()"},{"type":"text","text":". In key files, only"},{"text":" ","type":"text"},{"type":"codeVoice","code":"true"},{"type":"text","text":" and "},{"type":"codeVoice","code":"false"},{"text":" (in lower case) are allowed.","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"text":"Note that in contrast to the","type":"text"},{"type":"text","text":" "},{"isActive":true,"overridingTitle":"Desktop Entry Specification","type":"reference","overridingTitleInlineContent":[{"text":"Desktop Entry Specification","type":"text"}],"identifier":"https:\/\/specifications.freedesktop.org\/desktop-entry-spec\/latest\/"},{"text":",","type":"text"},{"text":" ","type":"text"},{"text":"groups in key files may contain the same key multiple times; the last entry wins.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Key files may also contain multiple groups with the same name; they are merged"},{"text":" ","type":"text"},{"type":"text","text":"together. Another difference is that keys and group names in key files are not"},{"type":"text","text":" "},{"type":"text","text":"restricted to ASCII characters."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Here is an example of loading a key file and reading a value:"}]},{"type":"codeListing","code":["`g_autoptr(GError)` error = NULL;","`g_autoptr(GKeyFile)` key_file = g_key_file_new ();","","if (!g_key_file_load_from_file (key_file, \"key-file.ini\", flags, &error))","  {","    if (!g_error_matches (error, G_FILE_ERROR, G_FILE_ERROR_NOENT))","      g_warning (\"Error loading key file: `s`\", error->message);","    return;","  }","","g_autofree gchar *val = g_key_file_get_string (key_file, \"Group Name\", \"SomeKey\", &error);","if (val == NULL &&","    !g_error_matches (error, G_KEY_FILE_ERROR, G_KEY_FILE_ERROR_KEY_NOT_FOUND))","  {","    g_warning (\"Error finding key in key file: `s`\", error->message);","    return;","  }","else if (val == NULL)","  {","    \/\/ Fall back to a default value.","    val = g_strdup (\"default-value\");","  }"],"syntax":"c"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Here is an example of creating and saving a key file:"}]},{"type":"codeListing","syntax":"c","code":["`g_autoptr(GKeyFile)` key_file = g_key_file_new ();","const gchar *val = …;","`g_autoptr(GError)` error = NULL;","","g_key_file_set_string (key_file, \"Group Name\", \"SomeKey\", val);","","\/\/ Save as a file.","if (!g_key_file_save_to_file (key_file, \"key-file.ini\", &error))","  {","    g_warning (\"Error saving key file: `s`\", error->message);","    return;","  }","","\/\/ Or store to a GBytes for use elsewhere.","gsize data_len;","g_autofree guint8 *data = (guint8 *) g_key_file_to_data (key_file, &data_len, &error);","if (data == NULL)","  {","    g_warning (\"Error saving key file: `s`\", error->message);","    return;","  }","`g_autoptr(GBytes)` bytes = g_bytes_new_take (g_steal_pointer (&data), data_len);"]},{"inlineContent":[{"text":"The ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/KeyFileRef","isActive":true},{"text":" type acts as a lightweight Swift reference to an underlying ","type":"text"},{"code":"GKeyFile","type":"codeVoice"},{"text":" instance.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"It exposes methods that can operate on this data type through "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/KeyFileProtocol"},{"type":"text","text":" conformance."},{"type":"text","text":" "},{"text":"Use ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/KeyFileRef"},{"type":"text","text":" only as an "},{"code":"unowned","type":"codeVoice"},{"text":" reference to an existing ","type":"text"},{"code":"GKeyFile","type":"codeVoice"},{"text":" instance.","type":"text"}],"type":"paragraph"},{"content":[{"type":"paragraph","inlineContent":[{"text":"Use ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/KeyFile","isActive":true},{"type":"text","text":" (instead of "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/KeyFileRef","type":"reference","isActive":true},{"type":"text","text":") if you want to use Automatic Reference Counting for memory management of the underlying "},{"type":"codeVoice","code":"GKeyFile"},{"type":"text","text":" instance."}]}],"style":"note","type":"aside","name":"Note"}]}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"references":{"doc://GLib/documentation/GLib/KeyFileRef/KeyFileProtocol-Implementations":{"role":"collectionGroup","type":"topic","kind":"article","abstract":[],"identifier":"doc:\/\/GLib\/documentation\/GLib\/KeyFileRef\/KeyFileProtocol-Implementations","url":"\/documentation\/glib\/keyfileref\/keyfileprotocol-implementations","title":"KeyFileProtocol Implementations"},"doc://GLib/documentation/GLib/KeyFileRef/init(constPointer:)":{"kind":"symbol","fragments":[{"text":"init","kind":"identifier"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"T"},{"kind":"text","text":">("},{"text":"constPointer","kind":"externalParam"},{"kind":"text","text":": "},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","text":"T"},{"text":">)","kind":"text"}],"title":"init(constPointer:)","identifier":"doc:\/\/GLib\/documentation\/GLib\/KeyFileRef\/init(constPointer:)","url":"\/documentation\/glib\/keyfileref\/init(constpointer:)","role":"symbol","abstract":[{"te