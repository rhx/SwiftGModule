{"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/LOG_DOMAIN"},"abstract":[{"type":"text","text":"Libraries should define this so that any messages"},{"type":"text","text":" "},{"type":"text","text":"which they log can be differentiated from messages from other"},{"type":"text","text":" "},{"text":"libraries and application code. But be careful not to define","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"it in any public header files."}],"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"symbol","variants":[{"paths":["\/documentation\/glib\/log_domain"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"symbolKind":"var","externalID":"s:4GLib10LOG_DOMAINSivp","fragments":[{"text":"let","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"LOG_DOMAIN"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"}],"platforms":[],"title":"LOG_DOMAIN","roleHeading":"Global Variable","modules":[{"name":"GLib"}],"role":"symbol"},"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"let"},{"text":" ","kind":"text"},{"kind":"identifier","text":"LOG_DOMAIN"},{"text":": ","kind":"text"},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"anchor":"discussion","text":"Discussion","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Log domains must be unique, and it is recommended that they are the"},{"text":" ","type":"text"},{"type":"text","text":"application or library name, optionally followed by a hyphen and a sub-domain"},{"text":" ","type":"text"},{"text":"name. For example, ","type":"text"},{"type":"codeVoice","code":"bloatpad"},{"text":" or ","type":"text"},{"type":"codeVoice","code":"bloatpad-io"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"text":"If undefined, it defaults to the default ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":" (or ","type":"text"},{"code":"\"\"","type":"codeVoice"},{"type":"text","text":") log domain; this is"},{"text":" ","type":"text"},{"text":"not advisable, as it cannot be filtered against using the ","type":"text"},{"code":"G_MESSAGES_DEBUG","type":"codeVoice"},{"text":" ","type":"text"},{"text":"environment variable.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"For example, GTK uses this in its ","type":"text"},{"type":"codeVoice","code":"Makefile.am"},{"text":":","type":"text"}]},{"type":"codeListing","code":["AM_CPPFLAGS = -DG_LOG_DOMAIN=\\\"Gtk\\\""],"syntax":null},{"type":"paragraph","inlineContent":[{"type":"text","text":"Applications can choose to leave it as the default "},{"type":"codeVoice","code":"nil"},{"text":" (or ","type":"text"},{"code":"\"\"","type":"codeVoice"},{"type":"text","text":")"},{"text":" ","type":"text"},{"type":"text","text":"domain. However, defining the domain offers the same advantages as"},{"text":" ","type":"text"},{"type":"text","text":"above."}]}]}],"sections":[],"references":{"doc://GLib/documentation/GLib/LOG_DOMAIN":{"url":"\/documentation\/glib\/log_domain","kind":"symbol","abstract":[{"type":"text","text":"Libraries should define this so that any messages"},{"type":"text","text":" "},{"type":"text","text":"which they log can be differentiated from messages from other"},{"text":" ","type":"text"},{"type":"text","text":"libraries and application code. But be careful not to define"},{"type":"text","text":" "},{"text":"it in any public header files.","type":"text"}],"role":"symbol","type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib\/LOG_DOMAIN","deprecated":true,"fragments":[{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"LOG_DOMAIN"},{"text":": ","kind":"text"},{"text":"Int","preciseIdentifier":"s:Si","kind"