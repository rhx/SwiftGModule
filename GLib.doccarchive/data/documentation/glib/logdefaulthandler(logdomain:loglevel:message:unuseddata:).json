text","text":"prints a new-line character after the message, so one does not need to be"},{"text":" ","type":"text"},{"text":"manually included in ","type":"text"},{"code":"message","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The behavior of this log handler can be influenced by a number of"},{"type":"text","text":" "},{"type":"text","text":"environment variables:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"code":"G_MESSAGES_PREFIXED","type":"codeVoice"},{"type":"text","text":": A "},{"code":":","type":"codeVoice"},{"type":"text","text":"-separated list of log levels for which"},{"text":" ","type":"text"},{"text":"messages should be prefixed by the program name and PID of the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"application."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"G_MESSAGES_DEBUG","type":"codeVoice"},{"text":": A space-separated list of log domains for","type":"text"},{"type":"text","text":" "},{"type":"text","text":"which debug and informational messages are printed. By default"},{"type":"text","text":" "},{"type":"text","text":"these messages are not printed. If you need to set the allowed"},{"text":" ","type":"text"},{"text":"domains at runtime, use [func","type":"text"},{"type":"codeVoice","code":"GLib.log_writer_default_set_debug_domains"},{"type":"text","text":"]."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"DEBUG_INVOCATION","type":"codeVoice"},{"text":": If set to ","type":"text"},{"code":"1","type":"codeVoice"},{"type":"text","text":", this is equivalent to"},{"text":" ","type":"text"},{"code":"G_MESSAGES_DEBUG=all","type":"codeVoice"},{"type":"text","text":". "},{"type":"codeVoice","code":"DEBUG_INVOCATION"},{"type":"text","text":" is a standard environment"},{"text":" ","type":"text"},{"text":"variable set by systemd to prompt debug output. (Since: 2.84)","t