{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/logDomain"},"kind":"symbol","metadata":{"role":"symbol","roleHeading":"Global Variable","externalID":"s:4GLib9logDomainSivp","symbolKind":"var","title":"logDomain","modules":[{"name":"GLib"}],"fragments":[{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"logDomain","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"}]},"abstract":[{"type":"text","text":"Defines the log domain. See "},{"type":"reference","identifier":"#log-domains","isActive":true},{"type":"text","text":"."}],"sections":[],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"variants":[{"paths":["\/documentation\/glib\/logdomain"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"minor":3,"major":0,"patch":0},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"let","kind":"keyword"},{"kind":"text","text":" "},{"text":"logDomain","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"}]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Discussion","type":"heading","level":2,"anchor":"discussion"},{"inlineContent":[{"type":"text","text":"Libraries should define this so that any messages"},{"text":" ","type":"text"},{"type":"text","text":"which they log can be differentiated from messages from other"},{"type":"text","text":" "},{"text":"libraries and application code. But be careful not to define","type":"text"},{"text":" ","type":"text"},{"text":"it in any public header files.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Log domains must be unique, and it is recommended that they are the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"application or library name, optionally followed by a hyphen and a sub-domain"},{"type":"text","text":" "},{"text":"name. For example, ","type":"text"},{"type":"codeVoice","code":"bloatpad"},{"text":" or ","type":"text"},{"type":"codeVoice","code":"bloatpad-io"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If undefined, it defaults to the default "},{"type":"codeVoice","code":"nil"},{"text":" (or ","type":"text"},{"code":"\"\"","type":"codeVoice"},{"type":"text","text":") log domain; this is"},{"type":"text","text":" "},{"type":"text","text":"not advisable, as it cannot be filtered against using the "},{"code":"G_MESSAGES_DEBUG","type":"codeVoice"},{"text":" ","type":"text"},{"type":"text","text":"environment variable."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"For example, GTK uses this in its "},{"type":"codeVoice","code":"Makefile.am"},{"type":"text","text":":"}],"type":"paragraph"},{"type":"codeListing","syntax":null,"code":["AM_CPPFLAGS = -DG_LOG_DOMAIN=\\\"Gtk\\\""]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Applications can choose to leave it as the default "},{"type":"codeVoice","code":"nil"},{"text":" (or ","type":"text"},{"code":"\"\"","type":"codeVoice"},{"text":")","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"domain. However, defining the domain offers the same advantages as"},{"text":" ","type":"text"},{"type":"text","text":"above."}]}]}],"references":{"doc://GLib/documentation/GLib/logDomain":{"abstract":[{"type":"text","text":"Defines the log domain. See "},{"identifier":"#log-domains","isActive":true,"type":"reference"},{"type":"text","text":"."}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/logDomain","kind":"symbol","title":"logDomain","url":"\/documentation\/glib\/logdomain","type":"topic","role":"symbol","fragments":[{"text":"let","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"logDomain"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"}]},"doc://GLib/documentation/GLib":{"kind":"symbol","role":"collection","abstract":[],"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","type":"topic","url":"\/documentation\/glib"},"#log-domains":{"identifier":"#log-domains","title":"Log Domains","url":"#log-domains","titleInlineContent":[{"type":"text","text":"Log Domains"}],"type":"link"}}}