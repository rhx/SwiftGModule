{"sections":[],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"kind":"symbol","schemaVersion":{"minor":3,"patch":0,"major":0},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/LogWriterFunc"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/logwriterfunc"]}],"metadata":{"role":"symbol","fragments":[{"kind":"keyword","text":"typealias"},{"text":" ","kind":"text"},{"kind":"identifier","text":"LogWriterFunc"}],"roleHeading":"Type Alias","externalID":"s:4GLib13LogWriterFunca","symbolKind":"typealias","navigatorTitle":[{"kind":"identifier","text":"LogWriterFunc"}],"modules":[{"name":"GLib"}],"title":"LogWriterFunc"},"abstract":[{"type":"text","text":"Writer function for log entries. A log entry is a collection of one or more"},{"text":" ","type":"text"},{"code":"GLogFields","type":"codeVoice"},{"type":"text","text":", using the standard "},{"isActive":true,"identifier":"https:\/\/www.freedesktop.org\/software\/systemd\/man\/systemd.journal-fields.html","type":"reference"},{"text":".","type":"text"},{"type":"text","text":" "},{"text":"See ","type":"text"},{"code":"g_log_structured()","type":"codeVoice"},{"type":"text","text":" for more information."}],"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"typealias"},{"text":" ","kind":"text"},{"kind":"identifier","text":"LogWriterFunc"},{"text":" = ","kind":"text"},{"text":"GLogWriterFunc","preciseIdentifier":"c:@T@GLogWriterFunc","kind":"typeIdentifier"}],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"content","content":[{"anchor":"discussion","level":2,"text":"Discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Writer functions must ignore fields which they do not recognise, unless they"},{"text":" ","type":"text"},{"type":"text","text":"can write arbitrary binary output, as field values may be arbitrary binary."}]},{"type":"paragraph","inlineContent":[{"code":"logLevel","type":"codeVoice"},{"type":"text","text":" is guaranteed to be included in "},{"code":"fields","type":"codeVoice"},{"type":"text","text":" as the "},{"type":"codeVoice","code":"PRIORITY"},{"type":"text","text":" field,"},{"type":"text","text":" "},{"type":"text","text":"but is provided separately for convenience of deciding whether or where to"},{"type":"text","text":" "},{"text":"output the log entry.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Writer functions should return ","type":"text"},{"code":"handled","type":"codeVoice"},{"type":"text","text":" if they handled the log"},{"type":"text","text":" "},{"text":"message successfully or if they deliberately ignored it. If there was an","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"error handling the message (for example, if the writer function is meant to"},{"text":" ","type":"text"},{"type":"text","text":"send messages to a remote logging server and there is a network error), it"},{"text":" ","type":"text"},{"type":"text","text":"should return "},{"code":"unhandled","type":"codeVoice"},{"text":". This allows writer functions to be","type":"text"},{"type":"text","text":" "},{"type":"text","text":"chained and fall back to simpler handlers in case of failure."}]}]}],"references":{"doc://GLib/documentation/GLib/LogWriterFunc":{"url":"\/documentation\/glib\/logwriterfunc","kind":"symbol","abstract":[{"text":"Writer function for log entries. A log entry is a collection of one or more","type":"text"},{"text":" ","type":"text"},{"code":"GLogFields","type":"codeVoice"},{"text":", using the standard ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/www.freedesktop.org\/software\/systemd\/man\/systemd.journal-fields.html"},{"text":".","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"See "},{"code":"g_log_structured()","type":"codeVoice"},{"type":"text","text":" for more information."}],"role":"symbol","navigatorT