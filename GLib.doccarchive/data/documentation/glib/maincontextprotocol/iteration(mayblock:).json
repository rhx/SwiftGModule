"role":"collection","abstract":[],"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","type":"topic","url":"\/documentation\/glib"},"doc://GLib/documentation/GLib/MainContextProtocol":{"navigatorTitle":[{"text":"MainContextProtocol","kind":"identifier"}],"url":"\/documentation\/glib\/maincontextprotocol","type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib\/MainContextProtocol","abstract":[{"type":"text","text":"The "},{"code":"GMainContext","type":"codeVoice"},{"type":"text","text":" struct is an opaque data"},{"type":"text","text":" "},{"text":"type representing a set of sources to be handled in a main loop.","type":"text"}],"fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"MainContextProtocol","kind":"identifier"}],"title":"MainContextProtocol","role":"symbol","kind":"symbol"}}}