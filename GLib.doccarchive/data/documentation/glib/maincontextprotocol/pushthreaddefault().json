],"abstract":[{"text":"The ","type":"text"},{"type":"codeVoice","code":"GMainLoop"},{"type":"text","text":" struct is an opaque data type"},{"type":"text","text":" "},{"type":"text","text":"representing the main event loop of a GLib or GTK application."}],"url":"\/documentation\/glib\/mainloop","type":"topic","navigatorTitle":[{"kind":"identifier","text":"MainLoop"}],"kind":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/MainLoop","title":"MainLoop"},"doc://GLib/documentation/GLib/MainContextProtocol":{"navigatorTitle":[{"text":"MainContextProtocol","kind":"identifier"}],"url":"\/documentation\/glib\/maincontextprotocol","type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib\/MainContextProtocol","abstract":[{"type":"text","text":"The "},{"code":"GMainContext","type":"codeVoice"},{"type":"text","text":" struct is an opaque data"},{"type":"text","text":" "},{"text":"type representing a set of sources to be handled in a main loop.","type":"text"}],"fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"MainContextProtocol","kind":"identifier"}],"title":"MainContextProtocol","role":"symbol","kind":"symbol"},"doc://GLib/documentation/GLib":{"kind":"symbol","role":"collection","abstract":[],"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","type":"topic","url":"\/documentation\/glib"}}}