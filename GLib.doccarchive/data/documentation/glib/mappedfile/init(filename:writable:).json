:"text"},{"type":"codeVoice","code":"writable"},{"type":"text","text":" is "},{"type":"codeVoice","code":"true"},{"text":", the mapped buffer may be modified, otherwise","type":"text"},{"type":"text","text":" "},{"type":"text","text":"it is an error to modify the mapped buffer. Modifications to the buffer"},{"type":"text","text":" "},{"type":"text","text":"are not visible to other processes mapping the same file, and are not"},{"type":"text","text":" "},{"type":"text","text":"written back to the file."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that modifications of the underlying file might affect the contents"},{"type":"text","text":" "},{"text":"of the ","type":"text"},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/MappedFile","type":"reference"},{"type":"text","text":". Therefore, mapping should only be used if the file"},{"text":" ","type":"text"},{"text":"will not be modified, or if all modifications of the file are done","type":"text"},{"type":"text","text":" "},{"text":"atomically (e.g. using ","type":"text"},{"type":"codeVoice","code":"g_file_set_contents()"},{"text":").","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"filename"},{"type":"text","text":" is the name of an empty, regular file, the function"},{"text":" ","type":"text"},{"type":"text","text":"will successfully return an empty "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/MappedFile","type":"reference","isActive":true},{"text":". In other cases of","type":"text"},{"type":"text","text":" "},{"type":"text","text":"size 0 (e.g. device files such as \/dev\/null), "},{"type":"codeVoice","code":"error"},{"text":" will be set","type":"text"},{"type":"text","text":" "},{"type":"text","text":"to the "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/FileError"},{"type":"text","text":" value "},{"code":"inval","type":"codeVoice"},{"text":".","type":"text"}]