,{"kind":"keyword","text":"throws"}]}],"kind":"declarations"},{"content":[{"text":"Discussion","type":"heading","level":2,"anchor":"discussion"},{"inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"writable"},{"type":"text","text":" is "},{"code":"true","type":"codeVoice"},{"text":", the mapped buffer may be modified, otherwise","type":"text"},{"text":" ","type":"text"},{"text":"it is an error to modify the mapped buffer. Modifications to the buffer","type":"text"},{"text":" ","type":"text"},{"text":"are not visible to other processes mapping the same file, and are not","type":"text"},{"text":" ","type":"text"},{"text":"written back to the file.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Note that modifications of the underlying file might affect the contents"},{"type":"text","text":" "},{"type":"text","text":"of the "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/MappedFile","type":"reference","isActive":true},{"text":". Therefore, mapping should only be used if the file","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"will not be modified, or if all modifications of the file are done"},{"type":"text","text":" "},{"type":"text","text":"atomically (e.g. using "},{"code":"g_file_set_contents()","type":"codeVoice"},{"text":").","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"code":"filename","type":"codeVoice"},{"type":"text","text":" is the name of an empty, regular file, the function"},{"type":"text","text":" "},{"text":"will successfully return an empty ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/MappedFile"},{"type":"text","text":". In other cases of"},{"type":"text","text":" "},{"type":"text","text":"size 0 (e.g. device files such as \/dev\/null), "},{"type":"codeVoice","code":"error"},{"text":" will be set","type":"text"},{"type":"text","text":" "},{"type":"text","text":"to the "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/FileError","type":"reference","isActive":true},{"text":" value ","type":"text"},{"code":"inval","type":"codeVoice"},{"text":".","type":"text"}]}],"kind":"content"}],"sections":[],"references":{"doc://GLib/documentation/GLib/MappedFileRef/init(filename:writable:)":{"title":"init(filename:writable:)","type":"topic","url":"\/documentation\/glib\/mappedfileref\/init(filename:writable:)","kind":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/MappedFileRef\/init(filename:writable:)","role":"symbol","fragments":[{"kind":"identifier","text":"init"},{"kind":"text","text":"("},{"kind":"externalParam","text":"filename"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"text":"<","kind":"text"},{"preciseIdentifier":"c:@T@gchar","kind":"typeIdentifier","text":"gchar"},{"text":">!, ","kind":"text"},{"kind":"externalParam","text":"writable"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"kind":"keyword","text":"throws"}],"abstract":[{"type":"text","text":"Maps a file into memory. On UNIX, this is using the "},{"code":"mmap()","type":"codeVoice"},{"type":"text","text":" function."}]},"doc://GLib/documentation/GLib/MappedFile":{"abstract":[{"type":"text","text":"The "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/MappedFile","isActive":true,"type":"reference"},{"text":" represents a file mapping created with","type":"text"},{"text":" ","type":"text"},{"code":"g_mapped_file_new()","type":"codeVoice"},{"text":". It has only private members and should","type":"text"},{"type":"text","text":" "},{"type":"text","text":"not be accessed directly."}],"type":"topic","kind":"symbol","title":"MappedFile","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"MappedFile","kind":"identifier"}],"navigatorTitle":[{"text":"MappedFile","kind":"identifier"}],"url":"\/do