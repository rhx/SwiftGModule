rivate members and should","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"not be accessed directly."}],"url":"\/documentation\/glib\/mappedfileref","navigatorTitle":[{"kind":"identifier","text":"MappedFileRef"}],"kind":"symbol","title":"MappedFileRef","type":"topic","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"kind":"identifier","text":"MappedFileRef"}]}}}