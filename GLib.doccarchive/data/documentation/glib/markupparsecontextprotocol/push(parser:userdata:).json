{"abstract":[{"type":"text","text":"Temporarily redirects markup data to a sub-parser."}],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/MarkupParseContextProtocol\/push(parser:userData:)","interfaceLanguage":"swift"},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"push","kind":"identifier"},{"kind":"text","text":"<"},{"text":"MarkupParserT","kind":"genericParameter"},{"text":">(","kind":"text"},{"kind":"externalParam","text":"parser"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"MarkupParserT"},{"kind":"text","text":", "},{"kind":"externalParam","text":"userData"},{"kind":"text","text":": "},{"preciseIdentifier":"c:@T@gpointer","text":"gpointer","kind":"typeIdentifier"},{"text":"? = nil) ","kind":"text"},{"text":"where","kind":"keyword"},{"text":" ","kind":"text"},{"text":"MarkupParserT","kind":"typeIdentifier"},{"kind":"text","text":" : "},{"text":"MarkupParserProtocol","identifier":"doc:\/\/GLib\/documentation\/GLib\/MarkupParserProtocol","kind":"typeIdentifier","preciseIdentifier":"s:4GLib20MarkupParserProtocolP"}]}]},{"content":[{"level":2,"text":"Discussion","anchor":"discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This function may only be called from the start_element handler of"},{"type":"text","text":" "},{"type":"text","text":"a "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/MarkupParser"},{"type":"text","text":". It must be matched with a corresponding call to"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_markup_parse_context_pop()"},{"text":" in the matching end_element handler","type":"text"},{"type":"text","text":" "},{"type":"text","text":"(except in the case that the parser aborts due to an error)."}]},{"inlineContent":[{"type":"text","text":"All tags, text and other data between the matching tags is"},{"type":"text","text":" "},{"text":"redirected to the subparser given by ","type":"text"},{"code":"parser","type":"codeVoice"},{"type":"text","text":". "},{"type":"codeVoice","code":"userData"},{"type":"text","text":" is used"},{"text":" ","type":"text"},{"type":"text","text":"as the user_data for that parser. "},{"type":"codeVoice","code":"userData"},{"type":"text","text":" is also passed to the"},{"text":" ","type":"text"},{"text":"error callback in the event that an error occurs. This includes","type":"text"},{"text":" ","type":"text"},{"text":"errors that occur in subparsers of the subparser.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The end tag matching the start tag for which this call was made is","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"handled by the previous parser (which is given its own user_data)"},{"text":" ","type":"text"},{"type":"text","text":"which is why "},{"type":"codeVoice","code":"g_markup_parse_context_pop()"},{"type":"text","text":" is provided to allow “one"},{"type":"text","text":" "},{"text":"last access” to the ","type":"text"},{"code":"userData","type":"codeVoice"},{"type":"text","text":" provided to this function. In the"},{"type":"text","text":" "},{"type":"text","text":"case of error, the "},{"code":"userData","type":"codeVoice"},{"text":" provided here is passed directly to","type":"text"},{"text":" ","type":"text"},{"text":"the error callback of the subparser and ","type":"text"},{"type":"codeVoice","code":"g_markup_parse_context_pop()"},{"type":"text","text":" "},{"type":"text","text":"should not be called. In either case, if "},{"code":"userData","type":"codeVoice"},{"type":"text","text":" was allocated"},{"type":"text","text":" "},{"type":"text","text":"then it ought to be freed from both of these locations."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This function is not intended to be directly called by users"},{"type":"text","text":" "},{"text":"interested in invoking subparsers. Instead, it is intended to be","type":"text"},{"type":"text","text":" "},{"type":"text","text":"used by the subparsers themselves to implement a higher-level"},{"type":"text","text":" "},{"text":"interface.","type":"text"}]},{"inlineContent":[{"type":"text","text":"As an example, see the following implementation of a simple"},{"text":" ","type":"text"},{"text":"parser that counts the number of tags encountered.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"(C Language Example):","type":"text"}]},{"type":"codeListing","syntax":"C","code":["typedef struct","{","  gint tag_count;","} CounterData;","","static void","counter_start_element (GMarkupParseContext  *context,","                       const gchar          *element_name,","                       const gchar         **attribute_names,","                       const gchar         **attribute_values,","                       gpointer              user_data,","                       GError              **error)","{","  CounterData *data = user_data;","","  data->tag_count++;","}","","static void","counter_error (GMarkupParseContext *context,","               GError              *error,","               gpointer             user_data)","{","  CounterData *data = user_data;","","  g_slice_free (CounterData, data);","}","","static GMarkupParser counter_subparser =","{","  counter_start_element,","  NULL,","  NULL,","  NULL,","  counter_error","};"]},{"inlineContent":[{"text":"In order to allow this parser to be easily used as a subparser, the","type":"text"},{"text":" ","type":"text"},{"text":"following interface is provided:","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"(C Language Example):"}],"type":"paragraph"},{"code":["void","start_counting (GMarkupParseContext *context)","{","  CounterData *data = g_slice_new (CounterData);","","  data->tag_count = 0;","  g_markup_parse_context_push (context, &counter_subparser, data);","}","","gint","end_counting (GMarkupParseContext *context)","{","  CounterData *data = g_markup_parse_context_pop (context);","  int result;","","  result = data->tag_count;","  g_slice_free (CounterData, data);","","  return result;","}"],"syntax":"C","type":"codeListing"},{"inlineContent":[{"type":"text","text":"The subparser would then be used as follows:"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"(C Language Example):"}]},{"type":"codeListing","syntax":"C","code":["static void start_element (context, element_name, ...)","{","  if (strcmp (element_name, \"count-these\") == 0)","    start_counting (context);","","  \/\/ else, handle other tags...","}","","static void end_element (context, element_name, ...)","{","  if (strcmp (element_name, \"count-these\") == 0)","    g_print (\"Counted %d tags\\n\", end_counting (context));","","  \/\/ else, handle other tags...","}"]}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/MarkupParseContextProtocol"]]},"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/markupparsecontextprotocol\/push(parser:userdata:)"]}],"metadata":{"role":"symbol","roleHeading":"Instance Method","extendedModule":"GLib","externalID":"s:4GLib26MarkupParseContextProtocolPAAE4push6parser8userDatayqd___SvSgtAA0b6ParserE0Rd__lF","title":"push(parser:userData:)","symbolKind":"method","modules":[{"name":"GLib"}],"fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"push","kind":"identifier"},{"text":"<","kind":"text"},{"kind":"genericParameter","text":"MarkupParserT"},{"kind":"text","text":">("},{"kind":"externalParam","text":"parser"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"MarkupParserT"},{"kind":"text","text":", "},{"text":"userData","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"c:@T@gpointer","kind":"typeIdentifier","text":"gpointer"},{"kind":"text","text":"?)"}]},"sections":[],"schemaVersion":{"minor":3,"major":0,"patch":0},"references":{"doc://GLib/documentation/GLib/MarkupParseContextProtocol/push(parser:userData:)":{"abstract":[{"type":"text","text":"Temporarily redirects markup data to a sub-parser."}],"url":"\/documentation\/glib\/markupparsecontextprotocol\/push(parser:userdata:)","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"push","kind":"identifier"},{"text":"<","kind":"text"},{"text":"MarkupParserT","kind":"genericParameter"},{"text":">(","kind":"text"},{"kind":"externalParam","text":"parser"},{"kind":"text","text":": "},{"text":"MarkupParserT","kind":"typeIdentifier"},{"kind":"text","text":", "},{"kind":"externalParam","text":"userData"},{"kind":"text","text":": "},{"text":"gpointer","preciseIdentifier":"c:@T@gpointer","kind":"typeIdentifier"},{"text":"?)","kind":"text"}],"kind":"symbol","type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib\/MarkupParseContextProtocol\/push(parser:userData:)","role":"symbol","title":"push(parser:userData:)"},"doc://GLib/documentation/GLib/MarkupParseContextProtocol":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/MarkupParseContextProtocol","role":"symbol","title":"MarkupParseContextProtocol","url":"\/documentation\/glib\/markupparsecontextprotocol","navigatorTitle":[{"kind":"identifier","text":"MarkupParseContextProtocol"}],"abstract":[{"text":"A parse context is used to parse a stream of bytes that","type":"text"},{"text":" ","type":"text"},{"text":"you expect to contain marked-up text.","type":"text"}],"fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"MarkupParseContextProtocol"}],"type":"topic","kind":"symbol"},"doc://GLib/documentation/GLib/MarkupParserProtocol":{"navigatorTitle":[{"kind":"identifier","text":"MarkupParserProtocol"}],"url":"\/documentation\/glib\/markupparserprotocol","kind":"symbol","title":"MarkupParserProtocol","type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib\/MarkupParserProtocol","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"text":"MarkupParserProtocol","kind":"identifier"}],"abstract":[{"text":"Any of the fields in ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/MarkupParser","isActive":true},{"type":"text","text":" can be "},{"type":"codeVoice","code":"nil"},{"text":", in which case they","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"will be ignored. Except for the "},{"code":"error","type":"codeVoice"},{"text":" function, any of these callbacks","type":"text"},{"type":"text","text":" "},{"text":"can set an error; in particular the ","type":"text"},{"type":"codeVoice","code":"unknownElement"},{"type":"text","text":","},{"type":"text","text":" "},{"code":"unknownAttribute","type":"codeVoice"},{"type":"text","text":", and "},{"type":"codeVoice","code":"invalidContent"},{"text":" ","type":"text"},{"type":"text","text":"errors are intended to be set from these callbacks. If you set an error"},{"text":" ","type":"text"},{"type":"text","text":"from a callback, "},{"type":"codeVoice","code":"g_markup_parse_context_parse()"},{"text":" will report that error","type":"text"},{"type":"text","text":" "},{"type":"text","text":"back to its caller."}],"role":"symbol"},"doc://GLib/documentation/GLib":{"kind":"symbol","role":"collection","abstract":[],"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","type":"topic","url":"\/documentation\/glib"},"doc://GLib/documentation/GLib/MarkupParser":{"kind":"symbol","role":"symbol","abstract":[{"text":"Any of the fields in ","type":"text"},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/MarkupParser","type":"reference"},{"text":" can be ","type":"text"},{"code":"nil","type":"codeVoice"},{"type":"text","text":", in which case they"},{"type":"text","text":" "},{"text":"will be ignored. Except for the ","type":"text"},{"type":"codeVoice","code":"error"},{"type":"text","text":" function, any of these callbacks"},{"text":" ","type":"text"},{"type":"text","text":"can set an error; in particular the "},{"code":"unknownElement","type":"codeVoice"},{"type":"text","text":","},{"type":"text","text":" "},{"code":"unknownAttribute","type":"codeVoice"},{"type":"text","text":", and "},{"type":"codeVoice","code":"invalidContent"},{"type":"text","text":" "},{"text":"errors are intended to be set from these callbacks. If you set an error","type":"text"},{"type":"text","text":" "},{"text":"from a callback, ","type":"text"},{"code":"g_markup_parse_context_parse()","type":"codeVoice"},{"type":"text","text":" will report that error"},{"text":" ","type":"text"},{"text":"back to its caller.","type":"text"}],"url":"\/documentation\/glib\/markupparser","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"MarkupParser","kind":"identifier"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/MarkupParser","title":"MarkupParser","navigatorTitle":[{"text":"MarkupParser","kind":"identifier"}],"type":"topic"}}}