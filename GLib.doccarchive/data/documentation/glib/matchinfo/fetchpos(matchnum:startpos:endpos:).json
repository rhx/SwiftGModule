{"sections":[],"abstract":[{"type":"text","text":"Returns the start and end positions (in bytes) of a successfully matching"},{"type":"text","text":" "},{"type":"text","text":"capture parenthesis."}],"schemaVersion":{"minor":3,"major":0,"patch":0},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/MatchInfo","doc:\/\/GLib\/documentation\/GLib\/MatchInfo\/MatchInfoProtocol-Implementations"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"fetchPos"},{"text":"(","kind":"text"},{"text":"matchNum","kind":"externalParam"},{"kind":"text","text":": "},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"},{"kind":"text","text":", "},{"text":"startPos","kind":"externalParam"},{"kind":"text","text":": "},{"text":"UnsafeMutablePointer","kind":"typeIdentifier","preciseIdentifier":"s:Sp"},{"text":"<","kind":"text"},{"text":"gint","preciseIdentifier":"c:@T@gint","kind":"typeIdentifier"},{"text":">! = nil, ","kind":"text"},{"kind":"externalParam","text":"endPos"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"UnsafeMutablePointer","preciseIdentifier":"s:Sp"},{"kind":"text","text":"<"},{"preciseIdentifier":"c:@T@gint","text":"gint","kind":"typeIdentifier"},{"kind":"text","text":">! = nil) -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"}],"platforms":["macOS"]}]},{"kind":"content","content":[{"type":"heading","anchor":"discussion","level":2,"text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Valid values for "},{"type":"codeVoice","code":"matchNum"},{"type":"text","text":" are "},{"code":"0","type":"codeVoice"},{"type":"text","text":" for the full text of the match,"},{"type":"text","text":" "},{"code":"1","type":"codeVoice"},{"type":"text","text":" for the first paren set, "},{"type":"codeVoice","code":"2"},{"type":"text","text":" for the second, and so on."}]},{"inlineContent":[{"type":"text","text":"As "},{"type":"codeVoice","code":"endPos"},{"text":" is set to the byte after the final byte of the match (on success),","type":"text"},{"type":"text","text":" "},{"text":"the length of the match can be calculated as ","type":"text"},{"type":"codeVoice","code":"end_pos - start_pos"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"As a best practice, initialize "},{"code":"startPos","type":"codeVoice"},{"type":"text","text":" and "},{"type":"codeVoice","code":"endPos"},{"text":" to identifiable","type":"text"},{"text":" ","type":"text"},{"text":"values, such as ","type":"text"},{"code":"G_MAXINT","type":"codeVoice"},{"text":", so that you can test if","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_match_info_fetch_pos()"},{"text":" actually changed the value for a given","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"capture parenthesis."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The parameter ","type":"text"},{"code":"matchNum","type":"codeVoice"},{"type":"text","text":" corresponds to a matched capture parenthesis. The"},{"type":"text","text":" "},{"text":"actual value you use for ","type":"text"},{"type":"codeVoice","code":"matchNum"},{"type":"text","text":" depends on the method used to generate"},{"type":"text","text":" "},{"type":"codeVoice","code":"matchInfo"},{"text":". The following sections describe those methods.","type":"text"}]},{"anchor":"Methods-Using-Non-deterministic-Finite-Automata-Matching","type":"heading","text":"Methods Using Non-deterministic Finite Automata Matching","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"The methods [method"},{"type":"codeVoice","code":"GLib.Regex.match"},{"text":"] and [method","type":"text"},{"type":"codeVoice","code":"GLib.Regex.match_full"},{"type":"text","text":"]"},{"type":"text","text":" "},{"text":"return a [struct","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/MatchInfo","isActive":true},{"text":"] using traditional (greedy) pattern","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"matching, also known as"},{"text":" ","type":"text"},{"type":"reference","identifier":"https:\/\/en.wikipedia.org\/wiki\/Nondeterministic_finite_automaton","isActive":true},{"type":"text","text":" "},{"type":"text","text":"(NFA) matching. You pass the returned "},{"type":"codeVoice","code":"GMatchInfo"},{"text":" from these methods to","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_match_info_fetch_pos()"},{"type":"text","text":" to determine the start and end positions"},{"text":" ","type":"text"},{"type":"text","text":"of capture parentheses. The values for "},{"code":"matchNum","type":"codeVoice"},{"type":"text","text":" correspond to the capture"},{"text":" ","type":"text"},{"type":"text","text":"parentheses in order, with "},{"code":"0","type":"codeVoice"},{"type":"text","text":" corresponding to the entire matched string."}]},{"inlineContent":[{"type":"codeVoice","code":"matchNum"},{"text":" can refer to a capture parenthesis with no match. For example,","type":"text"},{"type":"text","text":" "},{"text":"the string ","type":"text"},{"code":"b","type":"codeVoice"},{"text":" matches against the pattern ","type":"text"},{"code":"(a)?b","type":"codeVoice"},{"type":"text","text":", but the capture"},{"text":" ","type":"text"},{"text":"parenthesis ","type":"text"},{"code":"(a)","type":"codeVoice"},{"text":" has no match. In this case, ","type":"text"},{"type":"codeVoice","code":"g_match_info_fetch_pos()"},{"type":"text","text":" "},{"type":"text","text":"returns true and sets "},{"type":"codeVoice","code":"startPos"},{"text":" and ","type":"text"},{"code":"endPos","type":"codeVoice"},{"text":" to ","type":"text"},{"code":"-1","type":"codeVoice"},{"type":"text","text":" when called with"},{"text":" ","type":"text"},{"type":"codeVoice","code":"match_num"},{"type":"text","text":" as "},{"type":"codeVoice","code":"1"},{"text":" (for ","type":"text"},{"type":"codeVoice","code":"(a)"},{"text":").","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"For an expanded example, a regex pattern is "},{"type":"codeVoice","code":"(a)?(.*?)the (.*)"},{"text":",","type":"text"},{"text":" ","type":"text"},{"text":"and a candidate string is ","type":"text"},{"type":"codeVoice","code":"glib regexes are the best"},{"type":"text","text":". In this scenario"},{"type":"text","text":" "},{"text":"there are four capture parentheses numbered 0–3: an implicit one","type":"text"},{"type":"text","text":" "},{"type":"text","text":"for the entire string, and three explicitly declared in the regex pattern."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Given this example, the following table describes the return values"},{"text":" ","type":"text"},{"text":"from ","type":"text"},{"type":"codeVoice","code":"g_match_info_fetch_pos()"},{"text":" for various values of ","type":"text"},{"type":"codeVoice","code":"matchNum"},{"type":"text","text":"."}]},{"rows":[[[{"inlineContent":[{"code":"match_num","type":"codeVoice"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"Contents","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Return value"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Returned "},{"type":"codeVoice","code":"start_pos"}]}],[{"inlineContent":[{"text":"Returned ","type":"text"},{"code":"end_pos","type":"codeVoice"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"text":"0","type":"text"}]}],[{"inlineContent":[{"type":"text","text":"Matches entire string"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"True"}],"type":"paragraph"}],[{"inlineContent":[{"text":"0","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"25","type":"text"}]}]],[[{"inlineContent":[{"type":"text","text":"1"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"Does not match first character","type":"text"}]}],[{"inlineContent":[{"type":"text","text":"True"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"-1"}]}],[{"inlineContent":[{"type":"text","text":"-1"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"2"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"All text before "},{"type":"codeVoice","code":"the "}]}],[{"inlineContent":[{"type":"text","text":"True"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"0","type":"text"}]}],[{"inlineContent":[{"text":"17","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"3"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"All text after ","type":"text"},{"code":"the ","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"True"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"21"}]}],[{"type":"paragraph","inlineContent":[{"text":"25","type":"text"}]}]],[[{"inlineContent":[{"text":"4","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Capture paren out of range","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"False"}]}],[{"inlineContent":[{"text":"Unchanged","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Unchanged","type":"text"}],"type":"paragraph"}]]],"header":"row","type":"table"},{"type":"paragraph","inlineContent":[{"text":"The following code sample and output implements this example.","type":"text"}]},{"type":"codeListing","syntax":"{ .c }","code":["`include` <glib.h>","","int","main (int argc, char *argv[])","{","  `g_autoptr(GError)` local_error = NULL;","  const char *regex_pattern = \"(a)?(.*?)the (.*)\";","  const char *test_string = \"glib regexes are the best\";","  `g_autoptr(GRegex)` regex = NULL;","","  regex = g_regex_new (regex_pattern,","                       G_REGEX_DEFAULT,","                       G_REGEX_MATCH_DEFAULT,","                       &local_error);","  if (regex == NULL)","    {","      g_printerr (\"Error creating regex: `s`\\n\", local_error->message);","      return 1;","    }","","  `g_autoptr(GMatchInfo)` match_info = NULL;","  g_regex_match (regex, test_string, G_REGEX_MATCH_DEFAULT, &match_info);","","  int n_matched_strings = g_match_info_get_match_count (match_info);","","  \/\/ Print header line","  g_print (\"match_num Contents                  Return value returned start_pos returned end_pos\\n\");","","  \/\/ Iterate over each capture paren, including one that is out of range as a demonstration.","  for (int match_num = 0; match_num <= n_matched_strings; match_num++)","    {","      gboolean found_match;","      g_autofree char *paren_string = NULL;","      int start_pos = G_MAXINT;","      int end_pos = G_MAXINT;","","      found_match = g_match_info_fetch_pos (match_info,","                                            match_num,","                                            &start_pos,","                                            &end_pos);","","      \/\/ If no match, display N\/A as the found string.","      if (start_pos == G_MAXINT || start_pos == -1)","        paren_string = g_strdup (\"N\/A\");","      else","        paren_string = g_strndup (test_string + start_pos, end_pos - start_pos);","","      g_print (\"`-9d` `-25s` `-12d` `-18d` `d`\\n\", match_num, paren_string, found_match, start_pos, end_pos);","    }","","  return 0;","}"]},{"type":"codeListing","code":["match_num Contents                  Return value returned start_pos returned end_pos","0         glib regexes are the best 1            0                  25","1         N\/A                       1            -1                 -1","2         glib regexes are          1            0                  17","3         best                      1            21                 25","4         N\/A                       0            2147483647         2147483647"],"syntax":null},{"text":"Methods Using Deterministic Finite Automata Matching","anchor":"Methods-Using-Deterministic-Finite-Automata-Matching","level":2,"type":"heading"},{"inlineContent":[{"text":"The methods [method","type":"text"},{"code":"GLib.Regex.match_all","type":"codeVoice"},{"type":"text","text":"] and"},{"type":"text","text":" "},{"type":"text","text":"[method"},{"type":"codeVoice","code":"GLib.Regex.match_all_full"},{"text":"]","type":"text"},{"type":"text","text":" "},{"type":"text","text":"return a "},{"type":"codeVoice","code":"GMatchInfo"},{"type":"text","text":" using"},{"text":" ","type":"text"},{"type":"reference","identifier":"https:\/\/en.wikipedia.org\/wiki\/Deterministic_finite_automaton","isActive":true},{"type":"text","text":" "},{"type":"text","text":"(DFA) pattern matching. This algorithm detects overlapping matches. You pass"},{"text":" ","type":"text"},{"text":"the returned ","type":"text"},{"type":"codeVoice","code":"GMatchInfo"},{"type":"text","text":" from these methods to "},{"type":"codeVoice","code":"g_match_info_fetch_pos()"},{"text":" ","type":"text"},{"text":"to determine the start and end positions of each overlapping match. Use the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"method [method"},{"code":"GLib.MatchInfo.get_match_count","type":"codeVoice"},{"type":"text","text":"] to determine the number"},{"text":" ","type":"text"},{"type":"text","text":"of overlapping matches."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For example, a regex pattern is "},{"type":"codeVoice","code":"<.*>"},{"text":", and a candidate string is","type":"text"},{"type":"text","text":" "},{"code":"<a> <b> <c>","type":"codeVoice"},{"type":"text","text":". In this scenario there are three implicit capture"},{"type":"text","text":" "},{"text":"parentheses: one for the entire string, one for ","type":"text"},{"type":"codeVoice","code":"<a> <b>"},{"text":", and one for ","type":"text"},{"code":"<a>","type":"codeVoice"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Given this example, the following table describes the return values from"},{"text":" ","type":"text"},{"code":"g_match_info_fetch_pos()","type":"codeVoice"},{"type":"text","text":" for various values of "},{"code":"matchNum","type":"codeVoice"},{"text":".","type":"text"}]},{"type":"table","header":"row","rows":[[[{"inlineContent":[{"type":"codeVoice","code":"match_num"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Contents","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Return value","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Returned ","type":"text"},{"code":"start_pos","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Returned ","type":"text"},{"type":"codeVoice","code":"end_pos"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"text":"0","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Matches entire string","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"True","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"0","type":"text"}]}],[{"inlineContent":[{"text":"11","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"1"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Matches "},{"type":"codeVoice","code":"<a> <b>"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"True"}]}],[{"type":"paragraph","inlineContent":[{"text":"0","type":"text"}]}],[{"inlineContent":[{"text":"7","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"2"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Matches "},{"type":"codeVoice","code":"<a>"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"True","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"0","type":"text"}]}],[{"inlineContent":[{"text":"3","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"3","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Capture paren out of range"}]}],[{"type":"paragraph","inlineContent":[{"text":"False","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Unchanged","type":"text"}]}],[{"inlineContent":[{"text":"Unchanged","type":"text"}],"type":"paragraph"}]]]},{"inlineContent":[{"type":"text","text":"The following code sample and output implements this example."}],"type":"paragraph"},{"syntax":"{ .c }","code":["`include` <glib.h>","","int","main (int argc, char *argv[])","{","  `g_autoptr(GError)` local_error = NULL;","  const char *regex_pattern = \"<.*>\";","  const char *test_string = \"<a> <b> <c>\";","  `g_autoptr(GRegex)` regex = NULL;","","  regex = g_regex_new (regex_pattern,","                       G_REGEX_DEFAULT,","                       G_REGEX_MATCH_DEFAULT,","                       &local_error);","  if (regex == NULL)","    {","      g_printerr (\"Error creating regex: `s`\\n\", local_error->message);","      return -1;","    }","","  `g_autoptr(GMatchInfo)` match_info = NULL;","  g_regex_match_all (regex, test_string, G_REGEX_MATCH_DEFAULT, &match_info);","","  int n_matched_strings = g_match_info_get_match_count (match_info);","","  \/\/ Print header line","  g_print (\"match_num Contents                  Return value returned start_pos returned end_pos\\n\");","","  \/\/ Iterate over each capture paren, including one that is out of range as a demonstration.","  for (int match_num = 0; match_num <= n_matched_strings; match_num++)","    {","      gboolean found_match;","      g_autofree char *paren_string = NULL;","      int start_pos = G_MAXINT;","      int end_pos = G_MAXINT;","","      found_match = g_match_info_fetch_pos (match_info, match_num, &start_pos, &end_pos);","","      \/\/ If no match, display N\/A as the found string.","      if (start_pos == G_MAXINT || start_pos == -1)","        paren_string = g_strdup (\"N\/A\");","      else","        paren_string = g_strndup (test_string + start_pos, end_pos - start_pos);","","      g_print (\"`-9d` `-25s` `-12d` `-18d` `d`\\n\", match_num, paren_string, found_match, start_pos, end_pos);","    }","","  return 0;","}"],"type":"codeListing"},{"type":"codeListing","code":["match_num Contents                  Return value returned start_pos returned end_pos","0         <a> <b> <c>               1            0                  11","1         <a> <b>                   1            0                  7","2         <a>                       1            0                  3","3         N\/A                       0            2147483647         2147483647"],"syntax":null}]}],"metadata":{"modules":[{"name":"GLib"}],"symbolKind":"method","role":"symbol","roleHeading":"Instance Method","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"fetchPos"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"matchNum"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"startPos"},{"text":": ","kind":"text"},{"text":"UnsafeMutablePointer","preciseIdentifier":"s:Sp","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"text":"gint","kind":"typeIdentifier","preciseIdentifier":"c:@T@gint"},{"kind":"text","text":">!, "},{"text":"endPos","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer"},{"text":"<","kind":"text"},{"text":"gint","kind":"typeIdentifier","preciseIdentifier":"c:@T@gint"},{"text":">!) -> ","kind":"text"},{"text":"Bool","preciseIdentifier":"s:Sb","kind":"typeIdentifier"}],"title":"fetchPos(matchNum:startPos:endPos:)