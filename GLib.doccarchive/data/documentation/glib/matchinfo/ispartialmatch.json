{"sections":[],"abstract":[{"text":"Usually if the string passed to g_regex_match*() matches as far as","type":"text"},{"type":"text","text":" "},{"type":"text","text":"it goes, but is too short to match the entire pattern, "},{"type":"codeVoice","code":"false"},{"type":"text","text":" is"},{"text":" ","type":"text"},{"text":"returned. There are circumstances where it might be helpful to","type":"text"},{"type":"text","text":" "},{"type":"text","text":"distinguish this case from other cases in which there is no match."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"var","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"isPartialMatch"},{"kind":"text","text":": "},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"},{"text":" { ","kind":"text"},{"text":"get","kind":"keyword"},{"text":" }","kind":"text"}]}]},{"content":[{"type":"heading","text":"Discussion","level":2,"anchor":"discussion"},{"inlineContent":[{"type":"text","text":"Consider, for example, an application where a human is required to"},{"text":" ","type":"text"},{"type":"text","text":"type in data for a field with specific formatting requirements. An"},{"text":" ","type":"text"},{"type":"text","text":"example might be a date in the form ddmmmyy, defined by the pattern"},{"type":"text","text":" "},{"type":"codeVoice","code":"\"^\\d?\\d(jan|feb|mar|apr|may|jun|jul|aug|sep|oct|nov|dec)"},{"text":"\\d\\d$”.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"If the application sees the user’s keystrokes one by one, and can"},{"type":"text","text":" "},{"type":"text","text":"check that what has been typed so far is potentially valid, it is"},{"text":" ","type":"text"},{"type":"text","text":"able to raise an error as soon as a mistake is made."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"GRegex supports the concept of partial matching by means of the","type":"text"},{"text":" ","type":"text"},{"code":"partialSoft","type":"codeVoice"},{"type":"text","text":" and "},{"code":"partialHard","type":"codeVoice"},{"type":"text","text":" flags."},{"type":"text","text":" "},{"text":"When they are used, the return code for","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_regex_match()"},{"type":"text","text":" or "},{"code":"g_regex_match_full()","type":"codeVoice"},{"text":" is, as usual, ","type":"text"},{"code":"true","type":"codeVoice"},{"text":" ","type":"text"},{"text":"for a complete match, ","type":"text"},{"code":"false","type":"codeVoice"},{"text":" otherwise. But, when these functions","type":"text"},{"type":"text","text":" "},{"type":"text","text":"return "},{"type":"codeVoice","code":"false"},{"type":"text","text":", you can check if the match was partial calling"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_match_info_is_partial_match()"},{"type":"text","text":"."}]},{"inlineContent":[{"type":"text","text":"The difference between "},{"code":"partialSoft","type":"codeVoice"},{"type":"text","text":" and"},{"type":"text","text":" "},{"code":"partialHard","type":"codeVoice"},{"text":" is that when a partial match is encountered","type":"text"},{"type":"text","text":" "},{"text":"with ","type":"text"},{"type":"codeVoice","code":"partialSoft"},{"type":"text","text":", matching continues to search for a"},{"type":"text","text":" "},{"type":"text","text":"possible complete match, while with "},{"type":"codeVoice","code":"partialHard"},{"type":"text","text":" matching"},{"text":" ","type":"text"},{"text":"stops at the partial match.","type":"text"},{"text":" ","type":"text"},{"text":"When both ","type":"text"},{"type":"codeVoice","code":"partialSoft"},{"text":" and ","type":"text"},{"code":"partialHard","type":"codeVoice"},{"text":" ","type":"text"},{"text":"are set, the latter takes precedence.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"There were formerly some restrictions on the pattern for partial matching.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"The restrictions no longer apply."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"See "},{"code":"pcrepartial(3)","type":"codeVoice"},{"type":"text","text":" for more information on partial matching."}]}],"kind":"content"}],"metadata":{"title":"isPartialMatch","modules":[{"name":"GLib"}],"extendedModule":"GLib","roleHeading":"Instance Property","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"isPartialMatch","kind":"identifier"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sb","kind":"typeIdentifier","text":"Bool"}],"externalID":"s:4GLib17MatchInfoProtocolPAAE09isPartialB0Sbvp::SYNTHESIZED::s:4GLib9MatchInfoC","role":"symbol","symbolKind":"property"},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/MatchInfo","doc:\/\/GLib\/documentation\/GLib\/MatchInfo\/MatchInfoProtocol-Implementations"]]},"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/matchinfo\/ispartialmatch"]}],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/MatchInfo\/isPartialMatch","interfaceLanguage":"swift"},"references":{"doc://GLib/documentation/GLib/MatchInfo/MatchInfoProtocol-Implementations":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/MatchInfo\/MatchInfoProtocol-Implementations","role":"collectionGroup","title":"MatchInfoProtocol Implementations","url":"\/documentation\/glib\/matchinfo\/matchinfoprotocol-implementations","abstract":[],"type":"topic","kind":"article"},"doc://GLib/documentation/GLib":{"kind":"symbol","role":"collection","abstract":[],"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","type":"topic","url":"\/documentation\/glib"},"doc://GLib/documentation/GLib/MatchInfo/isPartialMatch":{"title":"isPartialMatch","type":"topic","kind":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/MatchInfo\/isPartialMatch","fragments":[{"kind":"keyword","text":"var"},{"text":" ","kind":"text"},{"kind":"identifier","text":"isPartialMatch"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"}],"url":"\/documentation\/glib\/matchinfo\/ispartialmatch","role":"symbol","abstract":[{"type":"text","text":"Usually if the string passed to g_regex_match*() matches as far as"},{"text":" ","type":"text"},{"text":"it goes, but is too short to match the entire pattern, ","type":"text"},{"type":"codeVoice","code":"false"},{"type":"text","text":" is"},{"text":" ","type":"text"},{"type":"text","text":"returned. There are circumstances where it might be helpful to"},{"type":"text","text":" "},{"type":"text","text":"distinguish this case from other cases in which there is no match."}]},"doc://GLib/documentation/GLib/MatchInfo":{"title":"MatchInfo","abstract":[{"type":"text","text":"A GMatchInfo is an opaque struct used to return information about"},{"type":"text","text":" "},{"type":"text","text":"matches."}],"type":"topic","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"MatchInfo","kind":"identifier"}],"url":"\/documentation\/glib\/matchinfo","navigatorTitle":[{"kind":"identifier","text":"MatchInfo"}],"kind":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/MatchInfo","role":"symbol"}}}