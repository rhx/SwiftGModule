{"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"fetchAll"},{"kind":"text","text":"() -> "},{"text":"UnsafeMutablePointer","preciseIdentifier":"s:Sp","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"text":"UnsafeMutablePointer","preciseIdentifier":"s:Sp","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar"},{"kind":"text","text":">?>!"}],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"anchor":"discussion","type":"heading","text":"Discussion","level":2},{"inlineContent":[{"type":"text","text":"If a sub pattern didn’t match anything (e.g. sub pattern 1, matching"},{"text":" ","type":"text"},{"type":"text","text":"“b” against “(a)?b”) then an empty string is inserted."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"If the last match was obtained using the DFA algorithm, that is using","type":"text"},{"text":" ","type":"text"},{"code":"g_regex_match_all()","type":"codeVoice"},{"text":" or ","type":"text"},{"code":"g_regex_match_all_full()","type":"codeVoice"},{"type":"text","text":", the retrieved"},{"text":" ","type":"text"},{"type":"text","text":"strings are not that matched by sets of parentheses but that of the"},{"type":"text","text":" "},{"text":"matched substring. Substrings are matched in reverse order of length,","type":"text"},{"text":" ","type":"text"},{"text":"so the first one is the longest match.","type":"text"}]},{"inlineContent":[{"type":"text","text":"The strings are fetched from the string passed to the match function,"},{"type":"text","text":" "},{"type":"text","text":"so you cannot call this function after freeing the string."}],"type":"paragraph"}]}],"kind":"symbol","sections":[],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/MatchInfoProtocol\/fetchAll()","interfaceLanguage":"swift"},"variants":[{"p