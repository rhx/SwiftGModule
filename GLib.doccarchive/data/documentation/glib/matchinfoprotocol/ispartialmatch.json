{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/MatchInfoProtocol\/isPartialMatch"},"metadata":{"modules":[{"name":"GLib"}],"fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"isPartialMatch"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"}],"roleHeading":"Instance Property","title":"isPartialMatch","extendedModule":"GLib","role":"symbol","externalID":"s:4GLib17MatchInfoProtocolPAAE09isPartialB0Sbvp","symbolKind":"property"},"variants":[{"paths":["\/documentation\/glib\/matchinfoprotocol\/ispartialmatch"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"sections":[],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/MatchInfoProtocol"]]},"kind":"symbol","abstract":[{"text":"Usually if the string passed to g_regex_match*() matches as far as","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"it goes, but is too short to match the entire pattern, "},{"type":"codeVoice","code":"false"},{"text":" is","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"returned. There are circumstances where it might be helpful to"},{"type":"text","text":" "},{"text":"distinguish this case from other cases in which there is no match.","type":"text"}],"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"text":"isPartialMatch","kind":"identifier"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"},{"text":" { ","kind":"text"},{"text":"get","kind":"keyword"},{"text":" }","kind":"text"}],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"content","content":[{"type":"heading","level":2,"anchor":"discussion","text":"Discussion"},{"inlineContent":[{"text":"Consider, for example, an application where a human is required to","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"type in data for a field with specific formatting requirements. An"},{"type":"text","text":" "},{"type":"text","text":"example might be a date in the form ddmmmyy, defined by the pattern"},{"text":" ","type":"text"},{"code":"\"^\\d?\\d(jan|feb|mar|apr|may|jun|jul|aug|sep|oct|nov|dec)","type":"codeVoice"},{"text":"\\d\\d$”.","type":"text"},{"type":"text","text":" "},{"text":"If the application sees the user’s keystrokes one by one, and can","type":"text"},{"type":"text","text":" "},{"type":"text","text":"check that what has been typed so far is potentially valid, it is"},{"type":"text","text":" "},{"text":"able to raise an error as soon as a mistake is made.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"GRegex supports the concept of partial matching by means of the","type":"text"},{"text":" ","type":"text"},{"code":"partialSoft","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"partialHard","type":"codeVoice"},{"text":" flags.","type":"text"},{"text":" ","type":"text"},{"text":"When they are used, the return code for","type":"text"},{"type":"text","text":" "},{"code":"g_regex_match()","type":"codeVoice"},{"text":" or ","type":"text"},{"type":"codeVoice","code":"g_regex_match_full()"},{"text":" is, as usual, ","type":"text"},{"type":"codeVoice","code":"true"},{"text":" ","type":"text"},{"type":"text","text":"for a complete match, "},{"code":"false","type":"codeVoice"},{"text":" otherwise. But, when these functions","type":"text"},{"text":" ","type":"text"},{"text":"return ","type":"text"},{"code":"false","type":"codeVoice"},{"type":"text","text":", you can check if the match was partial calling"},{"text":" ","type":"text"},{"code":"g_match_info_is_partial_match()","type":"codeVoice"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The difference between ","type":"text"},{"type":"codeVoice","code":"partialSoft"},{"text":" and","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"partialHard"},{"text":" is that when a partial match is encountered","type":"text"},{"type":"text","text":" "},{"text":"with ","type":"text"},{"type":"codeVoice","code":"partialSoft"},{"text":", matching continues to search for a","type":"text"},{"type":"text","text":" "},{"text":"possible complete match, while with ","type":"text"},{"code":"partialHard","type":"codeVoice"},{"type":"text","text":" matching"},{"text":" ","type":"text"},{"text":"stops at the partial match.","type":"text"},{"text":" ","type":"text"},{"text":"When both ","type":"text"},{"code":"partialSoft","type":"codeVoice"},{"type":"text","text":" and "},{"type":"codeVoice","code":"partialHard"},{"text":" ","type":"text"},{"type":"text","text":"are set, the latter takes precedence."}]},{"inlineContent":[{"type":"text","text":"There were formerly some restrictions on the pattern for partial matching."},{"text":" ","type":"text"},{"text":"The restrictions no longer apply.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"See "},{"type":"codeVoice","code":"pcrepartial(3)"},{"type":"text","text":" for more information on partial matching."}],"type":"paragraph"}]}],"references":{"doc://GLib/documentation/GLib/MatchInfoProtocol/isPartialMatch":{"title":"isPartialMatch","identifier":"doc:\/\/GLib\/documentation\/GLib\/MatchInfoProtocol\/isPartialMatch","url":"\/documentation\/glib\/matchinfoprotocol\/ispartialmatch","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"isPartialMatch"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"}],"kind":"symbol","type":"topic","role":"symbol","abstract":[{"type":"text","text":"Usually if the string passed to g_regex_match*() matches as far as"},{"text":" ","type":"text"},{"text":"it goes, but is too short to match the entire pattern, ","type":"text"},{"code":"false","type":"codeVoice"},{"text":" is","type":"text"},{"type":"text","text":" "},{"text":"returned. There are circumstances where it might be helpful to","type":"text"},{"type":"text","text":" "},{"text":"distinguish this case from other cases in which there is no match.","type":"text"}]},"doc://GLib/documentation/GLib/MatchInfoProtocol":{"title":"MatchInfoProtocol","navigatorTitle":[{"text":"MatchInfoProtocol","kind":"identifier"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/MatchInfoProtocol","kind":"symbol","url":"\/documentation\/glib\/matchinfoprotocol","role":"symbol","type":"topic","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"MatchInfoProtocol"}],"abstract":[{"text":"A GMatchInfo is an opaque struct used to return information about","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"matches."}]},"doc://GLib/documentation/GLib":{"kind":"symbol","role":"collection","abstract":[],"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","type":"topic","url":"\/documentation\/glib"}}}