{"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/MatchInfoRef","doc:\/\/GLib\/documentation\/GLib\/MatchInfoRef\/MatchInfoProtocol-Implementations"]]},"sections":[],"schemaVersion":{"minor":3,"patch":0,"major":0},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/matchinforef\/fetchpos(matchnum:startpos:endpos:)"]}],"kind":"symbol","identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/MatchInfoRef\/fetchPos(matchNum:startPos:endPos:)","interfaceLanguage":"swift"},"abstract":[{"text":"Returns the start and end positions (in bytes) of a successfully matching","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"capture parenthesis."}],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"fetchPos"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"matchNum"},{"kind":"text","text":": "},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"startPos","kind":"externalParam"},{"kind":"text","text":": "},{"text":"UnsafeMutablePointer","preciseIdentifier":"s:Sp","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"gint","preciseIdentifier":"c:@T@gint"},{"kind":"text","text":">! = nil, "},{"kind":"externalParam","text":"endPos"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer"},{"kind":"text","text":"<"},{"text":"gint","kind":"typeIdentifier","preciseIdentifier":"c:@T@gint"},{"text":">! = nil) -> ","kind":"text"},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"}]}],"kind":"declarations"},{"content":[{"level":2,"text":"Discussion","type":"heading","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Valid values for "},{"type":"codeVoice","code":"matchNum"},{"text":" are ","type":"text"},{"code":"0","type":"codeVoice"},{"text":" for the full text of the match,","type":"text"},{"text":" ","type":"text"},{"code":"1","type":"codeVoice"},{"type":"text","text":" for the first paren set, "},{"code":"2","type":"codeVoice"},{"type":"text","text":" for the second, and so on."}]},{"inlineContent":[{"type":"text","text":"As "},{"type":"codeVoice","code":"endPos"},{"text":" is set to the byte after the final byte of the match (on success),","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the length of the match can be calculated as "},{"code":"end_pos - start_pos","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"text":"As a best practice, initialize ","type":"text"},{"type":"codeVoice","code":"startPos"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"endPos"},{"text":" to identifiable","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"values, such as "},{"type":"codeVoice","code":"G_MAXINT"},{"text":", so that you can test if","type":"text"},{"text":" ","type":"text"},{"code":"g_match_info_fetch_pos()","type":"codeVoice"},{"type":"text","text":" actually changed the value for a given"},{"type":"text","text":" "},{"type":"text","text":"capture parenthesis."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The parameter ","type":"text"},{"code":"matchNum","type":"codeVoice"},{"text":" corresponds to a matched capture parenthesis. The","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"actual value you use for "},{"code":"matchNum","type":"codeVoice"},{"text":" depends on the method used to generate","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"matchInfo"},{"type":"text","text":". The following sections describe those methods."}]},{"text":"Methods Using Non-deterministic Finite Automata Matching","anchor":"Methods-Using-Non-deterministic-Finite-Automata-Matching","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"The methods [method"},{"type":"codeVoice","code":"GLib.Regex.match"},{"text":"] and [method","type":"text"},{"type":"codeVoice","code":"GLib.Regex.match_full"},{"type":"text","text":"]"},{"type":"text","text":" "},{"text":"return a [struct","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/MatchInfo"},{"type":"text","text":"] using traditional (greedy) pattern"},{"text":" ","type":"text"},{"text":"matching, also known as","type":"text"},{"type":"text","text":" "},{"identifier":"https:\/\/en.wikipedia.org\/wiki\/Nondeterministic_finite_automaton","type":"reference","isActive":true},{"text":" ","type":"text"},{"type":"text","text":"(NFA) matching. You pass the returned "},{"type":"codeVoice","code":"GMatchInfo"},{"text":" from these methods to","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_match_info_fetch_pos()"},{"type":"text","text":" to determine the start and end positions"},{"text":" ","type":"text"},{"text":"of capture parentheses. The values for ","type":"text"},{"type":"codeVoice","code":"matchNum"},{"text":" correspond to the capture","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"parentheses in order, with "},{"code":"0","type":"codeVoice"},{"type":"text","text":" corresponding to the entire matched string."}]},{"inlineContent":[{"type":"codeVoice","code":"matchNum"},{"type":"text","text":" can refer to a capture parenthesis with no match. For example,"},{"text":" ","type":"text"},{"type":"text","text":"the string "},{"type":"codeVoice","code":"b"},{"type":"text","text":" matches against the pattern "},{"code":"(a)?b","type":"codeVoice"},{"type":"text","text":", but the capture"},{"type":"text","text":" "},{"text":"parenthesis ","type":"text"},{"type":"codeVoice","code":"(a)"},{"type":"text","text":" has no match. In this case, "},{"type":"codeVoice","code":"g_match_info_fetch_pos()"},{"text":" ","type":"text"},{"type":"text","text":"returns true and sets "},{"type":"codeVoice","code":"startPos"},{"text":" and ","type":"text"},{"code":"endPos","type":"codeVoice"},{"type":"text","text":" to "},{"code":"-1","type":"codeVoice"},{"type":"text","text":" when called with"},{"type":"text","text":" "},{"type":"codeVoice","code":"match_num"},{"text":" as ","type":"text"},{"code":"1","type":"codeVoice"},{"type":"text","text":" (for "},{"code":"(a)","type":"codeVoice"},{"type":"text","text":")."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For an expanded example, a regex pattern is "},{"type":"codeVoice","code":"(a)?(.*?)the (.*)"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"and a candidate string is "},{"type":"codeVoice","code":"glib regexes are the best"},{"text":". In this scenario","type":"text"},{"type":"text","text":" "},{"text":"there are four capture parentheses numbered 0–3: an implicit one","type":"text"},{"type":"text","text":" "},{"type":"text","text":"for the entire string, and three explicitly declared in the regex pattern."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Given this example, the following table describes the return values"},{"text":" ","type":"text"},{"type":"text","text":"from "},{"type":"codeVoice","code":"g_match_info_fetch_pos()"},{"type":"text","text":" for various values of "},{"code":"matchNum","type":"codeVoice"},{"text":".","type":"text"}]},{"rows":[[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"match_num"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Contents"}]}],[{"type":"paragraph","inlineContent":[{"text":"Return value","type":"text"}]}],[{"inlineContent":[{"text":"Returned ","type":"text"},{"code":"start_pos","type":"codeVoice"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Returned "},{"type":"codeVoice","code":"end_pos"}]}]],[[{"inlineContent":[{"text":"0","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Matches entire string"}]}],[{"type":"paragraph","inlineContent":[{"text":"True","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"0"}]}],[{"inlineContent":[{"type":"text","text":"25"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"1"}]}],[{"type":"paragraph","inlineContent":[{"text":"Does not match first character","type":"text"}]}],[{"inlineContent":[{"type":"text","text":"True"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"-1"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"-1"}]}]],[[{"inlineContent":[{"text":"2","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"All text before "},{"code":"the ","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"text":"True","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"0","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"17","type":"text"}]}]],[[{"inlineContent":[{"text":"3","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"All text after "},{"type":"codeVoice","code":"the "}]}],[{"inlineContent":[{"type":"text","text":"True"}],"type":"paragraph"}],[{"inlineContent":[{"text":"21","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"25"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"4"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Capture paren out of range"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"False"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Unchanged"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Unchanged"}]}]]],"header":"row","type":"table"},{"inlineContent":[{"type":"text","text":"The following code sample and output implements this example."}],"type":"paragraph"},{"syntax":"{ .c }","code":["`include` <glib.h>","","int","main (int argc, char *argv[])","{","  `g_autoptr(GError)` local_error = NULL;","  const char *regex_pattern = \"(a)?(.*?)the (.*)\";","  const char *test_string = \"glib regexes are the best\";","  `g_autoptr(GRegex)` regex = NULL;","","  regex = g_regex_new (regex_pattern,","                       G_REGEX_DEFAULT,","                       G_REGEX_MATCH_DEFAULT,","                       &local_error);","  if (regex == NULL)","    {","      g_printerr (\"Error creating regex: `s`\\n\", local_error->message);","      return 1;","    }","","  `g_autoptr(GMatchInfo)` match_info = NULL;","  g_regex_match (regex, test_string, G_REGEX_MATCH_DEFAULT, &match_info);","","  int n_matched_strings = g_match_info_get_match_count (match_info);","","  \/\/ Print header line","  g_print (\"match_num Contents                  Return value returned start_pos returned end_pos\\n\");","","  \/\/ Iterate over each capture paren, including one that is out of range as a demonstration.","  for (int match_num = 0; match_num <= n_matched_strings; match_num++)","    {","      gboolean found_match;","      g_autofree char *paren_string = NULL;","      int start_pos = G_MAXINT;","      int end_pos = G_MAXINT;","","      found_match = g_match_info_fetch_pos (match_info,","                                            match_num,","                                            &start_pos,","                                            &end_pos);","","      \/\/ If no match, display N\/A as the found string.","      if (start_pos == G_MAXINT || start_pos == -1)","        paren_string = g_strdup (\"N\/A\");","      else","        paren_string = g_strndup (test_string + start_pos, end_pos - start_pos);","","      g_print (\"`-9d` `-25s` `-12d` `-18d` `d`\\n\", match_num, paren_string, found_match, start_pos, end_pos);","    }","","  return 0;","}"],"type":"codeListing"},{"syntax":null,"code":["match_num Contents                  Return value returned start_pos returned end_pos","0         glib regexes are the best 1            0                  25","1         N\/A                       1            -1                 -1","2         glib regexes are          1            0                  17","3         best                      1            21                 25","4         N\/A                       0            2147483647         2147483647"],"type":"codeListing"},{"anchor":"Methods-Using-Deterministic-Finite-Automata-Matching","type":"heading","level":2,"text":"Methods Using Deterministic Finite Automata Matching"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The methods [method"},{"code":"GLib.Regex.match_all","type":"codeVoice"},{"text":"] and","type":"text"},{"text":" ","type":"text"},{"text":"[method","type":"text"},{"type":"codeVoice","code":"GLib.Regex.match_all_full"},{"text":"]","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"return a "},{"type":"codeVoice","code":"GMatchInfo"},{"type":"text","text":" using"},{"type":"text","text":" "},{"isActive":true,"identifier":"https:\/\/en.wikipedia.org\/wiki\/Deterministic_finite_automaton","type":"reference"},{"type":"text","text":" "},{"type":"text","text":"(DFA) pattern matching. This algorithm detects overlapping matches. You pass"},{"type":"text","text":" "},{"text":"the returned ","type":"text"},{"code":"GMatchInfo","type":"codeVoice"},{"type":"text","text":" from these methods to "},{"type":"codeVoice","code":"g_match_info_fetch_pos()"},{"type":"text","text":" "},{"type":"text","text":"to determine the start and end positions of each overlapping match. Use the"},{"type":"text","text":" "},{"type":"text","text":"method [method"},{"type":"codeVoice","code":"GLib.MatchInfo.get_match_count"},{"type":"text","text":"] to determine the number"},{"text":" ","type":"text"},{"text":"of overlapping matches.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For example, a regex pattern is "},{"code":"<.*>","type":"codeVoice"},{"type":"text","text":", and a candidate string is"},{"type":"text","text":" "},{"code":"<a> <b> <c>","type":"codeVoice"},{"text":". In this scenario there are three implicit capture","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"parentheses: one for the entire string, one for "},{"code":"<a> <b>","type":"codeVoice"},{"text":", and one for ","type":"text"},{"type":"codeVoice","code":"<a>"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"text":"Given this example, the following table describes the return values from","type":"text"},{"text":" ","type":"text"},{"code":"g_match_info_fetch_pos()","type":"codeVoice"},{"type":"text","text":" for various values of "},{"type":"codeVoice","code":"matchNum"},{"type":"text","text":"."}]},{"type":"table","header":"row","rows":[[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"match_num"}]}],[{"inlineContent":[{"text":"Contents","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Return value"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Returned "},{"type":"codeVoice","code":"start_pos"}]}],[{"inlineContent":[{"text":"Returned ","type":"text"},{"type":"codeVoice","code":"end_pos"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"0"}]}],[{"inlineContent":[{"text":"Matches entire string","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"True"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"0"}]}],[{"inlineContent":[{"text":"11","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"1"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Matches ","type":"text"},{"type":"codeVoice","code":"<a> <b>"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"True"}]}],[{"inlineContent":[{"text":"0","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"7"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"2"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Matches "},{"code":"<a>","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"True"}]}],[{"inlineContent":[{"text":"0","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"3","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"3","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Capture paren out of range"}]}],[{"type":"paragraph","inlineContent":[{"text":"False","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Unchanged"}]}],[{"inlineContent":[{"type":"text","text":"Unchanged"}],"type":"paragraph"}]]]},{"inlineContent":[{"text":"The following code sample and output implements this example.","type":"text"}],"type":"paragraph"},{"code":["`include` <glib.h>","","int","main (int argc, char *argv[])","{","  `g_autoptr(GError)` local_error = NULL;","  const char *regex_pattern = \"<.*>\";","  const char *test_string = \"<a> <b> <c>\";","  `g_autoptr(GRegex)` regex = NULL;","","  regex = g_regex_new (regex_pattern,","                       G_REGEX_DEFAULT,","                       G_REGEX_MATCH_DEFAULT,","                       &local_error);","  if (regex == NULL)","    {","      g_printerr (\"Error creating regex: `s`\\n\", local_error->message);","      return -1;","    }","","  `g_autoptr(GMatchInfo)` match_info = NULL;","  g_regex_match_all (regex, test_string, G_REGEX_MATCH_DEFAULT, &match_info);","","  int n_matched_strings = g_match_info_get_match_count (match_info);","","  \/\/ Print header line","  g_print (\"match_num Contents                  Return value returned start_pos returned end_pos\\n\");","","  \/\/ Iterate over each capture paren, including one that is out of range as a demonstration.","  for (int match_num = 0; match_num <= n_matched_strings; match_num++)","    {","      gboolean found_match;","      g_autofree char *paren_string = NULL;","      int start_pos = G_MAXINT;","      int end_pos = G_MAXINT;","","      found_match = g_match_info_fetch_pos (match_info, match_num, &start_pos, &end_pos);","","      \/\/ If no match, display N\/A as the found string.","      if (start_pos == G_MAXINT || start_pos == -1)","        paren_string = g_strdup (\"N\/A\");","      else","        paren_string = g_strndup (test_string + start_pos, end_pos - start_pos);","","      g_print (\"`-9d` `-25s` `-12d` `-18d` `d`\\n\", match_num, paren_string, found_match, start_pos, end_pos);","    }","","  return 0;","}"],"type":"codeListing","syntax":"{ .c }"},{"code":["match_num Contents                  Return value returned start_pos returned end_pos","0         <a> <b> <c>               1            0                  11","1         <a> <b>                   1            0                  7","2         <a>                       1            0                  3","3         N\/A                       0            2147483647         2147483647"],"type":"codeListing","syntax":null}],"kind":"content"}],"metadata":{"title":"fetchPos(matchNum:startPos:endPos:)","symbolKind":"method","extendedModule":"GLib","roleHeading":"Instance Method","role":"symbol","modules":[{"name":"GLib"}],"externalID":"s:4GLib17MatchInfoProtocolPAAE8fetchPos8matchNum05startF003endF0SbSi_Spys5Int32VGSgAKtF::SYNTHESIZED::s:4GLib12MatchInfoRefV","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"fetchPos","kind":"identifier"},{"text":"(","kind":"text"},{"text":"matchNum","kind":"externalParam"},{"kind":"text","text":": "},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"kind":"text","text":", "},{"text":"startPos","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer"},{"kind":"text","