{"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/MatchInfoRef","doc:\/\/GLib\/documentation\/GLib\/MatchInfoRef\/MatchInfoProtocol-Implementations"]]},"sections":[],"metadata":{"roleHeading":"Instance Property","title":"isPartialMatch","externalID":"s:4GLib17MatchInfoProtocolPAAE09isPartialB0Sbvp::SYNTHESIZED::s:4GLib12MatchInfoRefV","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"text":"isPartialMatch","kind":"identifier"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"}],"extendedModule":"GLib","symbolKind":"property","modules":[{"name":"GLib"}],"role":"symbol"},"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/MatchInfoRef\/isPartialMatch","interfaceLanguage":"swift"},"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/matchinforef\/ispartialmatch"]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"var"},{"text":" ","kind":"text"},{"text":"isPartialMatch","kind":"identifier"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"},{"text":" { ","kind":"text"},{"kind":"keyword","text":"get"},{"text":" }","kind":"text"}],"platforms":["macOS"]}]},{"content":[{"text":"Discussion","type":"heading","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Consider, for example, an application where a human is required to"},{"type":"text","text":" "},{"type":"text","text":"type in data for a field with specific formatting requirements. An"},{"text":" ","type":"text"},{"text":"example might be a date in the form ddmmmyy, defined by the pattern","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"\"^\\d?\\d(jan|feb|mar|apr|may|jun|jul|aug|sep|oct|nov|dec)"},{"text":"\\d\\d$”.","type":"text"},{"type":"text","text":" "},{"text":"If the application sees the user’s keystrokes one by one, and can","type":"text"},{"type":"text","text":" "},{"type":"text","text":"check that what has been typed so far is potentially valid, it is"},{"type":"text","text":" "},{"text":"able to raise an error as soon as a mistake is made.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"GRegex supports the concept of partial matching by means of the"},{"text":" ","type":"text"},{"type":"codeVoice","code":"partialSoft"},{"text":" and ","type":"text"},{"code":"partialHard","type":"codeVoice"},{"type":"text","text":" flags."},{"text":" ","type":"text"},{"text":"When they are used, the return code for","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_regex_match()"},{"text":" or ","type":"text"},{"type":"codeVoice","code":"g_regex_match_full()"},{"text":" is, as usual, ","type":"text"},{"type":"codeVoice","code":"true"},{"text":" ","type":"text"},{"text":"for a complete match, ","type":"text"},{"type":"codeVoice","code":"false"},{"type":"text","text":" otherwise. But, when these functions"},{"type":"text","text":" "},{"type":"text","text":"return "},{"type":"codeVoice","code":"false"},{"type":"text","text":", you can check if the match was partial calling"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_match_info_is_partial_match()"},{"type":"text","text":"."}]},{"inlineContent":[{"type":"text","text":"The difference between "},{"code":"partialSoft","type":"codeVoice"},{"text":" and","type":"text"},{"text":" ","type":"text"},{"code":"partialHard","type":"codeVoice"},{"type":"text","text":" is that when a partial match is encountered"},{"type":"text","text":" "},{"text":"with ","type":"text"},{"type":"codeVoice","code":"partialSoft"},{"text":", matching continues to search for a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"possible complete match, while with "},{"type":"codeVoice","code":"partialHard"},{"text":" matching","type":"text"},{"type":"text","text":" "},{"type":"text","text":"stops at the partial match."},{"text":" ","type":"text"},{"text":"When both ","type":"text"},{"code":"partialSoft","type":"codeVoice"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"partialHard"},{"type":"text","text":" "},{"type":"text","text":"are set, the latter takes precedence."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"There were formerly some restrictions on the pattern for partial matching."},{"type":"text","text":" "},{"type":"text","text":"The restrictions no longer apply."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"See "},{"code":"pcrepartial(3)","type":"codeVoice"},{"text":" for more information on partial matching.","type":"text"}]}],"kind":"content"}],"schemaVersion":{"patch":0,"major":0,"minor":3},"abstract":[{"type":"text","text":"Usually if the string passed to g_regex_match*() matches as far as"},{"text":" ","type":"text"},{"text":"it goes, but is too short to match the entire pattern, ","type":"text"},{"type":"codeVoice","code":"false"},{"text":" is","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"returned. There are circumstances where it might be helpful to"},{"type":"text","text":" "},{"text":"distinguish this case from other cases in which there is no match.","type":"text"}],"references":{"doc://GLib/documentation/GLib/MatchInfoRef":{"url":"\/documentation\/glib\/matchinforef","type":"topic","navigatorTitle":[{"text":"MatchInfoRef","kind":"identifier"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/MatchInfoRef","kind":"symbol","title":"MatchInfoRef","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"MatchInfoRef"}],"abstract":[{"text":"A GMatchInfo is an opaque struct used to return information about","type":"text"},{"type":"text","text":" "},{"text":"matches.","type":"text"}],"role":"symbol"},"doc://GLib/documentation/GLib":{"kind":"symbol","role":"collection","abstract":[],"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","type":"topic","url":"\/documentation\/glib"},"doc://GLib/documentation/GLib/MatchInfoRef/isPartialMatch":{"title":"isPartialMatch","abstract":[{"text":"Usually if the string passed to g_regex_match*() matches as far as","type":"text"},{"type":"text","text":" "},{"text":"it goes, but is too short to match the entire pattern, ","type":"text"},{"code":"false","type":"codeVoice"},{"type":"text","text":" is"},{"type":"text","text":" "},{"type":"text","text":"returned. There are circumstances where it might be helpful to"},{"type":"text","text":" "},{"type":"text","text":"distinguish this case from other cases in which there is no match."}],"type":"topic","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"text":"isPartialMatch","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"}],"url":"\/documentation\/glib\/matchinforef\/ispartialmatch","kind":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/MatchInfoRef\/isPartialMatch","role":"symbol"},"doc://GLib/documentation/GLib/MatchInfoRef/MatchInfoProtocol-Implementations":{"url":"\/documentation\/glib\/matchinforef\/matchinfoprotocol-implementations","type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib\/MatchInfoRef\/MatchInfoProtocol-Implementations","kind":"article","title":"MatchInfoProtocol Implementations","abstract":[],"role":"collectionGroup"}}}