{"sections":[],"abstract":[{"type":"text","text":"A wrapper for the POSIX "},{"code":"open()","type":"codeVoice"},{"type":"text","text":" function. The "},{"type":"codeVoice","code":"open()"},{"text":" function is","type":"text"},{"type":"text","text":" "},{"text":"used to convert a pathname into a file descriptor.","type":"text"}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/open(filename:flags:mode:)"},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"open","kind":"identifier"},{"text":"(","kind":"text"},{"text":"filename","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SP","text":"UnsafePointer","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"preciseIdentifier":"c:@T@gchar","text":"gchar","kind":"typeIdentifier"},{"text":">!, ","kind":"text"},{"kind":"externalParam","text":"flags"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"mode"},{"kind":"text","text":": "},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":") -> ","kind":"text"},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"type":"heading","level":2,"anchor":"discussion","text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"On POSIX systems file descriptors are implemented by the operating"},{"type":"text","text":" "},{"type":"text","text":"system. On Windows, it’s the C library that implements "},{"type":"codeVoice","code":"open()"},{"text":" and","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"file descriptors. The actual Win32 API for opening files is quite"},{"type":"text","text":" "},{"text":"different, see MSDN documentation for ","type":"text"},{"type":"codeVoice","code":"CreateFile()"},{"type":"text","text":". The Win32 API"},{"type":"text","text":" "},{"text":"uses file handles, which are more randomish integers, not small","type":"text"},{"type":"text","text":" "},{"type":"text","text":"integers like file descriptors."}]},{"type":"paragraph","inlineContent":[{"text":"Because file descriptors are specific to the C library on Windows,","type":"text"},{"text":" ","type":"text"},{"text":"the file descriptor returned by this function makes sense only to","type":"text"},{"type":"text","text":" "},{"type":"text","text":"functions in the same C library. Thus if the GLib-using code uses a"},{"text":" ","type":"text"},{"type":"text","text":"different C library than GLib does, the file descriptor returned by"},{"text":" ","type":"text"},{"text":"this function cannot be passed to C library functions like ","type":"text"},{"type":"codeVoice","code":"write()"},{"type":"text","text":" "},{"text":"or ","type":"text"},{"type":"codeVoice","code":"read()"},{"text":".","type":"text"}]},{"inlineContent":[{"text":"See your C library manual for more details about ","type":"text"},{"code":"open()","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"}]}],"metadata":{"externalID":"s:4GLib4open8filename5flags4modeSiSPys4Int8VGSg_S2itF","roleHeading":"Function","symbolKind":"func","title":"open(filename:flags:mode:)","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"open","kind":"identifier"},{"text":"(","kind":"text"},{"text":"filename","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:SP","kind":"typeIdentifier","text":"UnsafePointer"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"gchar","preciseIdentifier":"c:@T@gchar"},{"text":">!, ","kind":"text"},{"kind":"externalParam","text":"flags"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"text":", ","kind":"tex