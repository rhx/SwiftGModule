{"schemaVersion":{"minor":3,"patch":0,"major":0},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"set","kind":"identifier"},{"kind":"text","text":"("},{"text":"strictPosix","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"},{"kind":"text","text":")"}],"languages":["swift"]}],"kind":"declarations"},{"content":[{"type":"heading","level":2,"anchor":"discussion","text":"Discussion"},{"inlineContent":[{"type":"text","text":"By default, this mode is disabled."}],"type":"paragraph"},{"inlineContent":[{"text":"In strict POSIX mode, the first non-argument parameter encountered","type":"text"},{"type":"text","text":" "},{"text":"(eg: filename) terminates argument processing.  Remaining arguments","type":"text"},{"type":"text","text":" "},{"text":"are treated as non-options and are not attempted to be parsed.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"If strict POSIX mode is disabled then parsing is done in the GNU way","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"where option arguments can be freely mixed with non-options."}]},{"type":"paragraph","inlineContent":[{"text":"As an example, consider “ls foo -l”.  With GNU style parsing, this","type":"text"},{"type":"text","text":" "},{"text":"will list “foo” in long mode.  In strict POSIX style, this will list","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the files named “foo” and “-l”."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"It may be useful to force strict POSIX mode when creating “verb"},{"text":" ","type":"text"},{"type":"text","text":"style” command line tools.  For example, the “gsettings” command line"},{"type":"text","text":" "},{"type":"text","text":"tool supports the global option “–schemadir” as well as many"},{"type":"text","text":" "},{"text":"subcommands (“get”, “set”, etc.) which each have their own set of","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"arguments.  Using strict POSIX mode will allow parsing the global"},{"type":"text","text":" "},{"text":"options up to the verb name while leaving the remaining options to be","type":"text"},{"text":" ","type":"text"},{"text":"parsed by the relevant subcommand (which can be determined by","type":"text"},{"type":"text","text":" "},{"type":"text","text":"examining the verb name, which should be present in argv[1] after"},{"type":"text","text":" "},{"text":"parsing).","type":"text"}]}],"kind":"content"}],"sections":[],"metadata":{"modules":[{"name":"GLib"}],"extendedModule":"GLib","role":"symbol","title":"set(strictPosix:)","roleHeading":"Instance Method","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"set","kind":"identifier"},{"kind":"text","text":"("},{"text":"strictPosix","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"},{"text":")","kind":"text"}],"externalID":"s:4GLib21OptionContextProtocolPAAE3set11strictPosixySb_tF","symbolKind":"method"},"abstract":[{"text":"Sets strict POSIX mode.","type":"text"}],"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/optioncontextprotocol\/set(strictposix:)"]}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/OptionContextProtocol"]]},"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/OptionContextProtocol\/set(strictPosix:)","interfaceLanguage":"swift"},"references":{"doc://GLib/documentation/GLib/OptionContextProtocol/set(strictPosix:)":{"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"set","kind":"identifier"},{"kind":"text","text":"("},{"text":"strictPosix","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"},{"text":")","kind":"text"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/OptionContextProtocol\/set(strictPosix:)","url":"\/documentation\/glib\/optioncontextprotocol\/set(strictposix:)","kind":"symbol","abstract":[{"text":"Sets strict POSIX mode.","type":"text"}],"title":"set(strictPosix:)","type":"topic","role":"symbol"},"doc://GLib/documentation/GLib/OptionContextProtocol":{"role":"symbol","kind":"symbol","abstract":[{"text":"A ","type":"text"},{"type":"codeVoice","code":"GOptionContext"},{"type":"text","text":" struct defines which options"},{"text":" ","type":"text"},{"type":"text","text":"are accepted by the commandline option parser. The struct has only private"},{"type":"text","text":" "},{"text":"fields and should not be directly accessed.","type":"text"}],"fragments":[{"kind":"keyword","text":"protocol"},{"text":" ","kind":"text"},{"text":"OptionContextProtocol","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"OptionContextProtocol"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/OptionContextProtocol","type":"topic","url":"\/documentation\/glib\/optioncontextprotocol","title":"OptionContextProtocol"},"doc://GLib/documentation/GLib":{"kind":"symbol","role":"collection","abstract":[],"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","type":"topic","url":"\/documentation\/glib"}}}