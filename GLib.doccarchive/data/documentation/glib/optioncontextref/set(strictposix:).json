{"sections":[],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/OptionContextRef","doc:\/\/GLib\/documentation\/GLib\/OptionContextRef\/OptionContextProtocol-Implementations"]]},"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/OptionContextRef\/set(strictPosix:)"},"schemaVersion":{"major":0,"minor":3,"patch":0},"variants":[{"paths":["\/documentation\/glib\/optioncontextref\/set(strictposix:)"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"title":"set(strictPosix:)","modules":[{"name":"GLib"}],"symbolKind":"method","roleHeading":"Instance Method","role":"symbol","extendedModule":"GLib","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"set"},{"text":"(","kind":"text"},{"text":"strictPosix","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"},{"text":")","kind":"text"}],"externalID":"s:4GLib21OptionContextProtocolPAAE3set11strictPosixySb_tF::SYNTHESIZED::s:4GLib16OptionContextRefV"},"abstract":[{"text":"Sets strict POSIX mode.","type":"text"}],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"set","kind":"identifier"},{"text":"(","kind":"text"},{"text":"strictPosix","kind":"externalParam"},{"kind":"text","text":": "},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"},{"kind":"text","text":")"}]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Discussion","type":"heading","anchor":"discussion","level":2},{"inlineContent":[{"text":"By default, this mode is disabled.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"In strict POSIX mode, the first non-argument parameter encountered"},{"text":" ","type":"text"},{"text":"(eg: filename) terminates argument processing.  Remaining arguments","type":"text"},{"type":"text","text":" "},{"type":"text","text":"are treated as non-options and are not attempted to be parsed."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If strict POSIX mode is disabled then parsing is done in the GNU way"},{"type":"text","text":" "},{"type":"text","text":"where option arguments can be freely mixed with non-options."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"As an example, consider “ls foo -l”.  With GNU style parsing, this"},{"text":" ","type":"text"},{"type":"text","text":"will list “foo” in long mode.  In strict POSIX style, this will list"},{"text":" ","type":"text"},{"type":"text","text":"the files named “foo” and “-l”."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"It may be useful to force strict POSIX mode when creating “verb","type":"text"},{"type":"text","text":" "},{"text":"style” command line tools.  For example, the “gsettings” command line","type":"text"},{"type":"text","text":" "},{"type":"text","text":"tool supports the global option “–schemadir” as well as many"},{"type":"text","text":" "},{"text":"subcommands (“get”, “set”, etc.) which each have their own set of","type":"text"},{"text":" ","type":"text"},{"text":"arguments.  Using strict POSIX mode will allow parsing the global","type":"text"},{"type":"text","text":" "},{"text":"options up to the verb name while leaving the remaining options to be","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"parsed by the relevant subcommand (which can be determined by"},{"text":" ","type":"text"},{"type":"text","text":"examining the verb name, which should be present in argv[1] after"},{"text":" ","type":"text"},{"text":"parsing).","type":"text"}]}]}],"references":{"doc://GLib/documentation/GLib/OptionContextRef":{"url":"\/documentation\/glib\/optioncontextref","abstract":[{"type":"text","text":"A "},{"type":"codeVoice","code":"GOptionContext"},{"text":" struct defines which options","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"are accepted by the commandline option parser. The struct has only private"},{"type":"text","text":" "},{"type":"text","text":"fields and should not be directly accessed."}],"kind":"symbol","type":"topic","role":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"OptionContextRef","kind":"identifier"}],"title":"OptionContextRef","identifier":"doc:\/\/GLib\/documentation\/GLib\/OptionContextRef","navigatorTitle":[{"kind":"identifier","text":"OptionContextRef"}]},"doc://GLib/documentation/GLib/OptionContextRef/set(strictPosix:)":{"url":"\/documentation\/glib\/optioncontextref\/set(strictposix:)","kind":"symbol","role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"set"},{"text":"(","kind":"text"},{"text":"strictPosix","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Bool","preciseIdentifier":"s:Sb","kind":"typeIdentifier"},{"kind":"text","text":")"}],"type":"topic","title":"set(strictPosix:)","identifier":"doc:\/\/GLib\/documentation\/GLib\/OptionContextRef\/set(strictPosix:)","abstract":[{"text":"Sets strict POSIX mode.","type":"text"}]},"doc://GLib/documentation/GLib/OptionContextRef/OptionContextProtocol-Implementations":{"abstract":[],"kind":"article","title":"OptionContextProtocol Implementations","role":"collectionGroup","identifier":"doc:\/\/GLib\/documentation\/GLib\/OptionContextRef\/OptionContextProtocol-Implementations","type":"topic","url":"\/documentation\/glib\/optioncontextref\/optioncontextprotocol-implementations"},"doc://GLib/documentation/GLib":{"kind":"symbol","role":"collection","abstract":[],"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","type":"topic","url":"\/documentation\/glib"}}}