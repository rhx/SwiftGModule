{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/pathisabsolute(filename:)"]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"symbol","sections":[],"abstract":[{"type":"text","text":"Returns "},{"code":"true","type":"codeVoice"},{"text":" if the given ","type":"text"},{"code":"fileName","type":"codeVoice"},{"text":" is an absolute file name.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Note that this is a somewhat vague concept on Windows."}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/pathIsAbsolute(fileName:)"},"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"pathIsAbsolute","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"fileName"},{"kind":"text","text":": "},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"kind":"text","text":"<"},{"text":"gchar","preciseIdentifier":"c:@T@gchar","kind":"typeIdentifier"},{"text":">!) -> ","kind":"text"},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"}],"platforms":["macOS"]}],"kind":"declarations"},{"content":[{"anchor":"discussion","level":2,"text":"Discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"On POSIX systems, an absolute file name is well-defined. It always"},{"type":"text","text":" "},{"type":"text","text":"starts from the single root directory. For example “\/usr\/local”."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"On Windows, the concepts of current drive and drive-specific"},{"text":" ","type":"text"},{"type":"text","text":"current directory introduce vagueness. This function interprets as"},{"type":"text","text":" "},{"text":"an absolute file name one that either begins with a directory","type":"text"},{"text":" ","type":"text"},{"text":"separator such as “\\Users\\tml” or begins with the root on a drive,","type":"text"},{"text":" ","type":"text"},{"text":"for example “C:\\Windows”. The first case also includes UNC paths","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"such as “\\\\myserver\\docs\\foo”. In all cases, either slashes or"},{"type":"text","text":" "},{"text":"backslashes are accepted.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that a file name relative to the current drive root does not"},{"type":"text","text":" "},{"text":"truly specify a file uniquely over time and across processes, as","type":"text"},{"type":"text","text":" "},{"text":"the current drive is a per-process value and can be changed.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"File names relative the current directory on some specific drive,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"such as “D:foo\/bar”, are not interpreted as absolute by this"},{"text":" ","type":"text"},{"type":"text","text":"function, but they obviously are not relative to the normal current"},{"text":" ","type":"text"},{"text":"directory as returned by ","type":"text"},{"type":"codeVoice","code":"getcwd()"},{"type":"text","text":" or "},{"code":"g_get_current_dir()","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"either. Such paths should be avoided, or need to be handled using"},{"type":"text","text":" "},{"text":"Windows-specific code.","type":"text"}]}],"kind":"content"}],"metadata":{"symbolKind":"func","roleHeading":"Function","role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"pathIsAbsolute","kind":"identifier"},{"kind":"text","text":"("},{"text":"fileName","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","text":"gchar","preciseIdentifier":"c:@T@gchar"},{"text":">!) -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"}],"externalID":"s:4GLib14pathIsAbsolute8fileNameSbSPys4Int8VGSg_tF","modules":[{"name":"GLib"}],"title":"pathIsAbsolute(fileName:)"},"references":{"doc://GLib/documentation/GLib/pathIsAbsolute(fileName:)":{"url":"\/documentation\/glib\/pathisabsolute(filename:)","kind":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/pathIsAbsolute(fileName:)","role":"symbol","type":"topic","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"pathIsAbsolute"},{"text":"(","kind":"text"},{"text":"fileName","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"text":"<","kind":"text"},{"preciseIdentifier":"c:@T@gchar","text":"gchar","kind":"typeIdentifier"},{"text":">!) -> ","kind":"text"},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"}],"abstract":[{"type":"text","text":"Returns "},{"type":"codeVoice","code":"true"},{"text":" if the given ","type":"text"},{"type":"codeVoice","code":"fileName"},{"type":"text","text":" is an absolute file name."},{"type":"text","text":" "},{"text":"Note that this is a somewhat vague concept on Windows.","type":"text"}],"title":"pathIsAbsolute(fileName:)"},"doc://GLib/documentation/GLib":{"kind":"symbol","role":"collection","abstract":[],"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","type":"topic","url":"\/documentation\/glib"}}}