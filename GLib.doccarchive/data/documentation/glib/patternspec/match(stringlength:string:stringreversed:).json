{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/patternspec\/match(stringlength:string:stringreversed:)"]}],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/PatternSpec","doc:\/\/GLib\/documentation\/GLib\/PatternSpec\/PatternSpecProtocol-Implementations"]]},"sections":[],"metadata":{"modules":[{"name":"GLib"}],"title":"match(stringLength:string:stringReversed:)","symbolKind":"method","roleHeading":"Instance Method","role":"symbol","extendedModule":"GLib","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"match","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"stringLength"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"kind":"text","text":", "},{"text":"string","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:SP","text":"UnsafePointer","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar"},{"kind":"text","text":">!, "},{"text":"stringReversed","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SP","kind":"typeIdentifier","text":"UnsafePointer"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar","text":"gchar"},{"text":">?) -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"}],"externalID":"s:4GLib19PatternSpecProtocolPAAE5match12stringLength0F00F8ReversedSbSi_SPys4Int8VGSgAKtF::SYNTHESIZED::s:4GLib11PatternSpecC"},"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"match","kind":"identifier"},{"text":"(","kind":"text"},{"text":"stringLength","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"text":", ","kind":"text"},{"text":"string","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"text":"<","kind":"text"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar"},{"text":">!, ","kind":"text"},{"text":"stringReversed","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:SP","kind":"typeIdentifier","text":"UnsafePointer"},{"text":"<","kind":"text"},{"preciseIdentifier":"c:@T@gchar","text":"gchar","kind":"typeIdentifier"},{"text":">? = nil) -> ","kind":"text"},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"}],"platforms":["macOS"]}],"kind":"declarations"},{"content":[{"text":"Discussion","type":"heading","anchor":"discussion","level":2},{"type":"paragraph","inlineContent":[{"text":"Passing the correct","type":"text"},{"type":"text","text":" "},{"text":"length of the string given is mandatory. The reversed string can be","type":"text"},{"type":"text","text":" "},{"type":"text","text":"omitted by passing "},{"code":"NULL","type":"codeVoice"},{"type":"text","text":", this is more efficient if the reversed"},{"type":"text","text":" "},{"text":"version of the string to be matched is not at hand, as","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"[method"},{"type":"codeVoice","code":"GLib.PatternSpec.match"},{"text":"] will only construct it if the compiled pattern","type":"text"},{"type":"text","text":" "},{"type":"text","text":"requires reverse matches."}]},{"type":"paragraph","inlineContent":[{"text":"Note that, if the user code will (possibly) match a string against a","type":"text"},{"text":" ","type":"text"},{"text":"multitude of patterns containing wildcards, chances are high that","type":"text"},{"type":"text","text":" "},{"type":"text","text":"some patterns will require a reversed string. In this case, it’s"},{"text":" ","type":"text"},{"type":"text","text":"more efficient to provide the reversed string to avoid multiple"},{"type":"text","text":" "},{"type":"text","text":"constructions thereof in the various calls to [method"},{"code":"GLib.PatternSpec.match","type":"codeVoice"},{"type":"text","text":"]."}]},{"inlineContent":[{"type":"text","text":"Note also that the reverse of a UTF-8 encoded string can in general"},{"text":" ","type":"text"},{"type":"text","text":"not be obtained by [func"},{"type":"codeVoice","code":"GLib.strreverse"},{"type":"text","text":"]. This works only if the string"},{"text":" ","type":"text"},{"text":"does not contain any multibyte characters. GLib offers the","type":"text"},{"type":"text","text":" "},{"text":"[func","type":"text"},{"code":"GLib.utf8_strreverse","type":"codeVoice"},{"type":"text","text":"] function to reverse UTF-8 encoded strings."}],"type":"paragraph"}],"kind":"content"}],"schemaVersion":{"patch":0,"minor":3,"major":0},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/PatternSpec\/match(stringLength:string:stringReversed:)"},"abstract":[{"type":"text","text":"Matches a string against a compiled pattern."}],"references":{"doc://GLib/documentation/GLib/PatternSpec":{"url":"\/documentation\/glib\/patternspec","abstract":[{"text":"A ","type":"text"},{"type":"codeVoice","code":"GPatternSpec"},{"text":" struct is the ‘compiled’ form of a glob-style pattern.","type":"text"}],"kind":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/PatternSpec","type":"topic","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"PatternSpec","kind":"identifier"}],"title":"PatternSpec","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"PatternSpec"}]},"doc://GLib/documentation/GLib":{"kind":"symbol","role":"collection","abstract":[],"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","type":"topic","url":"\/documentation\/glib"},"doc://GLib/documentation/GLib/PatternSpec/PatternSpecProtocol-Implementations":{"type":"topic","abstract":[],"url":"\/documentation\/gl