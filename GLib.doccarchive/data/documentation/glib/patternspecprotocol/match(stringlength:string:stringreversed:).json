d":"identifier","text":"match"},{"kind":"text","text":"("},{"text":"stringLength","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"string"},{"kind":"text","text":": "},{"text":"UnsafePointer","preciseIdentifier":"s:SP","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"gchar","preciseIdentifier":"c:@T@gchar"},{"kind":"text","text":">!, "},{"text":"stringReversed","kind":"externalParam"},{"kind":"text","text":": "},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"preciseIdentifier":"c:@T@gchar","kind":"typeIdentifier","text":"gchar"},{"kind":"text","text":">? = nil) -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"}]}]},{"kind":"content","content":[{"level":2,"text":"Discussion","anchor":"discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"Passing the correct"},{"text":" ","type":"text"},{"text":"length of the string given is mandatory. The reversed string can be","type":"text"},{"type":"text","text":" "},{"text":"omitted by passing ","type":"text"},{"type":"codeVoice","code":"NULL"},{"text":", this is more efficient if the reversed","type":"text"},{"type":"text","text":" "},{"type":"text","text":"version of the string to be matched is not at hand, as"},{"text":" ","type":"text"},{"type":"text","text":"[method"},{"type":"codeVoice","code":"GLib.PatternSpec.match"},{"type":"text","text":"] will only construct it if the compiled pattern"},{"text":" ","type":"text"},{"type":"text","text":"requires reverse matches."}],"type":"paragraph"},{"inlineContent":[{"text":"Note that, if the user code will (possibly) match a string against a","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"multitude of patterns containing wildcards, chances are high that"},{"text":" ","type":"text"},{"text":"some patterns will require a reversed string. In this case, it’s","type":"text"},{"type":"text","text":" "},{"text":"more efficient to provide the reversed string to avoid multiple","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"constructions thereof in the various calls to [method"},{"code":"GLib.PatternSpec.match","type":"codeVoice"},{"text":"].","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note also that the reverse of a UTF-8 encoded string can in general"},{"type":"text","text":" "},{"text":"not be obtained by [func","type":"text"},{"code":"GLib.strreverse","type":"codeVoice"},{"text":"]. This works only if the string","type":"text"},{"type":"text","text":" "},{"text":"does not contain any multibyte characters. GLib offers the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[func"},{"code":"GLib.utf8_strreverse","type":"codeVoice"},{"text":"] function to reverse UTF-8 encoded strings.","type":"text"}]}]}],"references":{"doc://GLib/documentation/GLib":{"kind":"symbol","role":"collection","abstract":[],"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","type":"topic","url":"\/documentation\/glib"},"doc://GLib/documentation/GLib/PatternSpecProtocol/match(stringLength:string:stringReversed:)":{"type":"topic","title":"match(stringLength:string:stringReversed:)","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"match"},{"kind":"text","text":"("},{"kind":"externalParam","text":"stringLength"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"kind":"text","text":", "},{"kind":"externalParam","text":"string"},{"kind":"text","text":": "},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar"},{"text":">!, ","kind":"text"},{"text":"stringReversed","kind":"externalParam"},{"te