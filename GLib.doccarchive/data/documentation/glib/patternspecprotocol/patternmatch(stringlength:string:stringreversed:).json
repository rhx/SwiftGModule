ext":" "},{"type":"text","text":"more efficient to provide the reversed string to avoid multiple"},{"text":" ","type":"text"},{"type":"text","text":"constructions thereof in the various calls to "},{"type":"codeVoice","code":"g_pattern_match()"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Note also that the reverse of a UTF-8 encoded string can in general"},{"type":"text","text":" "},{"text":"not be obtained by [func","type":"text"},{"type":"codeVoice","code":"GLib.strreverse"},{"text":"]. This works only if the string","type":"text"},{"text":" ","type":"text"},{"text":"does not contain any multibyte characters. GLib offers the","type":"text"},{"text":" ","type":"text"},{"text":"[func","type":"text"},{"type":"codeVoice","code":"GLib.utf8_strreverse"},{"text":"] function to reverse UTF-8 encoded strings.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"pattern_match is deprecated:"}]},{"type":"text","text":" "},{"type":"text","text":"Use [method@GLib.PatternSpec.match] instead"}],"type":"paragraph"}],"kind":"content"}],"abstract":[{"text":"Matches a string against a compiled pattern.","type":"text"}],"references":{"doc://GLib/documentation/GLib":{"kind":"symbol","role":"collection","abstract":[],"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","type":"topic","url":"\/documentation\/glib"},"doc://GLib/documentation/GLib/PatternSpecProtocol":{"url":"\/documentation\/glib\/patternspecprotocol","abstract":[{"text":"A ","type":"text"},{"type":"codeVoice","code":"GPatternSpec"},{"text":" struct is the ‘compiled’ form of a glob-style pattern.","type":"text"}],"kind":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/PatternSpecProtocol","type":"topic","fragments":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"PatternSpecProtocol"}],"title":"PatternSpecProtocol","role":"symbol","navigatorTitle":[{"tex