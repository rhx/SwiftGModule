nd":"keyword"},{"text":" ","kind":"text"},{"text":"match","kind":"identifier"},{"kind":"text","text":"("},{"text":"stringLength","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"},{"text":", ","kind":"text"},{"text":"string","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:SP","text":"UnsafePointer","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"preciseIdentifier":"c:@T@gchar","text":"gchar","kind":"typeIdentifier"},{"text":">!, ","kind":"text"},{"kind":"externalParam","text":"stringReversed"},{"kind":"text","text":": "},{"preciseIdentifier":"s:SP","kind":"typeIdentifier","text":"UnsafePointer"},{"kind":"text","text":"<"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar"},{"kind":"text","text":">? = nil) -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"anchor":"discussion","text":"Discussion","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Passing the correct"},{"text":" ","type":"text"},{"text":"length of the string given is mandatory. The reversed string can be","type":"text"},{"type":"text","text":" "},{"text":"omitted by passing ","type":"text"},{"type":"codeVoice","code":"NULL"},{"text":", this is more efficient if the reversed","type":"text"},{"type":"text","text":" "},{"text":"version of the string to be matched is not at hand, as","type":"text"},{"text":" ","type":"text"},{"text":"[method","type":"text"},{"type":"codeVoice","code":"GLib.PatternSpec.match"},{"type":"text","text":"] will only construct it if the compiled pattern"},{"type":"text","text":" "},{"type":"text","text":"requires reverse matches."}]},{"inlineContent":[{"type":"text","text":"Note that, if the user code will (possibly) match a string against a"},{"text":" ","type":"text"},{"text":"multitude of patterns containing wildcards, chances are high that","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"some patterns will require a reversed string. In this case, it’s"},{"type":"text","text":" "},{"type":"text","text":"more efficient to provide the reversed string to avoid multiple"},{"type":"text","text":" "},{"type":"text","text":"constructions thereof in the various calls to [method"},{"type":"codeVoice","code":"GLib.PatternSpec.match"},{"type":"text","text":"]."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note also that the reverse of a UTF-8 encoded string can in general"},{"type":"text","text":" "},{"type":"text","text":"not be obtained by [func"},{"type":"codeVoice","code":"GLib.strreverse"},{"type":"text","text":"]. This works only if the string"},{"type":"text","text":" "},{"text":"does not contain any multibyte characters. GLib offers the","type":"text"},{"type":"text","text":" "},{"text":"[func","type":"text"},{"type":"codeVoice","code":"GLib.utf8_strreverse"},{"type":"text","text":"] function to reverse UTF-8 encoded strings."}]}]}],"references":{"doc://GLib/documentation/GLib/PatternSpecRef/PatternSpecProtocol-Implementations":{"role":"collectionGroup","kind":"article","identifier":"doc:\/\/GLib\/documentation\/GLib\/PatternSpecRef\/PatternSpecProtocol-Implementations","type":"topic","url":"\/documentation\/glib\/patternspecref\/patternspecprotocol-implementations","abstract":[],"title":"PatternSpecProtocol Implementations"},"doc://GLib/documentation/GLib":{"kind":"symbol","role":"collection","abstract":[],"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","type":"topic","url":"\/documentation\/glib"},"doc://GLib/documentation/GLib/PatternSpecRef":{"navigatorTitle":[{"text":"PatternSpecRef","kind":"identifier"}],"abstract":[{"text":"A ","type":"text"},{"code":"GPatternSpec","type":"codeVoice"},{"text":" struct is the ‘compiled’ form of a glob-style pattern.","type":"text"}],"type":"topic","title