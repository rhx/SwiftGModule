{"schemaVersion":{"minor":3,"major":0,"patch":0},"abstract":[{"type":"text","text":"Matches a string against a compiled pattern."}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/PatternSpecRef","doc:\/\/GLib\/documentation\/GLib\/PatternSpecRef\/PatternSpecProtocol-Implementations"]]},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"patternMatch"},{"text":"(","kind":"text"},{"text":"stringLength","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"kind":"text","text":", "},{"kind":"externalParam","text":"string"},{"kind":"text","text":": "},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar"},{"text":">!, ","kind":"text"},{"kind":"externalParam","text":"stringReversed"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"kind":"text","text":"<"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar"},{"text":">? = nil) -> ","kind":"text"},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Discussion","anchor":"discussion","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Passing the correct"},{"text":" ","type":"text"},{"type":"text","text":"length of the string given is mandatory. The reversed string can be"},{"text":" ","type":"text"},{"type":"text","text":"omitted by passing "},{"code":"NULL","type":"codeVoice"},{"text":", this is more efficient if the reversed","type":"text"},{"type":"text","text":" "},{"text":"version of the string to be matched is not at hand, as","type":"text"},{"text":" ","type":"text"},{"code":"g_pattern_match()","type":"codeVoice"},{"type":"text","text":" will only construct it if the compiled pattern"},{"text":" ","type":"text"},{"type":"text","text":"requires reverse matches."}]},{"inlineContent":[{"type":"text","text":"Note that, if the user code will (possibly) match a string against a"},{"type":"text","text":" "},{"text":"multitude of patterns containing wildcards, chances are high that","type":"text"},{"type":"text","text":" "},{"text":"some patterns will require a reversed string. In this case, it’s","type":"text"},{"text":" ","type":"text"},{"text":"more efficient to provide the reversed string to avoid multiple","type":"text"},{"text":" ","type":"text"},{"text":"constructions thereof in the various calls to ","type":"text"},{"code":"g_pattern_match()","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note also that the reverse of a UTF-8 encoded string can in general"},{"type":"text","text":" "},{"type":"text","text":"not be obtained by [func"},{"code":"GLib.strreverse","type":"codeVoice"},{"type":"text","text":"]. This works only if the string"},{"text":" ","type":"text"},{"text":"does not contain any multibyte characters. GLib offers the","type":"text"},{"type":"text","text":" "},{"text":"[func","type":"text"},{"type":"codeVoice","code":"GLib.utf8_strreverse"},{"type":"text","text":"] function to reverse UTF-8 encoded strings."}]},{"inlineContent":[{"type":"strong","inlineContent":[{"text":"pattern_match is deprecated:","type":"text"}]},{"text":" ","type":"text"},{"type":"text","text":"Use [method@GLib.PatternSpec.match] instead"}],"type":"paragraph"}]}],"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/patternspecref\/patternmatch(stringlength:string:stringreversed:)"]}],"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/PatternSpecRef\/patternMatch(string