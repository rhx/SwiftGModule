l()"},{"type":"text","text":", it is emulated using "},{"type":"codeVoice","code":"select()"},{"type":"text","text":".)"},{"type":"text","text":" "},{"text":"This is used internally by ","type":"text"},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/MainContext","type":"reference"},{"type":"text","text":", but it can be called"},{"type":"text","text":" "},{"type":"text","text":"directly if you need to block until a file descriptor is ready, but"},{"text":" ","type":"text"},{"type":"text","text":"don’t want to run the full main loop."}],"references":{"doc://GLib/documentation/GLib/MainContext":{"abstract":[{"type":"text","text":"The "},{"type":"codeVoice","code":"GMainContext"},{"type":"text","text":" struct is an opaque data"},{"type":"text","text":" "},{"text":"type representing a set of sources to be handled in a main loop.","type":"text"}],"role":"symbol","kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"MainContext"}],"type":"topic","url":"\/documentation\/glib\/maincontext","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"MainContext"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/MainContext","title":"MainContext"},"doc://GLib/documentation/GLib/PollFD":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/PollFD","url":"\/documentation\/glib\/pollfd","role":"symbol","abstract":[{"text":"Represents a file descriptor, which events to poll for, and which events","type":"text"},{"type":"text","text":" "},{"type":"text","text":"occurred."}],"kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"PollFD"}],"title":"PollFD","type":"topic","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"PollFD","kind":"identifier"}]},"doc://GLib/documentation/GLib":{"kind":"symbol","role":"collection","abstract":[],"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","type":"topic","url":"\/documentation\/glib"},"doc://GLib/documentation/GLib/PollF