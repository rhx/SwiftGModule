"text":"Note that if the array is ","type":"text"},{"type":"codeVoice","code":"NULL"},{"text":" terminated this may still return","type":"text"},{"type":"text","text":" "},{"code":"NULL","type":"codeVoice"},{"type":"text","text":" if the length of the array was zero and pdata was not yet"},{"text":" ","type":"text"},{"type":"text","text":"allocated."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Even if set, the [callback"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/DestroyNotify","isActive":true},{"text":"] function will never be called","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"on the current contents of the array and the caller is"},{"type":"text","text":" "},{"text":"responsible for freeing the array elements.","type":"text"}]},{"inlineContent":[{"type":"text","text":"An example of use:"}],"type":"paragraph"},{"type":"codeListing","syntax":"c","code":["`g_autoptr(GPtrArray)` chunk_buffer = g_ptr_array_new_with_free_func (g_bytes_unref);","","\/\/ Some part of your application appends a number of chunks to the pointer array.","g_ptr_array_add (chunk_buffer, g_bytes_new_static (\"hello\", 5));","g_ptr_array_add (chunk_buffer, g_bytes_new_static (\"world\", 5));","","…","","\/\/ Periodically, the chunks need to be sent as an array-and-length to some","\/\/ other part of the program.","GBytes **chunks;","gsize n_chunks;","","chunks = g_ptr_array_steal (chunk_buffer, &n_chunks);","for (gsize i = 0; i < n_chunks; i++)","  {","    \/\/ Do something with each chunk here, and then free them, since","    \/\/ `g_ptr_array_steal()` transfers ownership of all the elements and the","    \/\/ array to the caller.","    …","","    g_bytes_unref (chunks[i]);","  }","","g_free (chunks);","","\/\/ After calling `g_ptr_array_steal()`, the pointer array can be reused for the","\/\/ next set of chunks.","g_assert (chunk_buffer->len == 0);"]}],"kind":"content"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/PtrArray\/steal(len:)"},"kind":"symbol","sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/ptrarray\/steal(len:)"]}],"abstract":[{"text":"Frees the data in the array and resets the size to zero, while","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the underlying array is preserved for use elsewhere and returned"},{"type":"text","text":" "},{"text":"to the caller.","type":"text"}],"references":{"doc://GLib/documentation/GLib/PtrArray":{"title":"PtrArray","navigatorTitle":[{"text":"PtrArray","kind":"identifier"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/PtrArray","kind":"symbol","url":"\/documentation\/glib\/ptrarray","role":"symbol","type":"topic","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"PtrArray","kind":"identifier"}],"abstract":[{"type":"text","text":"Contains the public fields of a "},{"type":"codeVoice","code":"GPtrArray"},{"type":"text","text":"."}]},"doc://GLib/documentation/GLib/PtrArray/steal(len:)":{"type":"topic","kind":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/PtrArray\/steal(len:)","role":"symbol","abstract":[{"text":"Frees the data in the array and resets the size to zero, while","type":"text"},{"type":"text","text":" "},{"text":"the underlying array is preserved for use elsewhere and returned","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"to the caller."}],"url":"\/documentation\/glib\/ptrarray\/steal(len:)","title":"steal(len:)","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"steal"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"len"},{"kind":"text","text":": "},{"text":"UnsafeMutablePointer","kind":"typeIdentifier","preciseIdentifier":"s:Sp"},{"text":"<","kind":"text"},{"text":"gsize","kind":"typeIdentifier","preciseIdentifier":"c:@T@gsize"},{"text":">!) -> ","kind":"text"},{"preciseIdenti