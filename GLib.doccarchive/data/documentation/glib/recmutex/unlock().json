cked","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"and can lock "},{"type":"codeVoice","code":"recMutex"},{"type":"text","text":" itself."}],"kind":"symbol","title":"unlock()","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"unlock"},{"kind":"text","text":"()"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/RecMutex\/unlock()","url":"\/documentation\/glib\/recmutex\/unlock()","role":"symbol","type":"topic"},"doc://GLib/documentation/GLib/Mutex":{"role":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex","url":"\/documentation\/glib\/mutex","title":"Mutex","navigatorTitle":[{"kind":"identifier","text":"Mutex"}],"abstract":[{"type":"text","text":"The "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex"},{"type":"text","text":" struct is an opaque data structure to represent a mutex"},{"type":"text","text":" "},{"type":"text","text":"(mutual exclusion). It can be used to protect data against shared"},{"text":" ","type":"text"},{"text":"access.","type":"text"}],"kind":"symbol","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"Mutex","kind":"identifier"}],"type":"topic"}}}