{"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/RefArrayRef","doc:\/\/GLib\/documentation\/GLib\/RefArrayRef\/PtrArrayProtocol-Implementations"]]},"metadata":{"roleHeading":"Instance Method","role":"symbol","extendedModule":"GLib","modules":[{"name":"GLib"}],"title":"steal(len:)","symbolKind":"method","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"steal","kind":"identifier"},{"kind":"text","text":"("},{"text":"len","kind":"externalParam"},{"kind":"text","text":": "},{"text":"UnsafeMutablePointer","kind":"typeIdentifier","preciseIdentifier":"s:Sp"},{"kind":"text","text":"<"},{"preciseIdentifier":"c:@T@gsize","kind":"typeIdentifier","text":"gsize"},{"text":">!) -> ","kind":"text"},{"preciseIdentifier":"s:Sp","kind":"typeIdentifier","text":"UnsafeMutablePointer"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"gpointer","preciseIdentifier":"c:@T@gpointer"},{"text":"?>!","kind":"text"}],"externalID":"s:4GLib16PtrArrayProtocolPAAE5steal3lenSpySvSgGSgSpySuGSg_tF::SYNTHESIZED::s:4GLib08RefArrayB0V"},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/RefArrayRef\/steal(len:)"},"variants":[{"paths":["\/documentation\/glib\/refarrayref\/steal(len:)"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"minor":3,"major":0,"patch":0},"sections":[],"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"steal","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"len"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer"},{"kind":"text","text":"<"},{"text":"gsize","preciseIdentifier":"c:@T@gsize","kind":"typeIdentifier"},{"text":">! = nil) -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer"},{"text":"<","kind":"text"},{"text":"gpointer","kind":"typeIdentifier","preciseIdentifier":"c:@T@gpointer"},{"text":"?>!","kind":"text"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"content":[{"type":"heading","anchor":"discussion","text":"Discussion","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that if the array is "},{"type":"codeVoice","code":"NULL"},{"text":" terminated this may still return","type":"text"},{"text":" ","type":"text"},{"code":"NULL","type":"codeVoice"},{"type":"text","text":" if the length of the array was zero and pdata was not yet"},{"text":" ","type":"text"},{"text":"allocated.","type":"text"}]},{"inlineContent":[{"type":"text","text":"Even if set, the [callback"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/DestroyNotify","isActive":true},{"text":"] function will never be called","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"on the current contents of the array and the caller is"},{"text":" ","type":"text"},{"type":"text","text":"responsible for freeing the array elements."}],"type":"paragraph"},{"inlineContent":[{"text":"An example of use:","type":"text"}],"type":"paragraph"},{"syntax":"c","type":"codeListing","code":["`g_autoptr(GPtrArray)` chunk_buffer = g_ptr_array_new_with_free_func (g_bytes_unref);","","\/\/ Some part of your application appends a number of chunks to the pointer array.","g_ptr_array_add (chunk_buffer, g_bytes_new_static (\"hello\", 5));","g_ptr_array_add (chunk_buffer, g_bytes_new_static (\"world\", 5));","","…","","\/\/ Periodically, the chunks need to be sent as an array-and-length to some","\/\/ other part of the program.","GBytes **chunks;","gsize n_chunks;","","chunks = g_ptr_array_steal (chunk_buffer, &n_chunks);","for (gsize i = 0; i < n_chunks; i++)","  {","    \/\/ Do something with each chunk here, and then free them, since","    \/\/ `g_ptr_array_steal()` transfers ownership of all the elements and the","    \/\/ array to the caller.","    …","","    g_bytes_unref (chunks[i]);","  }","","g_free (chunks);","","\/\/ After calling `g_ptr_array_steal()`, the pointer array can be reused for the","\/\/ next set of chunks.","g_assert (chunk_buffer->len == 0);"]}],"kind":"content"}],"kind":"symbol","abstract":[{"type":"text","text":"Frees the data in the array and resets the size to zero, while"},{"text":" ","type":"text"},{"type":"text","text":"the underlying array is preserved for use elsewhere and returned"},{"type":"text","text":" "},{"type":"text","text":"to the caller."}],"references":{"doc://GLib/documentation/GLib":{"kind":"symbol","role":"collection","abstract":[],"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","type":"topic","url":"\/documentation\/glib"},"doc://GLib/documentation/GLib/DestroyNotify":{"title":"DestroyNotify","fragments":[{"text":"typealias","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"DestroyNotify"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/DestroyNotify","abstract":[{"type":"text","text":"Specifies the type of function which is called when a data element"},{"type":"text","text":" "},{"type":"text","text":"is destroyed. It is passed the pointer to the data element and"},{"type":"text","text":" "},{"text":"should free any memory and resources allocated for it.","type":"text"}],"navigatorTitle":[{"text":"DestroyNotify","kind":"identifier"}],"type":"topic","role":"symbol","url":"\/documentation\/glib\/destroynotify","kind":"symbol"},"doc://GLib/documentation/GLib/RefArrayRef/PtrArrayProtocol-Implementations":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/RefArrayRef\/PtrArrayProtocol-Implementations","title":"PtrArrayProtocol Implementations","type":"topic","role":"collectionGroup","abstract":[],"kind":"article","url":"\/documentation\/glib\/refarrayref\/ptrarrayprotocol-implementations"},"doc://GLib/documentation/GLib/RefArrayRef/steal(len:)":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/RefArrayRef\/steal(len:)","title":"steal(len:)","type":"topic","r