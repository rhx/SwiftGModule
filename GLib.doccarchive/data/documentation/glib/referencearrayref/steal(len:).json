{"kind":"symbol","identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/ReferenceArrayRef\/steal(len:)","interfaceLanguage":"swift"},"abstract":[{"text":"Frees the data in the array and resets the size to zero, while","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the underlying array is preserved for use elsewhere and returned"},{"type":"text","text":" "},{"type":"text","text":"to the caller."}],"variants":[{"paths":["\/documentation\/glib\/referencearrayref\/steal(len:)"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/ReferenceArrayRef","doc:\/\/GLib\/documentation\/GLib\/ReferenceArrayRef\/PtrArrayProtocol-Implementations"]]},"schemaVersion":{"major":0,"minor":3,"patch":0},"sections":[],"metadata":{"role":"symbol","extendedModule":"GLib","modules":[{"name":"GLib"}],"symbolKind":"method","externalID":"s:4GLib16PtrArrayProtocolPAAE5steal3lenSpySvSgGSgSpySuGSg_tF::SYNTHESIZED::s:4GLib17ReferenceArrayRefV","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"steal"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"len"},{"text":": ","kind":"text"},{"text":"UnsafeMutablePointer","kind":"typeIdentifier","preciseIdentifier":"s:Sp"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gsize","text":"gsize"},{"kind":"text","text":">!) -> "},{"preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gpointer","text":"gpointer"},{"kind":"text","text":"?>!"}],"roleHeading":"Instance Method","title":"steal(len:)"},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"steal"},{"text":"(","kind":"text"},{"text":"len","kind":"externalParam"},{"kind":"text","text":": "},{"text":"UnsafeMutablePointer","kind":"typeIdentifier","preciseIdentifier":"s:Sp"},{"text":"<","kind":"text"},{"text":"gsize","kind":"typeIdentifier","preciseIdentifier":"c:@T@gsize"},{"text":">! = nil) -> ","kind":"text"},{"text":"UnsafeMutablePointer","kind":"typeIdentifier","preciseIdentifier":"s:Sp"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","text":"gpointer","preciseIdentifier":"c:@T@gpointer"},{"kind":"text","text":"?>!"}]}]},{"content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that if the array is "},{"code":"NULL","type":"codeVoice"},{"type":"text","text":" terminated this may still return"},{"type":"text","text":" "},{"code":"NULL","type":"codeVoice"},{"type":"text","text":" if the length of the array was zero and pdata was not yet"},{"text":" ","type":"text"},{"text":"allocated.","type":"text"}]},{"inlineContent":[{"type":"text","text":"Even if set, the [callback"},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/DestroyNotify","type":"reference"},{"type":"text","text":"] function will never be called"},{"type":"text","text":" "},{"type":"text","text":"on the current contents of the array and the caller is"},{"type":"text","text":" "},{"type":"text","text":"responsible for freeing the array elements."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"An example of use:","type":"text"}]},{"type":"codeListing","syntax":"c","code":["`g_autoptr(GPtrArray)` chunk_buffer = g_ptr_array_new_with_free_func (g_bytes_unref);","","\/\/ Some part of your application appends a number of chunks to the pointer array.","g_ptr_array_add (chunk_buffer, g_bytes_new_static (\"hello\", 5));","g_ptr_array_add (chunk_buffer, g_bytes_new_static (\"world\", 5));","","…","","\/\/ Periodically, the chunks need to be sent as an array-and-length to some","\/\/ other part of the program.","GBytes **chunks;","gsize n_chunks;","","chunks = g_ptr_array_steal (chunk_buffer, &n_chunks);","for (gsize i = 0; i < n_chunks; i++)","  {","    \/\/ Do something with each chunk here, and then free them, since","    \/\/ `g_ptr_array_steal()` transfers ownership of all the elements and the","    \/\/ array to the caller.","    …","","    g_bytes_unref (chunks[i]);","  }","","g_free (chunks);","","\/\/ After calling `g_ptr_array_steal()`, the pointer array can be reused for the","\/\/ next set of chunks.","g_assert (chunk_buffer->len == 0);"]}],"kind":"content"}],"references":{"doc://GLib/documentation/GLib/ReferenceArrayRef/PtrArrayProtocol-Implementations":{"url":"\/documentation\/glib\/referencearrayref\/ptrarrayprotocol-implementations","kind":"article","identifier":"doc:\/\/GLib\/documentation\/GLib\/ReferenceArrayRef\/PtrArrayProtocol-Implementations","abstract":[],"role":"collectionGroup","title":"PtrArrayProtocol Implementations","type":"topic"},"doc://GLib/documentation/GLib/DestroyNotify":{"title":"DestroyNotify","fragments":[{"text":"typealias","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"DestroyNotify"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/DestroyNotify","abstract":[{"type":"text","text":"Specifies the type of function which is called when a data element"},{"type":"text","text":" "},{"type":"text","text":"is destroyed. It is passed the pointer to the data element and"},{"type":"text","text":" "},{"text":"should free any memory and resources allocated for it.","type":"text"}],"navigatorTitle":[{"text":"DestroyNotify","kind":"identifier"}],"type":"topic","role":"symbol","url":"\/documentation\/glib\/destroynotify","kind":"symbol"},"doc://GLib/documentation/GLib":{"kind":"symbol","role":"collection","abstract":[],"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","type":"topic","url":"\/documentation\/glib"},"doc://GLib/documentation/GLib/ReferenceArrayRef/steal(len:)":{"title":"steal(len:)","kind":"symbol","abstract":[{"text":"