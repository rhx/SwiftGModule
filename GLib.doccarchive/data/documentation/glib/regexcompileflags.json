the cost of extra processing before the"},{"type":"text","text":" "},{"text":"match is performed, so it is most beneficial to use this when the same","type":"text"},{"type":"text","text":" "},{"text":"compiled pattern is used for matching many times. Before 2.74 this","type":"text"},{"type":"text","text":" "},{"text":"option used the built-in non-JIT optimizations in pcre1.","type":"text"}],"fragments":[{"text":"static","kind":"keyword"},{"kind":"text","text":" "},{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"optimize","kind":"identifier"},{"kind":"text","text":": "},{"preciseIdentifier":"s:4GLib17RegexCompileFlagsV","kind":"typeIdentifier","text":"RegexCompileFlags"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/RegexCompileFlags\/optimize","title":"optimize","type":"topic"},"doc://GLib/documentation/GLib/RegexCompileFlags/int":{"url":"\/documentation\/glib\/regexcompileflags\/int","type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib\/RegexCompileFlags\/int","role":"symbol","title":"int","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"int"},{"kind":"text","text":": "},{"text":"gint","preciseIdentifier":"c:@T@gint","kind":"typeIdentifier"}],"abstract":[{"type":"text","text":"The equivalent raw "},{"code":"gint","type":"codeVoice"},{"type":"text","text":" value"}],"kind":"symbol"},"doc://GLib/s25ExpressibleByArrayLiteralP":{"title":"Swift.ExpressibleByArrayLiteral","type":"unresolvable","identifier":"doc:\/\/GLib\/s25ExpressibleByArrayLiteralP"},"doc://GLib/documentation/GLib/RegexCompileFlags/newlineCr":{"role":"symbol","url":"\/documentation\/glib\/regexcompileflags\/newlinecr","kind":"symbol","abstract":[{"type":"text","text":"Usually any newline character or character sequence is"},{"text":" ","type":"text"},{"text":"recognized. If this option is set, the only recognized newline character","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"is ‘\\r’."}],"fragments":[{"kind":"keyword","text":"static"},{"text":" ","kind":"text"},{"text":"let","kind":"keyword"},{"kind":"text","text":" "},{"text":"newlineCr","kind":"identifier"},{"text":": ","kind":"text"},{"text":"RegexCompileFlags","kind":"typeIdentifier","preciseIdentifier":"s:4GLib17RegexCompileFlagsV"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/RegexCompileFlags\/newlineCr","title":"newlineCr","type":"topic"},"doc://GLib/documentation/GLib/RegexCompileFlags/multiline":{"title":"multiline","type":"topic","kind":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/RegexCompileFlags\/multiline","fragments":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"multiline"},{"kind":"text","text":": "},{"preciseIdentifier":"s:4GLib17RegexCompileFlagsV","text":"RegexCompileFlags","kind":"typeIdentifier"}],"url":"\/documentation\/glib\/regexcompileflags\/multiline","role":"symbol","abstract":[{"type":"text","text":"By default, GRegex treats the strings as consisting"},{"type":"text","text":" "},{"type":"text","text":"of a single line of characters (even if it actually contains"},{"type":"text","text":" "},{"type":"text","text":"newlines). The “start of line” metacharacter (”^”) matches only"},{"text":" ","type":"text"},{"type":"text","text":"at the start of the string, while the “end of line” metacharacter"},{"text":" ","type":"text"},{"text":"(”$”) matches only at the end of the string, or before a terminating","type":"text"},{"text":" ","type":"text"},{"text":"newline (unless ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/RegexCompileFlags\/dollarEndonly","isActive":true},{"type":"text","text":" is set). When"},{"text":" ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/RegexCompileFlags\/multiline","type":"reference","isActive":true},{"type":"text","text":" is set, the “start of line” and “end of line”"},{"text":" ","type":"text"},{"type":"text","text":"constructs match immediately following or immediately before any"},{"text":" ","type":"text"},{"type":"text","text":"newline in the string, respectively, as well as at the very start"},{"text":" ","type":"text"},{"type":"text","text":"and end. This can be changed within a pattern by a “(?m)” option"},{"type":"text","text":" "},{"type":"text","text":"setting."}]},"doc://GLib/documentation/GLib/RegexCompileFlags/newlineAnycrlf":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/RegexCompileFlags\/newlineAnycrlf","fragments":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"text":"let","kind":"keyword"},{"kind":"text","text":" "},{"text":"newlineAnycrlf","kind":"identifier"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:4GLib17RegexCompileFlagsV","text":"RegexCompileFlags"}],"abstract":[{"type":"text","text":"Usually any newline character or character sequence"},{"text":" ","type":"text"},{"type":"text","text":"is recognized. If this option is set, the only recognized newline character"},{"text":" ","type":"text"},{"text":"sequences are ‘\\r’, ‘\\n’, and ‘\\r\\n’. Since: 2.34","type":"text"}],"type":"topic","title":"newlineAnycrlf","kind":"symbol","url":"\/documentation\/glib\/regexcompileflags\/newlineanycrlf","role":"symbol"}}}