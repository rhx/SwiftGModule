{"kind":"symbol","primaryContentSections":[{"declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"matchAllFull"},{"text":"(","kind":"text"},{"text":"string","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"kind":"text","text":"<"},{"preciseIdentifier":"c:@T@gchar","text":"gchar","kind":"typeIdentifier"},{"kind":"text","text":">!, "},{"kind":"externalParam","text":"stringLen"},{"kind":"text","text":": "},{"preciseIdentifier":"c:@T@gssize","kind":"typeIdentifier","text":"gssize"},{"kind":"text","text":", "},{"kind":"externalParam","text":"startPosition"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"},{"kind":"text","text":", "},{"text":"matchOptions","kind":"externalParam"},{"kind":"text","text":": "},{"text":"RegexMatchFlags","preciseIdentifier":"s:4GLib15RegexMatchFlagsV","kind":"typeIdentifier","identifier":"doc:\/\/GLib\/documentation\/GLib\/RegexMatchFlags"},{"kind":"text","text":", "},{"kind":"externalParam","text":"matchInfo"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"UnsafeMutablePointer","preciseIdentifier":"s:Sp"},{"kind":"text","text":"<"},{"text":"GMatchInfo","kind":"typeIdentifier"},{"kind":"text","text":">?>! = nil) "},{"kind":"keyword","text":"throws"},{"text":" -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"}]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Discussion","type":"heading","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This function uses a different algorithm (called DFA, i.e. deterministic"},{"type":"text","text":" "},{"type":"text","text":"finite automaton), so it can retrieve all the possible matches, all"},{"text":" ","type":"text"},{"text":"starting at the same point in the string. For instance matching","type":"text"},{"type":"text","text":" "},{"code":"\"<a> <b> <c>\"","type":"codeVoice"},{"type":"text","text":" against the pattern "},{"code":"\"<.*>\"","type":"codeVoice"},{"text":" ","type":"text"},{"text":"you would obtain three matches: ","type":"text"},{"code":"\"<a> <b> <c>\"","type":"codeVoice"},{"type":"text","text":","},{"text":" ","type":"text"},{"type":"codeVoice","code":"\"<a> <b>\""},{"type":"text","text":" and "},{"code":"\"<a>\"","type":"codeVoice"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The number of matched strings is retrieved using"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_match_info_get_match_count()"},{"type":"text","text":". To obtain the matched strings and"},{"text":" ","type":"text"},{"type":"text","text":"their position you can use, respectively, "},{"code":"g_match_info_fetch()","type":"codeVoice"},{"type":"text","text":" and"},{"text":" ","type":"text"},{"code":"g_match_info_fetch_pos()","type":"codeVoice"},{"type":"text","text":". Note that the strings are returned in"},{"text":" ","type":"text"},{"type":"text","text":"reverse order of length; that is, the longest matching string is"},{"text":" ","type":"text"},{"text":"given first.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Note that the DFA algorithm is slower than the standard one and it","type":"text"},{"text":" ","type":"text"},{"text":"is not able to capture substrings, so backreferences do not work.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Setting "},{"code":"startPosition","type":"codeVoice"},{"text":" differs from just passing over a shortened","type":"text"},{"type":"text","text":" "},{"type":"text","text":"string and setting "},{"code":"notbol","type":"codeVoice"},{"text":" in the case of a pattern","type":"text"},{"text":" ","type":"text"},{"text":"that begins with any kind of lookbehind assertion, such as “\\b”.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Unless "},{"type":"codeVoice","code":"raw"},{"type":"text","text":" is specified in the options, "},{"code":"string","type":"codeVoice"},{"text":" must be valid UTF-8.","type":"text"}]},{"inlineContent":[{"type":"text","text":"A "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/MatchInfo"},{"text":" structure, used to get information on the match, is","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"stored in "},{"code":"matchInfo","type":"codeVoice"},{"type":"text","text":" if not "},{"code":"nil","type":"codeVoice"},{"type":"text","text":". Note that if "},{"code":"matchInfo","type":"codeVoice"},{"type":"text","text":" is"},{"type":"text","text":" "},{"type":"text","text":"not "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" then it is created even if the function returns "},{"type":"codeVoice","code":"false"},{"type":"text","text":","},{"text":" ","type":"text"},{"type":"text","text":"i.e. you must free it regardless if regular expression actually"},{"type":"text","text":" "},{"type":"text","text":"matched."}],"type":"paragraph"},{"inlineContent":[{"type":"codeVoice","code":"string"},{"type":"text","text":" is not copied and is used in "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/MatchInfo"},{"type":"text","text":" internally. If"},{"text":" ","type":"text"},{"type":"text","text":"you use any "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/MatchInfo","type":"reference","isActive":true},{"text":" method (except ","type":"text"},{"type":"codeVoice","code":"g_match_info_free()"},{"type":"text","text":") after"},{"text":" ","type":"text"},{"type":"text","text":"freeing or modifying "},{"type":"codeVoice","code":"string"},{"type":"text","text":" then the behaviour is undefined."}],"type":"parag