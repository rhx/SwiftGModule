{"schemaVersion":{"minor":3,"patch":0,"major":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"matchAllFull"},{"kind":"text","text":"("},{"text":"string","kind":"externalParam"},{"kind":"text","text":": "},{"text":"UnsafePointer","preciseIdentifier":"s:SP","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar","text":"gchar"},{"text":">!, ","kind":"text"},{"text":"stringLen","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gssize","text":"gssize"},{"kind":"text","text":", "},{"kind":"externalParam","text":"startPosition"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"},{"text":", ","kind":"text"},{"text":"matchOptions","kind":"externalParam"},{"text":": ","kind":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/RegexMatchFlags","kind":"typeIdentifier","text":"RegexMatchFlags","preciseIdentifier":"s:4GLib15RegexMatchFlagsV"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"matchInfo"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"text":"UnsafeMutablePointer","preciseIdentifier":"s:Sp","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"text":"GMatchInfo","kind":"typeIdentifier"},{"kind":"text","text":">?>! = nil) "},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"}],"languages":["swift"]}]},{"kind":"content","content":[{"type":"heading","level":2,"anchor":"discussion","text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This function uses a different algorithm (called DFA, i.e. deterministic"},{"text":" ","type":"text"},{"type":"text","text":"finite automaton), so it can retrieve all the possible matches, all"},{"text":" ","type":"text"},{"text":"starting at the same point in the string. For instance matching","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"\"<a> <b> <c>\""},{"text":" against the pattern ","type":"text"},{"type":"codeVoice","code":"\"<.*>\""},{"text":" ","type":"text"},{"type":"text","text":"you would obtain three matches: "},{"type":"codeVoice","code":"\"<a> <b> <c>\""},{"text":",","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"\"<a> <b>\""},{"type":"text","text":" and "},{"type":"codeVoice","code":"\"<a>\""},{"type":"text","text":"."}]},{"inlineContent":[{"text":"The number of matched strings is retrieved using","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_match_info_get_match_count()"},{"type":"text","text":". To obtain the matched strings and"},{"type":"text","text":" "},{"type":"text","text":"their position you can use, respectively, "},{"code":"g_match_info_fetch()","type":"codeVoice"},{"type":"text","text":" and"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_match_info_fetch_pos()"},{"type":"text","text":". Note that the strings are returned in"},{"type":"text","text":" "},{"text":"reverse order of length; that is, the longest matching string is","type":"text"},{"text":" ","type":"text"},{"text":"given first.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Note that the DFA algorithm is slower than the standard one and it","type":"text"},{"type":"text","text":" "},{"text":"is not able to capture substrings, so backreferences do not work.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Setting "},{"code":"startPosition","type":"codeVoice"},{"text":" differs from just passing over a shortened","type":"text"},{"text":" ","type":"text"},{"text":"string and setting ","type":"text"},{"code":"notbol","type":"codeVoice"},{"text":" in the case of a pattern","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"that begins with any kind of lookbehind assertion, such as “\\b”."}]},{"inlineContent":[{"text":"Unless ","type":"text"},{"code":"raw","type":"codeVoice"},{"text":" is specified in the options, ","type":"text"},{"type":"codeVoice","code":"string"},{"text":" must be valid UTF-8.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"A ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/MatchInfo","isActive":true,"type":"reference"},{"type":"text","text":" structure, used to get information on the match, is"},{"text":" ","type":"text"},{"text":"stored in ","type":"text"},{"type":"codeVoice","code":"matchInfo"},{"text":" if not ","type":"text"},{"type":"codeVoice","code":"nil"},{"text":". Note that if ","type":"text"},{"type":"codeVoice","code":"matchInfo"},{"type":"text","text":" is"},{"text":" ","type":"text"},{"type":"text","text":"not "},{"type":"codeVoice","code":"nil"},{"text":" then it is created even if the function returns ","type":"text"},{"code":"false","type":"codeVoice"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"i.e. you must free it regardless if regular expression actually"},{"type":"text","text":" "},{"text":"matched.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"code":"string","type":"codeVoice"},{"type":"text","text":" is not copied and is used in "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/MatchInfo","isActive":true,"type":"reference"},{"type":"text","text":" internally. If"},{"text":" ","type":"text"},{"type":"text","text":"you use any "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/MatchInfo","isActive":true,"type":"reference"},{"text":" method (except ","type":"text"},{"code":"g_match_info_free()","type":"codeVoice"},{"text":") after","type":"text"},{"text":" ","type":"text"},{"text":"freeing or modifying ","type":"text"},{"type":"codeVoice","code":"string"},{"type":"text","text":" then the behaviou