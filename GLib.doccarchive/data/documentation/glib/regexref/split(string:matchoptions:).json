xt","text":"of the substrings will also be returned. If the pattern does not match"},{"type":"text","text":" "},{"text":"anywhere in the string, then the whole string is returned as the first","type":"text"},{"type":"text","text":" "},{"text":"token.","type":"text"}],"schemaVersion":{"major":0,"minor":3,"patch":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"split"},{"text":"(","kind":"text"},{"text":"string","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"gchar","preciseIdentifier":"c:@T@gchar"},{"kind":"text","text":">!, "},{"text":"matchOptions","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:4GLib15RegexMatchFlagsV","text":"RegexMatchFlags","identifier":"doc:\/\/GLib\/documentation\/GLib\/RegexMatchFlags","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"text":"UnsafeMutablePointer","kind":"typeIdentifier","preciseIdentifier":"s:Sp"},{"text":"<","kind":"text"},{"preciseIdentifier":"s:Sp","kind":"typeIdentifier","text":"UnsafeMutablePointer"},{"kind":"text","text":"<"},{"text":"gchar","preciseIdentifier":"c:@T@gchar","kind":"typeIdentifier"},{"text":">?>!","kind":"text"}],"platforms":["macOS"],"languages":["swift"]}]},{"content":[{"text":"Discussion","anchor":"discussion","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"As a special case, the result of splitting the empty string “” is an"},{"type":"text","text":" "},{"type":"text","text":"empty vector, not a vector containing a single string. The reason for"},{"type":"text","text":" "},{"text":"this special case is that being able to represent an empty vector is","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"typically more useful than consistent handling of empty elements. If"},{"type