{"abstract":[{"type":"text","text":"Breaks the string on the pattern, and returns an array of"},{"type":"text","text":" "},{"text":"the tokens. If the pattern contains capturing parentheses,","type":"text"},{"type":"text","text":" "},{"text":"then the text for each of the substrings will also be returned.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"If the pattern does not match anywhere in the string, then the"},{"text":" ","type":"text"},{"text":"whole string is returned as the first token.","type":"text"}],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/regexSplitSimple(pattern:string:compileOptions:matchOptions:)","interfaceLanguage":"swift"},"sections":[],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"metadata":{"roleHeading":"Function","title":"regexSplitSimple(pattern:string:compileOptions:matchOptions:)","externalID":"s:4GLib16regexSplitSimple7pattern6string14compileOptions05matchH0SpySpys4Int8VGSgGSgSPyAHGSg_AnA17RegexCompileFlagsVAA0k5MatchM0VtF","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"regexSplitSimple","kind":"identifier"},{"text":"(","kind":"text"},{"text":"pattern","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"kind":"text","text":"<"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar"},{"kind":"text","text":">!, "},{"kind":"externalParam","text":"string"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SP","text":"UnsafePointer","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","text":"gchar","preciseIdentifier":"c:@T@gchar"},{"kind":"text","text":">!, "},{"text":"compileOptions","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:4GLib17RegexCompileFlagsV","text":"RegexCompileFlags","kind":"typeIdentifier"},{"kind":"text","text":", "},{"kind":"externalParam","text":"matchOptions"},{"text":": ","kind":"text"},