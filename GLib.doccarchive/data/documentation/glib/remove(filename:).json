{"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/remove(filename:)","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"A wrapper for the POSIX "},{"code":"remove()","type":"codeVoice"},{"text":" function. The ","type":"text"},{"type":"codeVoice","code":"remove()"},{"text":" function","type":"text"},{"type":"text","text":" "},{"type":"text","text":"deletes a name from the filesystem."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/remove(filename:)"]}],"sections":[],"metadata":{"role":"symbol","symbolKind":"func","roleHeading":"Function","title":"remove(filename:)","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"remove"},{"kind":"text","text":"("},{"kind":"externalParam","text":"filename"},{"kind":"text","text":": "},{"preciseIdentifier":"s:SP","kind":"typeIdentifier","text":"UnsafePointer"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar","text":"gchar"},{"text":">!) -> ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"}],"modules":[{"name":"GLib"}],"externalID":"s:4GLib6remove8filenameSiSPys4Int8VGSg_tF"},"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"remove","kind":"identifier"},{"kind":"text","text":"("},{"text":"filename","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:SP","kind":"typeIdentifier","text":"UnsafePointer"},{"text":"<","kind":"text"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar"},{"text":">!) -> ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"}],"platforms":["macOS"]}]},{"kind":"content","content":[{"text":"Discussion","type":"heading","level":2,"anchor":"discussion"},{"inlineContent":[{"text":"See your C library manual for more details about how ","type":"text"},{"type":"codeVoice","code":"remove()"},{"type":"text","text":" works"},{"type":"text","text":" "},{"type":"text","text":"on your system. On Unix, "},{"type":"codeVoice","code":"remove()"},{"type":"text","text":" removes also directories, as it"},{"type":"text","text":" "},{"type":"text","text":"calls "},{"code":"unlink()","type":"codeVoice"},{"type":"text","text":" for files and "},{"code":"rmdir()","type":"codeVoice"},{"text":" for directories. On Windows,","type":"text"},{"type":"text","text":" "},{"text":"although ","type":"text"},{"type":"codeVoice","code":"remove()"},{"text":" in the C library only works for files, this","type":"text"},{"text":" ","type":"text"},{"text":"function tries first ","type":"text"},{"type":"codeVoice","code":"remove()"},{"text":" and then if that fails ","type":"text"},{"type":"codeVoice","code":"rmdir()"},{"type":"text","text":", and"},{"type":"text","text":" "},{"text":"thus works for both files and directories. Note however, that on","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Windows, it is in general not possible to remove a file that is"},{"text":" ","type":"text"},{"text":"open to some process, or mapped into memory.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"If this function fails on Windows you can’t infer too much from the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"errno value. "},{"type":"codeVoice","code":"rmdir()"},{"text":" is tried regardless of what caused ","type":"text"},{"code":"remove()","type":"codeVoice"},{"text":" to","type":"text"},{"type":"text","text":" "},{"text":"fail. Any errno value set by ","type":"text"},{"type":"codeVoice","code":"remove()"},{"type":"text","text":" will be overwritten by that"},{"type":"text","text":" "},{"type":"text","text":"set by "},{"code":"rmdir()","type":"codeVoice"},{"type":"text","text":"."}]}]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/GLib