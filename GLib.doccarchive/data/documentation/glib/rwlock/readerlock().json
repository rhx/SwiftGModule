{"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/RWLock","doc:\/\/GLib\/documentation\/GLib\/RWLock\/RWLockProtocol-Implementations"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"readerLock"},{"kind":"text","text":"()"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"inlineContent":[{"text":"Calling ","type":"text"},{"code":"g_rw_lock_reader_lock()","type":"codeVoice"},{"type":"text","text":" while the current thread already"},{"text":" ","type":"text"},{"type":"text","text":"owns a write lock leads to undefined behaviour. Read locks however"},{"text":" ","type":"text"},{"text":"can be taken recursively, in which case you need to make sure to","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"call "},{"code":"g_rw_lock_reader_unlock()","type":"codeVoice"},{"type":"text","text":" the same amount of times."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"It is implementation-defined how many read locks are allowed to be"},{"type":"text","text":" "},{"type":"text","text":"held on the same lock simultaneously. If the limit is hit,"},{"text":" ","type":"text"},{"type":"text","text":"or if a deadlock is detected, a critical warning will be emitted."}],"type":"paragraph"}]}],"metadata":{"title":"readerLock()","externalID":"s:4GLib14RWLockProtocolPAAE10readerLockyyF::SYNTHESIZED::s:4GLib6RWLockC","role":"symbol","extendedModule":"GLib","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"readerLock","kind":"identifier"},{"text":"()","kind":"text"}],"roleHeading":"Instance Method","symbolKind":"method","modules":[{"name":"GLib"}]},"kind":"symbol","identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/RWLock\/readerLock()","interfaceLanguage":"swift"},"schemaVersion":{"major":0,"patch":0,"minor":3},"variants":[{"paths":["\/documentation\/glib\/rwlock\/readerlock()"],"traits":[{"interfaceLanguage":"swift"}]}],"abstract":[{"type":"text","text":"Obtain a read lock on "},{"type":"codeVoice","code":"rwLock"},{"text":". If another thread currently holds","type":"text"},{"text":" ","type":"text"},{"text":"the write lock on ","type":"text"},{"type":"codeVoice","code":"rwLock"},{"type":"text","text":", the current thread will block until the"},{"type":"text","text":" "},{"type":"text","text":"write lock was (held and) released. If another thread does not hold"},{"type":"text","text":" "},{"type":"text","text":"the write lock, but is waiting for it, it is implementation defined"},{"text":" ","type":"text"},{"type":"text","text":"whether the reader or writer will block. Read locks can be taken"},{"text":" ","type":"text"},{"text":"recursively.","type":"text"}],"sections":[],"references":{"doc://GLib/documentation/GLib/RWLock/readerLock()":{"title":"readerLock()","type":"topic","kind":"symbol","url":"\/documentation\/glib\/rwlock\/readerlock()","identifier":"doc:\/\/GLib\/documentation\/GLib\/RWLock\/readerLock()","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"readerLock"},{"text":"()","kind":"text"}],"abstract":[{"text":"Obtain a read lock on ","type":"text"},{"code":"rwLock","type":"codeVoice"},{"text":". If another thread currently holds","type":"text"},{"type":"text","text":" "},{"text":"the write lock on ","type":"text"},{"type":"codeVoice","code":"rwLock"},{"type":"text","text":", the current thread will block until the"},{"type":"text","text":" "},{"text":"write lock was (held and) released. If another thread does not hold","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the write lock, but is waiting for it, it is implementation defined"},{"type":"text","text":" "},{"text":"whether the reader or writer will block. Read locks can be taken","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"recursively."}],"role":"symbol"},"doc://GLib/documentation/GLib":{"kind":"symbol","role":"collection","abstract":[],"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","type":"topic","url":"\/documentation\/glib"},"doc://GLib/documentation/GLib/RWLock":{"abstract":[{"text":"The GRWLock struct is an opaque data structure to represent a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"reader-writer lock. It is similar to a "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex","type":"reference","isActive":true},{"text":" in that it allows","type":"text"},{"type":"text","text":" "},{"text":"multiple threads to coordinate access to a shared resource.","type":"text"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/RWLock","type":"topic","url":"\/documentation\/glib\/rwlock","role":"symbol","kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"RWLock"}],"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"RWLock","kind":"identifier"}],"title":"RWLock"},"doc://GLib/documentation/GLib/Mutex":{"role":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex","url":"\/documentation\/glib\/mutex","title":"Mutex","navigatorTitle":[{"kind":"identifier","text":"Mutex"}],"abstract":[{"type":"text","text":"The "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex"},{"type":"text","text":" struct is an opaque data structure to represent a mutex"},{"type":"text","text":" "},{"type":"text","text":"(mutual exclusion). It can be used to protect data against shared"},{"text":" ","type":"text"},{"text":"access.","type":"text"}],"kind":"symbol","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"Mutex","kind":"identifier"}],"type":"topic"},"doc://GLib/documentation/GLib/RWLock/RWLockProtocol-Implementations":{"abstract":[],"title":"RWLockProtocol Implementations","type":"topic","ur