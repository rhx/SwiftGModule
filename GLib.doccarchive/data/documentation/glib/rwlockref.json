{"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"sections":[],"topicSections":[{"title":"Initializers","generated":true,"anchor":"Initializers","identifiers":["doc:\/\/GLib\/documentation\/GLib\/RWLockRef\/init(_:)-3kjfl","doc:\/\/GLib\/documentation\/GLib\/RWLockRef\/init(_:)-4ny6y","doc:\/\/GLib\/documentation\/GLib\/RWLockRef\/init(_:)-6up5f","doc:\/\/GLib\/documentation\/GLib\/RWLockRef\/init(_:)-8ofb","doc:\/\/GLib\/documentation\/GLib\/RWLockRef\/init(_:)-8tf2d","doc:\/\/GLib\/documentation\/GLib\/RWLockRef\/init(cPointer:)","doc:\/\/GLib\/documentation\/GLib\/RWLockRef\/init(constPointer:)","doc:\/\/GLib\/documentation\/GLib\/RWLockRef\/init(gconstpointer:)","doc:\/\/GLib\/documentation\/GLib\/RWLockRef\/init(gpointer:)","doc:\/\/GLib\/documentation\/GLib\/RWLockRef\/init(mutating:)","doc:\/\/GLib\/documentation\/GLib\/RWLockRef\/init(opaquePointer:)"]},{"title":"Instance Properties","anchor":"Instance-Properties","generated":true,"identifiers":["doc:\/\/GLib\/documentation\/GLib\/RWLockRef\/ptr"]},{"generated":true,"identifiers":["doc:\/\/GLib\/documentation\/GLib\/RWLockRef\/PointerWrapper-Implementations","doc:\/\/GLib\/documentation\/GLib\/RWLockRef\/RWLockProtocol-Implementations"],"title":"Default Implementations","anchor":"Default-Implementations"}],"metadata":{"symbolKind":"struct","navigatorTitle":[{"text":"RWLockRef","kind":"identifier"}],"externalID":"s:4GLib9RWLockRefV","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"text":"RWLockRef","kind":"identifier"}],"roleHeading":"Structure","title":"RWLockRef","modules":[{"name":"GLib"}],"role":"symbol"},"variants":[{"paths":["\/documentation\/glib\/rwlockref"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/RWLockRef"},"schemaVersion":{"minor":3,"major":0,"patch":0},"relationshipsSections":[{"identifiers":["doc:\/\/GLib\/documentation\/GLib\/PointerWrapper","doc:\/\/GLib\/documentation\/GLib\/RWLockProtocol"],"title":"Conforms To","kind":"relationships","type":"conformsTo"}],"kind":"symbol","abstract":[{"text":"The GRWLock struct is an opaque data structure to represent a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"reader-writer lock. It is similar to a "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex"},{"type":"text","text":" in that it allows"},{"text":" ","type":"text"},{"text":"multiple threads to coordinate access to a shared resource.","type":"text"}],"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"RWLockRef","kind":"identifier"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"content":[{"text":"Overview","level":2,"type":"heading","anchor":"overview"},{"type":"paragraph","inlineContent":[{"text":"The difference to a mutex is that a reader-writer lock discriminates","type":"text"},{"type":"text","text":" "},{"type":"text","text":"between read-only (‘reader’) and full (‘writer’) access. While only"},{"type":"text","text":" "},{"type":"text","text":"one thread at a time is allowed write access (by holding the ‘writer’"},{"type":"text","text":" "},{"type":"text","text":"lock via "},{"type":"codeVoice","code":"g_rw_lock_writer_lock()"},{"text":"), multiple threads can gain","type":"text"},{"type":"text","text":" "},{"type":"text","text":"simultaneous read-only access (by holding the ‘reader’ lock via"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_rw_lock_reader_lock()"},{"type":"text","text":")."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"It is unspecified whether readers or writers have priority in acquiring the"},{"type":"text","text":" "},{"text":"lock when a reader already holds the lock and a writer is queued to acquire","type":"text"},{"type":"text","text":" "},{"text":"it.","type":"text"}]},{"inlineContent":[{"text":"Here is an example for an array with access functions:","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"(C Language Example):"}],"type":"paragraph"},{"syntax":"C","code":["  GRWLock lock;","  GPtrArray *array;","","  gpointer","  my_array_get (guint index)","  {","    gpointer retval = NULL;","","    if (!array)","      return NULL;","","    g_rw_lock_reader_lock (&lock);","    if (index < array->len)","      retval = g_ptr_array_index (array, index);","    g_rw_lock_reader_unlock (&lock);","","    return retval;","  }","","  void","  my_array_set (guint index, gpointer data)","  {","    g_rw_lock_writer_lock (&lock);","","    if (!array)","      array = g_ptr_array_new ();","","    if (index >= array->len)","      g_ptr_array_set_size (array, index+1);","    g_ptr_array_index (array, index) = data;","","    g_rw_lock_writer_unlock (&lock);","  }"," "],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"This example shows an array which can be accessed by many readers","type":"text"},{"text":" ","type":"text"},{"text":"(the ","type":"text"},{"code":"my_array_get()","type":"codeVoice"},{"type":"text","text":" function) simultaneously, whereas the writers"},{"text":" ","type":"text"},{"type":"text","text":"(the "},{"type":"codeVoice","code":"my_array_set()"},{"type":"text","text":" function) will only be allowed one at a time"},{"type":"text","text":" "},{"type":"text","text":"and only if no readers currently access the array. This is because"},{"type":"text","text":" "},{"text":"of the potentially dangerous resizing of the array. Using these","type":"text"},{"type":"text","text":" "},{"text":"functions is fully multi-thread safe now.","type":"text"}]},{"inlineContent":[{"type":"text","text":"If a "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/RWLock","isActive":true,"type":"reference"},{"text":" is allocated in static storage then it can be used","type":"text"},{"type":"text","text":" "},{"type":"text","text":"without initialisation.  Otherwise, you should call"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_rw_lock_init()"},{"type":"text","text":" on it and "},{"type":"codeVoice","code":"g_rw_lock_clear()"},{"text":" when done.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"A GRWLock should only be accessed with the g_rw_lock_ functions."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/RWLockRef"},{"text":" type acts as a lightweight Swift reference to an underlying ","type":"text"},{"type":"codeVoice","code":"GRWLock"},{"text":" instance.","type":"text"},{"type":"text","text":" "},{"text":"It exposes methods that can operate on this data type through ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/RWLockProtocol","isActive":true},{"type":"text","text":" conformance."},{"text":" ","type":"text"},{"type":"text","text":"Use "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/RWLockRef"},{"type":"text","text":" only as an "},{"type":"codeVoice","code":"unowned"},{"type":"text","text":" reference to an existing "},{"type":"codeVoice","code":"GRWLock"},{"text":" instance.","type":"text"}]},{"name":"Note","style":"note","content":[{"type":"paragraph","inlineContent":[{"text":"Use ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/RWLock","isActive":true,"type":"reference"},{"type":"text","text":" (instead of "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/RWLockRef","type":"reference","isActive":true},{"text":") if you want to use Automatic Reference Counting for memory management of the underlying ","type":"text"},{"code":"GRWLock","type":"codeVoice"},{"text":" instance.","type":"text"}]}],"type":"aside"}],"kind":"content"}],"references":{"doc://GLib/documentation/GLib/RWLockRef/init(_:)-8tf2d":{"title":"init(_:)","kind":"symbol","url":"\/documentation\/glib