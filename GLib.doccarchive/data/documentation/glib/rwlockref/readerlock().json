{"schemaVersion":{"minor":3,"patch":0,"major":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"readerLock"},{"kind":"text","text":"()"}],"languages":["swift"]}]},{"kind":"content","content":[{"type":"heading","text":"Discussion","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"Calling ","type":"text"},{"code":"g_rw_lock_reader_lock()","type":"codeVoice"},{"type":"text","text":" while the current thread already"},{"type":"text","text":" "},{"text":"owns a write lock leads to undefined behaviour. Read locks however","type":"text"},{"type":"text","text":" "},{"type":"text","text":"can be taken recursively, in which case you need to make sure to"},{"type":"text","text":" "},{"text":"call ","type":"text"},{"code":"g_rw_lock_reader_unlock()","type":"codeVoice"},{"type":"text","text":" the same amount of times."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"It is implementation-defined how many read locks are allowed to be"},{"text":" ","type":"text"},{"type":"text","text":"held on the same lock simultaneously. If the limit is hit,"},{"type":"text","text":" "},{"type":"text","text":"or if a deadlock is detected, a critical warning will be emitted."}]}]}],"sections":[],"metadata":{"modules":[{"name":"GLib"}],"extendedModule":"GLib","role":"symbol","title":"readerLock()","roleHeading":"Instance Method","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"readerLock","kind":"identifier"},{"kind":"text","text":"()"}],"externalID":"s:4GLib14RWLockProtocolPAAE10readerLockyyF::SYNTHESIZED::s:4GLib9RWLockRefV","symbolKind":"method"},"abstract":[{"type":"text","text":"Obtain a read lock on "},{"type":"codeVoice","code":"rwLock"},{"type":"text","text":". If another thread currently holds"},{"text":" ","type":"text"},{"text":"the write lock on ","type":"text"},{"type":"codeVoice","code":"rwLock"},{"text":", the current thread will block until the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"write lock was (held and) released. If another thread does not hold"},{"type":"text","text":" "},{"type":"text","text":"the write lock, but is waiting for it, it is implementation defined"},{"text":" ","type":"text"},{"text":"whether the reader or writer will block. Read locks can be taken","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"recursively."}],"kind":"symbol","variants":[{"paths":["\/documentation\/glib\/rwlockref\/readerlock()"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/RWLockRef","doc:\/\/GLib\/documentation\/GLib\/RWLockRef\/RWLockProtocol-Implementations"]]},"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/RWLockRef\/readerLock()","interfaceLanguage":"swift"},"references":{"doc://GLib/documentation/GLib/Mutex":{"role":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex","url":"\/documentation\/glib\/mutex","title":"Mutex","navigatorTitle":[{"kind":"identifier","text":"Mutex"}],"abstract":[{"type":"text","text":"The "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex"},{"type":"text","text":" struct is an opaque data structure to represent a mutex"},{"type":"text","text":" "},{"type":"text","text":"(mutual exclusion). It can be used to protect data against shared"},{"text":" ","type":"text"},{"text":"access.","type":"text"}],"kind":"symbol","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"Mutex","kind":"identifier"}],"type":"topic"},"doc://GLib/documentation/GLib/RWLockRef/RWLockProtocol-Implementations":{"type":"topic","title":"RWLockProtocol Implementations","role":"collectionGroup","abstract":[],"identifier":"doc:\/\/GLib\/documentation\/GLib\/RWLockRef\/RWLockProtocol-Implementations","kind":"article","url":"\/documentation\/glib\/rwlockref\/rwlockprotocol-implementations"},"doc://GLib/documentation/GLib/RWLockRef":{"abstract":[{"text":"The GRWLock struct is an opaque data structure to represent a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"reader-writer lock. It is similar to a "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex","type":"reference","isActive":true},{"text":" in that it allows","type":"text"},{"type":"text","text":" "},{"type":"text","text":"multiple threads to coordinate access to a shared resource."}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/RWLockRef","title":"RWLockRef","role":"symbol","type":"topic","navigatorTitle":[{"text":"RWLockRef","kind":"identifier"}],"kind":"symbol","url":"\/documentation\/glib\/rwlockref","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"kind":"identifier","text":"RWLockRef"}]},"doc://GLib/documentation/GLib/RWLockRef/readerLock()":{"role":"symbol","abstract":[{"type":"text","text":"Obtain a read lock on "},{"type":"codeVoice","code":"rwLock"},{"type":"text","text":". If another thread currently holds"},{"text":" ","type":"text"},{"type":"text","text":"the write lock on "},{"code":"rwLock","type":"codeVoice"},{"text":", the current thread will block until the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"write lock was (held and) released. If another thread does not hold"},{"type":"text","text":" "},{"type":"text","text":"the write lock, but is waiting for it, it is implementation defined"},{"type":"text","text":" "},{"text":"whether the reader or writer will block. Read locks can be taken","type":"text"},{"type":"text","text":" "},{"text":"recursively.","type":"text"}],"kind":"symbol","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"readerLock"},{"text":"()","kind":"text"}],"url":"\/documentation\/glib\/rwlockref\/readerlock()","title":"readerLock()","type":"topic","identifier":"doc