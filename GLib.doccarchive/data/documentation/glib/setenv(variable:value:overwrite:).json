","kind":"text"},{"kind":"externalParam","text":"overwrite"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"},{"kind":"text","text":") -> "},{"preciseIdentifier":"s:Sb","kind":"typeIdentifier","text":"Bool"}],"languages":["swift"]}],"kind":"declarations"},{"content":[{"text":"Discussion","level":2,"anchor":"discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Note that on some systems, when variables are overwritten, the memory","type":"text"},{"type":"text","text":" "},{"text":"used for the previous variables and its value isn’t reclaimed.","type":"text"}]},{"inlineContent":[{"type":"text","text":"You should be mindful of the fact that environment variable handling"},{"text":" ","type":"text"},{"text":"in UNIX is not thread-safe, and your program may crash if one thread","type":"text"},{"type":"text","text":" "},{"text":"calls ","type":"text"},{"type":"codeVoice","code":"g_setenv()"},{"type":"text","text":" while another thread is calling "},{"type":"codeVoice","code":"getenv()"},{"type":"text","text":". (And note"},{"text":" ","type":"text"},{"type":"text","text":"that many functions, such as "},{"code":"gettext()","type":"codeVoice"},{"type":"text","text":", call "},{"code":"getenv()","type":"codeVoice"},{"text":" internally.)","type":"text"},{"text":" ","type":"text"},{"text":"This function is only safe to use at the very start of your program,","type":"text"},{"type":"text","text":" "},{"text":"before creating any other threads (or creating objects that create","type":"text"},{"text":" ","type":"text"},{"text":"worker threads of their own).","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"If you need to set up the environment for a child process, you can","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"use "},{"type":"codeVoice","code":"g_get_environ()"},{"type":"text","text":" to get an environment array, modify that with"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_environ_setenv()"},{"text":" and ","type":"text"},{"code":"g_environ_unsetenv()","type":"codeVoice"},{"type":"text","text":", and then pass that"},{"type":"text","text":" "},{"type":"text","text":"array directly to "},{"code":"execvpe()","type":"codeVoice"},{"text":", ","type":"text"},{"code":"g_spawn_async()","type":"codeVoice"},{"type":"text","text":", or the like."}]}],"kind":"content"}],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/setenv(variable:value:overwrite:)","interfaceLanguage":"swift"},"kind":"symbol","sections":[],"variants":[{"paths":["\/documentation\/glib\/setenv(variable:value:overwrite:)"],"traits":[{"interfaceLanguage":"swift"}]}],"abstract":[{"text":"Sets an environment variable. On UNIX, both the variable’s name and","type":"text"},{"type":"text","text":" "},{"type":"text","text":"value can be arbitrary byte strings, except that the variable’s name"},{"type":"text","text":" "},{"text":"cannot contain ‘=’. On Windows, they should be in UTF-8.","type":"text"}],"references":{"doc://GLib/documentation/GLib":{"kind":"symbol","role":"collection","abstract":[],"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","type":"topic","url":"\/documentation\/glib"},"doc://GLib/documentation/GLib/setenv(variable:value:overwrite:)":{"abstract":[{"type":"text","text":"Sets an environment variable. On UNIX, both the variable’s name and"},{"type":"text","text":" "},{"type":"text","text":"value can be arbitrary byte strings, except that the variable’s name"},{"text":" ","type":"text"},{"type":"text","text":"cannot contain ‘=’. On Windows, they should be in UTF-8."}],"role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"setenv","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"variable"},{"kind":"text","text":": "},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"kind":"typeIdent