quoting rules are a bit strange. Single quotes preserve the"},{"text":" ","type":"text"},{"type":"text","text":"literal string exactly. escape sequences are not allowed; not even"},{"text":" ","type":"text"},{"type":"codeVoice","code":"\\'"},{"text":" - if you want a ","type":"text"},{"type":"codeVoice","code":"'"},{"text":" in the quoted text, you have to do something","type":"text"},{"text":" ","type":"text"},{"text":"like ","type":"text"},{"type":"codeVoice","code":"'foo'\\''bar'"},{"text":". Double quotes allow ","type":"text"},{"type":"codeVoice","code":"$"},{"type":"text","text":", ```, "},{"code":"\"","type":"codeVoice"},{"text":", ``, and","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"newline to be escaped with backslash. Otherwise double quotes"},{"type":"text","text":" "},{"type":"text","text":"preserve things literally."}],"type":"paragraph"}]}],"references":{"doc://GLib/documentation/GLib":{"kind":"symbol","role":"collection","abstract":[],"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","type":"topic","url":"\/documentation\/glib"},"doc://GLib/documentation/GLib/shellUnquote(quotedString:)":{"role":"symbol","abstract":[{"text":"Unquotes a string as the shell (\/bin\/sh) would.","type":"text"}],"kind":"symbol","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"shellUnquote","kind":"identifier"},{"kind":"text","text":"("},{"text":"quotedString","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SP","text":"UnsafePointer","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"preciseIdentifier":"c:@T@gchar","text":"gchar","kind":"typeIdentifier"},{"text":">!) ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"preciseIdentifier":"s:SS","kind":"typeIdentifier","text":"String"},{"kind":"text","text":"!"}],"url":"\/documentation\/glib\/shellunquote(quotedstring:)","title":"shellUnquote(quotedString:)","type":"topic","identifier":"doc:\/\/GL