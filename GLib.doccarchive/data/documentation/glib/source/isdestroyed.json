{"metadata":{"role":"symbol","extendedModule":"GLib","externalID":"s:4GLib14SourceProtocolPAAE11isDestroyedSbvp::SYNTHESIZED::s:4GLib6SourceC","roleHeading":"Instance Property","title":"isDestroyed","symbolKind":"property","modules":[{"name":"GLib"}],"fragments":[{"text":"var","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"isDestroyed"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sb","kind":"typeIdentifier","text":"Bool"}]},"abstract":[{"type":"text","text":"Returns whether "},{"code":"source","type":"codeVoice"},{"text":" has been destroyed.","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/source\/isdestroyed"]}],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/Source\/isDestroyed","interfaceLanguage":"swift"},"sections":[],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/Source","doc:\/\/GLib\/documentation\/GLib\/Source\/SourceProtocol-Implementations"]]},"kind":"symbol","schemaVersion":{"major":0,"minor":3,"patch":0},"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"isDestroyed","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"},{"kind":"text","text":" { "},{"kind":"keyword","text":"get"},{"kind":"text","text":" }"}],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"content","content":[{"type":"heading","level":2,"anchor":"discussion","text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This is important when you operate upon your objects"},{"text":" ","type":"text"},{"text":"from within idle handlers, but may have freed the object","type":"text"},{"text":" ","type":"text"},{"text":"before the dispatch of your idle handler.","type":"text"}]},{"code":["static gboolean","idle_callback (gpointer data)","{","  SomeWidget *self = data;","   ","  g_mutex_lock (&self->idle_id_mutex);","  \/\/ do stuff with self","  self->idle_id = 0;","  g_mutex_unlock (&self->idle_id_mutex);","   ","  return G_SOURCE_REMOVE;","}"," ","static void","some_widget_do_stuff_later (SomeWidget *self)","{","  g_mutex_lock (&self->idle_id_mutex);","  self->idle_id = g_idle_add (idle_callback, self);","  g_mutex_unlock (&self->idle_id_mutex);","}"," ","static void","some_widget_init (SomeWidget *self)","{","  g_mutex_init (&self->idle_id_mutex);","","  \/\/ ...","}","","static void","some_widget_finalize (GObject *object)","{","  SomeWidget *self = SOME_WIDGET (object);","   ","  if (self->idle_id)","    g_source_remove (self->idle_id);","   ","  g_mutex_clear (&self->idle_id_mutex);","","  G_OBJECT_CLASS (parent_class)->finalize (object);","}"],"type":"codeListing","syntax":"c"},{"type":"paragraph","inlineContent":[{"text":"This will fail in a multi-threaded application if the","type":"text"},{"type":"text","text":" "},{"text":"widget is destroyed before the idle handler fires due","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"to the use after free in the callback. A solution, to"},{"type":"text","text":" "},{"text":"this particular problem, is to check to if the source","type":"text"},{"type":"text","text":" "},{"text":"has already been destroy within the callback.","type":"text"}]},{"syntax":"c","type":"codeListing","code":["static gboolean","idle_callback (gpointer data)","{","  SomeWidget *self = data;","  ","  g_mutex_lock (&self->idle_id_mutex);","  if (!g_source_is_destroyed (g_main_current_source ()))","    {","      \/\/ do stuff with self","    }","  g_mutex_unlock (&self->idle_id_mutex);","  ","  return FALSE;","}"]},{"inlineContent":[{"text":"Calls to this function from a thread other than the one acquired by the","type":"text"},{"text":" ","type":"text"},{"text":"[struct","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/MainContext","type":"reference","isActive":true},{"text":"] the [struct","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Source","type":"reference","isActive":true},{"type":"text","text":"] is attached to are typically"},{"text":" ","type":"text"},{"type":"text","text":"redundant, as the source could be destroyed immediately after this function"},{"type":"text","text":" "},{"text":"returns. However, once a source is destroyed it cannot be un-destroyed, so","type":"text"},{"type":"text","text":" "},{"text":"this function can be used for opportunistic checks from any thread.","type":"text"}],"type":"paragraph"}]}],"references":{"doc://GLib/documentation/GLib/Source":{"role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Source","kind":"identifier"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/Source","kind":"symbol","url":"\/documentation\/glib\/source","navigatorTitle":[{"text":"Source","kind":"identifier"}],"abstract":[{"type":"text","text":"The "},{"code":"GSource","type":"codeVoice"},{"text":" struct is an opaque data type","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"representing an event source."}],"title":"Source","type":"topic"},"doc://GLib/documentation/GLib/Source/SourceProtocol-Implementations":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Source\/SourceProtocol-Implementations","abstract":[],"kind":"article","role":"collectionGroup","type":"topic","url":"\/documentation\/glib\/source\/sourceprotocol-implementations","title":"SourceProtocol Implementations"},"doc://GLib/documentation/GLib/Source/isDestroyed":{"abstract":[{"type":"text","text":"Returns whether "},{"type":"codeVoice","code":"source"},{"type":"text","text":" has been destroyed."}],"title":"isDestroyed","url":"\/documentation\/glib\/source\/isdestroyed","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"isDestroyed","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"}],"