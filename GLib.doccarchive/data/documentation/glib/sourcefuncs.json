{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/SourceFuncs"},"schemaVersion":{"major":0,"patch":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"kind":"symbol","sections":[],"abstract":[{"text":"The ","type":"text"},{"code":"GSourceFuncs","type":"codeVoice"},{"type":"text","text":" struct contains a table of"},{"type":"text","text":" "},{"text":"functions used to handle event sources in a generic manner.","type":"text"}],"variants":[{"paths":["\/documentation\/glib\/sourcefuncs"],"traits":[{"interfaceLanguage":"swift"}]}],"relationshipsSections":[{"title":"Conforms To","kind":"relationships","type":"conformsTo","identifiers":["doc:\/\/GLib\/documentation\/GLib\/PointerWrapper","doc:\/\/GLib\/documentation\/GLib\/SourceFuncsProtocol"]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"SourceFuncs","kind":"identifier"}]}]},{"content":[{"type":"heading","text":"Overview","anchor":"overview","level":2},{"type":"paragraph","inlineContent":[{"text":"For idle sources, the prepare and check functions always return ","type":"text"},{"type":"codeVoice","code":"true"},{"text":" ","type":"text"},{"type":"text","text":"to indicate that the source is always ready to be processed. The prepare"},{"text":" ","type":"text"},{"type":"text","text":"function also returns a timeout value of 0 to ensure that the "},{"type":"codeVoice","code":"poll()"},{"text":" call","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"doesn’t block (since that would be time wasted which could have been spent"},{"text":" ","type":"text"},{"text":"running the idle function).","type":"text"}]},{"inlineContent":[{"text":"For timeout sources, the prepare and check functions both return ","type":"text"},{"type":"codeVoice","code":"true"},{"type":"text","text":" "},{"text":"if the timeout interval has expired. The prepare function also returns","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"a timeout value to ensure that the "},{"type":"codeVoice","code":"poll()"},{"type":"text","text":" call doesn’t block too long"},{"text":" ","type":"text"},{"text":"and miss the next timeout.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"For file descriptor sources, the prepare function typically returns "},{"code":"false","type":"codeVoice"},{"text":",","type":"text"},{"type":"text","text":" "},{"type":"text","text":"since it must wait until "},{"code":"poll()","type":"codeVoice"},{"text":" has been called before it knows whether","type":"text"},{"type":"text","text":" "},{"type":"text","text":"any events need to be processed. It sets the returned timeout to -1 to"},{"type":"text","text":" "},{"type":"text","text":"indicate that it doesn’t mind how long the "},{"code":"poll()","type":"codeVoice"},{"text":" call blocks. In the","type":"text"},{"text":" ","type":"text"},{"text":"check function, it tests the results of the ","type":"text"},{"type":"codeVoice","code":"poll()"},{"type":"text","text":" call to see if the"},{"type":"text","text":" "},{"text":"required condition has been met, and returns ","type":"text"},{"code":"true","type":"codeVoice"},{"type":"text","text":" if so."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/SourceFuncs"},{"text":" type acts as an owner of an underlying ","type":"text"},{"type":"codeVoice","code":"GSourceFuncs"},{"text":" instance.","type":"text"},{"type":"text","text":" "},{"text":"It provides the methods that can operate on this data type through ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/SourceFuncsProtocol","isActive":true,"type":"reference"},{"type":"text","text":" conformance."},{"type":"text","text":" "},{"type":"text","text":"Use "}