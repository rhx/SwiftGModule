{"metadata":{"navigatorTitle":[{"kind":"identifier","text":"SourceFuncsPrepareFunc"}],"role":"symbol","modules":[{"name":"GLib"}],"symbolKind":"typealias","externalID":"s:4GLib22SourceFuncsPrepareFunca","fragments":[{"text":"typealias","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"SourceFuncsPrepareFunc"}],"roleHeading":"Type Alias","title":"SourceFuncsPrepareFunc"},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/SourceFuncsPrepareFunc"},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"variants":[{"paths":["\/documentation\/glib\/sourcefuncspreparefunc"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"abstract":[{"text":"Checks the source for readiness.","type":"text"}],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"typealias"},{"text":" ","kind":"text"},{"kind":"identifier","text":"SourceFuncsPrepareFunc"},{"text":" = ","kind":"text"},{"preciseIdentifier":"c:@T@GSourceFuncsPrepareFunc","kind":"typeIdentifier","text":"GSourceFuncsPrepareFunc"}],"languages":["swift"]}],"kind":"declarations"},{"content":[{"type":"heading","text":"Discussion","anchor":"discussion","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Called before all the file descriptors are polled. If the"},{"type":"text","text":" "},{"type":"text","text":"source can determine that it is ready here (without waiting for the"},{"type":"text","text":" "},{"text":"results of the poll call) it should return ","type":"text"},{"code":"true","type":"codeVoice"},{"type":"text","text":". It can also return"},{"type":"text","text":" "},{"type":"text","text":"a "},{"type":"codeVoice","code":"timeout"},{"text":" value which should be the maximum timeout (in milliseconds)","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"which should be passed to the poll call. The actual timeout used will"},{"text":" ","type":"text"},{"type":"text","text":"be "},{"code":"-1","type":"codeVoice"},{"type":"text","text":" if all sources returned "},{"code":"-1","type":"codeVoice"},{"type":"text","text":", or it will be the minimum of all"},{"text":" ","type":"text"},{"text":"the ","type":"text"},{"code":"timeout","type":"codeVoice"},{"type":"text","text":" values returned which were greater than or equal to "},{"type":"codeVoice","code":"0"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"If the prepare function returns a timeout and the source also has a","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"ready time set, then the lower of the two will be used."}]},{"inlineContent":[{"type":"text","text":"Since 2.36 this may be "},{"code":"NULL","type":"codeVoice"},{"text":", in which case the effect is as if the","type":"text"},{"type":"text","text":" "},{"text":"function always returns ","type":"text"},{"code":"FALSE","type":"codeVoice"},{"type":"text","text":" with a timeout of "},{"code":"-1","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"}],"kind":"content"}],"kind":"symbol","references":{"doc://GLib/documentation/GLib/SourceFuncsPrepareFunc":{"url":"\/documentation\/glib\/sourcefuncspreparefunc","kind":"symbol","abstract":[{"text":"Checks the source for readiness.","type":"text"}],"role":"symbol","navigatorTitle":[{"text":"SourceFuncsPrepareFunc","kind":"identifier"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/SourceFuncsPrepareFunc","type":"topic","fragments":[{"text":"typealias","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SourceFuncsPrepareFunc","kind":"identifier"}],"title":"SourceFuncsPrepareFunc"},"doc://GLib/documentation/GLib":{"kind":"symbol","role":"collection","abstract":[],"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","type":"topic","url":"\/documentation\/glib"}}}