{"schemaVersion":{"minor":3,"major":0,"patch":0},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/SourceFuncsRef\/SourceFuncsProtocol-Implementations"},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/SourceFuncsRef"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/sourcefuncsref\/sourcefuncsprotocol-implementations"]}],"sections":[],"metadata":{"title":"SourceFuncsProtocol Implementations","role":"collectionGroup","roleHeading":"API Collection","modules":[{"name":"GLib"}]},"kind":"article","topicSections":[{"title":"Instance Properties","generated":true,"anchor":"Instance-Properties","identifiers":["doc:\/\/GLib\/documentation\/GLib\/SourceFuncsRef\/check","doc:\/\/GLib\/documentation\/GLib\/SourceFuncsRef\/dispatch","doc:\/\/GLib\/documentation\/GLib\/SourceFuncsRef\/finalize","doc:\/\/GLib\/documentation\/GLib\/SourceFuncsRef\/prepare"]},{"title":"Instance Methods","anchor":"Instance-Methods","identifiers":["doc:\/\/GLib\/documentation\/GLib\/SourceFuncsRef\/sourceRemoveByFuncs(userData:)"],"generated":true}],"references":{"doc://GLib/documentation/GLib/SourceFuncsRef":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/SourceFuncsRef","title":"SourceFuncsRef","type":"topic","role":"symbol","navigatorTitle":[{"text":"SourceFuncsRef","kind":"identifier"}],"abstract":[{"type":"text","text":"The "},{"code":"GSourceFuncs","type":"codeVoice"},{"type":"text","text":" struct contains a table of"},{"text":" ","type":"text"},{"type":"text","text":"functions used to handle event sources in a generic manner."}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SourceFuncsRef","kind":"identifier"}],"kind":"symbol","url":"\/documentation\/glib\/sourcefuncsref"},"doc://GLib/documentation/GLib/SourceFuncsRef/sourceRemoveByFuncs(userData:)":{"fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"sourceRemoveByFuncs"},{"text":"(","kind":"text"},{"text":"userData","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"gpointer","preciseIdentifier":"c:@T@gpointer"},{"kind":"text","text":"?) -> "},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"}],"url":"\/documentation\/glib\/sourcefuncsref\/sourceremovebyfuncs(userdata:)","title":"sourceRemoveByFuncs(userData:)","type":"topic","abstract":[{"text":"Removes a source from the default main loop context given the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"source functions and user data."}],"kind":"symbol","role":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/SourceFuncsRef\/sourceRemoveByFuncs(userData:)"},"doc://GLib/documentation/GLib/SourceFuncsRef/dispatch":{"role":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/SourceFuncsRef\/dispatch","fragments":[{"text":"var","kind":"keyword"},{"kind":"text","text":" "},{"text":"dispatch","kind":"identifier"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@GSourceFuncsDispatchFunc","text":"GSourceFuncsDispatchFunc"},{"text":"!","kind":"text"}],"kind":"symbol","url":"\/documentation\/glib\/sourcefuncsref\/dispatch","title":"dispatch","abstract":[{"type":"text","text":"Called to dispatch the event source, after it has returned"},{"type":"text","text":" "},{"code":"true","type":"codeVoice"},{"type":"text","text":" in either its "},{"type":"codeVoice","code":"prepare"},{"type":"text","text":" or its "},{"type":"codeVoice","code":"check"},{"text":" function, or if a ready time","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"has been reached. The "},{"code":"dispatch","type":"codeVoice"},{"text":" function receives a callback function and","type":"text"},{"type":"text","text":" "},{"text":"user data. The callback function may be ","type":"text"},{"type":"codeVoice","code":"nil"},{"type":"text","text":" if the source was never"},{"text":" ","type":"text"},{"type":"text","text":"connected to a callback using [method"},{"type":"codeVoice","code":"GLib.Source.set_callback"},{"text":"]. The","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"dispatch"},{"type":"text","text":" function should call the callback function with "},{"type":"codeVoice","code":"user_data"},{"text":" and","type":"text"},{"type":"text","text":" "},{"type":"text","text":"whatever additional parameters are needed for this type of event source."},{"text":" ","type":"text"},{"text":"The return value of the ","type":"text"},{"type":"codeVoice","code":"dispatch"},{"type":"text","text":" function should be"},{"type":"text","text":" "},{"text":"[const","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/sourceRemove","isActive":true,"type":"reference"},{"type":"text","text":"] if the source should be removed or"},{"type":"text","text":" "},{"type":"text","text":"[const"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/sourceContinue"},{"text":"] to keep it.","type":"text"}],"type":"topic"},"doc://GLib/documentation/GLib/SourceFuncsRef/check":{"fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"check"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"GSourceFuncsCheckFunc","preciseIdentifier":"c:@T@GSourceFuncsCheckFunc"},{"kind":"text","text":"!"}],"url":"\/documentation\/glib\/sourcefuncsref\/check","title":"check","type":"topic","abstract":[{"text":"Called after all the file descriptors are polled. The","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"source should return "},{"code":"true","type":"codeVoice"},{"type":"text","text":" if it is ready to be dispatched. Note that"},{"text":" ","type":"text"},{"text":"some time may have passed since the previous prepare function was called,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"so the source should be checked again here.  Since 2.36 this may"},{"type":"text","text":" "},{"text":"be ","type":"text"},{"code":"nil","type":"codeVoice"},{"type":"text","text":", in which case the effect is as if the function always returns"},{"type":"text","text":" "},{"type":"codeVoice","code":"false"},{"type":"text","text":"."}],"kind":"symbol","role":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/SourceFuncsRef\/check"},"doc://GLib/documentation/GLib/SourceFuncsRef/finalize":{"role":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/SourceFuncsRef\/finalize","fragments":[{"text":"var","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"finalize"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"GSourceFuncsFinalizeFunc","preciseIdentifier":"c:@T@GSourceFuncsFinalizeFunc"},{"kind":"text","text":"!"}],"kind":"symbol","url":"\/documentation\/glib\/sourcefuncsref\/finalize","title":"finalize","abstract":[{"type":"text","text":"Called when the source is finalized. At this point,"},{"text":" ","type":"text"},{"type":"text","text":"the source will have been destroyed, had its callback cleared, and have"},{"type":"text","text":" "},{"text":"been removed from its [struct","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/MainContext","isActive":true,"type":"reference"},{"type":"text","text":"], but it will still have"},{"type":"text","text":" "},{"type":"text","text":"its final reference count, so methods can be called on it from within"},{"text":" ","type":"text"},{"text":"this function. This may be ","type":"text"},{"type":"codeVoice","code":"nil"},{"type":"text","text":", in which case the effect is as if the"},{"type":"text","text":" "},{"text":"function does nothing and returns.","type":"text"}],"type":"topic"},"doc://GLib/documentation/GLib/SourceFuncsRef/prepare":{"fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"prepare"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@GSourceFuncsPrepareFunc","text":"GSourceFuncsPrepareFunc"},{"text":"!","kind":"text"}],"url":"\/documentation\/glib\/sourcefuncsref\/prepare","title":"prepare","type":"topic","abstract":[{"text":"Called before all the file descriptors are polled. If","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the source can determine that it is ready here (without waiting for the"},{"type":"text","text":" "},{"text":"results of the ","type":"text"},{"code":"poll()","type":"codeVoice"},{"type":"text","text":" call) it should return "},{"type":"codeVoice","code":"true"},{"type":"text","text":". It can also return"},{"text":" ","type":"text"},{"text":"a ","type":"text"},{"code":"timeout_","type":"codeVoice"},{"type":"text","text":" value which should be the maximum timeout (in milliseconds)"},{"text":" ","type":"text"},{"type":"text","text":"which should be passed to the "},{"type":"codeVoice","code":"poll()"},{"type":"text","text":" call. The actual timeout used will"},{"text":" ","type":"text"},{"type":"text","text":"be -1 if all sources returned -1, or it will be the minimum of all"},{"type":"text","text":" "},{"text":"the ","type":"text"},{"type":"codeVoice","code":"timeout_"},{"text":" values returned which were >= 0.  Since 2.36 this may","type":"text"},{"type":"text","text":" "},{"type":"text","text":"be "},{"code":"nil","type":"codeVoice"},{"type":"text","text":", in which case the effect is as if the function always returns"},{"text":" ","type":"text"},{"code":"false","type":"codeVoice"},{"type":"text","text":" with a timeout of -1.  If "},{"code":"prepare","type":"codeVoice"},{"text":" returns a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"timeout and the source also has a ready time set, then the"},{"type":"text","text":" "},{"type":"text","text":"lower of the two will be used."}],"kind":"symbol","role":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/SourceFuncsRef\/prepare"},"doc://GLib/documenta