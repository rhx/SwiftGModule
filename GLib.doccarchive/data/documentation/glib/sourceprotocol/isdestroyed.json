{"metadata":{"role":"symbol","fragments":[{"kind":"keyword","text":"var"},{"text":" ","kind":"text"},{"kind":"identifier","text":"isDestroyed"},{"text":": ","kind":"text"},{"text":"Bool","preciseIdentifier":"s:Sb","kind":"typeIdentifier"}],"symbolKind":"property","externalID":"s:4GLib14SourceProtocolPAAE11isDestroyedSbvp","title":"isDestroyed","modules":[{"name":"GLib"}],"extendedModule":"GLib","roleHeading":"Instance Property"},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"var"},{"text":" ","kind":"text"},{"kind":"identifier","text":"isDestroyed"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sb","kind":"typeIdentifier","text":"Bool"},{"text":" { ","kind":"text"},{"text":"get","kind":"keyword"},{"text":" }","kind":"text"}]}]},{"kind":"content","content":[{"anchor":"discussion","text":"Discussion","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This is important when you operate upon your objects"},{"text":" ","type":"text"},{"type":"text","text":"from within idle handlers, but may have freed the object"},{"text":" ","type":"text"},{"text":"before the dispatch of your idle handler.","type":"text"}]},{"code":["static gboolean","idle_callback (gpointer data)","{","  SomeWidget *self = data;","   ","  g_mutex_lock (&self->idle_id_mutex);","  \/\/ do stuff with self","  self->idle_id = 0;","  g_mutex_unlock (&self->idle_id_mutex);","   ","  return G_SOURCE_REMOVE;","}"," ","static void","some_widget_do_stuff_later (SomeWidget *self)","{","  g_mutex_lock (&self->idle_id_mutex);","  self->idle_id = g_idle_add (idle_callback, self);","  g_mutex_unlock (&self->idle_id_mutex);","}"," ","static void","some_widget_init (SomeWidget *self)","{","  g_mutex_init (&self->idle_id_mutex);","","  \/\/ ...","}","","static void","some_widget_finalize (GObject *object)","{","  SomeWidget *self = SOME_WIDGET (object);","   ","  if (self->idle_id)","    g_source_remove (self->idle_id);","   ","  g_mutex_clear (&self->idle_id_mutex);","","  G_OBJECT_CLASS (parent_class)->finalize (object);","}"],"syntax":"c","type":"codeListing"},{"inlineContent":[{"type":"text","text":"This will fail in a multi-threaded application if the"},{"text":" ","type":"text"},{"text":"widget is destroyed before the idle handler fires due","type":"text"},{"text":" ","type":"text"},{"text":"to the use after free in the callback. A solution, to","type":"text"},{"type":"text","text":" "},{"text":"this particular problem, is to check to if the source","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"has already been destroy within the callback."}],"type":"paragraph"},{"syntax":"c","code":["static gboolean","idle_callback (gpointer data)","{","  SomeWidget *self = data;","  ","  g_mutex_lock (&self->idle_id_mutex);","  if (!g_source_is_destroyed (g_main_current_source ()))","    {","      \/\/ do stuff with self","    }","  g_mutex_unlock (&self->idle_id_mutex);","  ","  return FALSE;","}"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"Calls to this function from a thread other than the one acquired by the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"[struct"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/MainContext"},{"type":"text","text":"] the [struct"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Source","isActive":true},{"text":"] is attached to are typically","type":"text"},{"text":" ","type":"text"},{"text":"redundant, as the source could be destroyed immediately after this function","type":"text"},{"type":"text","text":" "},{"text":"returns. However, once a source is destroyed it cannot be un-destroyed, so","type":"text"},{"type":"text","text":" "},{"type":"text","text":"this function can be used for opportunistic checks from any thread."}]}]}],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/SourceProtocol\/isDestroyed","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/SourceProtocol"]]},"schemaVersion":{"major":0,"patch":0,"minor":3},"kind":"symbol","sections":[],"abstract":[{"type":"text","text":"Returns whether "},{"type":"codeVoice","code":"source"},{"type":"text","text":" has been destroyed."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/sourceprotocol\/isdestroyed"]}],"references":{"doc://GLib/documentation/GLib/SourceProtocol":{"navigatorTitle":[{"text":"SourceProtocol","kind":"identifier"}],"url":"\/documentation\/glib\/sourceprotocol","abstract":[{"type":"text","text":"The "},{"code":"GSource","type":"codeVoice"},{"type":"text","text":" struct is an opaque data type"},{"text":" ","type":"text"},{"text":"representing an event source.","type":"text"}],"title":"SourceProtocol","identifier":"doc:\/\/GLib\/documentation\/GLib\/SourceProtocol","kind":"symbol","role":"symbol","type":"topic","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"text":"SourceProtocol","kind":"identifier"}]},"doc://GLib/documentation/GLib/SourceProtocol/isDestroyed":{"kind":"symbol","title":"isDestroyed","abstract":[{"type":"text","text":"Returns whether "},{"type":"codeVoice","code":"source"},{"type":"text","text":" has been destroyed."}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/SourceProtocol\/isDestroyed","role":"symbol","fragments":[{"kind":"keyword","text":"var"},{"text":" ","kind":"text"},{"kind":"identifier","text":"isDestroyed"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"}],"type":"topic","url":"\/documentation\/glib\/sourceprotocol\/isdestroyed"},"doc://GLib/documentation/GLib":{"kind":"symbol","role":"collection","abstract":[],"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","type":"topic","url":"\/documentation\/glib"},"doc://GLib/documentation/GLib/MainConte