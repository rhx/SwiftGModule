{"schemaVersion":{"major":0,"minor":3,"patch":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"var","kind":"keyword"},{"kind":"text","text":" "},{"text":"id","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"text":" { ","kind":"text"},{"text":"get","kind":"keyword"},{"text":" }","kind":"text"}],"platforms":["macOS"],"languages":["swift"]}]},{"content":[{"anchor":"discussion","text":"Discussion","level":2,"type":"heading"},{"inlineContent":[{"text":"The ID of a source","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"is a positive integer which is unique within a particular main loop"},{"type":"text","text":" "},{"type":"text","text":"context. The reverse mapping from ID to source is done by"},{"type":"text","text":" "},{"text":"[method","type":"text"},{"code":"GLib.MainContext.find_source_by_id","type":"codeVoice"},{"text":"].","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"You can only call this function while the source is associated to a"},{"text":" ","type":"text"},{"type":"text","text":"[struct"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/MainContext","isActive":true,"type":"reference"},{"text":"] instance; calling this function before","type":"text"},{"type":"text","text":" "},{"text":"[method","type":"text"},{"code":"GLib.Source.attach","type":"codeVoice"},{"text":"] or after [method","type":"text"},{"type":"codeVoice","code":"GLib.Source.destroy"},{"text":"] yields","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"undefined behavior. The ID returned is unique within the"},{"type":"text","text":" "},{"type":"text","text":"[struct"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/MainContext","isActive":true,"type":"reference"},{"text":"] instance passed to [method","type":"text"},{"type":"codeVoice","code":"GLib.Source.attach"},{"text":"].","type":"text"}],"type":"paragraph"}],"kind":"