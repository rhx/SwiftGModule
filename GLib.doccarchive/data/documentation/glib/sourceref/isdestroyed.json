{"schemaVersion":{"minor":3,"major":0,"patch":0},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"var","kind":"keyword"},{"kind":"text","text":" "},{"text":"isDestroyed","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"},{"text":" { ","kind":"text"},{"kind":"keyword","text":"get"},{"text":" }","kind":"text"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"content","content":[{"type":"heading","anchor":"discussion","text":"Discussion","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"This is important when you operate upon your objects"},{"type":"text","text":" "},{"type":"text","text":"from within idle handlers, but may have freed the object"},{"type":"text","text":" "},{"text":"before the dispatch of your idle handler.","type":"text"}]},{"code":["static gboolean","idle_callback (gpointer data)","{","  SomeWidget *self = data;","   ","  g_mutex_lock (&self->idle_id_mutex);","  \/\/ do stuff with self","  self->idle_id = 0;","  g_mutex_unlock (&self->idle_id_mutex);","   ","  return G_SOURCE_REMOVE;","}"," ","static void","some_widget_do_stuff_later (SomeWidget *self)","{","  g_mutex_lock (&self->idle_id_mutex);","  self->idle_id = g_idle_add (idle_callback, self);","  g_mutex_unlock (&self->idle_id_mutex);","}"," ","static void","some_widget_init (SomeWidget *self)","{","  g_mutex_init (&self->idle_id_mutex);","","  \/\/ ...","}","","static void","some_widget_finalize (GObject *object)","{","  SomeWidget *self = SOME_WIDGET (object);","   ","  if (self->idle_id)","    g_source_remove (self->idle_id);","   ","  g_mutex_clear (&self->idle_id_mutex);","","  G_OBJECT_CLASS (parent_class)->finalize (object);","}"],"type":"codeListing","syntax":"c"},{"inlineContent":[{"type":"text","text":"This will fail in a multi-threaded application if the"},{"text":" ","type":"text"},{"text":"widget is destroyed before the idle handler fires due","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"to the use after free in the callback. A solution, to"},{"text":" ","type":"text"},{"type":"text","text":"this particular problem, is to check to if the source"},{"text":" ","type":"text"},{"text":"has already been destroy within the callback.","type":"text"}],"type":"paragraph"},{"type":"codeListing","code":["static gboolean","idle_callback (gpointer data)","{","  SomeWidget *self = data;","  ","  g_mutex_lock (&self->idle_id_mutex);","  if (!g_source_is_destroyed (g_main_current_source ()))","    {","      \/\/ do stuff with self","    }","  g_mutex_unlock (&self->idle_id_mutex);","  ","  return FALSE;","}"],"syntax":"c"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Calls to this function from a thread other than the one acquired by the"},{"text":" ","type":"text"},{"text":"[struct","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/MainContext","isActive":true},{"type":"text","text":"] the [struct"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Source"},{"type":"text","text":"] is attached to are typically"},{"text":" ","type":"text"},{"type":"text","text":"redundant, as the source could be destroyed immediately after this function"},{"type":"text","text":" "},{"type":"text","text":"returns. However, once a source is destroyed it cannot be un-destroyed, so"},{"type":"text","text":" "},{"type":"text","text":"this function can be used for opportunistic checks from any thread."}]}]}],"metadata":{"modules":[{"name":"GLib"}],"title":"isDestroyed","extendedModule":"GLib","role":"symbol","roleHeading":"Instance Property","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"isDestroyed"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sb","kind":"typeIdentifier","text":"Bool"}],"externalID":"s:4GLib14SourceProtocolPAAE11isDestroyedSbvp::SYNTHESIZED::s:4GLib9SourceRefV","symbolKin