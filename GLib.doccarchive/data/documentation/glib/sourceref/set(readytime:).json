{"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/SourceRef","doc:\/\/GLib\/documentation\/GLib\/SourceRef\/SourceProtocol-Implementations"]]},"sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/sourceref\/set(readytime:)"]}],"kind":"symbol","identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/SourceRef\/set(readyTime:)","interfaceLanguage":"swift"},"abstract":[{"text":"Sets a source to be dispatched when the given monotonic time is","type":"text"},{"type":"text","text":" "},{"type":"text","text":"reached (or passed)."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"set","kind":"identifier"},{"kind":"text","text":"("},{"text":"readyTime","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"gint64","preciseIdentifier":"c:@T@gint64","kind":"typeIdentifier"},{"text":")","kind":"text"}],"languages":["swift"],"platforms":["macOS"]}]},{"kind":"content","content":[{"type":"heading","level":2,"anchor":"discussion","text":"Discussion"},{"inlineContent":[{"text":"If the monotonic time is in the past (as it","type":"text"},{"text":" ","type":"text"},{"text":"always will be if ","type":"text"},{"code":"readyTime","type":"codeVoice"},{"type":"text","text":" is "},{"code":"0","type":"codeVoice"},{"text":") then the source will be","type":"text"},{"type":"text","text":" "},{"type":"text","text":"dispatched immediately."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"readyTime"},{"type":"text","text":" is "},{"code":"-1","type":"codeVoice"},{"type":"text","text":" then the source is never woken up on the basis"},{"text":" ","type":"text"},{"text":"of the passage of time.","type":"text"}]},{"inlineContent":[{"type":"text","text":"Dispatching the source does not reset the ready time.  You should do"},{"text":" ","type":"text"},{"type":"text","text":"so yourself, from the source dispatch function."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Note that if you have a pair of sources where the ready time of one"},{"text":" ","type":"text"},{"text":"suggests that it will be delivered first but the priority for the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"other suggests that it would be delivered first, and the ready time"},{"type":"text","text":" "},{"text":"for both sources is reached during the same main context iteration,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"then the order of dispatch is undefined."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"It is a no-op to call this function on a [struct","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Source","isActive":true,"type":"reference"},{"type":"text","text":"] which has"},{"type":"text","text":" "},{"text":"already been destroyed with [method","type":"text"},{"type":"codeVoice","code":"GLib.Source.destroy"},{"type":"text","text":"]."}]},{"inlineContent":[{"type":"text","text":"This API is only intended to be used by implementations of [struct"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Source","isActive":true},{"type":"text","text":"]."},{"type":"text","text":" "},{"text":"Do not call this API on a [struct","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Source","type":"reference","isActive":true},{"text":"] that you did not create.","type":"text"}],"type":"paragraph"}]}],"metadata":{"role":"symbol","extendedModule":"GLib","externalID":"s:4GLib14SourceProtocolPAAE3set9readyTimeys5Int64V_tF::SYNTHESIZED::s:4GLib9SourceRefV","roleHeading":"Instance Method","title":"set(readyTime:)","symbolKind":"method","modules":[{"name":"GLib"}],"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"set","kind":"identif