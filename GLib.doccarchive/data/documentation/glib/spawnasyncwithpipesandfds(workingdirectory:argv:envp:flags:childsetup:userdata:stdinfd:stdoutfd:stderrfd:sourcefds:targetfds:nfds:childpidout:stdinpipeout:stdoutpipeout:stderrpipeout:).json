{"sections":[],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"metadata":{"externalID":"s:4GLib25spawnAsyncWithPipesAndFds16workingDirectory4argv4envp5flags10childSetup8userData7stdinFd06stdoutR006stderrR006sourceG006targetG001nG00M6PidOut0q4PipeX00syX00tyX0SbSPys4Int8VGSg_SPyAVGSgAxA10SpawnFlagsVySvSgXCSgA_S3iSPys5Int32VGSgA4_SiSpyA2_GSgA6_A6_A6_tKF","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"spawnAsyncWithPipesAndFds"},{"text":"(","kind":"text"},{"text":"workingDirectory","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SP","kind":"typeIdentifier","text":"UnsafePointer"},{"kind":"text","text":"<"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar"},{"kind":"text","text":">?, "},{"text":"argv","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"preciseIdentifier":"c:@T@gchar","text":"gchar","kind":"typeIdentifier"},{"kind":"text","text":">?>!, "},{"text":"envp","kind":"externalParam"},{"kind":"text","text":": "},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"kind":"text","text":"<"},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"kind":"text","text":"<"},{"preciseIdentifier":"c:@T@gchar","text":"gchar","kind":"typeIdentifier"},{"text":">?>!, ","kind":"text"},{"text":"flags","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:4GLib10SpawnFlagsV","text":"SpawnFlags","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"childSetup","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@GSpawnChildSetupFunc","text":"GSpawnChildSetupFunc"},{"kind":"text","text":"?, "},{"kind":"externalParam","text":"userData"},{"text":": ","kind":"text"},{"text":"gpointer","preciseIdentifier":"c:@T@gpointer","kind":"typeIdentifier"},{"text":"?, ","kind":"text"},{"kind":"externalParam","text":"stdinFd"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"},{"kind":"text","text":", "},{"text":"stdoutFd","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"stderrFd"},{"kind":"text","text":": "},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":", ","kind":"text"},{"text":"sourceFds","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"text":"<","kind":"text"},{"preciseIdentifier":"c:@T@gint","text":"gint","kind":"typeIdentifier"},{"kind":"text","text":">!, "},{"kind":"externalParam","text":"targetFds"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SP","kind":"typeIdentifier","text":"UnsafePointer"},{"text":"<","kind":"text"},{"text":"gint","kind":"typeIdentifier","preciseIdentifier":"c:@T@gint"},{"text":">!, ","kind":"text"},{"text":"nFds","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"kind":"text","text":", "},{"text":"childPidOut","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer"},{"kind":"text","text":"<"},{"preciseIdentifier":"c:@T@GPid","text":"GPid","kind":"typeIdentifier"},{"text":">!, ","kind":"text"},{"kind":"externalParam","text":"stdinPipeOut"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"UnsafeMutablePointer","preciseIdentifier":"s:Sp"},{"kind":"text","text":"<"},{"preciseIdentifier":"c:@T@gint","text":"gint","kind":"typeIdentifier"},{"kind":"text","text":">!, "},{"text":"stdoutPipeOut","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"UnsafeMutablePointer","kind":"typeIdentifier","preciseIdentifier":"s:Sp"},{"kind":"text","text":"<"},{"text":"gint","kind":"typeIdentifier","preciseIdentifier":"c:@T@gint"},{"text":">!, ","kind":"text"},{"kind":"externalParam","text":"stderrPipeOut"},{"text":": ","kind":"text"},{"text":"UnsafeMutablePointer","kind":"typeIdentifier","preciseIdentifier":"s:Sp"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gint","text":"gint"},{"text":">!) ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"}],"title":"spawnAsyncWithPipesAndFds(workingDirectory:argv:envp:flags:childSetup:userData:stdinFd:stdoutFd:stderrFd:sourceFds:targetFds:nFds:childPidOut:stdinPipeOut:stdoutPipeOut:stderrPipeOut:)","role":"symbol","roleHeading":"Function","modules":[{"name":"GLib"}],"symbolKind":"func"},"abstract":[{"text":"Executes a child program asynchronously (your program will not","type":"text"},{"text":" ","type":"text"},{"text":"block waiting for the child to exit).","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/spawnasyncwithpipesandfds(workingdirectory:argv:envp:flags:childsetup:userdata:stdinfd:stdoutfd:stderrfd:sourcefds:targetfds:nfds:childpidout:stdinpipeout:stdoutpipeout:stderrpipeout:)"]}],"schemaVersion":{"major":0,"patch":0,"minor":3},"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/spawnAsyncWithPipesAndFds(workingDirectory:argv:envp:flags:childSetup:userData:stdinFd:stdoutFd:stderrFd:sourceFds:targetFds:nFds:childPidOut:stdinPipeOut:stdoutPipeOut:stderrPipeOut:)"},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"spawnAsyncWithPipesAndFds","kind":"identifier"},{"text":"(","kind":"text"},{"text":"workingDirectory","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar","text":"gchar"},{"kind":"text","text":">? = nil, "},{"kind":"externalParam","text":"argv"},{"text":": ","kind":"text"},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"preciseIdentifier":"s:SP","text":"UnsafePointer","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"preciseIdentifier":"c:@T@gchar","text":"gchar","kind":"typeIdentifier"},{"text":">?>!, ","kind":"text"},{"kind":"externalParam","text":"envp"},{"kind":"text","text":": "},{"preciseIdentifier":"s:SP","kind":"typeIdentifier","text":"UnsafePointer"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"kind":"text","text":"<"},{"text":"gchar","preciseIdentifier":"c:@T@gchar","kind":"typeIdentifier"},{"text":">?>! = nil, ","kind":"text"},{"text":"flags","kind":"externalParam"},{"kind":"text","text":": "},{"text":"SpawnFlags","kind":"typeIdentifier","preciseIdentifier":"s:4GLib10SpawnFlagsV","identifier":"doc:\/\/GLib\/documentation\/GLib\/SpawnFlags"},{"text":", ","kind":"text"},{"text":"childSetup","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@GSpawnChildSetupFunc","text":"GSpawnChildSetupFunc"},{"kind":"text","text":"? = nil, "},{"kind":"externalParam","text":"userData"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gpointer","text":"gpointer"},{"kind":"text","text":"? = nil, "},{"text":"stdinFd","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"},{"text":", ","kind":"text"},{"text":"stdoutFd","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"kind":"text","text":", "},{"text":"stderrFd","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":", ","kind":"text"},{"text":"sourceFds","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gint","text":"gint"},{"kind":"text","text":">! = nil, "},{"text":"targetFds","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"UnsafePointer","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"text":"gint","kind":"typeIdentifier","preciseIdentifier":"c:@T@gint"},{"kind":"text","text":">! = nil, "},{"kind":"externalParam","text":"nFds"},{"kind":"text","text":": "},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":", ","kind":"text"},{"text":"childPidOut","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sp","kind":"typeIdentifier","text":"UnsafeMutablePointer"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@GPid","text":"GPid"},{"text":">! = nil, ","kind":"text"},{"text":"stdinPipeOut","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"UnsafeMutablePointer","preciseIdentifier":"s:Sp"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"gint","preciseIdentifier":"c:@T@gint"},{"text":">! = nil, ","kind":"text"},{"text":"stdoutPipeOut","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer"},{"text":"<","kind":"text"},{"text":"gint","kind":"typeIdentifier","preciseIdentifier":"c:@T@gint"},{"kind":"text","text":">! = nil, "},{"kind":"externalParam","text":"stderrPipeOut"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer"},{"kind":"text","text":"<"},{"text":"gint","kind":"typeIdentifier","preciseIdentifier":"c:@T@gint"},{"kind":"text","text":">! = nil) "},{"kind":"keyword","text":"throws"},{"text":" -> ","kind":"text"},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"}],"platforms":["macOS"],"languages":["swift"]}]},{"content":[{"type":"heading","level":2,"anchor":"discussion","text":"Discussion"},{"type":"paragraph","inlineContent":[{"text":"The child program is specified by the only argument that must be","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"provided, "},{"type":"codeVoice","code":"argv"},{"type":"text","text":". "},{"type":"codeVoice","code":"argv"},{"text":" should be a ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":"-terminated array of strings,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"to be passed as the argument vector for the child. The first string"},{"text":" ","type":"text"},{"type":"text","text":"in "},{"type":"codeVoice","code":"argv"},{"type":"text","text":" is of course the name of the program to execute. By default,"},{"text":" ","type":"text"},{"type":"text","text":"the name of the program must be a full path. If "},{"type":"codeVoice","code":"flags"},{"type":"text","text":" contains the"},{"text":" ","type":"text"},{"type":"codeVoice","code":"searchPath"},{"text":" flag, the ","type":"text"},{"type":"codeVoice","code":"PATH"},{"text":" environment variable is used to","type":"text"},{"type":"text","text":" "},{"type":"text","text":"search for the executable. If "},{"code":"flags","type":"codeVoice"},{"type":"text","text":" contains the"},{"text":" ","type":"text"},{"type":"codeVoice","code":"searchPathFromEnvp"},{"type":"text","text":" flag, the "},{"code":"PATH","type":"codeVoice"},{"text":" variable from ","type":"text"},{"code":"envp","type":"codeVoice"},{"text":" ","type":"text"},{"text":"is used to search for the executable. If both the","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"searchPath"},{"type":"text","text":" and "},{"code":"searchPathFromEnvp","type":"codeVoice"},{"type":"text","text":" flags are"},{"type":"text","text":" "},{"text":"set, the ","type":"text"},{"type":"codeVoice","code":"PATH"},{"type":"text","text":" variable from "},{"code":"envp","type":"codeVoice"},{"text":" takes precedence over the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"environment variable."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If the program name is not a full path and "},{"code":"searchPath","type":"codeVoice"},{"type":"text","text":" flag"},{"type":"text","text":" "},{"type":"text","text":"is not used, then the program will be run from the current directory"},{"type":"text","text":" "},{"type":"text","text":"(or "},{"type":"codeVoice","code":"workingDirectory"},{"type":"text","text":", if specified); this might be unexpected or even"},{"type":"text","text":" "},{"type":"text","text":"dangerous in some cases when the current directory is world-writable."}]},{"inlineContent":[{"text":"On Windows, note that all the string or string vector arguments to","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"this function and the other "},{"code":"g_spawn*()","type":"codeVoice"},{"type":"text","text":" functions are in UTF-8, the"},{"text":" ","type":"text"},{"type":"text","text":"GLib file name encoding. Unicode characters that are not part of"},{"type":"text","text":" "},{"type":"text","text":"the system codepage passed in these arguments will be correctly"},{"text":" ","type":"text"},{"type":"text","text":"available in the spawned program only if it uses wide character API"},{"type":"text","text":" "},{"text":"to retrieve its command line. For C programs built with Microsoft’s","type":"text"},{"type":"text","text":" "},{"text":"tools it is enough to make the program have a ","type":"text"},{"type":"codeVoice","code":"wmain()"},{"type":"text","text":" instead of"},{"text":" ","type":"text"},{"code":"main()","type":"codeVoice"},{"type":"text","text":". "},{"type":"codeVoice","code":"wmain()"},{"text":" has a wide character argument vector as parameter.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"At least currently, mingw doesn’t support "},{"code":"wmain()","type":"codeVoice"},{"text":", so if you use","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"mingw to develop the spawned program, it should call"},{"text":" ","type":"text"},{"code":"g_win32_get_command_line()","type":"codeVoice"},{"text":" to get arguments in UTF-8.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"On Windows the low-level child process creation API "},{"type":"codeVoice","code":"CreateProcess()"},{"text":" ","type":"text"},{"text":"doesn’t use argument vectors, but a command line. The C runtime","type":"text"},{"type":"text","text":" "},{"type":"text","text":"library’s "},{"code":"spawn*()","type":"codeVoice"},{"type":"text","text":" family of functions (which "},{"type":"codeVoice","code":"g_spawn_async_with_pipes()"},{"text":" ","type":"text"},{"type":"text","text":"eventually calls) paste the argument vector elements together into"},{"text":" ","type":"text"},{"text":"a command line, and the C runtime startup code does a corresponding","type":"text"},{"type":"text","text":" "},{"type":"text","text":"reconstruction of an argument vector from the command line, to be"},{"type":"text","text":" "},{"type":"text","text":"passed to "},{"code":"main()","type":"codeVoice"},{"text":". Complications arise when you have argument vector","type":"text"},{"type":"text","text":" "},{"type":"text","text":"elements that contain spaces or double quotes. The "},{"type":"codeVoice","code":"spawn*()"},{"text":" functions","type":"text"},{"type":"text","text":" "},{"text":"don’t do any quoting or escaping, but on the other hand the startup","type":"text"},{"type":"text","text":" "},{"type":"text","text":"code does do unquoting and unescaping in order to enable receiving"},{"type":"text","text":" "},{"text":"arguments with embedded spaces or double quotes. To work around this","type":"text"},{"type":"text","text":" "},{"type":"text","text":"asymmetry, "},{"type":"codeVoice","code":"g_spawn_async_with_pipes()"},{"text":" will do quoting and escaping on","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"argument vector elements that need it before calling the C runtime"},{"type":"text","text":" "},{"code":"spawn()","type":"codeVoice"},{"type":"text","text":" function."}]},{"inlineContent":[{"type":"text","text":"The returned "},{"code":"child_pid","type":"codeVoice"},{"text":" on Windows is a handle to the child","type":"text"},{"type":"text","text":" "},{"type":"text","text":"process, not its identifier. Process handles and process"},{"type":"text","text":" "},{"text":"identifiers are different concepts on Windows.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"envp"},{"text":" is a ","type":"text"},{"type":"codeVoice","code":"nil"},{"type":"text","text":"-terminated array of strings, where each string"},{"type":"text","text":" "},{"text":"has the form ","type":"text"},{"code":"KEY=VALUE","type":"codeVoice"},{"type":"text","text":". This will become the child’s environment."},{"text":" ","type":"text"},{"type":"text","text":"If "},{"type":"codeVoice","code":"envp"},{"type":"text","text":" is "},{"code":"nil","type":"codeVoice"},{"text":", the child inherits its parent’s environment.","type":"text"}]},{"inlineContent":[{"type":"codeVoice","code":"flags"},{"text":" should be the bitwise OR of any flags you want to affect the","type":"text"},{"type":"text","text":" "},{"text":"function’s behaviour. The ","type":"text"},{"type":"codeVoice","code":"doNotReapChild"},{"text":" means that the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"child will not automatically be reaped; you must use a child watch"},{"text":" ","type":"text"},{"type":"text","text":"("},{"type":"codeVoice","code":"g_child_watch_add()"},{"text":") to be notified about the death of the child process,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"otherwise it will stay around as a zombie process until this process exits."},{"type":"text","text":" "},{"type":"text","text":"Eventually you must call "},{"type":"codeVoice","code":"g_spawn_close_pid()"},{"type":"text","text":" on the "},{"type":"codeVoice","code":"child_pid"},{"type":"text","text":", in order to"},{"type":"text","text":" "},{"type":"text","text":"free resources which may be associated with the child process. (On Unix,"},{"text":" ","type":"text"},{"type":"text","text":"using a child watch is equivalent to calling "},{"code":"waitpid()","type":"codeVoice"},{"type":"text","text":" or handling"},{"text":" ","type":"text"},{"text":"the ","type":"text"},{"code":"SIGCHLD","type":"codeVoice"},{"text":" signal manually. On Windows, calling ","type":"text"},{"type":"codeVoice","code":"g_spawn_close_pid()"},{"text":" ","type":"text"},{"text":"is equivalent to calling ","type":"text"},{"code":"CloseHandle()","type":"codeVoice"},{"text":" on the process handle returned","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"in "},{"code":"child_pid","type":"codeVoice"},{"text":"). See ","type":"text"},{"type":"codeVoice","code":"g_child_watch_add()"},{"text":".","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Open UNIX file descriptors marked as "},{"code":"FD_CLOEXEC","type":"codeVoice"},{"text":" will be automatically","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"closed in the child process. "},{"code":"leaveDescriptorsOpen","type":"codeVoice"},{"type":"text","text":" means that"},{"text":" ","type":"text"},{"type":"text","text":"other open file descriptors will be inherited by the child; otherwise all"},{"type":"text","text":" "},{"text":"descriptors except stdin\/stdout\/stderr will be closed before calling ","type":"text"},{"code":"exec()","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"in the child. "},{"type":"codeVoice","code":"searchPath"},{"text":" means that ","type":"text"},{"type":"codeVoice","code":"argv"},{"type":"text","text":"[0] need not be an"},{"text":" ","type":"text"},{"type":"text","text":"absolute path, it will be looked for in the "},{"code":"PATH","type":"codeVoice"},{"type":"text","text":" environment"},{"type":"text","text":" "},{"type":"text","text":"variable. "},{"code":"searchPathFromEnvp","type":"codeVoice"},{"text":" means need not be an","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"absolute path, it will be looked for in the "},{"type":"codeVoice","code":"PATH"},{"type":"text","text":" variable from"},{"text":" ","type":"text"},{"type":"codeVoice","code":"envp"},{"type":"text","text":". If both "},{"type":"codeVoice","code":"searchPath"},{"type":"text","text":" and "},{"type":"codeVoice","code":"searchPathFromEnvp"},{"type":"text","text":" "},{"text":"are used, the value from ","type":"text"},{"type":"codeVoice","code":"envp"},{"type":"text","text":" takes precedence over the environment."}]},{"type":"paragraph","inlineContent":[{"code":"childInheritsStdin","type":"codeVoice"},{"type":"text","text":" means that the child will inherit the parent’s"},{"text":" ","type":"text"},{"type":"text","text":"standard input (by default, the child’s standard input is attached to"},{"type":"text","text":" "},{"code":"\/dev\/null","type":"codeVoice"},{"text":"). ","type":"text"},{"code":"stdinFromDevNull","type":"codeVoice"},{"text":" explicitly imposes the default","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"behavior. Both flags cannot be enabled at the same time and, in both cases,"},{"text":" ","type":"text"},{"type":"text","text":"the "},{"type":"codeVoice","code":"stdinPipeOut"},{"text":" argument is ignored.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"stdoutToDevNull"},{"type":"text","text":" means that the child’s standard output"},{"type":"text","text":" "},{"type":"text","text":"will be discarded (by default, it goes to the same location as the parent’s"},{"type":"text","text":" "},{"type":"text","text":"standard output). "},{"type":"codeVoice","code":"childInheritsStdout"},{"text":" explicitly imposes the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"default behavior. Both flags cannot be enabled at the same time and, in"},{"type":"text","text":" "},{"text":"both cases, the ","type":"text"},{"code":"stdoutPipeOut","type":"codeVoice"},{"type":"text","text":" argument is ignored."}]},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"stderrToDevNull"},{"type":"text","text":" means that the child’s standard error"},{"text":" ","type":"text"},{"type":"text","text":"will be discarded (by default, it goes to the same location as the parent’s"},{"type":"text","text":" "},{"text":"standard error). ","type":"text"},{"type":"codeVoice","code":"childInheritsStderr"},{"type":"text","text":" explicitly imposes the"},{"type":"text","text":" "},{"text":"default behavior. Both flags cannot be enabled at the same time and, in","type":"text"},{"type":"text","text":" "},{"type":"text","text":"both cases, the "},{"code":"stderrPipeOut","type":"codeVoice"},{"type":"text","text":" argument is ignored."}]},{"inlineContent":[{"type":"text","text":"It is valid to pass the same FD in multiple parameters (e.g. you can pass"},{"type":"text","text":" "},{"type":"text","text":"a single FD for both "},{"type":"codeVoice","code":"stdoutFd"},{"text":" and ","type":"text"},{"code":"stderrFd","type":"codeVoice"},{"type":"text","text":", and include it in"},{"type":"text","text":" "},{"code":"sourceFds","type":"codeVoice"},{"type":"text","text":" too)."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"sourceFds"},{"type":"text","text":" and "},{"type":"codeVoice","code":"targetFds"},{"type":"text","text":" allow zero or more FDs from this process to be"},{"type":"text","text":" "},{"type":"text","text":"remapped to different FDs in the spawned process. If "},{"type":"codeVoice","code":"nFds"},{"type":"text","text":" is greater than"},{"text":" ","type":"text"},{"text":"zero, ","type":"text"},{"type":"codeVoice","code":"sourceFds"},{"type":"text","text":" and "},{"type":"codeVoice","code":"targetFds"},{"text":" must both be non-","type":"text"},{"code":"nil","type":"codeVoice"},{"type":"text","text":" and the same length."},{"text":" ","type":"text"},{"text":"Each FD in ","type":"text"},{"code":"sourceFds","type":"codeVoice"},{"type":"text","text":" is remapped to the FD number at the same index in"},{"type":"text","text":" "},{"code":"targetFds","type":"codeVoice"},{"type":"text","text":". The source and target FD may be equal to simply propagate an FD"},{"type":"text","text":" "},{"type":"text","text":"to the spawned process. FD remappings are processed after standard FDs, so"},{"text":" ","type":"text"},{"type":"text","text":"any target FDs which equal "},{"code":"stdinFd","type":"codeVoice"},{"type":"text","text":", "},{"code":"stdoutFd","type":"codeVoice"},{"text":" or ","type":"text"},{"code":"stderrFd","type":"codeVoice"},{"text":" will overwrite","type":"text"},{"type":"text","text":" "},{"type":"text","text":"them in the spawned process."}]},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"sourceFds"},{"text":" is supported on Windows since 2.72.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"fileAndArgvZero"},{"type":"text","text":" means that the first element of "},{"code":"argv","type":"codeVoice"},{"type":"text","text":" is"},{"type":"text","text":" "},{"type":"text","text":"the file to execute, while the remaining elements are the actual"},{"type":"text","text":" "},{"text":"argument vector to pass to the file. Normally ","type":"text"},{"code":"g_spawn_async_with_pipes()","type":"codeVoice"},{"text":" ","type":"text"},{"text":"uses ","type":"text"},{"code":"argv","type":"codeVoice"},{"type":"text","text":"[0] as the file to execute, and passes all of "},{"code":"argv","type":"codeVoice"},{"type":"text","text":" to the child."}]},{"inlineContent":[{"code":"childSetup","type":"codeVoice"},{"type":"text","text":" and "},{"code":"userData","type":"codeVoice"},{"text":" are a function and user data. On POSIX","type":"text"},{"type":"text","text":" "},{"text":"platforms, the function is called in the child after GLib has","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"performed all the setup it plans to perform (including creating"},{"type":"text","text":" "},{"type":"text","text":"pipes, closing file descriptors, etc.) but before calling "},{"type":"codeVoice","code":"exec()"},{"type":"text","text":"."},{"type":"text","text":" "},{"text":"That is, ","type":"text"},{"code":"childSetup","type":"codeVoice"},{"type":"text","text":" is called just before calling "},{"type":"codeVoice","code":"exec()"},{"type":"text","text":" in the"},{"type":"text","text":" "},{"type":"text","text":"child. Obviously actions taken in this function will only affect"},{"type":"text","text":" "},{"type":"text","text":"the child, not the parent."}],"type":"paragraph"},{"inlineContent":[{"text":"On Windows, there is no separate ","type":"text"},{"code":"fork()","type":"codeVoice"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"exec()"},{"text":" functionality.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Child processes are created and run with a single API call,"},{"type":"text","text":" "},{"type":"codeVoice","code":"CreateProcess()"},{"type":"text","text":". There is no sensible thing "},{"code":"childSetup","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"could be used for on Windows so it is ignored and not called."}],"type":"paragraph"},{"inlineContent":[{"text":"If non-","type":"text"},{"code":"nil","type":"codeVoice"},{"type":"text","text":", "},{"code":"child_pid","type":"codeVoice"},{"type":"text","text":" will on Unix be filled with the child’s"},{"type":"text","text":" "},{"text":"process ID. You can use the process ID to send signals to the child,","type":"text"},{"type":"text","text":" "},{"text":"or to use ","type":"text"},{"code":"g_child_watch_add()","type":"codeVoice"},{"type":"text","text":" (or "},{"type":"codeVoice","code":"waitpid()"},{"type":"text","text":") if you specified the"},{"text":" ","type":"text"},{"code":"doNotReapChild","type":"codeVoice"},{"type":"text","text":" flag. On Windows, "},{"type":"codeVoice","code":"child_pid"},{"text":" will be","type":"text"},{"type":"text","text":" "},{"text":"filled with a handle to the child process only if you specified the","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"doNotReapChild"},{"type":"text","text":" flag. You can then access the child"},{"text":" ","type":"text"},{"text":"process using the Win32 API, for example wait for its termination","type":"text"},{"text":" ","type":"text"},{"text":"with the ","type":"text"},{"code":"WaitFor*()","type":"codeVoice"},{"type":"text","text":" functions, or examine its exit code with"},{"text":" ","type":"text"},{"code":"GetExitCodeProcess()","type":"codeVoice"},{"type":"text","text":". You should close the handle with "},{"code":"CloseHandle()","type":"codeVoice"},{"type":"text","text":" "},{"text":"or ","type":"text"},{"code":"g_spawn_close_pid()","type":"codeVoice"},{"type":"text","text":" when you no longer need it."}],"type":"paragraph"},{"inlineContent":[{"text":"If non-","type":"text"},{"type":"codeVoice","code":"nil"},{"type":"text","text":", the "},{"type":"codeVoice","code":"stdinPipeOut"},{"text":", ","type":"text"},{"type":"codeVoice","code":"stdoutPipeOut"},{"type":"text","text":", "},{"type":"codeVoice","code":"stderrPipeOut"},{"type":"text","text":" "},{"type":"text","text":"locations will be filled with file descriptors for writing to the child’s"},{"text":" ","type":"text"},{"type":"text","text":"standard input or reading from its standard output or standard error."},{"type":"text","text":" "},{"type":"text","text":"The caller of "},{"type":"codeVoice","code":"g_spawn_async_with_pipes()"},{"type":"text","text":" must close these file descriptors"},{"type":"text","text":" "},{"text":"when they are no longer in use. If these parameters are ","type":"text"},{"type":"codeVoice","code":"nil"},{"text":", the","type":"text"},{"text":" ","type":"text"},{"text":"corresponding pipe won’t be created.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"code":"stdinPipeOut","type":"codeVoice"},{"type":"text","text":" is "},{"code":"nil","type":"codeVoice"},{"type":"text","text":", the child’s standard input is attached to"},{"text":" ","type":"text"},{"code":"\/dev\/null","type":"codeVoice"},{"text":" unless ","type":"text"},{"type":"codeVoice","code":"childInheritsStdin"},{"text":" is set.","type":"text"}]},{"inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"stderrPipeOut"},{"text":" is NULL, the child’s standard error goes to the same","type":"text"},{"text":" ","type":"text"},{"text":"location as the parent’s standard error unless ","type":"text"},{"code":"stderrToDevNull","type":"codeVoice"},{"text":" ","type":"text"},{"text":"is set.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"code":"stdoutPipeOut","type":"codeVoice"},{"text":" is NULL, the child’s standard output goes to the same","type":"text"},{"type":"text","text":" "},{"type":"text","text":"location as the parent’s standard output unless "},{"code":"stdoutToDevNull","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"is set."}]},{"inlineContent":[{"type":"codeVoice","code":"error"},{"type":"text","text":" can be "},{"type":"codeVoice","code":"nil"},{"text":" to ignore errors, or non-","type":"text"},{"type":"codeVoice","code":"nil"},{"type":"text","text":" to report errors."},{"text":" ","type":"text"},{"text":"If an error is set, the function returns ","type":"text"},{"code":"false","type":"codeVoice"},{"text":". Errors are reported","type":"text"},{"text":" ","type":"text"},{"text":"even if they occur in the child (for example if the executable in","type":"text"},{"text":" ","type":"text"},{"text":"``argv","type":"text"},{"type":"codeVoice","code":"[0]"},{"text":" is not found). Typically the `message` field of returned","type":"text"},{"text":" ","type":"text"},{"text":"errors should be displayed to users. Possible errors are those from","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the `G_SPAWN_ERROR` domain."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If an error occurs, "},{"code":"child_pid","type":"codeVoice"},{"type":"text","text":", "},{"type":"codeVoice","code":"stdinPipeOut"},{"text":", ","type":"text"},{"code":"stdoutPipeOut","type":"codeVoice"},{"text":",","type":"text"},{"type":"text","text":" "},{"type":"text","text":"and "},{"code":"stderrPipeOut","type":"codeVoice"},{"type":"text","text":" will not be filled with valid values."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If "},{"code":"child_pid","type":"codeVoice"},{"type":"text","text":" is not "},{"type":"codeVoice","code":"nil"},{"text":" and an error does not occur then the returned","type":"text"},{"type":"text","text":" "},{"type":"text","text":"process reference must be closed using "},{"type":"codeVoice","code":"g_spawn_close_pid()"},{"type":"text","text":"."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"On modern UNIX platforms, GLib can use an efficient process launching","type":"text"},{"type":"text","text":" "},{"text":"codepath driven internally by ","type":"text"},{"type":"codeVoice","code":"posix_spawn()"},{"type":"text","text":". This has the advantage of"},{"type":"text","text":" "},{"type":"text","text":"avoiding the fork-time performance costs of cloning the parent process"},{"text":" ","type":"text"},{"type":"text","text":"address space, and avoiding associated memory overcommit checks that are"},{"text":" ","type":"text"},{"type":"text","text":"not relevant in the context of immediately executing a distinct process."},{"type":"text","text":" "},{"type":"text","text":"This optimized codepath will be used provided that the following conditions"},{"text":" ","type":"text"},{"type":"text","text":"are met:"}]},{"type":"orderedList","items":[{"content":[{"inlineContent":[{"type":"codeVoice","code":"doNotReapChild"},{"type":"text","text":" is set"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"code":"leaveDescriptorsOpen","type":"codeVoice"},{"text":" is set","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"searchPathFromEnvp"},{"type":"text","text":" is not set"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"workingDirectory"},{"text":" is ","type":"text"},{"code":"nil","type":"codeVoice"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"childSetup","type":"codeVoice"},{"type":"text","text":" is "},{"code":"nil","type":"codeVoice"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The program is of a recognised binary format, or has a shebang."},{"text":" ","type":"text"},{"text":"Otherwise, GLib will have to execute the program through the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"shell, which is not done using the optimized codepath."}]}]}]},{"type":"paragraph","inlineContent":[{"text":"If you are writing a GTK application, and the program you are spawning is a","type":"text"},{"type":"text","text":" "},{"text":"graphical application too, then to ensure that the spawned program opens its","type":"text"},{"text":" ","type":"text"},{"text":"windows on the right screen, you may want to use ","type":"text"},{"code":"GdkAppLaunchContext","type":"codeVoice"},{"text":",","type":"text"},{"type":"text","text":" "},{"code":"GAppLaunchContext","type":"codeVoice"},{"text":", or set the ","type":"text"},{"code":"DISPLAY","type":"codeVoice"},{"type":"text","text":" environment variable."}]}],"kind":"content"}],"references":{"doc://GLib/documentation/GLib":{"kind":"symbol","role":"collection","abstract":[],"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","type":"topic","url":"\/documentation\/glib"},"doc://GLib/documentation/GLib/SpawnFlags":{"abstract":[{"type":"text","text":"Flags passed to "},{"code":"g_spawn_sync()","type":"codeVoice"},{"text":", ","type":"text"},{"code":"g_spawn_async()","type":"codeVoice"},{"type":"text","text":" and "},{"code":"g_spawn_async_with_pipes()","type":"codeVoice"},{"text":".","type":"text"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/SpawnFlags","type":"topic","url":"\/documentation\/glib\/spawnflags","role":"symbol","kind":"symbol","navigatorTitle":[{"text":"SpawnFlags","kind":"identifier"}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SpawnFlags","kind":"identifier"}],"title":"SpawnFlags"},"doc://GLib/documentation/GLib/spawnAsyncWithPipesAndFds(workingDirectory:argv:envp:flags:childSetup:userData:stdinFd:stdoutFd:stderrFd:sourceFds:targetFds:nFds:childPidOut:stdinPipeOut:stdoutPipeOut:stderrPipeOut:)":{"kind":"symbol","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"spawnAsyncWithPipesAndFds","kind":"identifier"},{"kind":"text","text":"("},{"text":"workingDirectory","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"gchar","preciseIdentifier":"c:@T@gchar"},{"kind":"text","text":">?, "},{"text":"argv","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"