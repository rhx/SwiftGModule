":"text","text":">!, "},{"text":"targetFds","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"text":"<","kind":"text"},{"text":"gint","preciseIdentifier":"c:@T@gint","kind":"typeIdentifier"},{"text":">!, ","kind":"text"},{"text":"nFds","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"},{"kind":"text","text":", "},{"text":"childPidOut","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"UnsafeMutablePointer","preciseIdentifier":"s:Sp"},{"kind":"text","text":"<"},{"text":"GPid","preciseIdentifier":"c:@T@GPid","kind":"typeIdentifier"},{"text":">!, ","kind":"text"},{"kind":"externalParam","text":"stdinPipeOut"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"preciseIdentifier":"c:@T@gint","kind":"typeIdentifier","text":"gint"},{"text":">!, ","kind":"text"},{"text":"stdoutPipeOut","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sp","kind":"typeIdentifier","text":"UnsafeMutablePointer"},{"text":"<","kind":"text"},{"preciseIdentifier":"c:@T@gint","text":"gint","kind":"typeIdentifier"},{"text":">!, ","kind":"text"},{"kind":"externalParam","text":"stderrPipeOut"},{"kind":"text","text":": "},{"text":"UnsafeMutablePointer","kind":"typeIdentifier","preciseIdentifier":"s:Sp"},{"text":"<","kind":"text"},{"text":"gint","kind":"typeIdentifier","preciseIdentifier":"c:@T@gint"},{"kind":"text","text":">!) "},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"preciseIdentifier":"s:Sb","kind":"typeIdentifier","text":"Bool"}],"title":"spawnAsyncWithPipesAndFds(workingDirectory:argv:envp:flags:childSetup:userData:stdinFd:stdoutFd:stderrFd:sourceFds:targetFds:nFds:childPidOut:stdinPipeOut:stdoutPipeOut:stderrPipeOut:)","identifier":"doc:\/\/GLib\/documentation\/GLib\/spawnAsyncWi