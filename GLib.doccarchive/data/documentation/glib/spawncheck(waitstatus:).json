{"sections":[],"abstract":[{"text":"Set ","type":"text"},{"code":"error","type":"codeVoice"},{"text":" if ","type":"text"},{"type":"codeVoice","code":"waitStatus"},{"type":"text","text":" indicates the child exited abnormally"},{"text":" ","type":"text"},{"text":"(e.g. with a nonzero exit code, or via a fatal signal).","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"spawnCheck","kind":"identifier"},{"text":"(","kind":"text"},{"text":"waitStatus","kind":"externalParam"},{"kind":"text","text":": "},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":") ","kind":"text"},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"preciseIdentifier":"s:Sb","kind":"typeIdentifier","text":"Bool"}],"platforms":["macOS"],"languages":["swift"]}]},{"content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"type":"codeVoice","code":"g_spawn_sync()"},{"text":" and ","type":"text"},{"code":"g_child_watch_add()","type":"codeVoice"},{"text":" family of APIs return the","type":"text"},{"type":"text","text":" "},{"text":"status of subprocesses encoded in a platform-specific way.","type":"text"},{"type":"text","text":" "},{"text":"On Unix, this is guaranteed to be in the same format ","type":"text"},{"code":"waitpid()","type":"codeVoice"},{"type":"text","text":" returns,"},{"type":"text","text":" "},{"type":"text","text":"and on Windows it is guaranteed to be the result of "},{"type":"codeVoice","code":"GetExitCodeProcess()"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"text":"Prior to the introduction of this function in GLib 2.34, interpreting","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"waitStatus"},{"text":" required use of platform-specific APIs, which is problematic","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"for software using GLib as a cross-platform layer."}]},{"type":"paragraph","inlineContent":[{"text":"Additionally, many programs simply want to determine whether or not","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the child exited successfully, and either propagate a "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/GLibError","isActive":true},{"text":" or","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"print a message to standard error. In that common case, this function"},{"text":" ","type":"text"},{"type":"text","text":"can be used. Note that the error message in "},{"type":"codeVoice","code":"error"},{"type":"text","text":" will contain"},{"type":"text","text":" "},{"type":"text","text":"human-readable information about the wait status."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"domain"},{"type":"text","text":" and "},{"code":"code","type":"codeVoice"},{"type":"text","text":" of "},{"type":"codeVoice","code":"error"},{"text":" have special semantics in the case","type":"text"},{"type":"text","text":" "},{"text":"where the process has an “exit code”, as opposed to being killed by","type":"text"},{"type":"text","text":" "},{"text":"a signal. On Unix, this happens if ","type":"text"},{"type":"codeVoice","code":"WIFEXITED()"},{"text":" would be true of","type":"text"},{"text":" ","type":"text"},{"code":"waitStatus","type":"codeVoice"},{"type":"text","text":". On Windows, it is always the case."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The special semantics are that the actual exit code will be the"},{"type":"text","text":" "},{"type":"text","text":"code set in "},{"type":"codeVoice","code":"error"},{"text":", and the domain will be ","type":"text"},{"type":"codeVoice","code":"G_SPAWN_EXIT_ERROR"},{"type":"text","text":"."},{"type":"text","text":" "},{"text":"This allows you to differentiate between different exit codes.","type":"text"}]},{"inlineContent":[{"text":"If the process was terminated by some means other than an exit","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"status (for example if it was killed by a signal), the domain will be"},{"type":"text","text":" "},{"code":"G_SPAWN_ERROR","type":"codeVoice"},{"text":" and the code will be ","type":"text"},{"code":"failed","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This function just offers convenience; you can of course also check"},{"type":"text","text":" "},{"text":"the available platform via a macro such as ","type":"text"},{"type":"codeVoice","code":"G_OS_UNIX"},{"type":"text","text":", and use"},{"text":" ","type":"text"},{"type":"codeVoice","code":"WIFEXITED()"},{"text":" and ","type":"text"},{"code":"WEXITSTATUS()","type":"codeVoice"},{"type":"text","text":" on "},{"code":"waitStatus","type":"codeVoice"},{"type":"text","text":" directly. Do not attempt"},{"type":"text","text":" "},{"type":"text","text":"to scan or parse the error message string; it may be translated and\/or"},{"text":" ","type":"text"},{"type":"text","text":"change in future versions of GLib."}]},{"type":"paragraph","inlineContent":[{"text":"Prior to version 2.70, ","type":"text"},{"type":"codeVoice","code":"g_spawn_check_exit_status()"},{"text":" provides the same","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"functionality, although under a misleading name."}]}],"kind":"content"}],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"metadata":{"role":"symbol","externalID":"s:4GLib10spawnCheck10waitStatusSbSi_tKF","roleHeading":"Function","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"spawnCheck","kind":"identifier"},{"text":"(","kind":"text"},{"text":"waitStatus","kind":"externalParam"},{"kind":"text","text":": "},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"kind":"text","text":") "},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"}],"title":"spawnCheck(waitStatus:)","symbolKind":"func","modules":[{"name":"GLib"}]},"schemaVersion":{"major":0,"patch":0,"minor":3},"variants":[{"paths":["\/documentation\/glib\/spawncheck(waitstatus:)"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/spawnCheck(waitStatus:)","interfaceLanguage":"swift"},"references":{"doc://GLib/documentation/GLib":{"kind":"symbol","role":"collection","abstract":[],"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","type":"topic","url":"\/documentation\/glib"},"doc://GLib/documentation/GLib/GLibError":{"title":"GLibError","navigatorTitle":[{"kind":"identifier","text":"GLibError"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/GLibError","kind":"symbol","url":"\/documentation\/glib\/gliberror","role":"symbol","type":"topic","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"GLibError","kind":"identifier"}],"abstract":[{"type":"text","text":"The "},{"type":"codeVoice","code":"GError"},{"type":"text","text":" structure contains information about"},{"text":" ","type":"text"},{"text":"an error that has occurred.","type":"text"}]},"doc://GLib/documentation/GLib/spawnCheck(waitStatus:)":{"url":"\/documentation\/glib\/spawncheck(waitstatus:)","role":"symbol","kind":"symbol","type":"topic","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"spawnCheck"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"waitStatus"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"kind":"text","text":") "},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"text":"Bool","preciseIdentifier":"s:Sb","kind":"typeIdentifier"}],"abstract":[{"text":"Set ","type":"text"},{"code":"error","type":"codeVoice"},{"type":"text","text":" if "},{"type":"codeVoice","code":"waitStatus"},{"text":" indicates the child exited abnormally","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"(e.g. with a nonzero exit code, or via a fatal signal)."}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/spawnCheck(waitStatus:)","title":"spawnCheck(waitStatus:)"}}}