{"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/staticmutex"]}],"topicSections":[{"anchor":"Initializers","identifiers":["doc:\/\/GLib\/documentation\/GLib\/StaticMutex\/init(_:)-30gyb","doc:\/\/GLib\/documentation\/GLib\/StaticMutex\/init(_:)-5ndjt","doc:\/\/GLib\/documentation\/GLib\/StaticMutex\/init(_:)-6lhvr","doc:\/\/GLib\/documentation\/GLib\/StaticMutex\/init(_:)-7apmz","doc:\/\/GLib\/documentation\/GLib\/StaticMutex\/init(_:)-8rbuv","doc:\/\/GLib\/documentation\/GLib\/StaticMutex\/init(cPointer:)","doc:\/\/GLib\/documentation\/GLib\/StaticMutex\/init(gconstpointer:)","doc:\/\/GLib\/documentation\/GLib\/StaticMutex\/init(gpointer:)","doc:\/\/GLib\/documentation\/GLib\/StaticMutex\/init(opaquePointer:)","doc:\/\/GLib\/documentation\/GLib\/StaticMutex\/init(raw:)-1nyk4","doc:\/\/GLib\/documentation\/GLib\/StaticMutex\/init(raw:)-5it8v","doc:\/\/GLib\/documentation\/GLib\/StaticMutex\/init(retaining:)","doc:\/\/GLib\/documentation\/GLib\/StaticMutex\/init(retainingCPointer:)","doc:\/\/GLib\/documentation\/GLib\/StaticMutex\/init(retainingOpaquePointer:)","doc:\/\/GLib\/documentation\/GLib\/StaticMutex\/init(retainingRaw:)-290rd","doc:\/\/GLib\/documentation\/GLib\/StaticMutex\/init(retainingRaw:)-8drmn"],"title":"Initializers","generated":true},{"title":"Instance Properties","identifiers":["doc:\/\/GLib\/documentation\/GLib\/StaticMutex\/ptr"],"anchor":"Instance-Properties","generated":true},{"title":"Default Implementations","anchor":"Default-Implementations","generated":true,"identifiers":["doc:\/\/GLib\/documentation\/GLib\/StaticMutex\/StaticMutexProtocol-Implementations"]}],"sections":[],"kind":"symbol","schemaVersion":{"minor":3,"major":0,"patch":0},"metadata":{"roleHeading":"Class","modules":[{"name":"GLib"}],"externalID":"s:4GLib11StaticMutexC","symbolKind":"class","title":"StaticMutex","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"StaticMutex"}],"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"StaticMutex","kind":"identifier"}]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/StaticMutex"},"abstract":[{"type":"text","text":"A "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticMutex","type":"reference","isActive":true},{"type":"text","text":" works like a "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex","isActive":true,"type":"reference"},{"type":"text","text":"."}],"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"StaticMutex","kind":"identifier"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"content":[{"level":2,"type":"heading","text":"Overview","anchor":"overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Prior to GLib 2.32, GStaticMutex had the significant advantage"},{"type":"text","text":" "},{"text":"that it doesn’t need to be created at run-time, but can be defined","type":"text"},{"text":" ","type":"text"},{"text":"at compile-time. Since 2.32, ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex"},{"type":"text","text":" can be statically allocated"},{"text":" ","type":"text"},{"type":"text","text":"as well, and GStaticMutex has been deprecated."}]},{"inlineContent":[{"text":"Here is a version of our ","type":"text"},{"type":"codeVoice","code":"give_me_next_number()"},{"text":" example using","type":"text"},{"type":"text","text":" "},{"type":"text","text":"a GStaticMutex:"}],"type":"paragraph"},{"code":["  int","  give_me_next_number (void)","  {","    static int current_number = 0;","    int ret_val;","    static GStaticMutex mutex = G_STATIC_MUTEX_INIT;","","    g_static_mutex_lock (&mutex);","    ret_val = current_number = calc_next_number (current_number);","    g_static_mutex_unlock (&mutex);","","    return ret_val;","  }"],"syntax":null,"type":"codeListing"},{"inlineContent":[{"text":"Sometimes you would like to dynamically create a mutex. If you don’t","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"want to require prior calling to "},{"code":"g_thread_init()","type":"codeVoice"},{"type":"text","text":", because your code"},{"type":"text","text":" "},{"text":"should also be usable in non-threaded programs, you are not able to","type":"text"},{"type":"text","text":" "},{"text":"use ","type":"text"},{"code":"g_mutex_new()","type":"codeVoice"},{"text":" and thus ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex","isActive":true,"type":"reference"},{"type":"text","text":", as that requires a prior call to"},{"type":"text","text":" "},{"code":"g_thread_init()","type":"codeVoice"},{"text":". In these cases you can also use a ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticMutex","isActive":true,"type":"reference"},{"text":".","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"It must be initialized with "},{"code":"g_static_mutex_init()","type":"codeVoice"},{"type":"text","text":" before using it"},{"type":"text","text":" "},{"text":"and freed with with ","type":"text"},{"code":"g_static_mutex_free()","type":"codeVoice"},{"text":" when not needed anymore to","type":"text"},{"type":"text","text":" "},{"type":"text","text":"free up any allocated resources."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Even though ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticMutex"},{"type":"text","text":" is not opaque, it should only be used with"},{"type":"text","text":" "},{"text":"the following functions, as it is defined differently on different","type":"text"},{"type":"text","text":" "},{"type":"text","text":"platforms."}]},{"inlineContent":[{"text":"All of the g_static_mutex_* functions apart from","type":"text"},{"text":" ","type":"text"},{"code":"g_static_mutex_get_mutex()","type":"codeVoice"},{"text":" can also be used even if ","type":"text"},{"code":"g_thread_init()","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"has not yet been called. Then they do nothing, apart from"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_static_mutex_trylock()"},{"text":" which does nothing but returning ","type":"text"},{"type":"codeVoice","code":"true"},{"type":"text","text":"."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"All of the g_static_mutex_* functions are actually macros. Apart from","type":"text"},{"type":"text","text":" "},{"type":"text","text":"taking their addresses, you can however use them as if they were"},{"type":"text","text":" "},{"type":"text","text":"functions."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticMutex","type":"reference"},{"type":"text","text":" type acts as an owner of an underlying "},{"type":"codeVoice","code":"GStaticMutex"},{"type":"text","text":" instance."},{"text":" ","type":"text"},{"text":"It provides the methods that can operate on this data type through ","type":"text"},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticMutexProtocol","type":"reference"},{"type":"text","text":" conformance."},{"type":"text","text":" "},{"text":"Use ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticMutex","isActive":true,"type":"reference"},{"text":" as a strong reference or owner of a ","type":"text"},{"type":"codeVoice","code":"GStaticMutex"},{"type":"text","text":" instance."}]},{"type":"aside","content":[{"type":"paragraph","inlineContent":[{"text":"Use ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticMutexRef","isActive":true},{"text":" (instead of ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticMutex"},{"type":"text","text":") for a lightweight Swift reference to an underlying "},{"code":"GStaticMutex","type":"codeVoice"},{"text":" instance.","type":"text"}]}],"style":"note","name":"Note"}],"kind":"content"}],"relationshipsSections":[{"kind":"relationships","type":"conformsTo","title":"Conforms To","identifiers":["doc:\/\/GLib\/documentation\/GLib\/PointerWrapper","doc:\/\/GLib\/documentation\/GLib\/StaticMutexProtocol"]}],"references":{"doc://GLib/documentation/GLib/StaticMutex/init(_:)-30gyb":{"url":"\/documentation\/glib\/staticmutex\/init(_:)-30gyb","abstract":[{"type":"text","text":"Designated initialiser from a constant pointer to the underlying "},{"code":"C","type":"codeVoice"},{"type":"text","text":" data type."},{"type":"text","text":" "},{"text":"This creates an instance without performing an unbalanced retain","type":"text"},{"text":" ","type":"text"},{"text":"i.e., ownership is transferred to the ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticMutex","isActive":true},{"type":"text","text":" instance."}],"title":"init(_:)","identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticMutex\/init(_:)-30gyb","kind":"symbol","role":"symbol","type":"topic","fragments":[{"text":"init","kind":"identifier"},{"kind":"text","text":"("},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"kind":"text","text":"<"},{"preciseIdentifier":"c:@SA@GStaticMutex","text":"GStaticMutex","kind":"typeIdentifier"},{"text":">)","kind":"text"}]},"doc://GLib/documentation/GLib/StaticMutex/init(raw:)-5it8v":{"title":"init(raw:)","identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticMutex\/init(raw:)-5it8v","fragments":[{"text":"init","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"raw"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sv","text":"UnsafeMutableRawPointer","kind":"typeIdentifier"},{"text":")","kind":"text"}],"kind":"symbol","abstract":[{"type":"text","