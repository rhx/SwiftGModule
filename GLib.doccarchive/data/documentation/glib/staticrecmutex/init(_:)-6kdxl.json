{"abstract":[{"type":"text","text":"Optional initialiser from a constant pointer to the underlying "},{"type":"codeVoice","code":"C"},{"type":"text","text":" data type."},{"text":" ","type":"text"},{"text":"This creates an instance without performing an unbalanced retain","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"i.e., ownership is transferred to the "},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRecMutex","type":"reference"},{"text":" instance.","type":"text"}],"schemaVersion":{"minor":3,"patch":0,"major":0},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/StaticRecMutex"]]},"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/StaticRecMutex\/init(_:)-6kdxl"},"variants":[{"paths":["\/documentation\/glib\/staticrecmutex\/init(_:)-6kdxl"],"traits":[{"interfaceLanguage":"swift"}]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"text":"init","kind":"keyword"},{"kind":"text","text":"!("},{"kind":"externalParam","text":"_"},{"text":" ","kind":"text"},{"text":"op","kind":"internalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"GStaticRecMutex"},{"kind":"text","text":">?)"}]}]},{"kind":"parameters","parameters":[{"content":[{"inlineContent":[{"text":"Pointer to the underlying object","type":"text"}],"type":"paragraph"}],"name":"op"}]}],"sections":[],"metadata":{"title":"init(_:)","roleHeading":"Initializer","modules":[{"name":"GLib"}],"fragments":[{"kind":"identifier","text":"init"},{"kind":"text","text":"!("},{"preciseIdentifier":"s:SP","text":"UnsafePointer","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","text":"GStaticRecMutex"},{"text":">?)","kind":"text"}],"externalID":"s:4GLib14StaticRecMutexCyACSgSPy