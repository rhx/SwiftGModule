xt","text":" "},{"text":"unlock a ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRecMutex"},{"type":"text","text":" completely returning the depth, (i.e. the"},{"text":" ","type":"text"},{"text":"number of times this mutex was locked). The depth can later be used","type":"text"},{"type":"text","text":" "},{"type":"text","text":"to restore the state of the "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRecMutex","type":"reference","isActive":true},{"text":" by calling","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_static_rec_mutex_lock_full()"},{"text":". In GLib 2.32, ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRecMutex","isActive":true,"type":"reference"},{"type":"text","text":" has"},{"text":" ","type":"text"},{"type":"text","text":"been deprecated in favor of "},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/RecMutex","type":"reference"},{"type":"text","text":"."}],"url":"\/documentation\/glib\/staticrecmutex","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"StaticRecMutex","kind":"identifier"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRecMutex","navigatorTitle":[{"text":"StaticRecMutex","kind":"identifier"}],"role":"symbol","type":"topic","title":"StaticRecMutex","kind":"symbol"}}}