":"text","text":"The GRecMutex struct is an opaque data structure to represent a"},{"text":" ","type":"text"},{"type":"text","text":"recursive mutex. It is similar to a "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex","isActive":true},{"text":" with the difference","type":"text"},{"type":"text","text":" "},{"text":"that it is possible to lock a GRecMutex multiple times in the same","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"thread without deadlock. When doing so, care has to be taken to"},{"text":" ","type":"text"},{"text":"unlock the recursive mutex as often as it has been locked.","type":"text"}],"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"RecMutex"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/RecMutex","url":"\/documentation\/glib\/recmutex","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"RecMutex"}],"title":"RecMutex"},"doc://GLib/documentation/GLib/StaticMutex":{"navigatorTitle":[{"kind":"identifier","text":"StaticMutex"}],"url":"\/documentation\/glib\/staticmutex","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"StaticMutex","kind":"identifier"}],"role":"symbol","title":"StaticMutex","kind":"symbol","type":"topic","abstract":[{"text":"A ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticMutex"},{"type":"text","text":" works like a "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex"},{"type":"text","text":"."}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticMutex"},"doc://GLib/documentation/GLib":{"kind":"symbol","role":"collection","abstract":[],"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","type":"topic","url":"\/documentation\/glib"},"doc://GLib/documentation/GLib/StaticRecMutex":{"abstract":[{"type":"text","text":"A "},{"type":"reference","isActive":true,"identifier":"do