rylock()"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"title":"trylock()","platforms":[],"symbolKind":"method","roleHeading":"Instance Method","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"trylock"},{"text":"() -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"}],"role":"symbol","modules":[{"name":"GLib"}],"extendedModule":"GLib","externalID":"s:4GLib22StaticRecMutexProtocolPAAE7trylockSbyF::SYNTHESIZED::s:4GLib14StaticRecMutexC"},"references":{"doc://GLib/documentation/GLib/StaticRecMutex/trylock()":{"deprecated":true,"fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"trylock"},{"text":"() -> ","kind":"text"},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"}],"url":"\/documentation\/glib\/staticrecmutex\/trylock()","identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRecMutex\/trylock()","title":"trylock()","abstract":[{"type":"text","text":"Tries to lock "},{"code":"mutex","type":"codeVoice"},{"type":"text","text":". If "},{"code":"mutex","type":"codeVoice"},{"type":"text","text":" is already locked by another thread,"},{"type":"text","text":" "},{"text":"it immediately returns ","type":"text"},{"type":"codeVoice","code":"false"},{"text":". Otherwise it locks ","type":"text"},{"type":"codeVoice","code":"mutex"},{"text":" and returns","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"true"},{"type":"text","text":". If "},{"code":"mutex","type":"codeVoice"},{"type":"text","text":" is already locked by the calling thread, this"},{"type":"text","text":" "},{"type":"text","text":"functions increases the depth of "},{"type":"codeVoice","code":"mutex"},{"type":"text","text":" and immediately returns"},{"type":"text","text":" "},{"code":"true","type":"codeVoice"},{"text":".","type":"text"}],"kind":"symbol","type":"topic","role":"symbol"},"doc://GLib/documentation/GLib/StaticRecMutex/StaticRecMutexProtocol-Implementations":{"url":"\/documentation\/glib\/staticrecmutex\/staticrecmutexprotocol-implementations","role":"collectionGroup","title":"StaticRecMutexProtocol Implementations","kind":"article","type":"topic","abstract":[],"identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRecMutex\/StaticRecMutexProtocol-Implementations"},"doc://GLib/documentation/GLib/StaticMutex":{"navigatorTitle":[{"kind":"identifier","text":"StaticMutex"}],"url":"\/documentation\/glib\/staticmutex","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"StaticMutex","kind":"identifier"}],"role":"symbol","title":"StaticMutex","kind":"symbol","type":"topic","abstract":[{"text":"A ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticMutex"},{"type":"text","text":" works like a "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex"},{"type":"text","text":"."}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticMutex"},"doc://GLib/documentation/GLib/RecMutex":{"kind":"symbol","type":"topic","abstract":[{"type":"text","text":"The GRecMutex struct is an opaque data structure to represent a"},{"text":" ","type":"text"},{"type":"text","text":"recursive mutex. It is similar to a "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex","isActive":true},{"text":" with the difference","type":"text"},{"type":"text","text":" "},{"text":"that it is possible to lock a GRecMutex multiple times in the same","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"thread without deadlock. When doing so, care has to be taken to"},{"text":" ","type":"text"},{"text":"unlock the recursive mutex as often as it has been locked.","type":"text"}],"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"RecMutex"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/RecMutex","url":"\/documentation\/glib\/recmutex","fragments":[{"kind":"k