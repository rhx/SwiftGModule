ive":true},{"text":" with the difference","type":"text"},{"type":"text","text":" "},{"text":"that it is possible to lock a GRecMutex multiple times in the same","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"thread without deadlock. When doing so, care has to be taken to"},{"text":" ","type":"text"},{"text":"unlock the recursive mutex as often as it has been locked.","type":"text"}],"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"RecMutex"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/RecMutex","url":"\/documentation\/glib\/recmutex","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"RecMutex"}],"title":"RecMutex"},"doc://GLib/documentation/GLib/StaticRecMutex/unlock()":{"kind":"symbol","title":"unlock()","abstract":[{"type":"text","text":"Unlocks "},{"type":"codeVoice","code":"mutex"},{"text":". Another thread will be allowed to lock ","type":"text"},{"code":"mutex","type":"codeVoice"},{"type":"text","text":" only"},{"text":" ","type":"text"},{"text":"when it has been unlocked as many times as it had been locked","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"before. If "},{"code":"mutex","type":"codeVoice"},{"type":"text","text":" is completely unlocked and another thread is"},{"type":"text","text":" "},{"text":"blocked in a ","type":"text"},{"type":"codeVoice","code":"g_static_rec_mutex_lock()"},{"text":" call for ","type":"text"},{"code":"mutex","type":"codeVoice"},{"text":", it will be","type":"text"},{"type":"text","text":" "},{"type":"text","text":"woken and can lock "},{"type":"codeVoice","code":"mutex"},{"type":"text","text":" itself."}],"url":"\/documentation\/glib\/staticrecmutex\/unlock()","identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRecMutex\/unlock()","role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"unlock","kind":"identifier"},{"text":"()","kind":"text"}],"deprecated":true,"type":"topic"