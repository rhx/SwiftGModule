xception"},{"text":" ","type":"text"},{"text":"is the function ","type":"text"},{"code":"g_static_rec_mutex_unlock_full()","type":"codeVoice"},{"type":"text","text":": that allows you to"},{"type":"text","text":" "},{"text":"unlock a ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRecMutex"},{"type":"text","text":" completely returning the depth, (i.e. the"},{"text":" ","type":"text"},{"text":"number of times this mutex was locked). The depth can later be used","type":"text"},{"type":"text","text":" "},{"type":"text","text":"to restore the state of the "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRecMutex","type":"reference","isActive":true},{"text":" by calling","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_static_rec_mutex_lock_full()"},{"text":". In GLib 2.32, ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRecMutex","isActive":true,"type":"reference"},{"type":"text","text":" has"},{"text":" ","type":"text"},{"type":"text","text":"been deprecated in favor of "},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/RecMutex","type":"reference"},{"type":"text","text":"."}],"url":"\/documentation\/glib\/staticrecmutex","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"StaticRecMutex","kind":"identifier"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRecMutex","navigatorTitle":[{"text":"StaticRecMutex","kind":"identifier"}],"role":"symbol","type":"topic","title":"StaticRecMutex","kind":"symbol"},"doc://GLib/documentation/GLib/RecMutex":{"kind":"symbol","type":"topic","abstract":[{"type":"text","text":"The GRecMutex struct is an opaque data structure to represent a"},{"text":" ","type":"text"},{"type":"text","text":"recursive mutex. It is similar to a "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex","isActive":true},{"text":" with the difference","type":"text"},{"type":"text","text":" "},{"text":"that it is possible to lock a GRecMutex multiple times in the same","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"thread without deadlock. When doing so, care has to be taken to"},{"text":" ","type":"text"},{"text":"unlock the recursive mutex as often as it has been locked.","type":"text"}],"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"RecMutex"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/RecMutex","url":"\/documentation\/glib\/recmutex","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"RecMutex"}],"title":"RecMutex"},"doc://GLib/documentation/GLib":{"kind":"symbol","role":"collection","abstract":[],"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","type":"topic","url":"\/documentation\/glib"}}}