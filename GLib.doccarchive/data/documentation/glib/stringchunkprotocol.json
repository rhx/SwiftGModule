{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/StringChunkProtocol"},"abstract":[{"code":"GStringChunk","type":"codeVoice"},{"text":" provides efficient storage of groups of strings","type":"text"}],"schemaVersion":{"major":0,"minor":3,"patch":0},"metadata":{"roleHeading":"Protocol","modules":[{"name":"GLib"}],"title":"StringChunkProtocol","externalID":"s:4GLib19StringChunkProtocolP","fragments":[{"kind":"keyword","text":"protocol"},{"text":" ","kind":"text"},{"text":"StringChunkProtocol","kind":"identifier"}],"role":"symbol","navigatorTitle":[{"text":"StringChunkProtocol","kind":"identifier"}],"symbolKind":"protocol"},"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/stringchunkprotocol"]}],"sections":[],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"relationshipsSections":[{"title":"Inherits From","kind":"relationships","type":"inheritsFrom","identifiers":["doc:\/\/GLib\/documentation\/GLib\/PointerWrapper"]},{"identifiers":["doc:\/\/GLib\/documentation\/GLib\/StringChunk","doc:\/\/GLib\/documentation\/GLib\/StringChunkRef"],"kind":"relationships","title":"Conforming Types","type":"conformingTypes"}],"topicSections":[{"title":"Instance Methods","generated":true,"anchor":"Instance-Methods","identifiers":["doc:\/\/GLib\/documentation\/GLib\/StringChunkProtocol\/clear()","doc:\/\/GLib\/documentation\/GLib\/StringChunkProtocol\/free()","doc:\/\/GLib\/documentation\/GLib\/StringChunkProtocol\/insert(string:)","doc:\/\/GLib\/documentation\/GLib\/StringChunkProtocol\/insertConst(string:)","doc:\/\/GLib\/documentation\/GLib\/StringChunkProtocol\/insertLen(string:len:)"]}],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"protocol"},{"text":" ","kind":"text"},{"kind":"identifier","text":"StringChunkProtocol"},{"kind":"text","text":" : "},{"kind":"typeIdentifier","identifier":"doc:\/\/GLib\/documentation\/GLib\/PointerWrapper","text":"PointerWrapper","preciseIdentifier":"s:4GLib14PointerWrapperP"}]}],"kind":"declarations"},{"kind":"content","content":[{"type":"heading","text":"Overview","anchor":"overview","level":2},{"inlineContent":[{"text":"String chunks are used to store groups of strings. Memory is","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"allocated in blocks, and as strings are added to the "},{"type":"codeVoice","code":"GStringChunk"},{"type":"text","text":" "},{"text":"they are copied into the next free position in a block. When a block","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"is full a new block is allocated."}],"type":"paragraph"},{"inlineContent":[{"text":"When storing a large number of strings, string chunks are more","type":"text"},{"type":"text","text":" "},{"type":"text","text":"efficient than using [func"},{"code":"GLib.strdup","type":"codeVoice"},{"text":"] since fewer calls to ","type":"text"},{"type":"codeVoice","code":"malloc()"},{"type":"text","text":" "},{"type":"text","text":"are needed, and less memory is wasted in memory allocation overheads."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"By adding strings with [method"},{"code":"GLib.StringChunk.insert_const","type":"codeVoice"},{"text":"] it is also","type":"text"},{"type":"text","text":" "},{"text":"possible to remove duplicates.","type":"text"}]},{"inlineContent":[{"type":"text","text":"To create a new "},{"code":"GStringChunk","type":"codeVoice"},{"text":" use [func","type":"text"},{"type":"codeVoice","code":"GLib.StringChunk.new"},{"text":"].","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"To add strings to a "},{"code":"GStringChunk","type":"codeVoice"},{"type":"text","text":" use [method"},{"type":"codeVoice","code":"GLib.StringChunk.insert"},{"text":"].","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"To add strings to a "},{"type":"codeVoice","code":"GStringChunk"},{"type":"text","text":", but without duplicating strings"},{"text":" ","type":"text"},{"type":"text","text":"which are already in the "},{"code":"GStringChunk","type":"codeVoice"},{"type":"text","text":", use [method"},{"code":"GLib.StringChunk.insert_const","type":"codeVoice"},{"text":"].","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To free the entire "},{"code":"GStringChunk","type":"codeVoice"},{"text":" use [method","type":"text"},{"code":"GLib.StringChunk.free","type":"codeVoice"},{"text":"].","type":"text"},{"type":"text","text":" "},{"type":"text","text":"It is not possible to free individual strings."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/StringChunkProtocol","isActive":true,"type":"reference"},{"text":" protocol exposes the methods and properties of an underlying ","type":"text"},{"type":"codeVoice","code":"GStringChunk"},{"text":" instance.","type":"text"},{"text":" ","type":"text"},{"text":"The default implementation of these can be found in the protocol extension below.","type":"text"},{"type":"text","text":" "},{"text":"For a concrete class that implements these methods and properties, see ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/StringChunk","isActive":true},{"text":".","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Alternatively, use "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/StringChunkRef","isActive":true},{"type":"text","text":" as a lighweight, "},{"code":"unowned","type":"codeVoice"},{"type":"text","text":" reference if you already have an instance you just want to use."}]}]}],"references":{"doc://GLib/documentation/GLib/PointerWrapper":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/PointerWrapper","kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"PointerWrapper"}],"role":"s