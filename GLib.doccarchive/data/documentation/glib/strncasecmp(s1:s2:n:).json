{"schemaVersion":{"patch":0,"major":0,"minor":3},"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"strncasecmp","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"s1"},{"kind":"text","text":": "},{"preciseIdentifier":"s:SP","text":"UnsafePointer","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","text":"gchar","preciseIdentifier":"c:@T@gchar"},{"text":">!, ","kind":"text"},{"kind":"externalParam","text":"s2"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar","text":"gchar"},{"kind":"text","text":">!, "},{"text":"n","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"kind":"text","text":") -> "},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"content":[{"text":"Discussion","type":"heading","anchor":"discussion","level":2},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Strncasecmp is deprecated:"}]},{"text":" ","type":"text"},{"text":"The problem with ","type":"text"},{"type":"codeVoice","code":"g_strncasecmp()"},{"text":" is that it does","type":"text"},{"type":"text","text":" "},{"text":"the comparison by calling ","type":"text"},{"code":"toupper()","type":"codeVoice"},{"type":"text","text":"\/"},{"code":"tolower()","type":"codeVoice"},{"text":". These functions","type":"text"},{"type":"text","text":" "},{"text":"are locale-specific and operate on single bytes. However, it is","type":"text"},{"type":"text","text":" "},{"type":"text","text":"impossible to handle things correctly from an internationalization"},{"text":" ","type":"text"},{"text":"standpoint by operating on bytes, since characters may be multibyte.","type":"text"},{"text":" ","type":"text"},{"text":"Thus ","type":"text"},{"code":"g_strncasecmp()","type":"codeVoice"},{"text":" is broken if your string is guaranteed to be","type":"text"},{"type":"text","text":" "},{"type":"text","text":"ASCII, since it is locale-sensitive, and it’s broken if your string"},{"text":" ","type":"text"},{"text":"is localized, since it doesn’t work on many encodings at all,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"including UTF-8, EUC-JP, etc."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"There are therefore two replacement techniques: [func@GLib.ascii_strncasecmp],","type":"text"},{"type":"text","text":" "},{"text":"which only works on ASCII and is not locale-sensitive, and","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"[func@GLib.utf8_casefold] followed by "},{"code":"strcmp()","type":"codeVoice"},{"type":"text","text":" on the resulting strings,"},{"type":"text","text":" "},{"type":"text","text":"which is good for case-insensitive sorting of UTF-8."}]}],"kind":"content"}],"sections":[],"metadata":{"modules":[{"name":"GLib"}],"title":"strncasecmp(s1:s2:n:)","role":"symbol","roleHeading":"Function","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"strncasecmp","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"s1"},{"text":": ","kind":"text"},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"text":"gchar","preciseIdentifier":"c:@T@gchar","kind":"typeIdentifier"},{"text":">!, ","kind":"text"},{"kind":"externalParam","text":"s2"},{"text":": ","kind":"text"},{"text":"UnsafePointer","preciseIdentifier":"s:SP","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar","text":"gchar"},{"kind":"text","text":">!, "},{"text":"n","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifie