{"sections":[],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/TEST_OPTION_ISOLATE_DIRS"},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"let","kind":"keyword"},{"kind":"text","text":" "},{"text":"TEST_OPTION_ISOLATE_DIRS","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SS","text":"String","kind":"typeIdentifier"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"content":[{"anchor":"discussion","text":"Discussion","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"Creates a unique temporary directory for each unit test and uses sets"},{"type":"text","text":" "},{"text":"XDG directories to point into subdirectories of it for the duration of","type":"text"},{"text":" ","type":"text"},{"text":"the unit test. The directory tree is cleaned up after the test finishes","type":"text"},{"text":" ","type":"text"},{"text":"successfully.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Note that this doesn’t take effect until [func","type":"text"},{"code":"GLib.test_run","type":"codeVoice"},{"type":"text","text":"] is called,"},{"text":" ","type":"text"},{"text":"so calls to (for example) [func","type":"text"},{"type":"codeVoice","code":"GLib.get_home_dir"},{"type":"text","text":"] will return the"},{"type":"text","text":" "},{"text":"system-wide value when made in a test program’s ","type":"text"},{"type":"codeVoice","code":"main()"},{"type":"text","text":" function."}]},{"inlineContent":[{"type":"text","text":"The following functions will return subdirectories of the temporary directory"},{"type":"text","text":" "},{"type":"text","text":"when this option is used. The specific subdirectory paths in use are not"},{"type":"text","text":" "},{"text":"guaranteed to be stable API — always use a getter function to retrieve them.","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"[func"},{"type":"codeVoice","code":"GLib.get_home_dir"},{"text":"]","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"[func","type":"text"},{"type":"codeVoice","code":"GLib.get_user_cache_dir"},{"text":"]","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"[func","type":"text"},{"code":"GLib.get_system_config_dirs","type":"codeVoice"},{"text":"]","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"[func"},{"code":"GLib.get_user_config_dir","type":"codeVoice"},{"type":"text","text":"]"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"[func","type":"text"},{"type":"codeVoice","code":"GLib.get_system_data_dirs"},{"type":"text","text":"]"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"[func"},{"code":"GLib.get_user_data_dir","type":"codeVoice"},{"text":"]","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"[func","type":"text"},{"code":"GLib.get_user_state_dir","type":"codeVoice"},{"type":"text","text":"]"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"[func"},{"code":"GLib.get_user_runtime_dir","type":"codeVoice"},{"type":"text","text":"]"}],"type":"paragraph"}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The subdirectories may not be created by the test harness; as with normal"},{"type":"text","text":" "},{"text":"calls to functions like [func","type":"text"},{"code":"GLib.get_user_cache_dir","type":"codeVoice"},{"type":"text","text":"], the caller must"},{"text":" ","type":"text"},{"type":"text","text":"be prepared to create the directory if it doesn’t exist."},{"type":"text","text":" "},{"inlineContent":[{"text":"TEST_OPTION_ISOLATE_DIRS is deprecated:","type":"text"}],"type":"strong"},{"type":"text","text":" "},{"type":"text","text":"Use "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/testOptionIsolateDirs","type":"reference","isActive":true},{"type":"text","text":" instead."}]}],"kind":"content"}],"abstract":[{"text":"A value that can be passed as an option to [func","type":"text"},{"type":"codeVoice","code":"GLib.test_init"},{"type":"text","text":"]."}],"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/test_option_isolate_dirs"]}],"metadata":{"fragments":[{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"TEST_OPTION_ISOLATE_DIRS","kind":"identifier"},{"kind":"text","text":": "},{"preciseIdentifier":"s:SS","text":"String","kind":"typeIdentifier"}],"symbolKind":"var","roleHeading":"Global Variable","role":"symbol","platforms":[],"externalID":"s:4GLib24TEST_OPTION_ISOLATE_DIRSSSvp","title":"TEST_OPTION_ISOLATE_DIRS","modules":[{"name":"GLib"}]},"references":{"doc://GLib/documentation/GLib/testOptionIsolateDirs":{"role":"symbol","fragments":[{"text":"let","kind":"keyword"},{"kind":"text","text":" "},{"text":"testOptionIsolateDirs","kind":"identifier"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"String","preciseIdentifier":"s:SS"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/testOptionIsolateDirs","title":"testOptionIsolateDirs","type":"topic","abstract":[{"text":"A value that can be passed as an option to [func","type":"text"},{"type":"codeVoice","code":"GLib.test_init"},{"text":"].","type":"text"}],"url":"\/documentation\/glib\/testoptionisolatedirs","kind":"symbol"},"doc://GLib/documentation/GLib":{"kind":"symbol","role":"collection","abstract":[],"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","type":"topic","url":"\/documentation\/glib"},"doc://GLib/documentation/GLib/TEST_OPTION_ISOLATE_DIRS":{"fragments":[{"kind":"keyword","text":"let"},{"text":" ","kind":"text"},{"text":"TEST_OPTION_ISOLATE_DIRS","kind":"identifier"},{"kind":"text","text":": "},{"preciseIdentifier":"s:SS","text"