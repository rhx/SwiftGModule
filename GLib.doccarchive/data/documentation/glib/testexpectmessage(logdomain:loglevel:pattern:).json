unc"},{"kind":"text","text":" "},{"kind":"identifier","text":"testExpectMessage"},{"kind":"text","text":"("},{"text":"logDomain","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar","text":"gchar"},{"kind":"text","text":">? = nil, "},{"kind":"externalParam","text":"logLevel"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:4GLib13LogLevelFlagsV","identifier":"doc:\/\/GLib\/documentation\/GLib\/LogLevelFlags","text":"LogLevelFlags"},{"kind":"text","text":", "},{"kind":"externalParam","text":"pattern"},{"kind":"text","text":": "},{"text":"UnsafePointer","preciseIdentifier":"s:SP","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"gchar","preciseIdentifier":"c:@T@gchar"},{"kind":"text","text":">!)"}],"platforms":["macOS"]}]},{"content":[{"type":"heading","anchor":"discussion","text":"Discussion","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"When this message is logged, it will not be printed, and the test case will"},{"type":"text","text":" "},{"text":"not abort.","type":"text"}]},{"inlineContent":[{"type":"text","text":"This API may only be used with the old logging API ([func"},{"code":"GLib.log","type":"codeVoice"},{"type":"text","text":"] without"},{"type":"text","text":" "},{"type":"codeVoice","code":"G_LOG_USE_STRUCTURED"},{"type":"text","text":" defined). It will not work with the structured logging"},{"type":"text","text":" "},{"text":"API. See ","type":"text"},{"type":"reference","identifier":"logging.html#testing-for-messages","isActive":true},{"text":".","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Use [func","type":"text"},{"code":"GLib.test_assert_expected_messages","type":"codeVoice"},{"text":"] to assert that all","type":"text"},{"type":"text","text":" "},{"text":"previously-expected messages have been seen and suppressed.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can call this multiple times in a row, if multiple messages are"},{"type":"text","text":" "},{"type":"text","text":"expected as a result of a single call. (The messages must appear in"},{"text":" ","type":"text"},{"type":"text","text":"the same order as the calls to [func"},{"type":"codeVoice","code":"GLib.test_expect_message"},{"type":"text","text":"].)"}]},{"inlineContent":[{"text":"For example:","type":"text"}],"type":"paragraph"},{"syntax":"c","type":"codeListing","code":["\/\/ `g_main_context_push_thread_default()` should fail if the","\/\/ context is already owned by another thread.","g_test_expect_message (G_LOG_DOMAIN,","                       G_LOG_LEVEL_CRITICAL,","                       \"assertion*acquired_context*failed\");","g_main_context_push_thread_default (bad_context);","g_test_assert_expected_messages ();"]},{"type":"paragraph","inlineContent":[{"text":"Note that you cannot use this to test [func","type":"text"},{"code":"GLib.error","type":"codeVoice"},{"type":"text","text":"] messages, since"},{"type":"text","text":" "},{"text":"[func","type":"text"},{"code":"GLib.error","type":"codeVoice"},{"type":"text","text":"] intentionally never returns even if the program doesn’t"},{"text":" ","type":"text"},{"type":"text","text":"abort; use [func"},{"type":"codeVoice","code":"GLib.test_trap_subprocess"},{"type":"text","text":"] in this case."}]},{"type":"paragraph","inlineContent":[{"text":"If messages at [flags","type":"text"},{"type":"codeVoice","code":"GLib.LogLevelFlags.LEVEL_DEBUG"},{"text":"] are emitted, but not explicitly","type":"text"},{"text":" ","type":"text"},{"text":"expected via [func","type":"text"},{"code":"GLib.test_expect_message","type":"codeVoice"},{"text":"] then they will be ignored.","type":"text"}]}],"kind":"content"}],"sections":[],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"refere