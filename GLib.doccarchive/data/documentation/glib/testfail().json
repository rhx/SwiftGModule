{"sections":[],"metadata":{"role":"symbol","title":"testFail()","symbolKind":"func","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"testFail","kind":"identifier"},{"kind":"text","text":"()"}],"externalID":"s:4GLib8testFailyyF","roleHeading":"Function","modules":[{"name":"GLib"}]},"schemaVersion":{"patch":0,"minor":3,"major":0},"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/testfail()"]}],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"testFail","kind":"identifier"},{"kind":"text","text":"()"}],"languages":["swift"]}],"kind":"declarations"},{"content":[{"type":"heading","anchor":"discussion","text":"Discussion","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"This function can be called multiple times from the same test."},{"text":" ","type":"text"},{"type":"text","text":"You can use this function if your test failed in a recoverable way."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Do not use this function if the failure of a test could cause"},{"text":" ","type":"text"},{"text":"other tests to malfunction.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Calling this function will not stop the test from running, you","type":"text"},{"type":"text","text":" "},{"text":"need to return from the test function yourself. So you can","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"produce additional diagnostic messages or even continue running"},{"text":" ","type":"text"},{"type":"text","text":"the test."}]},{"inlineContent":[{"text":"If not called from inside a test, this function does nothing.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that unlike [func"},{"type":"codeVoice","code":"GLib.test_skip"},{"type":"text","text":"] and [func"},{"code":"GLib.test_incomplete","type":"codeVoice"},{"type":"text","text":"],"},{"text":" ","type":"text"},{"type":"text","text":"this function does not log a message alongside the test failure."},{"text":" ","type":"text"},{"text":"If details of the test failure are available, either log them with","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"[func"},{"code":"GLib.test_message","type":"codeVoice"},{"text":"] before [func","type":"text"},{"code":"GLib.test_fail","type":"codeVoice"},{"type":"text","text":"], or use"},{"text":" ","type":"text"},{"type":"text","text":"[func"},{"code":"GLib.test_fail_printf","type":"codeVoice"},{"type":"text","text":"] instead."}]}],"kind":"content"}],"abstract":[{"text":"Indicates that a test failed.","type":"text"}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/testFail()","interfaceLanguage":"swift"},"references":{"doc://GLib/documentation/GLib":{"kind":"symbol","role":"collection","abstract":[],"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","type":"topic","url":"\/documentation\/glib"},"doc://GLib/documentation/GLib/testFail()":{"title":"testFail()","kind":"symbol","url":"\/documentation\/glib\/testfail()","type":"topic","role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"testFail"},{"text":"()","kind":"text"}],"abstract":[{"text":"Indicates that a test failed.","type":"text"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/testFail()"}}}