:"text","text":" "},{"text":"tarball) always go in srcdir (even if doing a srcdir != builddir","type":"text"},{"text":" ","type":"text"},{"text":"build from git) and are considered as distributed files.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The same principles apply for other build systems, such as meson.","type":"text"}]}]}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/testfiletype"]}],"metadata":{"role":"symbol","roleHeading":"Type Alias","symbolKind":"typealias","externalID":"s:4GLib12TestFileTypea","title":"TestFileType","navigatorTitle":[{"text":"TestFileType","kind":"identifier"}],"modules":[{"name":"GLib"}],"fragments":[{"text":"typealias","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"TestFileType"}]},"sections":[],"schemaVersion":{"minor":3,"patch":0,"major":0},"references":{"doc://GLib/documentation/GLib/TestFileType":{"abstract":[{"type":"text","text":"The type of file to return the filename for, when used with"},{"type":"text","text":" "},{"type":"text","text":"[func"},{"code":"GLib.test_build_filename","type":"codeVoice"},{"text":"].","type":"text"}],"navigatorTitle":[{"text":"TestFileType","kind":"identifier"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/TestFileType","kind":"symbol","title":"TestFileType","url":"\/documentation\/glib\/testfiletype","type":"topic","role":"symbol","fragments":[{"kind":"keyword","text":"typealias"},{"text":" ","kind":"text"},{"text":"TestFileType","kind":"identifier"}]},"doc://GLib/documentation/GLib":{"kind":"symbol","role":"collection","abstract":[],"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","type":"topic","url":"\/documentation\/glib"}}}