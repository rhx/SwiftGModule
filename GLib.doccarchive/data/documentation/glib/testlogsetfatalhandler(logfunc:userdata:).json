{"schemaVersion":{"major":0,"minor":3,"patch":0},"primaryContentSections":[{"declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"testLogSetFatalHandler","kind":"identifier"},{"kind":"text","text":"("},{"text":"logFunc","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"GTestLogFatalFunc","preciseIdentifier":"c:@T@GTestLogFatalFunc"},{"kind":"text","text":"?, "},{"text":"userData","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gpointer","text":"gpointer"},{"kind":"text","text":"? = nil)"}]}],"kind":"declarations"},{"kind":"content","content":[{"level":2,"text":"Discussion","type":"heading","anchor":"discussion"},{"inlineContent":[{"type":"text","text":"The use case here is that you are running a test case"},{"type":"text","text":" "},{"type":"text","text":"that depends on particular libraries or circumstances"},{"type":"text","text":" "},{"text":"and cannot prevent certain known critical or warning","type":"text"},{"type":"text","text":" "},{"text":"messages. So you install a handler that compares the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"domain and message to precisely not abort in such a case."}],"type":"paragraph"},{"inlineContent":[{"text":"Note that the handler is reset at the beginning of","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"any test case, so you have to set it inside each test"},{"type":"text","text":" "},{"type":"text","text":"function which needs the special behavior."}],"type":"paragraph"},{"inlineContent":[{"text":"This handler has no effect on g_error messages.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"This handler also has no effect on structured log messages (using","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"[func"},{"code":"GLib.log_structured","type":"codeVoice"},{"text":"] or [func","type":"text"},{"type":"codeVoice","code":"GLib.log_structured_array"},{"text":"]). To change the fatal","type":"text"},{"type":"text","text":" "},{"type":"text","text":"behaviour for specific log messages, programs must install a custom log"},{"type":"text","text":" "},{"text":"writer function using [func","type":"text"},{"code":"GLib.log_set_writer_func","type":"codeVoice"},{"type":"text","text":"].See"},{"type":"text","text":" "},{"identifier":"logging.html#using-structured-logging","type":"reference","isActive":true},{"text":".","type":"text"}]}]}],"metadata":{"modules":[{"name":"GLib"}],"title":"testLogSetFatalHandler(logFunc:userData:)","roleHeading":"Function","role":"symbol","externalID":"s:4GLib22testLogSetFatalHandler7logFunc8userDatays5Int32VSPys4Int8VGSg_So14GLogLevelFlagsaAJSvSgtXCSg_AMtF","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"testLogSetFatalHandler"},{"text":"(","kind":"text"},{"text":"logFunc","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@GTestLogFatalFunc","text":"GTestLogFatalFunc"},{"text":"?, ","kind":"text"},{"kind":"externalParam","text":"userData"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"gpointer","preciseIdentifier":"c:@T@gpointer"},{"text":"?)","kind":"text"}],"symbolKind":"func"},"sections":[],"abstract":[{"type":"text","text":"Installs a non-error fatal log handler which can be"},{"type":"text","text":" "},{"text":"used to decide whether log messages which are counted","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"as fatal abort the program."}],"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/testlogsetfatalhandler(logfunc:userdata:)"]}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/testLogSetFatalHandler(l