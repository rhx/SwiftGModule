{"sections":[],"abstract":[{"type":"text","text":"Respawns the test program to run only "},{"type":"codeVoice","code":"testPath"},{"type":"text","text":" in a subprocess with"},{"text":" ","type":"text"},{"text":"a given environment.","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"testTrapSubprocessWithEnvp"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"testPath"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SP","kind":"typeIdentifier","text":"UnsafePointer"},{"text":"<","kind":"text"},{"preciseIdentifier":"s:s5CChara","text":"CChar","kind":"typeIdentifier"},{"kind":"text","text":">? = nil, "},{"text":"envp","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"UnsafePointer","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","text":"CChar","preciseIdentifier":"s:s5CChara"},{"text":">?>! = nil, ","kind":"text"},{"text":"usecTimeout","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"guint64","kind":"typeIdentifier","preciseIdentifier":"c:@T@guint64"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"testFlags"},{"kind":"text","text":": "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/TestSubprocessFlags","text":"TestSubprocessFlags","kind":"typeIdentifier","preciseIdentifier":"s:4GLib19TestSubprocessFlagsV"},{"kind":"text","text":")"}],"platforms":["macOS"]}]},{"kind":"content","content":[{"type":"heading","level":2,"anchor":"discussion","text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This can be used for a test case that might not return, or that"},{"text":" ","type":"text"},{"type":"text","text":"might abort."}]},{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"code":"testPath","type":"codeVoice"},{"type":"text","text":" is "},{"type":"codeVoice","code":"NULL"},{"type":"text","text":" then the same test is re-run in a subprocess."},{"type":"text","text":" "},{"type":"text","text":"You can use [func"},{"code":"GLib.test_subprocess","type":"codeVoice"},{"type":"text","text":"] to determine whether the test"},{"text":" ","type":"text"},{"type":"text","text":"is in a subprocess or not."}]},{"inlineContent":[{"type":"codeVoice","code":"testPath"},{"text":" can also be the name of the parent test, followed by","type":"text"},{"text":" ","type":"text"},{"text":"“","type":"text"},{"code":"\/subprocess\/","type":"codeVoice"},{"type":"text","text":"” and then a name for the specific subtest (or just"},{"text":" ","type":"text"},{"type":"text","text":"ending with “"},{"code":"\/subprocess","type":"codeVoice"},{"type":"text","text":"” if the test only has one child test);"},{"type":"text","text":" "},{"type":"text","text":"tests with names of this form will automatically be skipped in the"},{"type":"text","text":" "},{"text":"parent process.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"envp"},{"type":"text","text":" is "},{"code":"NULL","type":"codeVoice"},{"text":", the parent process’ environment will be inherited.","type":"text"}]},{"inlineContent":[{"type":"text","text":"If "},{"code":"usecTimeout","type":"codeVoice"},{"type":"text","text":" is non-0, the test subprocess is aborted and"},{"text":" ","type":"text"},{"type":"text","text":"considered failing if its run time exceeds it."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The subprocess behavior can be configured with [flags","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/TestSubprocessFlags","isActive":true},{"type":"text","text":"]"},{"type":"text","text":" "},{"text":"flags.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"You can use methods such as [func","type":"text"},{"type":"codeVoice","code":"GLib.test_trap_assert_passed"},{"text":"],","type":"text"},{"text":" ","type":"text"},{"text":"[func","type":"text"},{"code":"GLib.test_trap_assert_failed","type":"codeVoice"},{"text":"], and [func","type":"text"},{"code":"GLib.test_trap_assert_stderr","type":"codeVoice"},{"text":"] to","type":"text"},{"type":"text","text":" "},{"text":"check the results of the subprocess. (But note that","type":"text"},{"type":"text","text":" "},{"text":"[func","type":"text"},{"type":"codeVoice","code":"GLib.test_trap_assert_stdout"},{"type":"text","text":"] and [func"},{"type":"codeVoice","code":"GLib.test_trap_assert_stderr"},{"text":"]","type":"text"},{"text":" ","type":"text"},{"text":"cannot be used if ","type":"text"},{"type":"codeVoice","code":"testFlags"},{"type":"text","text":" specifies that the child should"},{"type":"text","text":" "},{"text":"inherit the parent stdout\/stderr.)","type":"text"}]},{"inlineContent":[{"type":"text","text":"If your "},{"type":"codeVoice","code":"main ()"},{"type":"text","text":" needs to behave differently in the subprocess, you can"},{"text":" ","type":"text"},{"type":"text","text":"call [func"},{"type":"codeVoice","code":"GLib.test_subprocess"},{"text":"] (after calling [func","type":"text"},{"type":"codeVoice","code":"GLib.test_init"},{"type":"text","text":"])"},{"type":"text","text":" "},{"text":"to see whether you are in a subprocess.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Internally, this function tracks the child process using","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[func"},{"type":"codeVoice","code":"GLib.child_watch_source_new"},{"type":"text","text":"], so your process must not ignore"},{"type":"text","text":" "},{"code":"SIGCHLD","type":"codeVoice"},{"text":", and must not attempt to watch or wait for the child process","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"via another mechanism."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The following example tests that calling ","type":"text"},{"code":"my_object_new(1000000)","type":"codeVoice"},{"type":"text","text":" will"},{"type":"text","text":" "},{"type":"text","text":"abort with an error message."}]},{"code":["  static void","  test_create_large_object (void)","  {","    if (g_test_subprocess ())","      {","        my_object_new (1000000);","        return;","      }","","    \/\/ Reruns this same test in a subprocess","    g_test_trap_subprocess (NULL, 0, G_TEST_SUBPROCESS_DEFAULT);","    g_test_trap_assert_failed ();","    g_test_trap_assert_stderr (\"*ERROR*too large*\");","  }","","  static void","  test_different_username (void)","  {","    if (g_test_subprocess ())","      {","        \/\/ Code under test goes here","        g_message (\"Username is now simulated as `s`\", g_getenv (\"USER\"));","        return;","      }","","    \/\/ Reruns this same test in a subprocess","    `g_auto(GStrv)` envp = g_get_environ ();","    envp = g_environ_setenv (g_steal_pointer (&envp), \"USER\", \"charlie\", TRUE);","    g_test_trap_subprocess_with_envp (NULL, envp, 0, G_TEST_SUBPROCESS_DEFAULT);","    g_test_trap_assert_passed ();","    g_test_trap_assert_stdout (\"Username is now simulated as charlie\");","  }","","  int","  main (int argc, char **argv)","  {","    g_test_init (&argc, &argv, NULL);","","    g_test_add_func (\"\/myobject\/create-large-object\",","                     test_create_large_object);","    g_test_add_func (\"\/myobject\/different-username\",","                     test_different_username);","    return g_test_run ();","  }"],"syntax":"c","type":"codeListing"}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"symbol","metadata":{"title":"testTrapSubprocessWithEnvp(testPath:envp:usecTimeout:testFlags:)","modules":[{"name":"GLib"}],"roleHeading":"Function","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" 