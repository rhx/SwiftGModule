{"metadata":{"roleHeading":"Protocol","modules":[{"name":"GLib"}],"role":"symbol","externalID":"s:4GLib18ThreadPoolProtocolP","title":"ThreadPoolProtocol","symbolKind":"protocol","navigatorTitle":[{"kind":"identifier","text":"ThreadPoolProtocol"}],"fragments":[{"kind":"keyword","text":"protocol"},{"text":" ","kind":"text"},{"text":"ThreadPoolProtocol","kind":"identifier"}]},"abstract":[{"text":"The ","type":"text"},{"code":"GThreadPool","type":"codeVoice"},{"text":" struct represents a thread pool.","type":"text"}],"variants":[{"paths":["\/documentation\/glib\/threadpoolprotocol"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/ThreadPoolProtocol"},"sections":[],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"topicSections":[{"identifiers":["doc:\/\/GLib\/documentation\/GLib\/ThreadPoolProtocol\/exclusive","doc:\/\/GLib\/documentation\/GLib\/ThreadPoolProtocol\/func","doc:\/\/GLib\/documentation\/GLib\/ThreadPoolProtocol\/maxThreads","doc:\/\/GLib\/documentation\/GLib\/ThreadPoolProtocol\/numThreads","doc:\/\/GLib\/documentation\/GLib\/ThreadPoolProtocol\/userData"],"title":"Instance Properties","anchor":"Instance-Properties","generated":true},{"generated":true,"title":"Instance Methods","anchor":"Instance-Methods","identifiers":["doc:\/\/GLib\/documentation\/GLib\/ThreadPoolProtocol\/free(immediate:wait:)","doc:\/\/GLib\/documentation\/GLib\/ThreadPoolProtocol\/getMaxThreads()","doc:\/\/GLib\/documentation\/GLib\/ThreadPoolProtocol\/getNumThreads()","doc:\/\/GLib\/documentation\/GLib\/ThreadPoolProtocol\/moveToFront(data:)","doc:\/\/GLib\/documentation\/GLib\/ThreadPoolProtocol\/push(data:)","doc:\/\/GLib\/documentation\/GLib\/ThreadPoolProtocol\/set(maxThreads:)","doc:\/\/GLib\/documentation\/GLib\/ThreadPoolProtocol\/setSortFunction(func:userData:)","doc:\/\/GLib\/documentation\/GLib\/ThreadPoolProtocol\/unprocessed()"]}],"relationshipsSections":[{"title":"Inherits From","type":"inheritsFrom","identifiers":["doc:\/\/GLib\/documentation\/GLib\/PointerWrapper"],"kind":"relationships"},{"title":"Conforming Types","identifiers":["doc:\/\/GLib\/documentation\/GLib\/ThreadPool","doc:\/\/GLib\/documentation\/GLib\/ThreadPoolRef"],"kind":"relationships","type":"conformingTypes"}],"kind":"symbol","schemaVersion":{"patch":0,"major":0,"minor":3},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ThreadPoolProtocol","kind":"identifier"},{"kind":"text","text":" : "},{"kind":"typeIdentifier","preciseIdentifier":"s:4GLib14PointerWrapperP","identifier":"doc:\/\/GLib\/documentation\/GLib\/PointerWrapper","text":"PointerWrapper"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"content","content":[{"anchor":"overview","level":2,"type":"heading","text":"Overview"},{"inlineContent":[{"text":"A thread pool is useful when you wish to asynchronously fork out the execution of work","type":"text"},{"type":"text","text":" "},{"type":"text","text":"and continue working in your own thread. If that will happen often, the overhead of starting"},{"text":" ","type":"text"},{"text":"and destroying a thread each time might be too high. In such cases reusing already started","type":"text"},{"type":"text","text":" "},{"type":"text","text":"threads seems like a good idea. And it indeed is, but implementing this can be tedious"},{"text":" ","type":"text"},{"text":"and error-prone.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Therefore GLib provides thread pools for your convenience. An added advantage is, that the"},{"type":"text","text":" "},{"text":"threads can be shared between the different subsystems of your program, when they are using GLib.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"To create a new thread pool, you use [func","type":"text"},{"type":"codeVoice","code":"GLib.ThreadPool.new"},{"text":"].","type":"text"},{"text":" ","type":"text"},{"text":"It is destroyed by [method","type":"text"},{"type":"codeVoice","code":"GLib.ThreadPool.free"},{"text":"].","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you want to execute a certain task within a thread pool, use [method"},{"code":"GLib.ThreadPool.push","type":"codeVoice"},{"type":"text","text":"]."}]},{"type":"paragraph","inlineContent":[{"text":"To get the current number of running threads you call [method","type":"text"},{"type":"codeVoice","code":"GLib.ThreadPool.get_num_threads"},{"type":"text","text":"]."},{"text":" ","type":"text"},{"type":"text","text":"To get the number of still unprocessed tasks you call [method"},{"type":"codeVoice","code":"GLib.ThreadPool.unprocessed"},{"text":"].","type":"text"},{"type":"text","text":" "},{"text":"To control the maximum number of threads for a thread pool, you use","type":"text"},{"text":" ","type":"text"},{"text":"[method","type":"text"},{"type":"codeVoice","code":"GLib.ThreadPool.get_max_threads"},{"type":"text","text":"]. and [method"},{"code":"GLib.ThreadPool.set_max_threads","type":"codeVoice"},{"text":"].","type":"text"}]},{"inlineContent":[{"text":"Finally you can control the number of unused threads, that are kept alive by GLib for future use.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"The current number can be fetched with [func"},{"code":"GLib.ThreadPool.get_num_unused_threads","type":"codeVoice"},{"type":"text","text":"]."},{"type":"text","text":" "},{"type":"text","text":"The maximum number can be controlled by [func"},{"code":"GLib.ThreadPool.get_max_unused_threads","type":"codeVoice"},{"type":"text","text":"] and"},{"text":" ","type":"text"},{"text":"[func","type":"text"},{"code":"GLib.ThreadPool.set_max_unused_threads","type":"codeVoice"},{"text":"]. All currently unused threads","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"can be stopped by calling [func"},{"type":"codeVoice","code":"GLib.ThreadPool.stop_unused_threads"},{"text":"].","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/ThreadPoolProtocol","type":"reference"},{"text":" protocol exposes the methods and properties of an underlying ","type":"text"},{"type":"codeVoice","code":"GThreadPool"},{"type":"text","text":" instance."},{"text":" ","type":"text"},{"text":"The default implementation of these can be found in the protocol extension below.","type":"text"},{"type":"text","text":" "},{"text":"For a concrete class that implements these methods and properties, see ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/ThreadPool"},{"text":".","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Alternatively, use "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/ThreadPoolRef","isActive":true},{"type":"text","text":" as a lighweight, "},{"code":"unowned","type":"codeVoice"},{"type":"text","text":" reference if you already have an instance you just want to use."}]}]}],"references":{"doc://GLib/documentation/GLib/ThreadPoolProtocol/maxThreads":{"role":"symbol","url":"\/documentation\/glib\/threadpoolprotocol\/maxthreads","title":"maxThreads","type":"topic","kind":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/ThreadPoolProtocol\/maxThreads","fragments":[{"text":"var","kind":"keyword"},{"kind":"text","text":" "},{"text":"maxThreads","kind":"identifier"},{"kind":"text","text":": "},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"}],"abstract":[{"type":"text","text":"Returns the maximal number of threads for "},{"code":"pool","type":"codeVoice"},{"type":"text","text":"."}]},"doc://GLib/documentation/GLib":{"kind":"symbol","role":"collection","abstract":[],"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","type":"topic","url":"\/docum