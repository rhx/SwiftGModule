"inlineContent":[{"text":"When the number of currently running threads is lower than the","type":"text"},{"text":" ","type":"text"},{"text":"maximal allowed number of threads, a new thread is started (or","type":"text"},{"type":"text","text":" "},{"type":"text","text":"reused) with the properties given to "},{"type":"codeVoice","code":"g_thread_pool_new()"},{"type":"text","text":"."},{"text":" ","type":"text"},{"type":"text","text":"Otherwise, "},{"code":"data","type":"codeVoice"},{"type":"text","text":" stays in the queue until a thread in this pool"},{"type":"text","text":" "},{"type":"text","text":"finishes its previous task and processes "},{"code":"data","type":"codeVoice"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"code":"error","type":"codeVoice"},{"type":"text","text":" can be "},{"code":"nil","type":"codeVoice"},{"type":"text","text":" to ignore errors, or non-"},{"code":"nil","type":"codeVoice"},{"type":"text","text":" to report"},{"text":" ","type":"text"},{"text":"errors. An error can only occur when a new thread couldn’t be","type":"text"},{"text":" ","type":"text"},{"text":"created. In that case ","type":"text"},{"type":"codeVoice","code":"data"},{"text":" is simply appended to the queue of","type":"text"},{"text":" ","type":"text"},{"text":"work to do.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Before version 2.32, this function did not return a success status.","type":"text"}]}]}],"references":{"doc://GLib/documentation/GLib":{"kind":"symbol","role":"collection","abstract":[],"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","type":"topic","url":"\/documentation\/glib"},"doc://GLib/documentation/GLib/ThreadPoolProtocol/push(data:)":{"kind":"symbol","type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib\/ThreadPoolProtocol\/push(data:)","title":"push(data:)","url":"\/documentation\/glib\/threadpoolprotocol\/push(data:)","role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"k