{"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"timeoutAdd","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"interval"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"function"},{"text":": ","kind":"text"},{"text":"GSourceFunc","kind":"typeIdentifier","preciseIdentifier":"c:@T@GSourceFunc"},{"kind":"text","text":"?, "},{"text":"data","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gpointer","text":"gpointer"},{"text":"? = nil) -> ","kind":"text"},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"}]}],"kind":"declarations"},{"kind":"content","content":[{"level":2,"anchor":"discussion","type":"heading","text":"Discussion"},{"inlineContent":[{"type":"text","text":"The given "},{"type":"codeVoice","code":"function"},{"text":" is called repeatedly until it returns","type":"text"},{"type":"text","text":" "},{"text":"[const","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/sourceRemove","isActive":true},{"text":"], at which point the timeout is","type":"text"},{"text":" ","type":"text"},{"text":"automatically destroyed and the function will not be called again. The first","type":"text"},{"text":" ","type":"text"},{"text":"call to the function will be at the end of the first ","type":"text"},{"code":"interval","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that timeout functions may be delayed, due to the processing of other"},{"text":" ","type":"text"},{"type":"text","text":"event sources. Thus they should not be relied on for precise timing."},{"type":"text","text":" "},{"type":"text","text":"After each call to the timeout function, the time of the next"},{"type":"text","text":" "},{"text":"timeout is recalculated based on the current time and the given interval","type":"text"},{"type":"text","text":" "},{"type":"text","text":"(it does not try to ‘catch up’ time lost in delays)."}]},{"type":"paragraph","inlineContent":[{"text":"See ","type":"text"},{"identifier":"main-loop.html#memory-management-of-sources","isActive":true,"type":"reference"},{"text":" for details","type":"text"},{"text":" ","type":"text"},{"text":"on how to handle the return value and memory management of ","type":"text"},{"type":"codeVoice","code":"data"},{"type":"text","text":"."}]},{"inlineContent":[{"type":"text","text":"If you want to have a timer in the ‘seconds’ range and do not care"},{"text":" ","type":"text"},{"type":"text","text":"about the exact time of the first call of the timer, use the"},{"type":"text","text":" "},{"text":"[func","type":"text"},{"code":"GLib.timeout_add_seconds","type":"codeVoice"},{"text":"] function; this function allows for more","type":"text"},{"type":"text","text":" "},{"type":"text","text":"optimizations and more efficient system power usage."}],"type":"paragraph"},{"inlineContent":[{"text":"This internally creates a main loop source using","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[func"},{"type":"codeVoice","code":"GLib.timeout_source_new"},{"type":"text","text":"] and attaches it to the global"},{"text":" ","type":"text"},{"type":"text","text":"[struct"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/MainContext","isActive":true},{"type":"text","text":"] using [method"},{"code":"GLib.Source.attach","type":"codeVoice"},{"type":"text","text":"], so the callback"},{"type":"text","text":" "},{"type":"text","text":"will be invoked in whichever thread is running that main context. You can do"},{"text":" ","type":"text"},{"type":"text","text":"these steps manually if you need greater control or to use a custom main"},{"type":"text","text":" "},{"text":"context.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"It is safe to call this function from any thread."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The interval given is in terms of monotonic time, not wall clock","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"time. See [func"},{"code":"GLib.get_monotonic_time","type":"codeVoice"},{"type":"text","text":"]."}]}]}],"kind":"symbol","variants":[{"paths":["\/documentation\/glib\/timeoutadd(interval:function:data:)"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"sections":[],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/timeoutAdd(interval:function:data:)","interfaceLanguage":"swift"},"metadata":{"roleHeading":"Function","modules":[{"name":"GLib"}],"symbolKind":"func","externalID":"s:4GLib10timeoutAdd8interval8function4dataS2i_s5Int32VSvSgXCSgAHtF","title":"timeoutAdd(interval:function:data:)","role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"timeoutAdd","kind":"identifier"},{"text":"(","kind":"text"},{"text":"interval","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"function"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:@T@GSourceFunc","kind":"typeIdentifier","text":"GSourceFunc"},{"kind":"text","text":"?, "},{"kind":"externalParam","text":"data"},{"text":": ","kind":"text"},{"text":"gpointer","preciseIdentifier":"c:@T@gpointer","kind":"typeIdentifier"},{"text":"?) -> ","kind":"text"},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"}]},"abstract":[{"text":"Sets a function to be called at regular intervals, with the default","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"priority, [const"},{"identifier":"doc:\