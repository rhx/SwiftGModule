{"abstract":[{"type":"text","text":"Sets a function to be called at regular intervals, with the given"},{"type":"text","text":" "},{"text":"priority.","type":"text"}],"schemaVersion":{"major":0,"patch":0,"minor":3},"metadata":{"roleHeading":"Function","role":"symbol","externalID":"s:4GLib14timeoutAddFull8priority8interval8function4data6notifyS2i_Sis5Int32VSvSgXCSgAJyAJXCSgtF","modules":[{"name":"GLib"}],"symbolKind":"func","title":"timeoutAddFull(priority:interval:function:data:notify:)","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"timeoutAddFull"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"priority"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"},{"text":", ","kind":"text"},{"text":"interval","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"},{"kind":"text","text":", "},{"kind":"externalParam","text":"function"},{"kind":"text","text":": "},{"preciseIdentifier":"c:@T@GSourceFunc","text":"GSourceFunc","kind":"typeIdentifier"},{"kind":"text","text":"?, "},{"text":"data","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"gpointer","preciseIdentifier":"c:@T@gpointer","kind":"typeIdentifier"},{"text":"?, ","kind":"text"},{"text":"notify","kind":"externalParam"},{"kind":"text","text":": "},{"text":"GDestroyNotify","preciseIdentifier":"c:@T@GDestroyNotify","kind":"typeIdentifier"},{"kind":"text","text":"?) -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"}]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/timeoutaddfull(priority:interval:function:data:notify:)"]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/timeoutAddFull(priority:interval:function:data:notify:)"},"sections":[],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"timeoutAddFull"},{"kind":"text","text":"("},{"kind":"externalParam","text":"priority"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"interval"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"},{"text":", ","kind":"text"},{"text":"function","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"GSourceFunc","kind":"typeIdentifier","preciseIdentifier":"c:@T@GSourceFunc"},{"text":"?, ","kind":"text"},{"text":"data","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"gpointer","kind":"typeIdentifier","preciseIdentifier":"c:@T@gpointer"},{"kind":"text","text":"? = nil, "},{"text":"notify","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:@T@GDestroyNotify","text":"GDestroyNotify","kind":"typeIdentifier"},{"text":"? = nil) -> ","kind":"text"},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"}]}]},{"content":[{"text":"Discussion","type":"heading","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"The function is called repeatedly until it returns","type":"text"},{"type":"text","text":" "},{"text":"[const","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/sourceRemove","isActive":true,"type":"reference"},{"text":"], at which point the timeout is automatically","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"destroyed and"},{"type":"text","text":" "},{"text":"the function will not be called again.  The ","type":"text"},{"type":"codeVoice","code":"notify"},{"text":" function is","type":"text"},{"type":"text","text":" "},{"type":"text","text":"called when the timeout is destroyed.  The first call to the"},{"text":" ","type":"text"},{"type":"text","text":"function will be at the end of the first "},{"type":"codeVoice","code":"interval"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Note that timeout functions may be delayed, due to the processing of other","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"event sources. Thus they should not be relied on for precise timing."},{"type":"text","text":" "},{"type":"text","text":"After each call to the timeout function, the time of the next"},{"type":"text","text":" "},{"text":"timeout is recalculated based on the current time and the given interval","type":"text"},{"type":"text","text":" "},{"text":"(it does not try to ‘catch up’ time lost in delays).","type":"text"}]},{"inlineContent":[{"type":"text","text":"See "},{"isActive":true,"identifier":"main-loop.html#memory-management-of-sources","type":"reference"},{"type":"text","text":" for details"},{"text":" ","type":"text"},{"type":"text","text":"on how to handle the return value and memory management of "},{"type":"codeVoice","code":"data"},{"text":".","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"This internally creates a main loop source using","type":"text"},{"text":" ","type":"text"},{"text":"[func","type":"text"},{"type":"codeVoice","code":"GLib.timeout_source_new"},{"text":"] and attaches it to the global","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[struct"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/MainContext","isActive":true,"type":"reference"},{"type":"text","text":"] using [method"},{"code":"GLib.Source.attach","type":"codeVoice"},{"type":"text","text":"], so the callback"},{"type":"text","text":" "},{"text":"will be invoked in whichever thread is running that main context. You can do","type":"text"},{"type":"text","text":" "},{"type":"text","text":"these steps manually if you need greater control or to use a custom main"},{"text":" ","type":"text"},{"text":"context.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The interval given is in terms of monotonic time, not wall clock time.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"See [func"},{"code":"GLib.get_monotonic_time","type":"codeVoice"},{"text":"].","type":"text"}]}],"kind":"content"}],"kind":"symbol","references":{"main-loop.html#memory-management-of-sources":{"titleInlineContent":[{"type":"text","text":"main loop memory management"}],"identifier":"main-loop.html#memory-management-of-sources","title":"main loop memory management","type":"link","url":"main-loop.html#memory-management-of-sources"},"doc://GLib/documentation/GLib/MainContext":{"abstract":[{"type":"text","text":"The "},{"type":"codeVoice","code":"GMainContext"},{"type":"text","text":" struct is an opaque data"},{"type":"text","text":" "},{"text":"type representing a set of sources to be handled in a main loop.","type":"text"}],"role":"symbol","kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"MainContext"}],"type":"topic","url":"\/documentation\/glib\/maincontext","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"MainContext"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/MainContext","title":"MainContext"},"doc://GLib/documentation/GLib/sourceRemove":{"url":"\/documentation\/glib\/sourceremove","identifier":"doc:\/\/GLib\/documentation\/GLib\/sourceRemove","type":"topic","abstract":[{"type":"text","text":"Use this macro as the return value of a [callback"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/SourceFunc"},{"text":"] to remove","type":"text"},{"text":" ","type":"text"},{"text":"the [struct","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Source"},{"type":"text","text":"] from the main loop."}],"role":"symbol","fragments":[{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"sourceRemove","kind":"identifier"},{"text":": ","