{"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"metadata":{"role":"symbol","externalID":"s:4GLib21timeoutAddSecondsFull8priority8interval8function4data6notifyS2i_Sis5Int32VSvSgXCSgAJyAJXCSgtF","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"timeoutAddSecondsFull"},{"text":"(","kind":"text"},{"text":"priority","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"interval"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"},{"kind":"text","text":", "},{"text":"function","kind":"externalParam"},{"kind":"text","text":": "},{"text":"GSourceFunc","preciseIdentifier":"c:@T@GSourceFunc","kind":"typeIdentifier"},{"text":"?, ","kind":"text"},{"text":"data","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"gpointer","preciseIdentifier":"c:@T@gpointer"},{"text":"?, ","kind":"text"},{"kind":"externalParam","text":"notify"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@GDestroyNotify","text":"GDestroyNotify"},{"text":"?) -> ","kind":"text"},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"}],"symbolKind":"func","title":"timeoutAddSecondsFull(priority:interval:function:data:notify:)","modules":[{"name":"GLib"}],"roleHeading":"Function"},"kind":"symbol","sections":[],"abstract":[{"text":"Sets a function to be called at regular intervals, with ","type":"text"},{"type":"codeVoice","code":"priority"},{"text":".","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/timeoutaddsecondsfull(priority:interval:function:data:notify:)"]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"timeoutAddSecondsFull","kind":"identifier"},{"kind":"text","text":"("},{"text":"priority","kind":"externalParam"},{"kind":"text","text":": "},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"kind":"text","text":", "},{"text":"interval","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"kind":"text","text":", "},{"text":"function","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@GSourceFunc","text":"GSourceFunc"},{"text":"?, ","kind":"text"},{"text":"data","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gpointer","text":"gpointer"},{"kind":"text","text":"? = nil, "},{"text":"notify","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"GDestroyNotify","kind":"typeIdentifier","preciseIdentifier":"c:@T@GDestroyNotify"},{"kind":"text","text":"? = nil) -> "},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"text":"Discussion","level":2,"anchor":"discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"The function is called repeatedly until it returns [const"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/sourceRemove","isActive":true,"type":"reference"},{"type":"text","text":"],"},{"type":"text","text":" "},{"type":"text","text":"at which point the timeout is automatically destroyed and"},{"type":"text","text":" "},{"type":"text","text":"the function will not be called again."}],"type":"paragraph"},{"inlineContent":[{"text":"Unlike [func","type":"text"},{"type":"codeVoice","code":"GLib.timeout_add"},{"text":"], this function operates at whole second","type":"text"},{"type":"text","text":" "},{"type":"text","text":"granularity. The initial starting point of the timer is determined by the"},{"text":" ","type":"text"},{"text":"implementation and the implementation is expected to group multiple timers","type":"text"},{"type":"text","text":" "},{"type":"text","text":"together so that they fire all at the same time. To allow this grouping,"},{"type":"text","text":" "},{"type":"text","text":"the "},{"type":"codeVoice","code":"interval"},{"type":"text","text":" to the first timer is rounded and can deviate up to one second"},{"type":"text","text":" "},{"text":"from the specified interval. Subsequent timer iterations will generally run","type":"text"},{"type":"text","text":" "},{"type":"text","text":"at the specified interval."}],"type":"paragraph"},{"inlineContent":[{"text":"Note that timeout functions may be delayed, due to the processing of other","type":"text"},{"type":"text","text":" "},{"text":"event sources. Thus they should not be relied on for precise timing.","type":"text"},{"text":" ","type":"text"},{"text":"After each call to the timeout function, the time of the next","type":"text"},{"type":"text","text":" "},{"type":"text","text":"timeout is recalculated based on the current time and the given "},{"code":"interval","type":"codeVoice"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"See "},{"isActive":true,"type":"reference","identifier":"main-loop.html#memory-management-of-sources"},{"text":" for details","type":"text"},{"type":"text","text":" "},{"type":"text","text":"on how to handle the return value and memory management of "},{"type":"codeVoice","code":"data"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you want timing more precise than whole seconds, use"},{"text":" ","type":"text"},{"type":"text","text":"[func"},{"code":"GLib.timeout_add","type":"codeVoice"},{"type":"text","text":"] instead."}]},{"type":"paragraph","inlineContent":[{"text":"The grouping of timers to fire at the same time results in a more power","type":"text"},{"type":"text","text":" "},{"type":"text","text":"and CPU efficient behavior so if your timer is in multiples of seconds"},{"type":"text","text":" "},{"type":"text","text":"and you don’t require the first timer exactly one second from now, the"},{"text":" ","type":"text"},{"text":"use of [func","type":"text"},{"type":"codeVoice","code":"GLib.timeout_add_seconds"},{"text":"] is preferred over","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"[func"},{"type":"codeVoice","code":"GLib.timeout_add"},{"type":"text","text":"]."}]},{"type":"paragraph","inlineContent":[{"text":"This internally creates a main loop source using","type":"text"},{"text":" ","type":"text"},{"text":"[func","type":"text"},{"type":"codeVoice","code":"GLib.timeout_source_new_seconds"},{"type":"text","text":"] and attaches it to the main loop"},{"type":"text","text":" "},{"type":"text","text":"context using [method"},{"code":"GLib.Source.attach","type":"codeVoice"},{"text":"]. You can do these steps manually","type":"text"},{"type":"text","text":" "},{"text":"if you need greater control.","type":"text"}]},{"inlineContent":[{"type":"text","text":"It is safe to call this function from any thread."}],"type":"paragraph"},{"inlineContent":[{"text":"The interval given is in terms of monotonic time, not wall clock","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"time. See [func"},{"type":"codeVoice","code":"GLib.get_monotonic_time"},{"text":"].","type":"text"}],"type":"paragraph"}]}],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/timeoutAddSecondsFull(priority:interval:function:data:notify:)","interfaceLanguage":"swift"},"schemaVersion":{"minor":3,"patch":0,"major":0},"references":{"doc://GLib/documentation/GLib/sourceRemove":{"url":"\/documentation\/glib\/sourceremove","identifier":"doc:\/\/GLib\/documentation\/GLib\/sourceRemove","type":"topic","abstract":[{"type":"text","text":"Use this macro as the return value of a [callback"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/SourceFunc"},{"text":"] to remove","type":"text"},{"text":" ","type":"text"},{"text":"the [struct","typ