{"metadata":{"externalID":"s:4GLib15TimeValProtocolPAAE9toIso8601SSSgyF","modules":[{"name":"GLib"}],"role":"symbol","platforms":[],"fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"toIso8601"},{"kind":"text","text":"() -> "},{"text":"String","preciseIdentifier":"s:SS","kind":"typeIdentifier"},{"kind":"text","text":"!"}],"roleHeading":"Instance Method","symbolKind":"method","title":"toIso8601()","extendedModule":"GLib"},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"toIso8601"},{"text":"() -> ","kind":"text"},{"preciseIdentifier":"s:SS","kind":"typeIdentifier","text":"String"},{"text":"!","kind":"text"}],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"type":"heading","level":2,"anchor":"discussion","text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"ISO 8601 allows a large number of date\/time formats, with or without"},{"type":"text","text":" "},{"text":"punctuation and optional elements. The format returned by this function","type":"text"},{"text":" ","type":"text"},{"text":"is a complete date and time, with optional punctuation included, the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"UTC time zone represented as “Z”, and the "},{"code":"tv_usec","type":"codeVoice"},{"type":"text","text":" part included if"},{"type":"text","text":" "},{"type":"text","text":"and only if it is nonzero, i.e. either"},{"type":"text","text":" "},{"text":"“YYYY-MM-DDTHH:MM:SSZ” or “YYYY-MM-DDTHH:MM:SS.fffffZ”.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"This corresponds to the Internet date\/time format defined by","type":"text"},{"text":" ","type":"text"},{"identifier":"https:\/\/www.ietf.org\/rfc\/rfc3339.txt","type":"reference","isActive":true},{"text":",","type":"text"},{"type":"text","text":" "},{"type":"text","text":"and to either of the two most-precise formats defined by"},{"type":"text","text":" "},{"type":"text","text":"the W3C Note"},{"type":"text","text":" "},{"identifier":"http:\/\/www.w3.org\/TR\/NOTE-datetime-19980827","isActive":true,"type":"reference"},{"text":".","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Both of these documents are profiles of ISO 8601."}]},{"inlineContent":[{"text":"Use ","type":"text"},{"type":"codeVoice","code":"g_date_time_format()"},{"text":" or ","type":"text"},{"code":"g_strdup_printf()","type":"codeVoice"},{"type":"text","text":" if a different"},{"text":" ","type":"text"},{"text":"variation of ISO 8601 format is required.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"code":"time","type":"codeVoice"},{"text":" represents a date which is too large to fit into a ","type":"text"},{"code":"struct tm","type":"codeVoice"},{"type":"text","text":","},{"text":" ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":" will be returned. This is platform dependent. Note also that since","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"GTimeVal"},{"text":" stores the number of seconds as a ","type":"text"},{"type":"codeVoice","code":"glong"},{"type":"text","text":", on 32-bit systems it"},{"type":"text","text":" "},{"type":"text","text":"is subject to the year 2038 problem. Accordingly, since GLib 2.62, this"},{"type":"text","text":" "},{"type":"text","text":"function has been deprecated. Equivalent functionality is available using:"}]},{"type":"codeListing","syntax":null,"code":["GDateTime *dt = g_date_time_new_from_unix_utc (time_val);","iso8601_string = g_date_time_format_iso8601 (dt);","g_date_time_unref (dt);"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The return value of "},{"type":"codeVoice","code":"g_time_val_to_iso8601()"},{"type":"text","text":" has been nullable since GLib"},{"text":" ","type":"text"},{"type":"text","text":"2.54; before then, GLib would crash under the same conditions."}]},{"inlineContent":[{"type":"strong","inlineContent":[{"text":"to_iso8601 is deprecated:","type":"text"}]},{"type":"text","text":" "},{"type":"text","text":"#GTimeVal is not year-2038-safe. Use"},{"type":"text","text":" "},{"type":"text","text":"g_date_time_format_iso8601(dt) instead."}],"type":"paragraph"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/timevalprotocol\/toiso8601()"]}],"abstract":[{"text":"Converts ","type":"text"},{"code":"time","type":"codeVoice"},{"type":"text","text":" into an RFC 3339 encoded string, relative to the"},{"text":" ","type":"text"},{"text":"Coordinated Universal Time (UTC). This is one of the many formats","type":"text"},{"text":" ","type":"text"},{"text":"allowed by ISO 8601.","type":"text"}],"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/TimeValProtocol\/toIso8601()"},"sections":[],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/TimeValProtocol"]]},"schemaVersion":{"major":0,"patch":0,"minor":3},"references":{"doc://GLib/documentation/GLib/TimeValProtocol/toIso8601()":{"title":"toIso8601()","role":"symbol","abstract":[{"type":"text","text":"Converts "},{"type":"codeVoice","code":"time"},{"text":" into an RFC 3339 encoded string, relative to the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Coordinated Universal Time (UTC). This is one of the many formats"},{"type":"text","text":" "},{"type":"text","text":"allowed by ISO 8601."}],"kind":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"toIso8601"},{"kind":"text","text":"() -> "},{"preciseIdentifier":"s:SS","text":"String","kind":"typeIdentifier"},{"kind":"text","text":"!"}],"url":"\/documentation\/glib\/timevalprotocol\/toiso8601()","type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib\/TimeValProtocol\/toIso8601()","deprecated":true},"doc://GLib/documentation/GLib/TimeValProtocol":{"url":"\/documentation\/glib\/timevalprotocol","type":"topic","navigatorTitle":[{"kind":"identifier","text":"TimeValProtocol"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/TimeValProtocol","kind":"symbol","title":"TimeValProtocol","fragments":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"text":"TimeValProtocol","kind":"identifier"}],"abstract":[{"type":"text","text":"Represents a precise time, with seconds and microseconds."}],"role":"symbol"},"doc://GLib/documentation/GLib":{"kind":"symbol","role":"collection","abstract":[],"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","type":"topic","url":"\/documentation\/glib"},"http://www.w3.org/TR/NOTE-datetime-19980827":{"title":"Date and Time Formats","url":"http:\/\/www.w3.org\/TR\/NOTE-datetime-19980827","titleInlineContent":[{"text":"Date and Time Formats","type":"text"}],"type":"link","identifier":"http:\/\/www.w3.org\/TR\/NOTE-datetime-19980827"},"https://www.ietf.org/rfc/rfc3339.txt":{"title":"RFC 3339","url":"https:\/\/www.ietf.org\/rfc\/rfc3339.txt","titleInlineContent":[{"text":"RFC 3339","type":"text"}],"type":"link","identifier":"https:\/\/www.ietf.org\/rfc\/rfc3339.txt"}}}