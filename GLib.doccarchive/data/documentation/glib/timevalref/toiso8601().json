{"metadata":{"externalID":"s:4GLib15TimeValProtocolPAAE9toIso8601SSSgyF::SYNTHESIZED::s:4GLib10TimeValRefV","extendedModule":"GLib","symbolKind":"method","title":"toIso8601()","role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"toIso8601"},{"kind":"text","text":"() -> "},{"preciseIdentifier":"s:SS","text":"String","kind":"typeIdentifier"},{"kind":"text","text":"!"}],"platforms":[],"modules":[{"name":"GLib"}],"roleHeading":"Instance Method"},"schemaVersion":{"patch":0,"major":0,"minor":3},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/TimeValRef\/toIso8601()"},"abstract":[{"text":"Converts ","type":"text"},{"code":"time","type":"codeVoice"},{"type":"text","text":" into an RFC 3339 encoded string, relative to the"},{"text":" ","type":"text"},{"type":"text","text":"Coordinated Universal Time (UTC). This is one of the many formats"},{"type":"text","text":" "},{"type":"text","text":"allowed by ISO 8601."}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/TimeValRef","doc:\/\/GLib\/documentation\/GLib\/TimeValRef\/TimeValProtocol-Implementations"]]},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"toIso8601"},{"text":"() -> ","kind":"text"},{"kind":"typeIdentifier","text":"String","preciseIdentifier":"s:SS"},{"text":"!","kind":"text"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"inlineContent":[{"text":"ISO 8601 allows a large number of date\/time formats, with or without","type":"text"},{"type":"text","text":" "},{"type":"text","text":"punctuation and optional elements. The format returned by this function"},{"type":"text","text":" "},{"text":"is a complete date and time, with optional punctuation included, the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"UTC time zone represented as “Z”, and the "},{"code":"tv_usec","type":"codeVoice"},{"text":" part included if","type":"text"},{"type":"text","text":" "},{"type":"text","text":"and only if it is nonzero, i.e. either"},{"text":" ","type":"text"},{"text":"“YYYY-MM-DDTHH:MM:SSZ” or “YYYY-MM-DDTHH:MM:SS.fffffZ”.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This corresponds to the Internet date\/time format defined by"},{"type":"text","text":" "},{"type":"reference","identifier":"https:\/\/www.ietf.org\/rfc\/rfc3339.txt","isActive":true},{"type":"text","text":","},{"text":" ","type":"text"},{"type":"text","text":"and to either of the two most-precise formats defined by"},{"text":" ","type":"text"},{"type":"text","text":"the W3C Note"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"http:\/\/www.w3.org\/TR\/NOTE-datetime-19980827"},{"type":"text","text":"."},{"type":"text","text":" "},{"text":"Both of these documents are profiles of ISO 8601.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use "},{"code":"g_date_time_format()","type":"codeVoice"},{"type":"text","text":" or "},{"type":"codeVoice","code":"g_strdup_printf()"},{"type":"text","text":" if a different"},{"text":" ","type":"text"},{"text":"variation of ISO 8601 format is required.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"time"},{"text":" represents a date which is too large to fit into a ","type":"text"},{"code":"struct tm","type":"codeVoice"},{"type":"text","text":","},{"text":" ","type":"text"},{"code":"nil","type":"codeVoice"},{"type":"text","text":" will be returned. This is platform dependent. Note also that since"},{"type":"text","text":" "},{"code":"GTimeVal","type":"codeVoice"},{"type":"text","text":" stores the number of seconds as a "},{"code":"glong","type":"codeVoice"},{"type":"text","text":", on 32-bit systems it"},{"type":"text","text":" "},{"text":"is subject to the year 2038 problem. Accordingly, since GLib 2.62, this","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"function has been deprecated. Equivalent functionality is available using:"}]},{"code":["GDateTime *dt = g_date_time_new_from_unix_utc (time_val);","iso8601_string = g_date_time_format_iso8601 (dt);","g_date_time_unref (dt);"],"syntax":null,"type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"The return value of ","type":"text"},{"type":"codeVoice","code":"g_time_val_to_iso8601()"},{"text":" has been nullable since GLib","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"2.54; before then, GLib would crash under the same conditions."}]},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"to_iso8601 is deprecated:"}]},{"text":" ","type":"text"},{"type":"text","text":"#GTimeVal is not year-2038-safe. Use"},{"text":" ","type":"text"},{"type":"text","text":"g_date_time_format_iso8601(dt) instead."}],"type":"paragraph"}]}],"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/timevalref\/toiso8601()"]}],"kind":"symbol","references":{"doc://GLib/documentation/GLib":{"kind":"symbol","role":"collection","abstract":[],"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","type":"topic","url":"\/documentation\/glib"},"doc://GLib/documentation/GLib/TimeValRef":{"title":"TimeValRef","abstract":[{"type":"text","text":"Represents a precise time, with seconds and microseconds."}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"TimeValRef"}],"url":"\/documentation\/glib\/timevalref","navigatorTitle":[{"kind":"identifier","text":"TimeValRef"}],"kind":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/TimeValRef","role":"symbol"},"doc://GLib/documentation/GLib/TimeValRef/toIso8601()":{"fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"toIso8601","kind":"identifier"},{"kind":"text","text":"() -> "},{"kind":"typeIdentifier","text":"String","preciseIdentifier":"s:SS"},{"text":"!","kind":"text"}],"deprecated":true,"role":"symbol","abstract":[{"type":"text","text":"Converts "},{"type":"codeVoice","code":"time"},{"type":"text","text":" into an RFC 3339 encoded string, relative to the"},{"type":"text","text":" "},{"text":"Coordinated Universal Time (UTC). This is one of the many formats","type":"text"},{"type":"text","text":" "},{"text":"allowed by ISO 8601.","type":"text"}],"title":"toIso8601()","identifier":"doc:\/\/GLib\/documentation\/GLib\/TimeValRef\/toIso8601()","type":"topic","url":"\/documentation\/glib\/timevalref\/toiso8601()","kind":"symbol"},"doc://GLib/documentation/GLib/TimeValRef/TimeValProtocol-Implementations":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/TimeValRef\/TimeValProtocol-Implementations","url":"\/documentation\/glib\/timevalref\/timevalprotocol-implementations","role":"collectionGroup","kind":"article","abstract":[],"type":"topic","title":"TimeValProtocol Implementations"},"http://www.w3.org/TR/NOTE-datetime-19980827":{"identifier":"http:\/\/www.w3.org\/TR\/NOTE-datetime-19980827","title":"Date and Time Formats","type":"link","titleInlineContent":[{"type":"text","text":"Date and Time Formats"}],"url":"http:\/\/www.w3.org\/TR\/NOTE-datetime-19980827"},"https://www.ietf.org/rfc/rfc3339.txt":{"title":"RFC 3339","identifier":"https:\/\/www.ietf.org\/rfc\/rfc3339.txt","type":"link","titleInlineContent":[{"text":"RFC 3339","type":"text"}],"url":"https:\/\/www.ietf.org\/rfc\/rfc3339.txt"}}}