{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/TimeZone\/new(identifier:)"},"abstract":[{"type":"text","text":"Creates a "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/TimeZone","type":"reference","isActive":true},{"type":"text","text":" corresponding to "},{"code":"identifier","type":"codeVoice"},{"type":"text","text":". If "},{"type":"codeVoice","code":"identifier"},{"type":"text","text":" cannot be"},{"type":"text","text":" "},{"type":"text","text":"parsed or loaded, "},{"code":"nil","type":"codeVoice"},{"text":" is returned.","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/timezone\/new(identifier:)"]}],"kind":"symbol","metadata":{"modules":[{"name":"GLib"}],"title":"new(identifier:)","externalID":"s:4GLib8TimeZoneC3new10identifierACSgSPys4Int8VGSg_tFZ","fragments":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"new"},{"text":"(","kind":"text"},{"text":"identifier","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"UnsafePointer","preciseIdentifier":"s:SP"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"gchar","preciseIdentifier":"c:@T@gchar"},{"text":">?) -> ","kind":"text"},{"text":"TimeZone","kind":"typeIdentifier","preciseIdentifier":"s:4GLib8TimeZoneC"},{"kind":"text","text":"!"}],"roleHeading":"Type Method","role":"symbol","symbolKind":"method"},"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"static"},{"text":" ","kind":"text"},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"new","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"identifier"},{"kind":"text","text":": "},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar"},{"kind":"text","text":">? = nil) -> "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/TimeZone","kind":"typeIdentifier","text":"TimeZone","preciseIdentifier":"s:4GLib8TimeZoneC"},{"kind":"text","text":"!"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"anchor":"discussion","text":"Discussion","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"code":"identifier","type":"codeVoice"},{"text":" can either be an RFC3339\/ISO 8601 time offset or","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"something that would pass as a valid value for the "},{"code":"TZ","type":"codeVoice"},{"type":"text","text":" environment"},{"type":"text","text":" "},{"text":"variable (including ","type":"text"},{"type":"codeVoice","code":"nil"},{"text":").","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"In Windows, ","type":"text"},{"type":"codeVoice","code":"identifier"},{"text":" can also be the unlocalized name of a time","type":"text"},{"text":" ","type":"text"},{"text":"zone for standard time, for example “Pacific Standard Time”.","type":"text"}]},{"inlineContent":[{"text":"Valid RFC3339 time offsets are ","type":"text"},{"code":"\"Z\"","type":"codeVoice"},{"text":" (for UTC) or","type":"text"},{"type":"text","text":" "},{"code":"\"±hh:mm\"","type":"codeVoice"},{"type":"text","text":".  ISO 8601 additionally specifies"},{"type":"text","text":" "},{"code":"\"±hhmm\"","type":"codeVoice"},{"type":"text","text":" and "},{"type":"codeVoice","code":"\"±hh\""},{"type":"text","text":".  Offsets are"},{"type":"text","text":" "},{"text":"time values to be added to Coordinated Universal Time (UTC) to get","type":"text"},{"text":" ","type":"text"},{"text":"the local time.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In UNIX, the "},{"type":"codeVoice","code":"TZ"},{"type":"text","text":" environment variable typically corresponds"},{"text":" ","type":"text"},{"type":"text","text":"to the name of a file in the zoneinfo database, an absolute path to a file"},{"text":" ","type":"text"},{"type":"text","text":"somewhere else, or a string in"},{"type":"text","text":" "},{"type":"text","text":"“std offset [dst [offset],start[\/time],end[\/time]]” (POSIX) format."},{"text":" ","type":"text"},{"text":"There  are  no spaces in the specification. The name of standard","type":"text"},{"text":" ","type":"text"},{"text":"and daylight savings time zone must be three or more alphabetic","type":"text"},{"type":"text","text":" "},{"text":"characters. Offsets are time values to be added to local time to","type":"text"},{"type":"text","text":" "},{"text":"get Coordinated Universal Time (UTC) and should be","type":"text"},{"text":" ","type":"text"},{"code":"\"[±]hh[[:]mm[:ss]]\"","type":"codeVoice"},{"type":"text","text":".  Dates are either"},{"type":"text","text":" "},{"code":"\"Jn\"","type":"codeVoice"},{"text":" (Julian day with n between 1 and 365, leap","type":"text"},{"type":"text","text":" "},{"type":"text","text":"years not counted), "},{"type":"codeVoice","code":"\"n\""},{"text":" (zero-based Julian day","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"with n between 0 and 365) or "},{"code":"\"Mm.w.d\"","type":"codeVoice"},{"text":" (day d","type":"text"},{"text":" ","type":"text"},{"text":"(0 <= d <= 6) of week w (1 <= w <= 5) of month m (1 <= m <= 12), day","type":"text"},{"type":"text","text":" "},{"text":"0 is a Sunday).  Times are in local wall clock time, the default is","type":"text"},{"type":"text","text":" "},{"type":"text","text":"02:00:00."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"In Windows, the “tzn[+|–]hh"},{"type":"reference","identifier":"#dzn","isActive":true},{"type":"text","text":"” format is used, but also"},{"type":"text","text":" "},{"text":"accepts POSIX format.  The Windows format uses US rules for all time","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"zones; daylight savings time is 60 minutes behind the standard time"},{"type":"text","text":" "},{"text":"with date and time of change taken from Pacific Standard Time.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Offsets are time values to be added to the local time to get"},{"text":" ","type":"text"},{"type":"text","text":"Coordinated Universal Time (UTC)."}]},{"type":"paragraph","inlineContent":[{"code":"g_time_zone_new_local()","type":"codeVoice"},{"text":" calls this function with the value of the","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"TZ"},{"type":"text","text":" environment variable. This function itself is independent of"},{"type":"text","text":" "},{"type":"text","text":"the value of "},{"type":"codeVoice","code":"TZ"},{"type":"text","text":", but if "},{"type":"codeVoice","code":"identifier"},{"type":"text","text":" is "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" then "},{"type":"codeVoice","code":"\/etc\/localtime"},{"type":"text","text":" "},{"type":"text","text":"will be consulted to discover the correct time zone on UNIX and the"},{"type":"text","text":" "},{"text":"registry will be consulted or ","type":"text"},{"type":"codeVoice","code":"GetTimeZoneInformation()"},{"type":"text","text":" will be used"},{"text":" ","type":"text"},{"text":"to get the local time zone on Windows.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If intervals are not available, only time zone rules from "},{"type":"codeVoice","code":"TZ"},{"text":" ","type":"text"},{"type":"text","text":"environment variable or other means, then they will be computed"},{"text":" ","type":"text"},{"type":"text","text":"from year 1900 to 2037.  If the maximum year for the rules is"},{"type":"text","text":" "},{"type":"text","text":"available and it is greater than 2037, then it will followed"},{"type":"text","text":" "},{"type":"text","text":"instead."}]},{"inlineContent":[{"text":"See","type":"text"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"http:\/\/tools.ietf.org\/html\/rfc3339#section-5.6"},{"text":" ","type":"text"},{"text":"for a precise definition of valid RFC3339 time offsets","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"(the "},{"code":"time-offset","type":"codeVoice"},{"text":" expansion) and ISO 8601 for the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"full list of valid time offsets.  See"},{"type":"text","text":" "},{"identifier":"http:\/\/www.gnu.org\/s\/libc\/manual\/html_node\/TZ-Variable.html","type":"reference","isActive":true},{"text":" ","type":"text"},{"type":"text","text":"for an explanation of the possible"},{"type":"text","text":" "},{"type":"text","text":"values of the "},{"code":"TZ","type":"codeVoice"},{"text":" environment variable. See","type":"text"},{"text":" ","type":"text"},{"identifier":"http:\/\/msdn.microsoft.com\/en-us\/library\/ms912391%28v=winembedded.11%29.aspx","type":"reference","isActive":true},{"type":"text","text":" "},{"text":"for the list of time zones on Windows.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"You should release the return value by calling ","type":"text"},{"type":"codeVoice","code":"g_time_zone_unref()"},{"text":" ","type":"text"},{"text":"when you are done with it.","type":"text"}]}]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/TimeZone"]]},"references":{"doc://GLib/documentation/GLib":{"kind":"symbol","role":"collection","abstract":[],"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","type":"topic","url":"\/documentation\/glib"},"http://www.gnu.org/s/libc/manual/html_node/TZ-Variable.html":{"identifier":"http:\/\/www.gnu.org\/s\/libc\/manual\/html_node\/TZ-Variable.html","type":"link","titleInlineContent":[{"type":"text","text":"The GNU C Library manual"}],"url":"http:\/\/www.gnu.org\/s\/libc\/manual\/html_node\/TZ-Variable.html","title":"The GNU C Library manual"},"#dzn":{"identifier":"#dzn","type":"link","titleInlineContent":[{"type":"text","text":":mm[:ss]"}],"url":"#dzn","title":":mm[:ss]"},"doc://GLib/documentation/GLib/TimeZone/new(identifier:)":{"url":"\/documentation\/glib\/timezone\/new(identifier:)","identifier":"doc:\/\/GLib\/documentation\/GLib\/TimeZone\/new(identifier:)","kind":"symbol","title":"new(identifier:)","abstract":[{"type":"text","text":"Creates a "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/TimeZone"},{"text":" corresponding to ","type":"text"},{"type":"codeVoice","code":"identifier"},{"type":"text","text":". If "},{"code":"identifier","type":"codeVoice"},{"text":" cannot be","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"parsed or loaded, "},{"code":"nil","type":"codeVoice"},{"text":" is returned.","type":"text"}],"fragments":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"new"},{"kind":"text","text":"("},{"text":"identifier","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"UnsafePointer","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","text":"gchar","preciseIdentifier":"c:@T@gchar"},{"kind":"text","text":">?) -> "},{"text":"TimeZone","preciseIdentifier":"s:4GLib8TimeZoneC","kind":"typeIdentifier"},{"kind":"text","text":"!"}],"type":"topic","role":"symbol"},"http://tools.ietf.org/html/rfc3339#section-5.6":{"identifier":"http:\/\/tools.ietf.org\/html\/rfc3339#section-5.6","type":"link","titleInlineContent":[{"type":"text","text":"RFC3339 §5.6"}],"url":"http:\/\/tools.ietf.org\/html\/rfc3339#section-5.6","title":"RFC3339 §5.6"},"http://msdn.microsoft.com/en-us/library/ms912391%28v=winembedded.11%29.aspx":{"identifier":"http:\/\/msdn.microsoft.com\/en-us\/library\/ms912391%28v=winembedded.11%29.aspx","title":"Microsoft Time Zone Index Values","titleInlineContent":[{"text":"Microsoft Time Zone Index Values","type":"text"}],"url":"http:\/\/msdn.microsoft.com\/en-us\/library\/ms912391%28v=winembedded.11%29.aspx","type":"link"},"doc://GLib/documentation/GLib/TimeZone":{"kind":"symbol","abstract":[{"text":"A ","type":"text"},{"type":"codeVoice","code":"GTimeZone"},{"text":" represents a time zone, at no particular point in time.","type":"text"}],"type":"topic","url":"\/documentation\/glib\/timezone","role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"TimeZone","kind":"identifier"}],"title":"TimeZone","identifier":"doc:\/\/GLib\/documentation\/GLib\/TimeZone","navigatorTitle":[{"kind":"identifier","text":"TimeZone"}]}}}