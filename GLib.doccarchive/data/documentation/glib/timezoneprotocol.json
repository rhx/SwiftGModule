ns":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/timezoneprotocol"]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"TimeZoneProtocol","kind":"identifier"},{"kind":"text","text":" : "},{"preciseIdentifier":"s:4GLib14PointerWrapperP","identifier":"doc:\/\/GLib\/documentation\/GLib\/PointerWrapper","kind":"typeIdentifier","text":"PointerWrapper"}],"platforms":["macOS"]}]},{"content":[{"level":2,"type":"heading","text":"Overview","anchor":"overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"GTimeZone"},{"type":"text","text":" struct is refcounted and immutable."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Each time zone has an identifier (for example, ‘Europe\/London’) which is"},{"text":" ","type":"text"},{"type":"text","text":"platform dependent. See [ctor"},{"type":"codeVoice","code":"GLib.TimeZone.new"},{"type":"text","text":"] for information on the"},{"type":"text","text":" "},{"type":"text","text":"identifier formats. The identifier of a time zone can be retrieved using"},{"type":"text","text":" "},{"text":"[method","type":"text"},{"type":"codeVoice","code":"GLib.TimeZone.get_identifier"},{"type":"text","text":"]."}]},{"type":"paragraph","inlineContent":[{"text":"A time zone contains a number of intervals. Each interval has an abbreviation","type":"text"},{"type":"text","text":" "},{"type":"text","text":"to describe it (for example, ‘PDT’), an offset to UTC and a flag indicating"},{"text":" ","type":"text"},{"text":"if the daylight savings time is in effect during that interval. A time zone","type":"text"},{"type":"text","text":" "},{"text":"always has at least one interval — interval 0. Note that interval abbreviations","type":"text"},{"type":"text","text":" "},{"text":"are not the same as time zone identifiers (apart from ‘UTC’), and cannot be","type":"text"},{"text":" ","type":"text"},{"text":"passed to [ctor","type":"text"},{"code":"GLib.TimeZone.new","type":"codeVoice"},{"type":"text","text":"]."}]},{"inlineContent":[{"type":"text","text":"Every UTC time is contained within exactly one interval, but a given"},{"text":" ","type":"text"},{"text":"local time may be contained within zero, one or two intervals (due to","type":"text"},{"text":" ","type":"text"},{"text":"incontinuities associated with daylight savings time).","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"An interval may refer to a specific period of time (eg: the duration","type":"text"},{"type":"text","text":" "},{"type":"text","text":"of daylight savings time during 2010) or it may refer to many periods"},{"type":"text","text":" "},{"type":"text","text":"of time that share the same properties (eg: all periods of daylight"},{"type":"text","text":" "},{"type":"text","text":"savings time).  It is also possible (usually for political reasons)"},{"type":"text","text":" "},{"text":"that some properties (like the abbreviation) change between intervals","type":"text"},{"type":"text","text":" "},{"text":"without other properties changing.","type":"text"}]},{"inlineContent":[{"type":"text","text":"The "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/TimeZoneProtocol"},{"text":" protocol exposes the methods and properties of an underlying ","type":"text"},{"type":"codeVoice","code":"GTimeZone"},{"text":" instance.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"The default implementation of these can be found in the protocol extension below."},{"type":"text","text":" "},{"type":"text","text":"For a concrete class that implements these methods and properties, see "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/TimeZone"},{"text":".","type":"text"},{"tex