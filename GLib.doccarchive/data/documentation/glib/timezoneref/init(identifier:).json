{"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/TimeZoneRef"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/TimeZoneRef\/init(identifier:)"},"sections":[],"kind":"symbol","variants":[{"paths":["\/documentation\/glib\/timezoneref\/init(identifier:)"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"abstract":[{"type":"text","text":"Creates a "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/TimeZone","isActive":true,"type":"reference"},{"text":" corresponding to ","type":"text"},{"type":"codeVoice","code":"identifier"},{"type":"text","text":". If "},{"code":"identifier","type":"codeVoice"},{"type":"text","text":" cannot be"},{"text":" ","type":"text"},{"text":"parsed or loaded, ","type":"text"},{"type":"codeVoice","code":"nil"},{"type":"text","text":" is returned."}],"metadata":{"title":"init(identifier:)","symbolKind":"init","externalID":"s:4GLib11TimeZoneRefV10identifierACSPys4Int8VGSg_tcfc","roleHeading":"Initializer","extendedModule":"GLib","role":"symbol","modules":[{"name":"GLib"}],"fragments":[{"kind":"identifier","text":"init"},{"text":"(","kind":"text"},{"text":"identifier","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:SP","kind":"typeIdentifier","text":"UnsafePointer"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","text":"gchar","preciseIdentifier":"c:@T@gchar"},{"kind":"text","text":">?)"}]},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"init","kind":"keyword"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"identifier"},{"kind":"text","text":": "},{"text":"UnsafePointer","preciseIdentifier":"s:SP","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"preciseIdentifier":"c:@T@gchar","text":"gchar","kind":"typeIdentifier"},{"kind":"text","text":">? = nil)"}],"platforms":["macOS"]}]},{"content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"inlineContent":[{"code":"identifier","type":"codeVoice"},{"type":"text","text":" can either be an RFC3339\/ISO 8601 time offset or"},{"type":"text","text":" "},{"text":"something that would pass as a valid value for the ","type":"text"},{"type":"codeVoice","code":"TZ"},{"text":" environment","type":"text"},{"text":" ","type":"text"},{"text":"variable (including ","type":"text"},{"code":"nil","type":"codeVoice"},{"type":"text","text":")."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"In Windows, "},{"code":"identifier","type":"codeVoice"},{"type":"text","text":" can also be the unlocalized name of a time"},{"type":"text","text":" "},{"text":"zone for standard time, for example “Pacific Standard Time”.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Valid RFC3339 time offsets are "},{"type":"codeVoice","code":"\"Z\""},{"text":" (for UTC) or","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"\"±hh:mm\""},{"text":".  ISO 8601 additionally specifies","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"\"±hhmm\""},{"text":" and ","type":"text"},{"code":"\"±hh\"","type":"codeVoice"},{"type":"text","text":".  Offsets are"},{"text":" ","type":"text"},{"text":"time values to be added to Coordinated Universal Time (UTC) to get","type":"text"},{"type":"text","text":" "},{"text":"the local time.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"In UNIX, the ","type":"text"},{"type":"codeVoice","code":"TZ"},{"text":" environment variable typically corresponds","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"to the name of a file in the zoneinfo database, an absolute path to a file"},{"text":" ","type":"text"},{"text":"somewhere else, or a string in","type":"text"},{"type":"text","text":" "},{"type":"text","text":"“std offset [dst [offset],start[\/time],end[\/time]]” (POSIX) format."},{"type":"text","text":" "},{"type":"text","text":"There  are  no spaces in the specification. The name of standard"},{"type":"text","text":" "},{"text":"and daylight savings time zone must be three or more alphabetic","type":"text"},{"type":"text","text":" "},{"text":"characters. Offsets are time values to be added to local time to","type":"text"},{"text":" ","type":"text"},{"text":"get Coordinated Universal Time (UTC) and should be","type":"text"},{"type":"text","text":" "},{"code":"\"[±]hh[[:]mm[:ss]]\"","type":"codeVoice"},{"type":"text","text":".  Dates are either"},{"type":"text","text":" "},{"type":"codeVoice","code":"\"Jn\""},{"type":"text","text":" (Julian day with n between 1 and 365, leap"},{"text":" ","type":"text"},{"text":"years not counted), ","type":"text"},{"type":"codeVoice","code":"\"n\""},{"text":" (zero-based Julian day","type":"text"},{"text":" ","type":"text"},{"text":"with n between 0 and 365) or ","type":"text"},{"type":"codeVoice","code":"\"Mm.w.d\""},{"text":" (day d","type":"text"},{"text":" ","type":"text"},{"text":"(0 <= d <= 6) of week w (1 <= w <= 5) of month m (1 <= m <= 12), day","type":"text"},{"type":"text","text":" "},{"type":"text","text":"0 is a Sunday).  Times are in local wall clock time, the default is"},{"text":" ","type":"text"},{"text":"02:00:00.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"In Windows, the “tzn[+|–]hh"},{"type":"reference","identifier":"#dzn","isActive":true},{"type":"text","text":"” format is used, but also"},{"type":"text","text":" "},{"type":"text","text":"accepts POSIX format.  The Windows format uses US rules for all time"},{"type":"text","text":" "},{"type":"text","text":"zones; daylight savings time is 60 minutes behind the standard time"},{"type":"text","text":" "},{"text":"with date and time of change taken from Pacific Standard Time.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Offsets are time values to be added to the local time to get"},{"text":" ","type":"text"},{"text":"Coordinated Universal Time (UTC).","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"g_time_zone_new_local()"},{"type":"text","text":" calls this function with the value of the"},{"type":"text","text":" "},{"type":"codeVoice","code":"TZ"},{"text":" environment variable. This function itself is independent of","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the value of "},{"code":"TZ","type":"codeVoice"},{"type":"text","text":", but if "},{"code":"identifier","type":"codeVoice"},{"type":"text","text":" is "},{"code":"nil","type":"codeVoice"},{"type":"text","text":" then "},{"code":"\/etc\/localtime","type":"codeVoice"},{"type":"text","text":" "},{"text":"will be consulted to discover the correct time zone on UNIX and the","type":"text"},{"type":"text","text":" "},{"text":"registry will be consulted or ","type":"text"},{"type":"codeVoice","code":"GetTimeZoneInformation()"},{"type":"text","text":" will be used"},{"text":" ","type":"text"},{"type":"text","text":"to get the local time zone on Windows."}]},{"inlineContent":[{"text":"If intervals are not available, only time zone rules from ","type":"text"},{"type":"codeVoice","code":"TZ"},{"text":" ","type":"text"},{"type":"text","text":"environment variable or other means, then they will be computed"},{"text":" ","type":"text"},{"type":"text","text":"from year 1900 to 2037.  If the maximum year for the rules is"},{"type":"text","text":" "},{"text":"available and it is greater than 2037, then it will followed","type":"text"},{"type":"text","text":" "},{"type":"text","text":"instead."}],"type":"paragraph"},{"inlineContent":[{"text":"See","type":"text"},{"type":"text","text":" "},{"identifier":"http:\/\/tools.ietf.org\/html\/rfc3339#section-5.6","type":"reference","isActive":true},{"type":"text","text":" "},{"text":"for a precise definition of valid RFC3339 time offsets","type":"text"},{"type":"text","text":" "},{"type":"text","text":"(the "},{"type":"codeVoice","code":"time-offset"},{"text":" expansion) and ISO 8601 for the","type":"text"},{"type":"text","text":" "},{"text":"full list of valid time offsets.  See","type":"text"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"http:\/\/www.gnu.org\/s\/libc\/manual\/html_node\/TZ-Variable.html"},{"type":"text","text":" "},{"type":"text","text":"for an explanation of the possible"},{"text":" ","type":"text"},{"text":"values of the ","type":"text"},{"code":"TZ","type":"codeVoice"},{"type":"text","text":" environment variable. See"},{"type":"text","text":" "},{"isActive":true,"identifier":"http:\/\/msdn.microsoft.com\/en-us\/library\/ms912391%28v=winembedded.11%29.aspx","type":"reference"},{"text":" ","type":"text"},{"type":"text","text":"for the list of time zones on Windows."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You should release the return value by calling "},{"type":"codeVoice","code":"g_time_zone_unref()"},{"type":"text","text":" "},{"type":"text","text":"when you are done with it."}]}],"kind":"content"}],"references":{"#dzn":{"type":"link","identifier":"#dzn","titleInlineContent":[{"type":"text","text":":mm[:ss]"}],"title":":mm[:ss]","url":"#dzn"},"http://tools.ietf.org/html/rfc3339#section-5.6":{"type":"link","identifier":"http:\/\/tools.ietf.org\/html\/rfc3339#section-5.6","titleInlineContent":[{"type":"text","text":"RFC3339 §5.6"}],"title":"RFC3339 §5.6","url":"http:\/\/tools.ietf.org\/html\/rfc3339#section-5.6"},"doc://GLib/documentation/GLib":{"kind":"symbol","role":"collection","abstract":[],"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","type":"topic","url":"\/documentation\/glib"},"doc://GLib/documentation/GLib/TimeZoneRef/init(identifier:)":{"title":"init(identifier:)","url":"\/documentation\/glib\/timezoneref\/init(identifier:)","fragments":[{"text":"init","kind":"identifier"},{"kind":"text","text":"("},{"text":"identifier","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"text":"<","kind":"text"},{"text":"gchar","preciseIdentifier":"c:@T@gchar","kind":"typeIdentifier"},{"kind":"text","text":">?)"}],"abstract":[{"type":"text","text":"Creates a "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/TimeZone"},{"text":" corresponding to ","type":"text"},{"code":"identifier","type":"codeVoice"},{"type":"text","text":". If "},{"type":"codeVoice","code":"identifier"},{"text":" cannot be","type":"text"},{"type":"text","text":" "},{"text":"parsed or loaded, ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":" is returned.","type":"text"}],"type":"topic","role":"symbol","kind":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/TimeZoneRef\/init(identifier:)"},"doc://GLib/documentation/GLib/TimeZone":{"kind":"symbol","abstract":[{"text":"A ","type":"text"},{"type":"codeVoice","code":"GTimeZone"},{"text":" represents a time zone, at no particular point in time.","type":"text"}],"type":"topic","url":"\/documentation\/glib\/timezone","role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"TimeZone","kind":"identifier"}],"title":"TimeZone","identifier":"doc:\/\/GLib\/documentation\/GLib\/TimeZone","navigatorTitle":[{"kind":"identifier","text":"TimeZone"}]},"http://msdn.microsoft.com/en-us/library/ms912391%28v=winembedded.11%29.aspx":{"type":"link","identifier":"http:\/\/msdn.microsoft.com\/en-us\/library\/ms912391%28v=winembedded.11%29.aspx","titleInlineContent":[{"type":"text","text":"Microsoft Time Zone Index Values"}],"title":"Microsoft Time Zone Index Values","url":"http:\/\/msdn.microsoft.com\/en-us\/library\/ms912391%28v=winembedded.11%29.aspx"},"doc://GLib/documentation/GLib/TimeZoneRef":{"title":"TimeZoneRef","navigatorTitle":[{"text":"TimeZoneRef","kind":"identifier"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/TimeZoneRef","kind":"symbol","url":"\/documentation\/glib\/timezoneref","role":"symbol","type":"topic","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"TimeZoneRef"}],"abstract":[{"type":"text","text":"A "},{"code":"GTimeZone","type":"codeVoice"},{"text":" represents a time zone, at no particular point in time.","type":"text"}]},"http://www.gnu.org/s/libc/manual/html_node/TZ-Variable.html":{"type":"link","identifier":"http:\/\/www.gnu.org\/s\/libc\/manual\/html_node\/TZ-Variable.html","titleInlineContent":[{"type":"text","text":"The GNU C Library manual"}],"title":"The GNU C Library manual","url":"http:\/\/www.gnu.org\/s\/libc\/manual\/html_node\/TZ-Variable.html"}}}