f reentrancy."}],"type":"paragraph"},{"inlineContent":[{"text":"The interaction of this source when combined with native UNIX","type":"text"},{"text":" ","type":"text"},{"text":"functions like ","type":"text"},{"type":"codeVoice","code":"sigprocmask()"},{"text":" is not defined.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The source will not initially be associated with any ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/MainContext"},{"type":"text","text":" "},{"type":"text","text":"and must be added to one with "},{"type":"codeVoice","code":"g_source_attach()"},{"type":"text","text":" before it will be"},{"type":"text","text":" "},{"text":"executed.","type":"text"}]}]}],"variants":[{"paths":["\/documentation\/glib\/unixsignalsourcenew(signum:)"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"kind":"symbol","metadata":{"symbolKind":"func","modules":[{"name":"GLib"}],"externalID":"s:4GLib19unixSignalSourceNew6signumAA0D3RefVSgSi_tF","title":"unixSignalSourceNew(signum:)","roleHeading":"Function","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"unixSignalSourceNew","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"signum"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:4GLib9SourceRefV","text":"SourceRef"},{"text":"!","kind":"text"}],"role":"symbol"},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/unixSignalSourceNew(signum:)"},"abstract":[{"type":"text","text":"Create a "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/Source"},{"type":"text","text":" that will be dispatched upon delivery of the UNIX"},{"type":"text","text":" "},{"text":"signal 