{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/uriref"]}],"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"URIRef"}],"platforms":["macOS"]}]},{"kind":"content","content":[{"level":2,"anchor":"overview","text":"Overview","type":"heading"},{"inlineContent":[{"text":"Since ","type":"text"},{"type":"codeVoice","code":"GUri"},{"text":" only represents absolute URIs, all ","type":"text"},{"type":"codeVoice","code":"GUri"},{"type":"text","text":"s will have a"},{"text":" ","type":"text"},{"text":"URI scheme, so [method","type":"text"},{"code":"GLib.URI.get_scheme","type":"codeVoice"},{"type":"text","text":"] will always return a non-"},{"code":"NULL","type":"codeVoice"},{"text":" ","type":"text"},{"type":"text","text":"answer. Likewise, by definition, all URIs have a path component, so"},{"type":"text","text":" "},{"text":"[method","type":"text"},{"type":"codeVoice","code":"GLib.URI.get_path"},{"type":"text","text":"] will always return a non-"},{"type":"codeVoice","code":"NULL"},{"type":"text","text":" string (which may"},{"type":"text","text":" "},{"type":"text","text":"be empty)."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If the URI string has an"},{"type":"text","text":" "},{"type":"reference","identifier":"https:\/\/tools.ietf.org\/html\/rfc3986#section-3","isActive":true},{"text":" (that","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"is, if the scheme is followed by "},{"type":"codeVoice","code":":\/\/"},{"type":"text","text":" rather than just "},{"type":"codeVoice","code":":"},{"text":"), then the","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"GUri"},{"text":" will contain a hostname, and possibly a port and ‘userinfo’.","type":"text"},{"type":"text","text":" "},{"text":"Additionally, depending on how the ","type":"text"},{"type":"codeVoice","code":"GUri"},{"text":" was constructed\/parsed (for example,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"using the "},{"code":"G_URI_FLAGS_HAS_PASSWORD","type":"codeVoice"},{"type":"text","text":" and "},{"type":"codeVoice","code":"G_URI_FLAGS_HAS_AUTH_PARAMS"},{"type":"text","text":" flags),"},{"type":"text","text":" "},{"type":"text","text":"the userinfo may be split out into a username, password, and"},{"type":"text","text":" "},{"type":"text","text":"additional authorization-related parameters."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Normally, the components of a "},{"type":"codeVoice","code":"GUri"},{"text":" will have all ","type":"text"},{"type":"codeVoice","code":"-encoded characters decoded. However, if you construct\/parse a `GUri` with `G_URI_FLAGS_ENCODED`, then the "},{"text":"-encoding will be preserved instead in","type":"text"},{"text":" ","type":"text"},{"text":"the userinfo, path, and query fields (and in the host field if also","type":"text"},{"type":"text","text":" "},{"type":"text","text":"created with "},{"code":"G_URI_FLAGS_NON_DNS","type":"codeVoice"},{"text":"). In particular, this is necessary if","type":"text"},{"text":" ","type":"text"},{"text":"the URI may contain binary data or non-UTF-8 text, or if decoding","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the components might change the interpretation of the URI."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For example, with the encoded flag:"}]},{"syntax":"c","code":["`g_autoptr(GUri)` uri = g_uri_parse (\"http:\/\/host\/path?query=http`3A``2F``2Fhost``2Fpath``3Fparam``3Dvalue`\", G_URI_FLAGS_ENCODED, &err);","g_assert_cmpstr (g_uri_get_query (uri), ==, \"query=http`3A``2F``2Fhost``2Fpath``3Fparam``3Dvalue`\");"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"While the default ````-decoding behaviour would give:"}],"type":"paragraph"},{"syntax":"c","code":["`g_autoptr(GUri)` uri = g_uri_parse (\"http:\/\/host\/path?query=http`3A``2F``2Fhost``2Fpath``3Fparam``3Dvalue`\", G_URI_FLAGS_NONE, &err);","g_assert_cmpstr (g_uri_get_query (uri), ==, \"query=http:\/\/host\/path?param=value\");"],"type":"codeListing"},{"inlineContent":[{"text":"During decoding, if an invalid UTF-8 string is encountered, parsing will fail","type":"text"},{"type":"text","text":" "},{"text":"with an error indicating the bad string location:","type":"text"}],"type":"paragraph"},{"syntax":"c","code":["`g_autoptr(GUri)` uri = g_uri_parse (\"http:\/\/host\/path?query=http`3A``2F``2Fhost``2Fpath``3Fbad``3D``00alue`\", G_URI_FLAGS_NONE, &err);","g_assert_error (err, G_URI_ERROR, G_URI_ERROR_BAD_QUERY);"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"You should pass ","type":"text"},{"code":"G_URI_FLAGS_ENCODED","type":"codeVoice"},{"type":"text","text":" or "},{"type":"codeVoice","code":"G_URI_FLAGS_ENCODED_QUERY"},{"type":"text","text":" if you"},{"type":"text","text":" "},{"text":"need to handle that case manually. In particular, if the query string","type":"text"},{"type":"text","text":" "},{"text":"contains ","type":"text"},{"type":"codeVoice","code":"="},{"type":"text","text":" characters that are ````-encoded, you should let"},{"type":"text","text":" "},{"text":"[func","type":"text"},{"type":"codeVoice","code":"GLib.URI.parse_params"},{"text":"] do the decoding once of the query.","type":"text"}]},{"inlineContent":[{"type":"codeVoice","code":"GUri"},{"text":" is immutable once constructed, and can safely be accessed from","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"multiple threads. Its reference counting is atomic."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Note that the scope of ","type":"text"},{"code":"GUri","type":"codeVoice"},{"type":"text","text":" is to help manipulate URIs in various applications,"},{"text":" ","type":"text"},{"type":"text","text":"following "},{"type":"reference","identifier":"https:\/\/tools.ietf.org\/html\/rfc3986","isActive":true},{"type":"text","text":". In particular,"},{"type":"text","text":" "},{"type":"text","text":"it doesn’t intend to cover web browser needs, and doesn’t implement the"},{"text":" ","type":"text"},{"isActive":true,"identifier":"https:\/\/url.spec.whatwg.org\/","type":"reference"},{"text":" standard. No APIs are provided to","type":"text"},{"type":"text","text":" "},{"type":"text","text":"help prevent"},{"type":"text","text":" "},{"type":"reference","identifier":"https:\/\/en.wikipedia.org\/wiki\/IDN_homograph_attack","isActive":true},{"text":", so","type":"text"},{"type":"text","text":" "},{"code":"GUri","type":"codeVoice"},{"type":"text","text":" is not suitable for formatting URIs for display to the user for making"},{"text":" ","type":"text"},{"type":"text","text":"security-sensitive decisions."}]},{"level":2,"anchor":"Relative-and-absolute-URIs","type":"heading","text":"Relative and absolute URIs"},{"inlineContent":[{"type":"text","text":"As defined in "},{"identifier":"https:\/\/tools.ietf.org\/html\/rfc3986#section-4","type":"reference","isActive":true},{"text":", the","type":"text"},{"text":" ","type":"text"},{"text":"hierarchical nature of URIs means that they can either be ‘relative","type":"text"},{"type":"text","text":" "},{"text":"references’ (sometimes referred to as ‘relative URIs’) or ‘URIs’ (for","type":"text"},{"text":" ","type":"text"},{"text":"clarity, ‘URIs’ are referred to in this documentation as","type":"text"},{"type":"text","text":" "},{"type":"text","text":"‘absolute URIs’ — although"},{"type":"text","text":" "},{"isActive":true,"identifier":"https:\/\/tools.ietf.org\/html\/rfc3986#section-4.3","type":"reference"},{"text":",","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"fragment identifiers are always allowed)."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Relative references have one or more components of the URI missing. In"},{"type":"text","text":" "},{"text":"particular, they have no scheme. Any other component, such as hostname,","type":"text"},{"text":" ","type":"text"},{"text":"query, etc. may be missing, apart from a path, which has to be specified (but","type":"text"},{"text":" ","type":"text"},{"text":"may be empty). The path may be relative, starting with ","type":"text"},{"type":"codeVoice","code":".\/"},{"type":"text","text":" rather than "},{"type":"codeVoice","code":"\/"},{"text":".","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"For example, a valid relative reference is ","type":"text"},{"type":"codeVoice","code":".\/path?query"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"codeVoice","code":"\/?query"},{"type":"text","text":"fragment`` or "},{"type":"codeVoice","code":"\/\/example.com"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Absolute URIs have a scheme specified. Any other components of the URI which"},{"text":" ","type":"text"},{"type":"text","text":"are missing are specified as explicitly unset in the URI, rather than being"},{"text":" ","type":"text"},{"type":"text","text":"resolved relative to a base URI using [method"},{"type":"codeVoice","code":"GLib.URI.parse_relative"},{"text":"].","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For example, a valid absolute URI is "},{"type":"codeVoice","code":"file:\/\/\/home\/bob"},{"text":" or","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"https:\/\/search.com?query=string"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"A "},{"code":"GUri","type":"codeVoice"},{"text":" instance is always an absolute URI. A string may be an absolute URI","type":"text"},{"text":" ","type":"text"},{"text":"or a relative reference; see the documentation for individual functions as to","type":"text"},{"type":"text","text":" "},{"text":"what forms they accept.","type":"text"}]},{"anchor":"Parsing-URIs","level":2,"text":"Parsing URIs","type":"heading"},{"inlineContent":[{"type":"text","text":"The most minimalist APIs for parsing URIs are [func"},{"type":"codeVoice","code":"GLib.URI.split"},{"type":"text","text":"] and"},{"type":"text","text":" "},{"text":"[func","type":"text"},{"type":"codeVoice","code":"GLib.URI.split_with_user"},{"text":"]. These split a URI into its component","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"parts, and return the parts; the difference between the two is that"},{"type":"text","text":" "},{"text":"[func","type":"text"},{"type":"codeVoice","code":"GLib.URI.split"},{"type":"text","text":"] treats the ‘userinfo’ component of the URI as a"},{"type":"text","text":" "},{"type":"text","text":"single element, while [func"},{"code":"GLib.URI.split_with_user","type":"codeVoice"},{"type":"text","text":"] can (depending on the"},{"text":" ","type":"text"},{"type":"text","text":"[flags"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/URIFlags","isActive":true},{"type":"text","text":"] you pass) treat it as containing a username, password,"},{"type":"text","text":" "},{"type":"text","text":"and authentication parameters. Alternatively, [func"},{"type":"codeVoice","code":"GLib.URI.split_network"},{"type":"text","text":"]"},{"type":"text","text":" "},{"text":"can be used when you are only interested in the components that are","type":"text"},{"type":"text","text":" "},{"type":"text","text":"needed to initiate a network connection to the service (scheme,"},{"text":" ","type":"text"},{"type":"text","text":"host, and port)."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"[func"},{"code":"GLib.URI.parse","type":"codeVoice"},{"type":"text","text":"] is similar to [func"},{"type":"codeVoice","code":"GLib.URI.split"},{"text":"], but instead of","type":"text"},{"type":"text","text":" "},{"type":"text","text":"returning individual strings, it returns a "},{"type":"codeVoice","code":"GUri"},{"text":" structure (and it requires","type":"text"},{"type":"text","text":" "},{"text":"that the URI be an absolute URI).","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"[func","type":"text"},{"type":"codeVoice","code":"GLib.URI.resolve_relative"},{"text":"] and [method","type":"text"},{"code":"GLib.URI.parse_relative","type":"codeVoice"},{"text":"] allow","type":"text"},{"type":"text","text":" "},{"text":"you to resolve a relative URI relative to a base URI.","type":"text"},{"text":" ","type":"text"},{"text":"[func","type":"text"},{"type":"codeVoice","code":"GLib.URI.resolve_relative"},{"text":"] takes two strings and returns a string,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"and [method"},{"code":"GLib.URI.parse_relative","type":"codeVoice"},{"type":"text","text":"] takes a "},{"code":"GUri","type":"codeVoice"},{"type":"text","text":" and a string and returns a"},{"type":"text","text":" "},{"type":"codeVoice","code":"GUri"},{"type":"text","text":"."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"All of the parsing functions take a [flags","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/URIFlags","isActive":true,"type":"reference"},{"type":"text","text":"] argument describing"},{"type":"text","text":" "},{"type":"text","text":"exactly how to parse the URI; see the documentation for that type"},{"type":"text","text":" "},{"type":"text","text":"for more details on the specific flags that you can pass. If you"},{"type":"text","text":" "},{"text":"need to choose different flags based on the type of URI, you can","type":"text"},{"type":"text","text":" "},{"type":"text","text":"use [func"},{"code":"GLib.URI.peek_scheme","type":"codeVoice"},{"type":"text","text":"] on the URI string to check the scheme"},{"text":" ","type":"text"},{"type":"text","text":"first, and use that to decide what flags to parse it with."}]},{"type":"paragraph","inlineContent":[{"text":"For example, you might want to use ","type":"text"},{"code":"G_URI_PARAMS_WWW_FORM","type":"codeVoice"},{"type":"text","text":" when parsing the"},{"type":"text","text":" "},{"text":"params for a web URI, so compare the result of [func","type":"text"},{"code":"GLib.URI.peek_scheme","type":"codeVoice"},{"text":"]","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"against "},{"code":"http","type":"codeVoice"},{"type":"text","text":" and "},{"code":"https","type":"codeVoice"},{"type":"text","text":"."}]},{"level":2,"type":"heading","text":"Building URIs","anchor":"Building-URIs"},{"inlineContent":[{"type":"text","text":"[func"},{"code":"GLib.URI.join","type":"codeVoice"},{"type":"text","text":"] and [func"},{"type":"codeVoice","code":"GLib.URI.join_with_user"},{"text":"] can be used to construct","type":"text"},{"type":"text","text":" "},{"type":"text","text":"valid URI strings from a set of component strings. They are the"},{"text":" ","type":"text"},{"type":"text","text":"inverse of [func"},{"code":"GLib.URI.split","type":"codeVoice"},{"type":"text","text":"] and [func"},{"code":"GLib.URI.split_with_user","type":"codeVoice"},{"type":"text","text":"]."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Similarly, [func"},{"type":"codeVoice","code":"GLib.URI.build"},{"type":"text","text":"] and [func"},{"type":"codeVoice","code":"GLib.URI.build_with_user"},{"type":"text","text":"] can be"},{"text":" ","type":"text"},{"text":"used to construct a ","type":"text"},{"code":"GUri","type":"codeVoice"},{"type":"text","text":" from a set of component strings."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"As with the parsing functions, the building functions take a","type":"text"},{"text":" ","type":"text"},{"text":"[flags","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/URIFlags"},{"text":"] argument. In particular, it is important to keep in mind","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"whether the URI components you are using are already ````-encoded. If so,"},{"type":"text","text":" "},{"type":"text","text":"you must pass the "},{"type":"codeVoice","code":"G_URI_FLAGS_ENCODED"},{"text":" flag.","type":"text"}]},{"level":2,"anchor":"file-URIs","type":"heading","text":"`file:\/\/` URIs"},{"inlineContent":[{"type":"text","text":"Note that Windows and Unix both define special rules for parsing"},{"type":"text","text":" "},{"type":"codeVoice","code":"file:\/\/"},{"text":" URIs (involving non-UTF-8 character sets on Unix, and the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"interpretation of path separators on Windows). "},{"type":"codeVoice","code":"GUri"},{"type":"text","text":" does not"},{"type":"text","text":" "},{"type":"text","text":"implement these rules. Use [func"},{"type":"codeVoice","code":"GLib.filename_from_uri"},{"type":"text","text":"] and"},{"text":" ","type":"text"},{"text":"[func","type":"text"},{"code":"GLib.filename_to_uri","type":"codeVoice"},{"type":"text","text":"] if you want to properly convert between"},{"text":" ","type":"text"},{"type":"codeVoice","code":"file:\/\/"},{"type":"text","text":" URIs and local filenames."}],"type":"paragraph"},{"anchor":"URI-Equality","text":"URI Equality","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Note that there is no ","type":"text"},{"type":"codeVoice","code":"g_uri_equal ()"},{"type":"text","text":" function, because comparing"},{"text":" ","type":"text"},{"text":"URIs usefully requires scheme-specific knowledge that ","type":"text"},{"type":"codeVoice","code":"GUri"},{"type":"text","text":" does"},{"type":"text","text":" "},{"text":"not have. ","type":"text"},{"code":"GUri","type":"codeVoice"},{"text":" can help with normalization if you use the various","type":"text"},{"type":"text","text":" "},{"text":"encoded [flags","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/URIFlags"},{"type":"text","text":"] as well as "},{"type":"codeVoice","code":"G_URI_FLAGS_SCHEME_NORMALIZE"},{"text":" ","type":"text"},{"type":"text","text":"however it is not comprehensive."},{"type":"text","text":" "},{"type":"text","text":"For example, "},{"type":"codeVoice","code":"data:,foo"},{"type":"text","text":" and "},{"type":"codeVoice","code":"data:;base64,Zm9v"},{"type":"text","text":" resolve to the same"},{"text":" ","type":"text"},{"type":"text","text":"thing according to the "},{"type":"codeVoice","code":"data:"},{"type":"text","text":" URI specification which GLib does not"},{"type":"text","text":" "},{"type":"text","text":"handle."}]},{"inlineContent":[{"type":"text","text":"The "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/URIRef","isActive":true,"type":"reference"},{"type":"text","text":" type acts as a lightweight Swift reference to an underlying "},{"type":"codeVoice","code":"GUri"},{"text":" instance.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"It exposes methods that can operate on this data type through "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/URIProtocol","type":"reference","isActive":true},{"type":"text","text":" conformance."},{"type":"text","text":" "},{"text":"Use ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/URIRef","isActive":true,"type":"reference"},{"type":"text","text":" only as an "},{"code":"unowned","type":"codeVoice"},{"text":" reference to an existing ","type":"text"},{"code":"GUri","type":"codeVoice"},{"type":"text","text":" instance."}],"type":"paragraph"},{"type":"aside","style":"note","content":[{"type":"paragraph","inlineContent":[{"text":"Use ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/URI"},{"text":" (instead of ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/URIRef"},{"text":") if you want to use Automatic Reference Counting for memory management of the underlying ","type":"text"},{"code":"GUri","type":"codeVoice"},{"type":"text","text":" instance."}]}],"name":"Note"}]}],"metadata":{"title":"URIRef","roleHeading":"Structure","symbolKind":"struct","modules":[{"name":"GLib"}],"role":"symbol","externalID":"s:4GLib6URIRefV","navigatorTitle":[{"text":"URIRef","kind":"identifier"}],"fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"URIRef"}]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/URIRef"},"schemaVersion":{"minor":3,"patch":0,"major":0},"topicSections":[{"title":"Initializers","identifiers":["doc:\/\/GLib\/documentation\/GLib\/URIRef\/init(_:)-1m0g3","doc:\/\/GLib\/documentation\/GLib\/URIRef\/init(_:)-2ctpq","doc:\/\/GLib\/documentation\/GLib\/URIRef\/init(_:)-4kx37","doc:\/\/GLib\/documentation\/GLib\/URIRef\/init(_:)-5ugyq","doc:\/\/GLib\/documentation\/GLib\/URIRef\/init(_:)-86fph","doc:\/\/GLib\/documentation\/GLib\/URIRef\/init(cPointer:)","doc:\/\/GLib\/documentation\/GLib\/URIRef\/init(constPointer:)","doc:\/\/GLib\/documentation\/GLib\/URIRef\/init(gconstpointer:)","doc:\/\/GLib\/documentation\/GLib\/URIRef\/init(gpointer:)","doc:\/\/GLib\/documentation\/GLib\/URIRef\/init(mutating:)","doc:\/\/GLib\/documentation\/GLib\/URIRef\/init(opaquePointer:)"],"anchor":"Initializers","generated":true},{"generated":true,"title":"Instance Properties","identifiers":["doc:\/\/GLib\/documentation\/GLib\/URIRef\/ptr"],"anchor":"Instance-Properties"},{"title":"Type Methods","identifiers":["doc:\/\/GLib\/documentation\/GLib\/URIRef\/build(flags:scheme:userinfo:host:port:path:query:fragment:)","doc:\/\/GLib\/documentation\/GLib\/URIRef\/buildWith(user:scheme:user:password:authParams:host:port:path:query:fragment:)","doc:\/\/GLib\/documentation\/GLib\/URIRef\/parse(uriString:flags:)"],"anchor":"Type-Methods","generated":true},{"generated":true,"title":"Default Implementations","identi