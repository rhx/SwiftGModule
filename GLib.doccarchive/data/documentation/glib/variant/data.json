{"abstract":[{"type":"text","text":"Returns a pointer to the serialized form of a "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant"},{"type":"text","text":" instance."},{"text":" ","type":"text"},{"text":"The returned data may not be in fully-normalised form if read from an","type":"text"},{"type":"text","text":" "},{"type":"text","text":"untrusted source.  The returned data must not be freed; it remains"},{"type":"text","text":" "},{"text":"valid for as long as ","type":"text"},{"type":"codeVoice","code":"value"},{"type":"text","text":" exists."}],"schemaVersion":{"minor":3,"patch":0,"major":0},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/Variant","doc:\/\/GLib\/documentation\/GLib\/Variant\/VariantProtocol-Implementations"]]},"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/Variant\/data"},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"data","kind":"identifier"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gconstpointer","text":"gconstpointer"},{"text":"? { ","kind":"text"},{"text":"get","kind":"keyword"},{"text":" }","kind":"text"}],"platforms":["macOS"]}]},{"content":[{"level":2,"anchor":"discussion","text":"Discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"If "},{"code":"value","type":"codeVoice"},{"type":"text","text":" is a fixed-sized value that was deserialized from a"},{"text":" ","type":"text"},{"text":"corrupted serialized container then ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":" may be returned.  In this","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"case, the proper thing to do is typically to use the appropriate"},{"text":" ","type":"text"},{"text":"number of nul bytes in place of ","type":"text"},{"type":"codeVoice","code":"value"},{"text":".  If ","type":"text"},{"code":"value","type":"codeVoice"},{"type":"text","text":" is not fixed-sized"},{"type":"text","text":" "},{"text":"then ","type":"text"},{"type":"codeVoice","code":"nil"},{"type":"text","text":" is never returned."}],"type":"paragraph"},{"inlineContent":[{"text":"In the case that ","type":"text"},{"code":"value","type":"codeVoice"},{"text":" is already in serialized form, this function","type":"text"},{"type":"text","text":" "},{"text":"is ","type":"text"},{"type":"codeVoice","code":"O(1)"},{"type":"text","text":".  If the value is not already in serialized form,"},{"type":"text","text":" "},{"type":"text","text":"serialization occurs implicitly and is approximately "},{"type":"codeVoice","code":"O(n)"},{"type":"text","text":" in the size"},{"text":" ","type":"text"},{"type":"text","text":"of the result."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"To deserialize the data returned by this function, in addition to the"},{"text":" ","type":"text"},{"type":"text","text":"serialized data, you must know the type of the "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","isActive":true},{"type":"text","text":", and (if the"},{"text":" ","type":"text"},{"type":"text","text":"machine might be different) the endianness of the machine that stored"},{"type":"text","text":" "},{"type":"text","text":"it. As a result, file formats or network messages that incorporate"},{"type":"text","text":" "},{"type":"text","text":"serialized "},{"code":"GVariants","type":"codeVoice"},{"text":" must include this information either","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"implicitly (for instance “the file always contains a"},{"type":"text","text":" "},{"type":"codeVoice","code":"G_VARIANT_TYPE_VARIANT"},{"type":"text","text":" and it is always in little-endian order”) or"},{"text":" ","type":"text"},{"type":"text","text":"explicitly (by storing the type and\/or endianness in addition to the"},{"text":" ","type":"text"},{"type":"text","text":"serialized data)."}],"type":"paragraph"}],"kind":"content"}],"variants":[{"paths":["\/documentation\/glib\/variant\/data"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"metadata":{"title":"data","symbolKind":"property","externalID":"s:4GLib15VariantProtocolPAAE4dataSVSgvp::SYNTHESIZED::s:4GLib7VariantC","roleHeading":"Instance Property","extendedModule":"GLib","modules":[{"name":"GLib"}],"role":"symbol","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"data"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:@T@gconstpointer","text":"gconstpointer","kind":"typeIdentifier"},{"text":"?","kind":"text"}]},"references":{"doc://GLib/documentation/GLib/Variant/data":{"role":"symbol","abstract":[{"text":"Returns a pointer to the serialized form of a ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant"},{"text":" instance.","type":"text"},{"type":"text","text":" "},{"text":"The returned data may not be in fully-normalised form if read from an","type":"text"},{"type":"text","text":" "},{"text":"untrusted source.  The returned data must not be freed; it remains","type":"text"},{"type":"text","text":" "},{"type":"text","text":"valid for as long as "},{"type":"codeVoice","code":"value"},{"text":" exists.","type":"text"}],"fragments":[{"kind":"keyword","text":"var"},{"text":" ","kind":"text"},{"text":"data","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:@T@gconstpointer","text":"gconstpointer","kind":"typeIdentifier"},{"text":"?","kind":"text"}],"url":"\/documentation\/glib\/variant\/data","type":"topic","kind":"symbol","title":"data","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant\/data"},"doc://GLib/documentation/GLib":{"kind":"symbol","role":"collection","abstract":[],"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","