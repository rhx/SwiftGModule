{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/Variant\/refSink()"},"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"refSink","kind":"identifier"},{"text":"() -> ","kind":"text"},{"text":"VariantRef","preciseIdentifier":"s:4GLib10VariantRefV","kind":"typeIdentifier","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantRef"},{"text":"!","kind":"text"}],"languages":["swift"],"platforms":["macOS"]}]},{"content":[{"level":2,"anchor":"discussion","type":"heading","text":"Discussion"},{"inlineContent":[{"type":"text","text":"Calling "},{"type":"codeVoice","code":"g_variant_ref_sink()"},{"text":" on a ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","isActive":true},{"type":"text","text":" with a floating reference"},{"type":"text","text":" "},{"text":"will convert the floating reference into a full reference.  Calling","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_variant_ref_sink()"},{"text":" on a non-floating ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","isActive":true,"type":"reference"},{"type":"text","text":" results in an"},{"type":"text","text":" "},{"type":"text","text":"additional normal reference being added."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"In other words, if the "},{"type":"codeVoice","code":"value"},{"text":" is floating, then this call “assumes","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"ownership” of the floating reference, converting it to a normal"},{"text":" ","type":"text"},{"type":"text","text":"reference.  If the "},{"code":"value","type":"codeVoice"},{"text":" is not floating, then this call adds a","type":"text"},{"type":"text","text":" "},{"text":"new normal reference increasing the reference count by one.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"All calls that result in a ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","isActive":true},{"type":"text","text":" instance being inserted into a"},{"type":"text","text":" "},{"text":"container will call ","type":"text"},{"type":"codeVoice","code":"g_variant_ref_sink()"},{"type":"text","text":" on the instance.  This means"},{"text":" ","type":"text"},{"text":"that if the value was just created (and has only its floating","type":"text"},{"type":"text","text":" "},{"text":"reference) then the container will assume sole ownership of the value","type":"text"},{"text":" ","type":"text"},{"text":"at that point and the caller will not need to unreference it.  This","type":"text"},{"type":"text","text":" "},{"type":"text","text":"makes certain common styles of programming much easier while still"},{"text":" ","type":"text"},{"type":"text","text":"maintaining normal refcounting semantics in situations where values"},{"text":" ","type":"text"},{"type":"text","text":"are not floating."}]}],"kind":"content"}],"metadata":{"modules":[{"name":"GLib"}],"symbolKind":"method","extendedModule":"GLib","role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"refSink"},{"kind":"text","text":"() -> "},{"kind":"typeIdentifier","text":"VariantRef","preciseIdentifier":"s:4GLib10VariantRefV"},{"text":"!","kind":"text"}],"title":"refSink()","externalID":"s:4GLib15VariantProtocolPAAE7refSinkAA0B3RefVSgyF::SYNTHESIZED::s:4GLib7VariantC","roleHeading":"Instance Method"},"kind":"symbol","abstract":[{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant"},{"type":"text","text":" uses a floating reference count system.  All functions with"},{"text":" ","type":"text"},{"text":"names starting with ","type":"text"},{"type":"codeVoice","code":"g_variant_new_"},{"text":" return floating","type":"text"},{"type":"text"