ant_builder_end (&builder);"],"type":"codeListing"}],"kind":"content"}],"references":{"doc://GLib/documentation/GLib/VariantBuilder/open(type:)":{"title":"open(type:)","type":"topic","kind":"symbol","url":"\/documentation\/glib\/variantbuilder\/open(type:)","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantBuilder\/open(type:)","role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"open","kind":"identifier"},{"text":"<","kind":"text"},{"kind":"genericParameter","text":"VariantTypeT"},{"text":">(","kind":"text"},{"kind":"externalParam","text":"type"},{"kind":"text","text":": "},{"text":"VariantTypeT","kind":"typeIdentifier"},{"text":")","kind":"text"}],"abstract":[{"type":"text","text":"Opens a subcontainer inside the given "},{"code":"builder","type":"codeVoice"},{"type":"text","text":".  When done adding"},{"type":"text","text":" "},{"text":"items to the subcontainer, ","type":"text"},{"type":"codeVoice","code":"g_variant_builder_close()"},{"type":"text","text":" must be called. "},{"type":"codeVoice","code":"type"},{"type":"text","text":" "},{"text":"is the type of the container: so to build a tuple of several values, ","type":"text"},{"type":"codeVoice","code":"type"},{"text":" ","type":"text"},{"type":"text","text":"must include the tuple itself."}]},"doc://GLib/documentation/GLib/Variant":{"type":"topic","role":"symbol","url":"\/documentation\/glib\/variant","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","kind":"symbol","title":"Variant","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"Variant","kind":"identifier"}],"navigatorTitle":[{"text":"Variant","kind":"identifier"}],"abstract":[{"code":"GVariant","type":"codeVoice"},{"text":" is a variant datatype; it can contain one or more values","type":"text"},{"text":" ","type":"text"},{"text":"along with information about the type of the values.","type":"text"}]},"doc://GLib/documentation/GLib/VariantBuilder/VariantBuilder