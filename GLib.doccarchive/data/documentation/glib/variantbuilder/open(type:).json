{"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"symbol","abstract":[{"type":"text","text":"Opens a subcontainer inside the given "},{"code":"builder","type":"codeVoice"},{"type":"text","text":".  When done adding"},{"type":"text","text":" "},{"type":"text","text":"items to the subcontainer, "},{"type":"codeVoice","code":"g_variant_builder_close()"},{"type":"text","text":" must be called. "},{"code":"type","type":"codeVoice"},{"type":"text","text":" "},{"text":"is the type of the container: so to build a tuple of several values, ","type":"text"},{"code":"type","type":"codeVoice"},{"text":" ","type":"text"},{"text":"must include the tuple itself.","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/variantbuilder\/open(type:)"]}],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/VariantBuilder\/open(type:)","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/VariantBuilder","doc:\/\/GLib\/documentation\/GLib\/VariantBuilder\/VariantBuilderProtocol-Implementations"]]},"metadata":{"modules":[{"name":"GLib"}],"title":"open(type:)","role":"symbol","extendedModule":"GLib","roleHeading":"Instance Method","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"open"},{"text":"<","kind":"text"},{"kind":"genericParameter","text":"VariantTypeT"},{"text":">(","kind":"text"},{"kind":"externalParam","text":"type"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"VariantTypeT"},{"kind":"text","text":")"}],"externalID":"s:4GLib22VariantBuilderProtocolPAAE4open4typeyqd___tAA0b4TypeD0Rd__lF::SYNTHESIZED::s:4GLib14VariantBuilderC","symbolKind":"method"},"sections":[],"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"open","kind":"identifier"},{"text":"<","kind":"text"},{"text":"VariantTypeT","kind":"