{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/VariantBuilderRef\/init_(type:)"},"kind":"symbol","schemaVersion":{"patch":0,"major":0,"minor":3},"metadata":{"role":"symbol","extendedModule":"GLib","symbolKind":"method","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"init_"},{"text":"<","kind":"text"},{"kind":"genericParameter","text":"VariantTypeT"},{"text":">(","kind":"text"},{"text":"type","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"VariantTypeT","kind":"typeIdentifier"},{"text":")","kind":"text"}],"modules":[{"name":"GLib"}],"title":"init_(type:)","externalID":"s:4GLib22VariantBuilderProtocolPAAE5init_4typeyqd___tAA0b4TypeD0Rd__lF::SYNTHESIZED::s:4GLib17VariantBuilderRefV","roleHeading":"Instance Method"},"sections":[],"primaryContentSections":[{"declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"init_"},{"text":"<","kind":"text"},{"kind":"genericParameter","text":"VariantTypeT"},{"text":">(","kind":"text"},{"kind":"externalParam","text":"type"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"VariantTypeT"},{"kind":"text","text":") "},{"text":"where","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"typeIdentifier","text":"VariantTypeT"},{"kind":"text","text":" : "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantTypeProtocol","preciseIdentifier":"s:4GLib19VariantTypeProtocolP","kind":"typeIdentifier","text":"VariantTypeProtocol"}]}],"kind":"declarations"},{"kind":"content","content":[{"type":"heading","anchor":"discussion","level":2,"text":"Discussion"},{"type":"paragraph","inlineContent":[{"code":"type","type":"codeVoice"},{"type":"text","text":" must be non-"},{"type":"codeVoice","code":"nil"},{"text":".  It specifies the type of container to","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"construct.  It can be an indefinite type such as"},{"text":" ","type":"text"},{"type":"codeVoice","code":"G_VARIANT_TYPE_ARRAY"},{"type":"text","text":" or a definite type such as “as” or “(ii)”."},{"text":" ","type":"text"},{"text":"Maybe, array, tuple, dictionary entry and variant-typed values may be","type":"text"},{"text":" ","type":"text"},{"text":"constructed.","type":"text"}]},{"inlineContent":[{"text":"If using a static type such as one of the ","type":"text"},{"type":"codeVoice","code":"G_VARIANT_TYPE_*"},{"text":" constants","type":"text"},{"type":"text","text":" "},{"text":"or a ","type":"text"},{"type":"codeVoice","code":"G_VARIANT_TYPE (\"(ii)\")"},{"text":" macro, it is more performant to use","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_variant_builder_init_static()"},{"type":"text","text":" rather than "},{"type":"codeVoice","code":"g_variant_builder_init()"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"After the builder is initialised, values are added using"},{"type":"text","text":" "},{"code":"g_variant_builder_add_value()","type":"codeVoice"},{"type":"text","text":" or "},{"type":"codeVoice","code":"g_variant_builder_add()"},{"text":".","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"After all the child values are added, "},{"type":"codeVoice","code":"g_variant_builder_end()"},{"type":"text","text":" frees"},{"text":" ","type":"text"},{"type":"text","text":"the memory associated with the builder and returns the "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","isActive":true,"type":"reference"},{"text":" that","type":"text"},{"type":"text","text":" "},{"type":"text","text":"was created."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This function completely ignores the previous contents of "},{"type":"codeVoice","code":"builder"},{"type":"text","text":"."},{"text":" ","type":"text"},{"text":"On one hand this means that it is valid to pass in completely","type":"text"},{"type":"text","text":" "},{"text":"uninitialised memory.  On the other hand, this means that if you are","type":"text"},{"type":"text","text":" "},{"type":"text","text":"initialising over top of an existing "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantBuilder"},{"text":" you need to","type":"text"},{"type":"text","text":" "},{"text":"first call ","type":"text"},{"code":"g_variant_builder_clear()","type":"codeVoice"},{"text":" in order to avoid leaking","type":"text"},{"text":" ","type":"text"},{"text":"memory.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"You must not call ","type":"text"},{"type":"codeVoice","code":"g_variant_builder_ref()"},{"type":"text","text":" or"},{"text":" ","type":"text"},{"code":"g_variant_builder_unref()","type":"codeVoice"},{"type":"text","text":" on a "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantBuilder","isActive":true,"type":"reference"},{"text":" that was initialised","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"with this function.  If you ever pass a reference to a"},{"type":"text","text":" "},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantBuilder","type":"reference"},{"text":" outside of the control of your own code then you","type":"text"},{"text":" ","type":"text"},{"text":"should assume that the person receiving that reference may try to use","type":"text"},{"text":" ","type":"text"},{"text":"reference counting; you should use ","type":"text"},{"code":"g_variant_builder_new()","type":"codeVoice"},{"type":"text","text":" instead of"},{"text":" ","type":"text"},{"text":"this function.","type":"text"}]}]}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/VariantBuilderRef","doc:\/\/GLib\/documentation\/GLib\/VariantBuilderRef\/VariantBuilderProtocol-Implementations"]]},"abstract":[{"type":"text","text":"