,{"text":" ","kind":"text"},{"text":"VariantDict","kind":"identifier"}]}]},{"kind":"content","content":[{"text":"Overview","type":"heading","level":2,"anchor":"overview"},{"inlineContent":[{"text":"It can be used for doing a sequence of dictionary lookups in an","type":"text"},{"type":"text","text":" "},{"type":"text","text":"efficient way on an existing "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant"},{"text":" dictionary or it can be used","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"to construct new dictionaries with a hashtable-like interface.  It"},{"text":" ","type":"text"},{"type":"text","text":"can also be used for taking existing dictionaries and modifying them"},{"text":" ","type":"text"},{"type":"text","text":"in order to create new ones."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantDict","type":"reference","isActive":true},{"text":" can only be used with ","type":"text"},{"type":"codeVoice","code":"G_VARIANT_TYPE_VARDICT"},{"type":"text","text":" "},{"text":"dictionaries.","type":"text"}]},{"inlineContent":[{"text":"It is possible to use ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantDict","isActive":true},{"text":" allocated on the stack or on the","type":"text"},{"text":" ","type":"text"},{"text":"heap.  When using a stack-allocated ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantDict"},{"text":", you begin with a","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"call to "},{"code":"g_variant_dict_init()","type":"codeVoice"},{"type":"text","text":" and free the resources with a call to"},{"type":"text","text":" "},{"code":"g_variant_dict_clear()","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Heap-allocated "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantDict","isActive":true},{"text":" follows normal refcounting rules: you","type":"text"},{"type":"text","text":" "},{"type":"text","text":"allocate it with "},{"code":"g_variant_dict_new()","type":"codeVoice"},{"text":" and use ","type":"text"},{"type":"codeVoice","code":"g_variant_dict_ref()"},{"type":"text","text":" "},{"type":"text","text":"and "},{"type":"codeVoice","code":"g_variant_dict_unref()"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"code":"g_variant_dict_end()","type":"codeVoice"},{"text":" is used to convert the ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantDict","isActive":true,"type":"reference"},{"type":"text","text":" back into a"},{"text":" ","type":"text"},{"text":"dictionary-type ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant"},{"type":"text","text":".  When used with stack-allocated instances,"},{"type":"text","text":" "},{"text":"this also implicitly frees all associated memory, but for","type":"text"},{"type":"text","text":" "},{"type":"text","text":"heap-allocated instances, you must still call "},{"code":"g_variant_dict_unref()","type":"codeVoice"},{"text":" ","type":"text"},{"text":"afterwards.","type":"text"}]},{"inlineContent":[{"text":"You will typically want to use a heap-allocated ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantDict","isActive":true},{"type":"text","text":" when"},{"text":" ","type":"text"},{"type":"text","text":"you expose it as part of an API.  For most other uses, the"},{"type":"text","text":" "},{"text":"stack-allocated form will be more convenient.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Consider the following two examples that do the same thing in each","type":"text"},{"text":" ","type":"text"},{"text":"style: take an existing dictionary and look up the “count” uint32","type":"text"},{"text":" ","type":"text"},{"text":"key, adding 1 to it if it is found, or returning an error if the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"key is not found.  Each returns the new dictionary as a floating"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant"},{"type":"text","text":"."}],"type":"paragraph"},{"type":"heading","text":"Using a stack-allocated GVariantDict","level":2,"anchor":"Using-a-stack-allocated-GVariantDict"},{"inlineContent":[{"type":"text","text":"(C Language Example):"}],"type":"paragraph"},{"type":"codeListing","syntax":"C","code":["  GVariant *","  add_to_count (GVariant  *orig,","                GError   **error)","  {","    GVariantDict dict;","    guint32 count;","","    g_variant_dict_init (&dict, orig);","    if (!g_variant_dict_lookup (&dict, \"count\", \"u\", &count))","      {","        g_set_error (...);","        g_variant_dict_clear (&dict);","        return NULL;","      }","","    g_variant_dict_insert (&dict, \"count\", \"u\", count + 1);","","    return g_variant_dict_end (&dict);","  }"]},{"text":"Using heap-allocated GVariantDict","type":"heading","level":2,"anchor":"Using-heap-allocated-GVariantDict"},{"type":"paragraph","inlineContent":[{"type":"text","text":"(C Language Example):"}]},{"code":["  GVariant *","  add_to_count (GVariant  *orig,","                GError   **error)","  {","    GVariantDict *dict;","    GVariant *result;","    guint32 count;","","    dict = g_variant_dict_new (orig);","","    if (g_variant_dict_lookup (dict, \"count\", \"u\", &count))","      {","        g_variant_dict_insert (dict, \"count\", \"u\", count + 1);","        result = g_variant_dict_end (dict);","      }","    else","      {","        g_set_error (...);","        result = NULL;","      }","","    g_variant_dict_unref (dict);","","    return result;","  }"],"type":"codeListing","syntax":"C"},{"inlineContent":[{"type":"text","text":"The "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantDict","isActive":true,"type":"reference"},{"type":"text","text":" type acts as a reference-counted owner of an underlying "},{"type":"codeVoice","code":"GVariantDict"},{"text":" instance.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"It provides the methods that can operate on this data type through "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantDictProtocol","isActive":true,"type":"reference"},{"text":" conformance.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Use "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantDict","type":"reference","isActive":true},{"type":"text","text":" as a strong reference or owner of a "},{"type":"codeVoice","code":"GVariantDict"},{"type":"text","text":" instance."}],"type":"paragraph"},{"type":"aside","name":"Note","content":[{"inlineContent":[{"type":"text","text":"Use "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantDictRef"},{"text":" (instead of ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantDict","isActive":true},{"type":"text","text":") for a lightweight Swift reference to an underlying "},{"code":"GVariantDict","type":"codeVoice"},{"text":" instance.","type":"text"}],"type":"paragraph"}],"style":"note"}]}],"abstract":[{"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantDict","isActive":true,"type":"reference"},{"text":" is a mutable interface to ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","type":"reference","isActive":true},{"type":"text","text":" dictionaries."}],"variants":[{"paths":["\/documentation\/glib\/variantdict"],"traits":[{"interfaceLanguage":"swift"}]}],"relationshipsSections":[{"identifiers":["doc:\/\/GLib\/documentation\/GLib\/PointerWrapper","doc:\/\/GLib\/documentation\/GLib\/VariantDictProtocol"],"type":"conformsTo","kind":"relationships","title":