{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/VariantDictRef"},"metadata":{"title":"VariantDictRef","symbolKind":"struct","externalID":"s:4GLib14VariantDictRefV","roleHeading":"Structure","role":"symbol","modules":[{"name":"GLib"}],"navigatorTitle":[{"kind":"identifier","text":"VariantDictRef"}],"fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"VariantDictRef","kind":"identifier"}]},"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"kind":"identifier","text":"VariantDictRef"}]}]},{"kind":"content","content":[{"type":"heading","anchor":"overview","level":2,"text":"Overview"},{"inlineContent":[{"text":"It can be used for doing a sequence of dictionary lookups in an","type":"text"},{"type":"text","text":" "},{"type":"text","text":"efficient way on an existing "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","isActive":true},{"text":" dictionary or it can be used","type":"text"},{"type":"text","text":" "},{"type":"text","text":"to construct new dictionaries with a hashtable-like interface.  It"},{"text":" ","type":"text"},{"type":"text","text":"can also be used for taking existing dictionaries and modifying them"},{"type":"text","text":" "},{"type":"text","text":"in order to create new ones."}],"type":"paragraph"},{"inlineContent":[{"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantDict","isActive":true,"type":"reference"},{"text":" can only be used with ","type":"text"},{"code":"G_VARIANT_TYPE_VARDICT","type":"codeVoice"},{"text":" ","type":"text"},{"type":"text","text":"dictionaries."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"It is possible to use ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantDict","type":"reference","isActive":true},{"type":"text","text":" allocated on the stack or on the"},{"text":" ","type":"text"},{"type":"text","text":"heap.  When using a stack-allocated "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantDict"},{"text":", you begin with a","type":"text"},{"text":" ","type":"text"},{"text":"call to ","type":"text"},{"code":"g_variant_dict_init()","type":"codeVoice"},{"type":"text","text":" and free the resources with a call to"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_variant_dict_clear()"},{"type":"text","text":"."}]},{"inlineContent":[{"type":"text","text":"Heap-allocated "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantDict"},{"text":" follows normal refcounting rules: you","type":"text"},{"text":" ","type":"text"},{"text":"allocate it with ","type":"text"},{"type":"codeVoice","code":"g_variant_dict_new()"},{"text":" and use ","type":"text"},{"type":"codeVoice","code":"g_variant_dict_ref()"},{"text":" ","type":"text"},{"type":"text","text":"and "},{"type":"codeVoice","code":"g_variant_dict_unref()"},{"text":".","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"code":"g_variant_dict_end()","type":"codeVoice"},{"text":" is used to convert the ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantDict","isActive":true},{"text":" back into a","type":"text"},{"type":"text","text":" "},{"text":"dictionary-type ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","isActive":true},{"type":"text","text":".  When used with stack-allocated instances,"},{"text":" ","type":"text"},{"text":"this also implicitly frees all associated memory, but for","type":"text"},{"type":"text","text":" "},{"text":"heap-allocated instances, you must still call ","type":"text"},{"type":"codeVoice","code":"g_variant_dict_unref()"},{"text":" ","type":"text"},{"text":"afterwards.","type":"text"}]},{"inlineContent":[{"text":"You will typically want to use a heap-allocated ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantDict","type":"reference","isActive":true},{"type":"text","text":" when"},{"type":"text","text":" "},{"text":"you expose it as part of an API.  For most other uses, the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"stack-allocated form will be more convenient."}],"type":"paragraph"},{"inlineContent":[{"text":"Consider the following two examples that do the same thing in each","type":"text"},{"text":" ","type":"text"},{"text":"style: take an existing dictionary and look up the “count” uint32","type":"text"},{"type":"text","text":" "},{"type":"text","text":"key, adding 1 to it if it is found, or returning an error if the"},{"text":" ","type":"text"},{"type":"text","text":"key is not found.  Each returns the new dictionary as a floating"},{"text":" ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","isActive":true},{"text":".","type":"text"}],"type":"paragraph"},{"text":"Using a stack-allocated GVariantDict","level":2,"type":"heading","anchor":"Using-a-stack-allocated-GVariantDict"},{"inlineContent":[{"text":"(C Language Example):","type":"text"}],"type":"paragraph"},{"code":["  GVariant *","  add_to_count (GVariant  *orig,","                GError   **error)","  {","    GVariantDict dict;","    guint32 count;","","    g_variant_dict_init (&dict, orig);","    if (!g_variant_dict_lookup (&dict, \"count\", \"u\", &count))","      {","        g_set_error (...);","        g_variant_dict_clear (&dict);","        return NULL;","      }","","    g_variant_dict_insert (&dict, \"count\", \"u\", count + 1);","","    return g_variant_dict_end (&dict);","  }"],"type":"codeListing","syntax":"C"},{"level":2,"text":"Using heap-allocated GVariantDict","anchor":"Using-heap-allocated-GVariantDict","type":"heading"},{"inlineContent":[{"text":"(C Language Example):","type":"text"}],"type":"paragraph"},{"code":["  GVariant *","  add_to_count (GVariant  *orig,","                GError   **error)","  {","    GVariantDict *dict;","    GVariant *result;","    guint32 count;","","    dict = g_variant_dict_new (orig);","","    if (g_variant_dict_lookup (dict, \"count\", \"u\", &count))","      {","        g_variant_dict_insert (dict, \"count\", \"u\", count + 1);","        result = g_variant_dict_end (dict);","      }","    else","      {","        g_set_error (...);","        result = NULL;","      }","","    g_variant_dict_unref (dict);","","    return result;","  }"],"type":"codeListing","syntax":"C"},{"inlineContent":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantDictRef","isActive":true},{"text":" type acts as a lightweight Swift reference to an underlying ","type":"text"},{"type":"codeVoice","code":"GVariantDict"},{"type":"text","text":" instance."},{"type":"text","text":" "},{"text":"It exposes methods that can operate on this data type through ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantDictProtocol","type":"reference","isActive":true},{"text":" conformance.","type":"text"},{"text":" ","type":"text"},{"text":"Use ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantDictRef"},{"type":"text","text":" only as an "},{"type":"codeVoice","code":"unowned"},{"text":" reference to an existing ","type":"text"},{"code":"GVariantDict","type":"codeVoice"},{"type":"text","text":" instance."}],"type":"paragraph"},{"style":"note","name":"Note","type":"aside","content":[{"inlineContent":[{"text":"Use ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantDict","isActive":true},{"text":" (instead of ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantDictRef","isActive":true,"type":"reference"},{"type":"text","text":") if you want to use Automatic Reference Counting for memory management of the underlying "},{"type":"codeVoice","code":"GVariantDict"},{"text":" instance.","type":"text"}],"type":"paragraph"}]}]}],"variants":[{"paths":["\/documentation\/glib\/variantdictref"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"symbol","topicSections":[{"identifiers":["doc:\/\/GLib\/documentation\/GLib\/VariantDictRef\/init(_:)-1m81v","doc:\/\/GLib\/documentation\/GLib\/VariantDictRef\/init(_:)-2ionc","doc:\/\/GLib\/documentation\/GLib\/VariantDictRef\/init(_:)-32bsf","doc:\/\/GLib\/documentation\/GLib\/VariantDictRef\/init(_:)-3gqla","doc:\/\/GLib\/documentation\/GLib\/VariantDictRef\/init(_:)-9l5r7","doc:\/\/GLib\/documentation\/GLib\/VariantDictRef\/init(asv:)","doc:\/\/GLib\/documentation\/GLib\/VariantDictRef\/init(cPointer:)","doc:\/\/GLib\/documentation\/GLib\/VariantDictRef\/init(constPointer:)","doc:\/\/GLib\/documentation\/GLib\/VariantDictRef\/init(gconstpointer:)","doc:\/\/GLib\/documentation\/GLib\/VariantDictRef\/init(gpointer:)","doc:\/\/GLib\/documentation\/GLib\/VariantDictRef\/init(mutating:)","doc:\/\/GLib\/documentation\/GLib\/VariantDictRef\/init(opaquePointer:)"],"title":"Initializers","generated":true,"anchor":"Initializers"},{"identifiers":["doc:\/\/GLib\/documentation\/GLib\/VariantDictRef\/ptr"],"generated":true,"anchor":"Instance-Properties","title":"Instance Properties"},{"anchor":"Default-Implementations","identifiers":["doc:\/\/GLib\/documentation\/GLib\/VariantDictRef\/PointerWrapper-Implementations","doc:\/\/GLib\/documentation\/GLib\/VariantDictRef\/VariantDictProtocol-Implementations"],"generated":true,"title":"Default Implementations"}],"schemaVersion":{"major":0,"minor":3,"patch":0},"abstract":[{"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantDict","type":"reference","isActive":true},{"text":" is a mutable interface to ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant"},{"text":" dictionaries.","type":"text"}],"relationshipsSections":[{"type":"co