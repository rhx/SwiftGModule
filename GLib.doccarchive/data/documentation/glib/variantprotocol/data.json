{"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/VariantProtocol"]]},"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/VariantProtocol\/data","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"Returns a pointer to the serialized form of a "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","isActive":true},{"type":"text","text":" instance."},{"text":" ","type":"text"},{"text":"The returned data may not be in fully-normalised form if read from an","type":"text"},{"type":"text","text":" "},{"text":"untrusted source.  The returned data must not be freed; it remains","type":"text"},{"type":"text","text":" "},{"text":"valid for as long as ","type":"text"},{"code":"value","type":"codeVoice"},{"text":" exists.","type":"text"}],"schemaVersion":{"patch":0,"major":0,"minor":3},"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/variantprotocol\/data"]}],"metadata":{"modules":[{"name":"GLib"}],"fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"data","kind":"identifier"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gconstpointer","text":"gconstpointer"},{"text":"?","kind":"text"}],"roleHeading":"Instance Property","title":"data","extendedModule":"GLib","role":"symbol","externalID":"s:4GLib15VariantProtocolPAAE4dataSVSgvp","symbolKind":"property"},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"data"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"gconstpointer","preciseIdentifier":"c:@T@gconstpointer"},{"kind":"text","text":"? { "},{"text":"get","kind":"keyword"},{"kind":"text","text":" }"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"anchor":"discussion","type":"heading","level":2,"text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"code":"value","type":"codeVoice"},{"text":" is a fixed-sized value that was deserialized from a","type":"text"},{"type":"text","text":" "},{"text":"corrupted serialized container then ","type":"text"},{"type":"codeVoice","code":"nil"},{"type":"text","text":" may be returned.  In this"},{"text":" ","type":"text"},{"type":"text","text":"case, the proper thing to do is typically to use the appropriate"},{"type":"text","text":" "},{"text":"number of nul bytes in place of ","type":"text"},{"type":"codeVoice","code":"value"},{"text":".  If ","type":"text"},{"type":"codeVoice","code":"value"},{"text":" is not fixed-sized","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"then "},{"code":"nil","type":"codeVoice"},{"text":" is never returned.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"In the case that ","type":"text"},{"code":"value","type":"codeVoice"},{"text":" is already in serialized form, this function","type":"text"},{"type":"text","text":" "},{"type":"text","text":"is "},{"code":"O(1)","type":"codeVoice"},{"type":"text","text":".  If the value is not already in serialized form,"},{"type":"text","text":" "},{"text":"serialization occurs implicitly and is approximately ","type":"text"},{"code":"O(n)","type":"codeVoice"},{"type":"text","text":" in the size"},{"text":" ","type":"text"},{"type":"text","text":"of the result."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To deserialize the data returned by this function, in addition to the"},{"type":"text","text":" "},{"type":"text","text":"serialized data, you must know the type of the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant"},{"text":", and (if the","type":"text"},{"type":"text","text":" "},{"text":"machine might be different) the endianness of the machine that stored","type":"text"},{"type":"text","text":" "},{"text":"it. As a result, file formats or network messages that incorporate","type":"text"},{"text":" ","type":"text"},{"text":"serialized ","type":"text"},{"code":"GVariants","type":"codeVoice"},{"type":"text","text":" must include this information either"},{"text":" ","type":"text"},{"type":"text","text":"implicitly (for instance “the file always contains a"},{"type":"text","text":" "},{"code":"G_VARIANT_TYPE_VARIANT","type":"codeVoice"},{"text":" and it is always in little-endian order”) or","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"explicitly (by storing the type and\/or endianness in addition to the"},{"text":" ","type":"text"},{"text":"serialized data).","type":"text"}]}]}],"sections":[],"references":{"doc://GLib/documentation/GLib/Variant":{"type":"topic","role":"symbol","url":"\/documentation\/glib\/variant","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","kind":"symbol","title":"Variant","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"Variant","kind":"identifier"}],"navigatorTitle":[{"text":"Variant","kind":"identifier"}],"abstract":[{"code":"GVariant","type":"codeVoice"},{"text":" is a variant datatype; it can contain one or more values","type":"text"},{"text":" ","type":"text"},{"text":"along with information about the type of the values.","type":"text"}]},"doc://GLib/documentation/GLib":{"kind":"symbol","role":"collection","abstract":[],"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","type":"topic","url":"\/documentation\/glib"},"doc://GLib/documentation/GLib/VariantProtocol/data":{"title":"data","role":"symbol","kind":"symbol","fragments":[{"text":"var","kind":"keyword"},{"kind":"text","text":" "},{"text":"data","kind":"identifier"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"gconstpointer","preciseIdentifier":"c:@T@gconstpointer"},{"text":"?","kind":"text"}],"type":"topic","abstract":[{"text":"Returns a pointer to the serialized form of a ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\