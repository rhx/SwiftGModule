{"schemaVersion":{"patch":0,"major":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/VariantProtocol"]]},"abstract":[{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant"},{"text":" uses a floating reference count system.  All functions with","type":"text"},{"type":"text","text":" "},{"text":"names starting with ","type":"text"},{"type":"codeVoice","code":"g_variant_new_"},{"type":"text","text":" return floating"},{"type":"text","text":" "},{"text":"references.","type":"text"}],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"refSink","kind":"identifier"},{"kind":"text","text":"() -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:4GLib10VariantRefV","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantRef","text":"VariantRef"},{"kind":"text","text":"!"}]}],"kind":"declarations"},{"kind":"content","content":[{"level":2,"text":"Discussion","anchor":"discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Calling "},{"type":"codeVoice","code":"g_variant_ref_sink()"},{"type":"text","text":" on a "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","isActive":true},{"type":"text","text":" with a floating reference"},{"type":"text","text":" "},{"text":"will convert the floating reference into a full reference.  Calling","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_variant_ref_sink()"},{"text":" on a non-floating ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant"},{"type":"text","text":" results in an"},{"type":"text","text":" "},{"text":"additional normal reference being added.","type":"text"}]},{"inlineContent":[{"type":"text","text":"In other words, if the "},{"code":"value","type":"codeVoice"},{"text":" is floating, then this call “assumes","type":"text"},{"type":"text","text":" "},{"type":"text","text":"ownership” of the floating reference, converting it to a normal"},{"type":"text","text":" "},{"type":"text","text":"reference.  If the "},{"type":"codeVoice","code":"value"},{"text":" is not floating, then this call adds a","type":"text"},{"text":" ","type":"text"},{"text":"new normal reference increasing the reference count by one.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"All calls that result in a "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant"},{"text":" instance being inserted into a","type":"text"},{"type":"text","text":" "},{"text":"container will call ","type":"text"},{"type":"codeVoice","code":"g_variant_ref_sink()"},{"type":"text","text":" on the instance.  This means"},{"type":"text","text":" "},{"type":"text","text":"that if the value was just created (and has only its floating"},{"type":"text","text":" "},{"text":"reference) then the container will assume sole ownership of the value","type":"text"},{"text":" ","type":"text"},{"text":"at that point and the caller will not need to unreference it.  This","type":"text"},{"type":"text","text":" "},{"type":"text","text":"makes certain common styles of programming much easier while still"},{"text":" ","type":"text"},{"type":"text","text":"maintaining normal refcounting semantics in situations where values"},{"text":" ","type":"text"},{"text":"are not floating.","type":"text"}]}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/variantprotocol\/refsink()"]}],"metadata":{"externalID":"s:4GLib15VariantProtocolPAAE7refSinkAA0B3RefVSgyF","title":"refSink()","roleHeading":"Instance Method","modules":[{"name":"GLib"}],"symbolKind":"method","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"refSink","kind":"identifier"},{"kind":"text","text":"() -> "},{"preciseIdentifier":"s:4GLib10VariantRefV","text":"VariantRef","kind":"typeIdentifier"},{"kind":"text","text":"!"}],"extendedModule":"GLib","role":"symbol"},"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/VariantProtocol\/refSink()","interfaceLanguage":"swift"},"sections":[],"kind":"symbol","references":{"doc://GLib/documentation/GLib/Variant":{"type":"topic","role":"symbol","url":"\/documentation\/glib\/variant","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","kind":"symbol","title":"Variant","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"Variant","kind":"identifier"}],"navigatorTitle":[{"text":"Variant","kind":"identifier"}],"abstract":[{"code":"GVariant","type":"codeVoice"},{"text":" is a variant datatype; it can contain one or more values","type":"text"},{"text":" ","type":"text"},{"text":"along with information about the type of the values.","type":"text"}]},"doc://GLib/documentation/GLib/VariantRef":{"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"VariantRef"}],"kind":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantRef","type":"topic","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"VariantRef"}],"title":"VariantRef","url":"\/documentation\/glib\/variantref","abstract":[{"code":"GVariant","type":"codeVoice"},{"type":"text","text":" is a variant datatype; it can contain one or more values"},{"type":"text","text":" "},{"type":"text","text":"along with information about the type of the values."}]},"doc://GLib/documentation/GLib/VariantProtocol":{"title":"VariantProtocol","abstract":[{"code":"GVariant","type":"codeVoice"},{"text":" is a variant datatype; it can contain one or more values","type":"text"},{"type":"text","text":" "},{"text":"along with information about the type of the values.","type":"text"}],"type":"topic","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier