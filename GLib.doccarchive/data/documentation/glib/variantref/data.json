 machine that stored"},{"text":" ","type":"text"},{"text":"it. As a result, file formats or network messages that incorporate","type":"text"},{"type":"text","text":" "},{"type":"text","text":"serialized "},{"code":"GVariants","type":"codeVoice"},{"text":" must include this information either","type":"text"},{"type":"text","text":" "},{"type":"text","text":"implicitly (for instance “the file always contains a"},{"text":" ","type":"text"},{"type":"codeVoice","code":"G_VARIANT_TYPE_VARIANT"},{"type":"text","text":" and it is always in little-endian order”) or"},{"type":"text","text":" "},{"text":"explicitly (by storing the type and\/or endianness in addition to the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"serialized data)."}],"type":"paragraph"}]}],"references":{"doc://GLib/documentation/GLib/VariantRef/VariantProtocol-Implementations":{"role":"collectionGroup","kind":"article","type":"topic","url":"\/documentation\/glib\/variantref\/variantprotocol-implementations","abstract":[],"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantRef\/VariantProtocol-Implementations","title":"VariantProtocol Implementations"},"doc://GLib/documentation/GLib/VariantRef/data":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantRef\/data","kind":"symbol","role":"symbol","url":"\/documentation\/glib\/variantref\/data","type":"topic","title":"data","abstract":[{"text":"Returns a pointer to the serialized form of a ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","isActive":true,"type":"reference"},{"type":"text","text":" instance."},{"text":" ","type":"text"},{"text":"The returned data may not be in fully-normalised form if read from an","type":"text"},{"type":"text","text":" "},{"type":"text","text":"untrusted source.  The returned data must not be freed; it remains"},{"type":"text","text":" "},{"text":"valid for as long as ","type":"text"},{"code":"value","type":"codeVoice"},{"type":"text","text":" exists."}],"fragments":[{"text