t","text":" : "},{"kind":"typeIdentifier","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantTypeProtocol","preciseIdentifier":"s:4GLib19VariantTypeProtocolP","text":"VariantTypeProtocol"}]}]},{"content":[{"level":2,"text":"Discussion","anchor":"discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"A single "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","isActive":true},{"type":"text","text":" is parsed from the content of "},{"type":"codeVoice","code":"text"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The format is described "},{"isActive":true,"identifier":"gvariant-text-format.html","type":"reference"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"text":"The memory at ","type":"text"},{"type":"codeVoice","code":"limit"},{"type":"text","text":" will never be accessed and the parser behaves as"},{"type":"text","text":" "},{"text":"if the character at ","type":"text"},{"code":"limit","type":"codeVoice"},{"text":" is the nul terminator.  This has the","type":"text"},{"text":" ","type":"text"},{"text":"effect of bounding ","type":"text"},{"type":"codeVoice","code":"text"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If "},{"code":"endptr","type":"codeVoice"},{"text":" is non-","type":"text"},{"code":"nil","type":"codeVoice"},{"type":"text","text":" then "},{"code":"text","type":"codeVoice"},{"type":"text","text":" is permitted to contain data"},{"text":" ","type":"text"},{"text":"following the value that this function parses and ","type":"text"},{"code":"endptr","type":"codeVoice"},{"text":" will be","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"updated to point to the first character past the end of the text"},{"type":"text","text":" "},{"type":"text","text":"parsed by this function.  If "},{"code":"endptr","type":"codeVoice"},{"type":"text","text":" is "},{"type":"codeVoice","code":