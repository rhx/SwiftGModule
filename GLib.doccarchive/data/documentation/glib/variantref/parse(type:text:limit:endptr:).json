ariant_print()","type":"codeVoice"},{"text":"’s annotated types like ","type":"text"},{"type":"codeVoice","code":"int64 -1000"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"text":"There may be implementation specific restrictions on deeply nested values,","type":"text"},{"type":"text","text":" "},{"text":"which would result in a ","type":"text"},{"code":"recursion","type":"codeVoice"},{"type":"text","text":" error. "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant"},{"text":" is","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"guaranteed to handle nesting up to at least 64 levels."}],"type":"paragraph"}],"kind":"content"}],"metadata":{"roleHeading":"Type Method","modules":[{"name":"GLib"}],"role":"symbol","symbolKind":"method","fragments":[{"kind":"keyword","text":"static"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"parse"},{"text":"<","kind":"text"},{"text":"VariantTypeT","kind":"genericParameter"},{"text":">(","kind":"text"},{"kind":"externalParam","text":"type"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"VariantTypeT"},{"kind":"text","text":"?, "},{"text":"text","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"UnsafePointer","preciseIdentifier":"s:SP"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar","text":"gchar"},{"text":">!, ","kind":"text"},{"text":"limit","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"UnsafePointer","preciseIdentifier":"s:SP"},{"kind":"text","text":"<"},{"preciseIdentifier":"c:@T@gchar","text":"gchar","kind":"typeIdentifier"},{"text":">?, ","kind":"text"},{"kind":"externalParam","text":"endptr"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer"},{"kind":"text","text":"<"},{"text":"UnsafePointer","kin