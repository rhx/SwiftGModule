{"type":"text","text":"."}]},{"inlineContent":[{"type":"text","text":"The memory at "},{"code":"limit","type":"codeVoice"},{"type":"text","text":" will never be accessed and the parser behaves as"},{"type":"text","text":" "},{"type":"text","text":"if the character at "},{"type":"codeVoice","code":"limit"},{"type":"text","text":" is the nul terminator.  This has the"},{"text":" ","type":"text"},{"text":"effect of bounding ","type":"text"},{"code":"text","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"endptr"},{"text":" is non-","type":"text"},{"type":"codeVoice","code":"nil"},{"type":"text","text":" then "},{"type":"codeVoice","code":"text"},{"text":" is permitted to contain data","type":"text"},{"type":"text","text":" "},{"text":"following the value that this function parses and ","type":"text"},{"type":"codeVoice","code":"endptr"},{"type":"text","text":" will be"},{"type":"text","text":" "},{"type":"text","text":"updated to point to the first character past the end of the text"},{"type":"text","text":" "},{"type":"text","text":"parsed by this function.  If "},{"code":"endptr","type":"codeVoice"},{"type":"text","text":" is "},{"type":"codeVoice","code":"nil"},{"text":" and there is extra data","type":"text"},{"text":" ","type":"text"},{"text":"then an error is returned.","type":"text"}]},{"inlineContent":[{"type":"text","text":"If "},{"code":"type","type":"codeVoice"},{"type":"text","text":" is non-"},{"code":"nil","type":"codeVoice"},{"type":"text","text":" then the value will be parsed to have that"},{"text":" ","type":"text"},{"text":"type.  This may result in additional parse errors (in the case that","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the parsed value doesn’t fit the type) but may also result in fewer"},{"type":"text","text":" "},{"text":"errors (in the case that the type would have been ambiguous, such as","type":"text