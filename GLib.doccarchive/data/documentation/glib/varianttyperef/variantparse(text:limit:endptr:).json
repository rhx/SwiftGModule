":"doc:\/\/GLib\/documentation\/GLib\/Variant"},{"text":" is parsed from the content of ","type":"text"},{"type":"codeVoice","code":"text"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The format is described "},{"identifier":"gvariant-text-format.html","isActive":true,"type":"reference"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The memory at "},{"code":"limit","type":"codeVoice"},{"type":"text","text":" will never be accessed and the parser behaves as"},{"type":"text","text":" "},{"type":"text","text":"if the character at "},{"code":"limit","type":"codeVoice"},{"text":" is the nul terminator.  This has the","type":"text"},{"type":"text","text":" "},{"text":"effect of bounding ","type":"text"},{"code":"text","type":"codeVoice"},{"text":".","type":"text"}]},{"inlineContent":[{"text":"If ","type":"text"},{"code":"endptr","type":"codeVoice"},{"type":"text","text":" is non-"},{"type":"codeVoice","code":"nil"},{"text":" then ","type":"text"},{"type":"codeVoice","code":"text"},{"text":" is permitted to contain data","type":"text"},{"text":" ","type":"text"},{"text":"following the value that this function parses and ","type":"text"},{"type":"codeVoice","code":"endptr"},{"type":"text","text":" will be"},{"type":"text","text":" "},{"type":"text","text":"updated to point to the first character past the end of the text"},{"type":"text","text":" "},{"type":"text","text":"parsed by this function.  If "},{"code":"endptr","type":"codeVoice"},{"type":"text","text":" is "},{"code":"nil","type":"codeVoice"},{"type":"text","text":" and there is extra data"},{"text":" ","type":"text"},{"type":"text","text":"then an error is returned."}],"type":"paragraph"},{"inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"type"},{"type":"text","text":" is non-"},{"type":"codeVoice","code":"nil"},{"text":" then the value will be parsed to have that","type":"text"},{"type":"text","text":" "},{"text":"type.  This may result in additional parse errors (in the case that","type":"text"},{"type":"text","text":" "},{"text":"the parsed value doesn’t fit the type) but may also result in fewer","type":"text"},{"text":" ","type":"text"},{"text":"errors (in the case that the type would have been ambiguous, such as","type":"text"},{"text":" ","type":"text"},{"text":"with empty arrays).","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"In the event that the parsing is successful, the resulting ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","type":"reference","isActive":true},{"type":"text","text":" "},{"text":"is returned. It is never floating, and must be freed with","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[method"},{"type":"codeVoice","code":"GLib.Variant.unref"},{"text":"].","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In case of any error, "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" will be returned.  If "},{"type":"codeVoice","code":"error"},{"type":"text","text":" is non-"},{"code":"nil","type":"codeVoice"},{"type":"text","text":" "},{"text":"then it will be set to reflect the error that occurred.","type":"text"}]},{"inlineContent":[{"type":"text","text":"Officially, the language understood by the parser is “any string"},{"type":"text","text":" "},{"text":"produced by [method","type":"text"},{"type":"codeVoice","code":"GLib.Variant.print"},{"type":"text","text":"]”. This explicitly includes"},{"text":" ","type":"text"},{"code":"g_variant_print()","type":"codeVoice"},{"text":"’s annotated types like ","type":"text"},{"code":"int64 -1000","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"text":"There may be implementation specific restrictions on deeply nested values,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"which would result in a "},{"type":"codeVoice","code":"recursion"},{"type":"text","text":" error. "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","type":"reference","isActive":true},{"type":"text","text":" is"},{"text":" ","type":"text"},{"type":"text","text":"guaranteed to handle nesting up to at least 64 levels."}],"type":"paragraph"}],"kind":"content"}],"references":{"doc://GLib/documentation/GLib/VariantTypeRef":{"type":"topic","abstract":[{"text":"A type in the [type","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant"},{"text":"] type system.","type":"text"}],"navigatorTitle":[{"kind":"identifier","text":"VariantTypeRef"}],"url":"\/documentation\/glib\/varianttyperef","role":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantTypeRef","title":"VariantTypeRef","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"VariantTypeRef"}],"kind":"symbol"},"doc://GLib/documentation/GLib/VariantTypeRef/VariantTypeProtocol-Implementations":{"url":"\/documentation\/glib\/varianttyperef\/varianttypeprotocol-implementations","kind":"article","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantTypeRef\/VariantTypeProtocol-Implementations","abstract":[],"role":"collectionGroup","title":"VariantTypeProtocol Implementations","type":"topic"},"doc://GLib/documentation/GLib":{"kind":"symbol","role":"collection","abstract":[],"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","type":"topic","url":"\/documentation\/glib"},"gvariant-text-format.html":{"title":"here","url":"gvariant-text-format.html","titleInlineContent":[{"type":"text","text":"here"}],"type":"link","identifier":"gvariant-text-format.html"},"doc://GLib/documentation/GLib/VariantTypeRef/variantParse(text:limit:endptr:)":{"fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"variantParse","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"text"},{"kind":"text","text":": "