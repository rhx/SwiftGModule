"type":"text","text":" "},{"text":"way, if a matching .la file exists (and is a libtool archive) the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"libtool archive is parsed to find the actual file name, and that is"},{"type":"text","text":" "},{"text":"used.","type":"text"}],"type":"paragraph"}]}],"type":"orderedList"},{"type":"paragraph","inlineContent":[{"text":"If, at the end of all this, we have a file path that we can access on disk,","type":"text"},{"text":" ","type":"text"},{"text":"it is opened as a module. If not, ","type":"text"},{"code":"fileName","type":"codeVoice"},{"type":"text","text":" is attempted to be opened as a"},{"type":"text","text":" "},{"type":"text","text":"module verbatim in the hopes that the system implementation will somehow be"},{"type":"text","text":" "},{"type":"text","text":"able to access it. If that is not possible, "},{"code":"nil","type":"codeVoice"},{"type":"text","text":" is returned."}]},{"inlineContent":[{"text":"Note that this behaviour was different prior to 2.76, but there is some","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"overlap in functionality. If backwards compatibility is an issue, kindly"},{"text":" ","type":"text"},{"type":"text","text":"consult earlier "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GModule\/documentation\/GModule\/Module"},{"text":" documentation for the prior search order\/behavior","type":"text"},{"type":"text","text":" "},{"text":"of ","type":"text"},{"type":"codeVoice","code":"fileName"},{"text":".","type":"text"}],"type":"paragraph"}]}],"kind":"symbol","references":{"doc://GModule/documentation/GModule/Module":{"identifier":"doc:\/\/GModule\/documentation\/GModule\/Module","type":"topic","navigatorTitle":[{"kind":"identifier","text":"Module"}],"abstract":[{"type":"text","text":"The "},{"identifier":"doc:\/\/GModule\/documentation\/GModule\/Module","isActive":true,"type":"reference"},{"type":"text","text":" struct is an opaque data stru