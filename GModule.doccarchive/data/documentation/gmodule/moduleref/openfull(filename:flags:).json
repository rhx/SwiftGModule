{"identifier":{"url":"doc:\/\/GModule\/documentation\/GModule\/ModuleRef\/openFull(fileName:flags:)","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/GModule\/documentation\/GModule","doc:\/\/GModule\/documentation\/GModule\/ModuleRef"]]},"sections":[],"abstract":[{"text":"Opens a module. If the module has already been opened, its reference count","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"is incremented. If not, the module is searched using "},{"code":"fileName","type":"codeVoice"},{"text":".","type":"text"}],"schemaVersion":{"patch":0,"minor":3,"major":0},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gmodule\/moduleref\/openfull(filename:flags:)"]}],"metadata":{"role":"symbol","roleHeading":"Type Method","modules":[{"name":"GModule"}],"title":"openFull(fileName:flags:)","externalID":"s:7GModule9ModuleRefV8openFull8fileName5flagsACSgSPys4Int8VGSg_AA0B5FlagsVtKFZ","extendedModule":"GModule","symbolKind":"method","fragments":[{"kind":"keyword","text":"static"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"openFull","kind":"identifier"},{"kind":"text","text":"("},{"text":"fileName","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"UnsafePointer","preciseIdentifier":"s:SP","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"text":"gchar","preciseIdentifier":"c:@T@gchar","kind":"typeIdentifier"},{"kind":"text","text":">?, "},{"kind":"externalParam","text":"flags"},{"text":": ","kind":"text"},{"text":"ModuleFlags","kind":"typeIdentifier","preciseIdentifier":"s:7GModule11ModuleFlagsV"},{"kind":"text","text":") "},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:7GModule9ModuleRefV","text":"ModuleRef"},{"text":"!","kind":"text"}]},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"static","kind":"keyword"},{"kind":"text","text":" "},{"kind":"keywo